@model QLKH.Domain.Entities.Enrollment

@{
    ViewData["Title"] = "Thêm ghi danh";
}

<h2>Thêm ghi danh</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="StudentId" class="form-label">Học viên</label>
        <select asp-for="StudentId" asp-items="ViewBag.StudentId" class="form-control">
            <option value="">-- Chọn học viên --</option>
        </select>
        <span asp-validation-for="StudentId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ClassRoomId" class="form-label">Lớp học</label>
        <select asp-for="ClassRoomId" asp-items="ViewBag.ClassRoomId" class="form-control">
            <option value="">-- Chọn lớp học --</option>
        </select>
        <span asp-validation-for="ClassRoomId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" class="form-control" asp-items="Html.GetEnumSelectList<QLKH.Domain.Enums.EnrollmentStatus>()"></select>
    </div>

    <button type="submit" class="btn btn-success">Lưu</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}