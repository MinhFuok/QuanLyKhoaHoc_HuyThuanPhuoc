@model IEnumerable<QLKH.Domain.Entities.Enrollment>

@{
    ViewData["Title"] = "Danh sách ghi danh";
}

@section Styles {
    <link rel="stylesheet" href="~/css/AdminProfession.css" asp-append-version="true" />
}

<div class="course-page admin-profession-page enrollment-page">
    <div class="cp-header">
        <div class="cp-header-left">
            <h1 class="cp-title">Danh sách ghi danh</h1>
            <p class="cp-subtitle">Theo dõi học viên, lớp học, khóa học và trạng thái ghi danh.</p>
        </div>

        <a asp-action="Create" class="cp-btn cp-btn--primary">+ Thêm mới</a>
    </div>

    <div class="cp-table-wrap">
        <table class="cp-table">
            <thead>
                <tr>
                    <th>Học viên</th>
                    <th>Lớp học</th>
                    <th>Khóa học</th>
                    <th>Giảng viên</th>
                    <th>Ngày ghi danh</th>
                    <th>Trạng thái</th>
                    <th class="cp-col-action">Chức năng</th>
                </tr>
            </thead>
            <tbody>
                @if (Model?.Any() == true)
                {
                    foreach (var item in Model)
                    {
                        <tr class="cp-row">
                            <td><div class="cp-name">@item.Student?.FullName</div></td>
                            <td>@item.ClassRoom?.ClassName</td>
                            <td>@item.ClassRoom?.Course?.CourseName</td>
                            <td>@item.ClassRoom?.Teacher?.FullName</td>
                            <td>@item.EnrolledAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><span class="cp-badge cp-badge--@item.Status.ToString().ToLower()">@item.Status</span></td>
                            <td>
                                <div class="cp-actions">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="cp-btn cp-btn--info cp-btn--sm">Chi tiết</a>

                                    @if (User.IsInRole("Admin") || User.IsInRole("HocVu"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="cp-btn cp-btn--warning cp-btn--sm">Sửa</a>
                                    }

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="cp-btn cp-btn--danger cp-btn--sm">Xóa</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="cp-empty">Chưa có ghi danh nào trong hệ thống.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/AdminProfession.js" asp-append-version="true"></script>
}
