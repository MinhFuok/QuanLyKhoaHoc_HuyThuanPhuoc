@model IEnumerable<QLKH.Domain.Entities.Enrollment>

@{
    ViewData["Title"] = "Danh sách ghi danh";
}

<h2>Danh sách ghi danh</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Thêm mới</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Học viên</th>
            <th>Lớp học</th>
            <th>Khóa học</th>
            <th>Giảng viên</th>
            <th>Ngày ghi danh</th>
            <th>Trạng thái</th>
            <th width="220">Chức năng</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Student?.FullName</td>
                <td>@item.ClassRoom?.ClassName</td>
                <td>@item.ClassRoom?.Course?.CourseName</td>
                <td>@item.ClassRoom?.Teacher?.FullName</td>
                <td>@item.EnrolledAt.ToString("dd/MM/yyyy HH:mm")</td>
                <td>@item.Status</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Chi tiết</a>
                    @if (User.IsInRole("Admin") || User.IsInRole("HocVu"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Sửa</a>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Xóa</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>