@model QLKH.Domain.Entities.Student

@{
    ViewData["Title"] = "Chi tiết học viên";
}

@section Styles {
    <link rel="stylesheet" href="~/css/AdminProfession.css" asp-append-version="true" />
}

<div class="course-page admin-profession-page student-page">
    <div class="cp-header">
        <div class="cp-header-left">
            <h1 class="cp-title">Chi tiết học viên</h1>
            <p class="cp-subtitle">Thông tin hồ sơ của học viên <strong>@Model.StudentCode</strong>.</p>
        </div>
    </div>

    <div class="cp-detail-card">
        <div class="cp-detail-hero">
            <div class="cp-detail-hero-left">
                <span class="cp-code cp-code--lg">@Model.StudentCode</span>
                <h2 class="cp-detail-name">@Model.FullName</h2>
            </div>
            <span class="cp-badge cp-badge--lg">Học viên</span>
        </div>

        <div class="cp-detail-body">
            <div class="cp-detail-row">
                <div class="cp-detail-label">Email</div>
                <div class="cp-detail-value">@Model.Email</div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Số điện thoại</div>
                <div class="cp-detail-value">@Model.PhoneNumber</div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Ngày sinh</div>
                <div class="cp-detail-value">@Model.DateOfBirth.ToString("dd/MM/yyyy")</div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Địa chỉ</div>
                <div class="cp-detail-value">@Model.Address</div>
            </div>
        </div>

        <div class="cp-detail-footer">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="cp-btn cp-btn--warning">Sửa</a>
            <a asp-action="Index" class="cp-btn cp-btn--ghost">Quay lại</a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/AdminProfession.js" asp-append-version="true"></script>
}
