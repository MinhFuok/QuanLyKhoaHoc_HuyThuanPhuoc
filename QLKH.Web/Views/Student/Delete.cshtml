@model QLKH.Domain.Entities.Student

@{
    ViewData["Title"] = "Xóa học viên";
}

<h2>Xóa học viên</h2>

<h4>Bạn có chắc muốn xóa học viên này không?</h4>

<div>
    <dl class="row">
        <dt class="col-sm-3">Mã học viên</dt>
        <dd class="col-sm-9">@Model.StudentCode</dd>

        <dt class="col-sm-3">Họ tên</dt>
        <dd class="col-sm-9">@Model.FullName</dd>

        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9">@Model.Email</dd>

        <dt class="col-sm-3">Số điện thoại</dt>
        <dd class="col-sm-9">@Model.PhoneNumber</dd>

        <dt class="col-sm-3">Ngày sinh</dt>
        <dd class="col-sm-9">@Model.DateOfBirth.ToString("dd/MM/yyyy")</dd>

        <dt class="col-sm-3">Địa chỉ</dt>
        <dd class="col-sm-9">@Model.Address</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Xóa</button>
        <a asp-action="Index" class="btn btn-secondary">Hủy</a>
    </form>
</div>