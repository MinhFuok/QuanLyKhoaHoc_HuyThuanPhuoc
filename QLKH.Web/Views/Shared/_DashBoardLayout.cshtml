@using QLKH.Application.Interfaces.Services
@inject ISystemSettingService SystemSettingService

@{
    var systemSetting = await SystemSettingService.GetAsync();
    var siteName = systemSetting?.SiteName ?? "QLKH";

    var userName = User.Identity?.Name ?? "";
    var initials = userName.Length > 0 ? userName[..1].ToUpper() : "?";

    string userRole = "Người dùng";
    if (User.IsInRole("Admin")) userRole = "Quản trị viên";
    else if (User.IsInRole("HocVu")) userRole = "Học vụ";
    else if (User.IsInRole("GiaoVien")) userRole = "Giáo viên";
    else if (User.IsInRole("HocVien")) userRole = "Học viên";

    var currentArea = ViewContext.RouteData.Values["area"]?.ToString() ?? "";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var isAdminShell = string.Equals(currentArea, "Admin", StringComparison.OrdinalIgnoreCase);
    var isHocVuShell = string.Equals(currentArea, "HocVu", StringComparison.OrdinalIgnoreCase);
    var dashboardBodyClass = isAdminShell
        ? "db-body db-body-admin"
        : isHocVuShell
            ? "db-body db-body-hocvu"
            : "db-body";

    string IsActive(string area, string controller, string? action = null)
    {
        if (!string.Equals(currentArea, area, StringComparison.OrdinalIgnoreCase))
            return "";

        if (!string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase))
            return "";

        if (!string.IsNullOrWhiteSpace(action) &&
            !string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase))
            return "";

        return "active";
    }
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @siteName</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/dashboardlayout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/QLKH.Web.styles.css" asp-append-version="true" />
    @if (isAdminShell)
    {
        <link rel="stylesheet" href="~/css/AdminProfession.css" asp-append-version="true" />
    }
    @await RenderSectionAsync("Styles", required: false)

    <link rel="stylesheet" href="~/css/mobile.css" asp-append-version="true" />
    @if (isHocVuShell)
    {
        <link rel="stylesheet" href="~/css/HocVuProfession.css" asp-append-version="true" />
    }
</head>
<body class="@dashboardBodyClass">

    <div class="db-overlay" id="dbOverlay"></div>

    <aside class="db-sidebar" id="dbSidebar">

        <div class="db-sidebar-header">
            <a class="db-brand" href="/">
                <span class="db-brand-icon">🎓</span>
                <span class="db-brand-text">@siteName</span>
            </a>
            <button class="db-sidebar-close" id="dbSidebarClose" aria-label="Đóng menu">&#x2715;</button>
        </div>

        <nav class="db-nav" id="dbNav">
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                @if (User.IsInRole("Admin"))
                {
                    <div class="db-nav-group">
                        <a class="db-nav-link @IsActive("Admin", "Home", "Index")" asp-area="Admin" asp-controller="Home" asp-action="Index">
                            <span class="db-nav-icon">⊞</span> Dashboard Admin
                        </a>
                    </div>

                    <div class="db-nav-group">
                        <span class="db-nav-group-label">Quản Lý</span>
                        <a class="db-nav-link @IsActive("Admin", "UserManagement")" asp-area="Admin" asp-controller="UserManagement" asp-action="Index">
                            <span class="db-nav-icon">👥</span> Tài Khoản
                        </a>
                        <a class="db-nav-link @IsActive("Admin", "Department")" asp-area="Admin" asp-controller="Department" asp-action="Index">
                            <span class="db-nav-icon">🏫</span> Chương Trình Đào Tạo
                        </a>
                        <a class="db-nav-link @IsActive("Admin", "BulkNotification")" asp-area="Admin" asp-controller="BulkNotification" asp-action="Index">
                            <span class="db-nav-icon">📢</span> Thông Báo
                        </a>
                    </div>

                    <div class="db-nav-group">
                        <span class="db-nav-group-label">Hệ Thống</span>
                        <a class="db-nav-link @IsActive("Admin", "SystemSettings")" asp-area="Admin" asp-controller="SystemSettings" asp-action="Index">
                            <span class="db-nav-icon">⚙️</span> Cấu Hình Hệ Thống Website
                        </a>
                        <a class="db-nav-link @IsActive("Admin", "AdminAuditLog")" asp-area="Admin" asp-controller="AdminAuditLog" asp-action="Index">
                            <span class="db-nav-icon">📝</span> Lịch Sử Hoạt Động
                        </a>
                    </div>
                }

                @if (User.IsInRole("HocVu"))
                {
                    <div class="db-nav-group">
                        <a class="db-nav-link @IsActive("HocVu", "Home", "Index")" asp-area="HocVu" asp-controller="Home" asp-action="Index">
                            <span class="db-nav-icon">⊞</span> Dashboard HV
                        </a>
                    </div>

                    <div class="db-nav-group">
                        <span class="db-nav-group-label">Quản Lý</span>
                        <a class="db-nav-link @IsActive("HocVu", "Course")" asp-area="HocVu" asp-controller="Course" asp-action="Index">
                            <span class="db-nav-icon">📘</span> Khóa Học
                        </a>

                        <a class="db-nav-link @IsActive("HocVu", "ClassRoom")" asp-area="HocVu" asp-controller="ClassRoom" asp-action="Index">
                            <span class="db-nav-icon">🏫</span> Lớp Học
                        </a>

                        <a class="db-nav-link @IsActive("HocVu", "Teacher")" asp-area="HocVu" asp-controller="Teacher" asp-action="Index">
                            <span class="db-nav-icon">👨‍🏫</span> Giảng Viên
                        </a>

                        <a class="db-nav-link @IsActive("HocVu", "Student")" asp-area="HocVu" asp-controller="Student" asp-action="Index">
                            <span class="db-nav-icon">🎓</span> Học Viên
                        </a>

                        <a class="db-nav-link @IsActive("HocVu", "Enrollment")" asp-area="HocVu" asp-controller="Enrollment" asp-action="Index">
                            <span class="db-nav-icon">📝</span> Ghi Danh
                        </a>

                        <a class="db-nav-link @IsActive("HocVu", "ClassSchedule")" asp-area="HocVu" asp-controller="ClassSchedule" asp-action="Index">
                            <span class="db-nav-icon">🗓️</span> Lịch Học
                        </a>

                        <a class="db-nav-link @IsActive("HocVu", "StudentCertificate")" asp-area="HocVu" asp-controller="StudentCertificate" asp-action="Index">
                            <span class="db-nav-icon">🏅</span> Chứng Chỉ Học Viên
                        </a>
                    </div>
                }

                @if (User.IsInRole("GiaoVien"))
                {
                    <div class="db-nav-group">
                        <a class="db-nav-link @IsActive("GiaoVien", "Home", "Index")" asp-area="GiaoVien" asp-controller="Home" asp-action="Index">
                            <span class="db-nav-icon">⊞</span> Dashboard GV
                        </a>
                    </div>

                    <div class="db-nav-group">
                        <span class="db-nav-group-label">Giảng dạy</span>
                        <a class="db-nav-link @IsActive("GiaoVien", "MyClasses")" asp-area="GiaoVien" asp-controller="MyClasses" asp-action="Index">
                            <span class="db-nav-icon">🏷️</span> Lớp Của Tôi
                        </a>
                        <a class="db-nav-link @IsActive("GiaoVien", "MySchedule")" asp-area="GiaoVien" asp-controller="MySchedule" asp-action="Index">
                            <span class="db-nav-icon">📅</span> Lịch Dạy
                        </a>
                        <a class="db-nav-link @IsActive("GiaoVien", "MyMaterials")" asp-area="GiaoVien" asp-controller="MyMaterials" asp-action="Index">
                            <span class="db-nav-icon">📁</span> Tài Liệu
                        </a>
                        <a class="db-nav-link @IsActive("GiaoVien", "MyAssignments")" asp-area="GiaoVien" asp-controller="MyAssignments" asp-action="Index">
                            <span class="db-nav-icon">📝</span> Bài Tập
                        </a>
                        <a class="db-nav-link @IsActive("GiaoVien", "ClassGrades")" asp-area="GiaoVien" asp-controller="ClassGrades" asp-action="Classes">
                            <span class="db-nav-icon">📊</span> Bảng Điểm
                        </a>
                    </div>
                }

                @if (User.IsInRole("HocVien"))
                {
                    <div class="db-nav-group">
                        <a class="db-nav-link @IsActive("HocVien", "Home", "Index")" asp-area="HocVien" asp-controller="Home" asp-action="Index">
                            <span class="db-nav-icon">⊞</span> Dashboard HV
                        </a>
                    </div>

                    <div class="db-nav-group">
                        <span class="db-nav-group-label">Học tập</span>
                        <a class="db-nav-link @IsActive("HocVien", "MyClasses")" asp-area="HocVien" asp-controller="MyClasses" asp-action="Index">
                            <span class="db-nav-icon">🏷️</span> Lớp Của Tôi
                        </a>
                        <a class="db-nav-link @IsActive("HocVien", "MySchedule")" asp-area="HocVien" asp-controller="MySchedule" asp-action="Index">
                            <span class="db-nav-icon">📅</span> Lịch Học
                        </a>
                        <a class="db-nav-link @IsActive("HocVien", "MyMaterials")" asp-area="HocVien" asp-controller="MyMaterials" asp-action="Index">
                            <span class="db-nav-icon">📁</span> Tài Liệu
                        </a>
                        <a class="db-nav-link @IsActive("HocVien", "MyAssignments")" asp-area="HocVien" asp-controller="MyAssignments" asp-action="Index">
                            <span class="db-nav-icon">📝</span> Bài Tập
                        </a>
                        <a class="db-nav-link @IsActive("HocVien", "MyGrades")" asp-area="HocVien" asp-controller="MyGrades" asp-action="Index">
                            <span class="db-nav-icon">📊</span> Bảng Điểm
                        </a>
                        <a class="db-nav-link @IsActive("HocVien", "MyLearningProgress")" asp-area="HocVien" asp-controller="MyLearningProgress" asp-action="Index">
                            <span class="db-nav-icon">📈</span> Tiến Độ Học Tập
                        </a>
                    </div>
                }

                <div class="db-nav-group">
                    <span class="db-nav-group-label">Tài khoản</span>
                    <a class="db-nav-link @(currentArea == "" && currentController == "Account" && currentAction == "ChangePassword" ? "active" : "")"
                       asp-area=""
                       asp-controller="Account"
                       asp-action="ChangePassword">
                        <span class="db-nav-icon">🔑</span> Đổi Mật Khẩu
                    </a>
                </div>
            }
            else
            {
                <div class="db-nav-group">
                    <a class="db-nav-link" href="/">
                        <span class="db-nav-icon">🏠</span> Trang Chủ
                    </a>
                </div>
            }
        </nav>

        <div class="db-sidebar-footer">
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <div class="db-user-info">
                    <div class="db-user-avatar">@initials</div>
                    <div class="db-user-detail">
                        <span class="db-user-name">@userName</span>
                        <span class="db-user-role">@userRole</span>
                    </div>
                </div>

                <form class="db-logout-form" asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="db-logout-btn">
                        <span>⏻</span> Đăng xuất
                    </button>
                </form>
            }
            else
            {
                <a class="db-login-btn" asp-area="" asp-controller="Account" asp-action="Login">
                    Đăng nhập
                </a>
            }
        </div>
    </aside>

    <div class="db-main-wrap">
        <header class="db-mobile-topbar">
            <button type="button"
                    class="db-mobile-menu-btn"
                    id="dbMenuToggle"
                    aria-label="Mở menu"
                    aria-expanded="false">
                <span></span>
                <span></span>
                <span></span>
            </button>

            <a class="db-mobile-brand" href="/">
                <span class="db-mobile-brand-icon">🎓</span>
                <span class="db-mobile-brand-text">@siteName</span>
            </a>

            <div class="db-mobile-user">
                <span>@initials</span>
            </div>
        </header>

        <main class="db-content">

            <div id="dbAlertZone">
                @if (!string.IsNullOrWhiteSpace(TempData["SuccessMessage"]?.ToString()))
                {
                    <div class="db-alert db-alert-success">
                        <span class="db-alert-icon">✓</span>
                        <span class="db-alert-text">@TempData["SuccessMessage"]</span>
                        <button class="db-alert-close" aria-label="Đóng">&#x2715;</button>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(TempData["ErrorMessage"]?.ToString()))
                {
                    <div class="db-alert db-alert-danger">
                        <span class="db-alert-icon">!</span>
                        <span class="db-alert-text">@TempData["ErrorMessage"]</span>
                        <button class="db-alert-close" aria-label="Đóng">&#x2715;</button>
                    </div>
                }
            </div>

            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/dashboardlayout.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    @if (isAdminShell)
    {
        <script src="~/js/AdminProfession.js" asp-append-version="true"></script>
    }
</body>
</html>
