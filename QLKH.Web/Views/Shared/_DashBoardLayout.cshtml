@using QLKH.Application.Interfaces.Services
@inject ISystemSettingService SystemSettingService

@{
    var systemSetting = await SystemSettingService.GetAsync();
    var siteName = systemSetting?.SiteName ?? "QLKH";

    var userName = User.Identity?.Name ?? "";
    var initials = userName.Length > 0 ? userName[..1].ToUpper() : "?";

    string userRole = "Người dùng";
    if (User.IsInRole("Admin")) userRole = "Quản trị viên";
    else if (User.IsInRole("HocVu")) userRole = "Học vụ";
    else if (User.IsInRole("GiaoVien")) userRole = "Giáo viên";
    else if (User.IsInRole("HocVien")) userRole = "Học viên";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @siteName</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/dashboardlayout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/AdminProfession.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/QLKH.Web.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="db-body">

    <div class="db-overlay" id="dbOverlay"></div>

    <aside class="db-sidebar" id="dbSidebar">

        <div class="db-sidebar-header">
            <a class="db-brand" href="/">
                <span class="db-brand-icon">🎓</span>
                <span class="db-brand-text">@siteName</span>
            </a>
            <button class="db-sidebar-close" id="dbSidebarClose" aria-label="Đóng menu">&#x2715;</button>
        </div>

        <nav class="db-nav" id="dbNav">
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                @if (User.IsInRole("Admin"))
                {
                    <div class="db-nav-group">
                        <a class="db-nav-link" href="/Admin/Home">
                            <span class="db-nav-icon">⊞</span> Dashboard Admin
                        </a>
                    </div>

                    <div class="db-nav-group">
                        <span class="db-nav-group-label">Quản lý</span>
                        <a class="db-nav-link" asp-area="Admin" asp-controller="UserManagement" asp-action="Index">
                            <span class="db-nav-icon">👥</span> Tài khoản
                        </a>
                        <a class="db-nav-link" asp-area="Admin" asp-controller="SystemSettings" asp-action="Index">
                            <span class="db-nav-icon">⚙️</span> Cấu hình hệ thống
                        </a>
                    </div>

                    <div class="db-nav-group">
                        <span class="db-nav-group-label">Danh mục</span>
                        <a class="db-nav-link" asp-area="Admin" asp-controller="Department" asp-action="Index">
                            <span class="db-nav-icon">🏫</span> Khoa/Ngành đào tạo
                        </a>
                    </div>
                }

                @if (User.IsInRole("HocVu"))
                {
                    <div class="db-nav-group">
                        <a class="db-nav-link" asp-area="HocVu" asp-controller="Home" asp-action="Index">
                            <span class="db-nav-icon">⊞</span> Dashboard HV
                        </a>

                        <a class="db-nav-link" asp-area="HocVu" asp-controller="Course" asp-action="Index">
                            <span class="db-nav-icon">📘</span> Khóa học
                        </a>

                        <a class="db-nav-link" asp-area="HocVu" asp-controller="ClassRoom" asp-action="Index">
                            <span class="db-nav-icon">🏫</span> Lớp học
                        </a>

                        <a class="db-nav-link" asp-area="HocVu" asp-controller="Enrollment" asp-action="Index">
                            <span class="db-nav-icon">📝</span> Ghi danh
                        </a>
                        <a class="db-nav-link" asp-area="HocVu" asp-controller="ClassSchedule" asp-action="Index">
                            <span class="db-nav-icon">🗓️</span> Lịch học
                        </a>
                        <a class="db-nav-link" asp-area="HocVu" asp-controller="Student" asp-action="Index">
                            <span class="db-nav-icon">🎓</span> Học viên
                        </a>

                        <a class="db-nav-link" asp-area="HocVu" asp-controller="Teacher" asp-action="Index">
                            <span class="db-nav-icon">👨‍🏫</span> Giảng viên
                        </a>

                        <a class="db-nav-link" asp-area="HocVu" asp-controller="StudentCertificate" asp-action="Index">
                            <span class="db-nav-icon">🏅</span> Chứng chỉ học viên
                        </a>
                    </div>
                }

                @if (User.IsInRole("GiaoVien"))
                {
                    <div class="db-nav-group">
                        <a class="db-nav-link" href="/GiaoVien/Home">
                            <span class="db-nav-icon">⊞</span> Dashboard GV
                        </a>
                    </div>

                    <div class="db-nav-group">
                        <span class="db-nav-group-label">Giảng dạy</span>
                        <a class="db-nav-link" href="/GiaoVien/MyClasses">
                            <span class="db-nav-icon">🏷️</span> Lớp tôi dạy
                        </a>
                        <a class="db-nav-link" href="/GiaoVien/MySchedule">
                            <span class="db-nav-icon">📅</span> Lịch dạy
                        </a>
                        <a class="db-nav-link" href="/GiaoVien/MyMaterials">
                            <span class="db-nav-icon">📁</span> Tài liệu
                        </a>
                        <a class="db-nav-link" href="/GiaoVien/ClassMaterials/Create">
                            <span class="db-nav-icon">➕</span> Tạo tài liệu
                        </a>
                        <a class="db-nav-link" href="/GiaoVien/MyAssignments">
                            <span class="db-nav-icon">📝</span> Bài tập
                        </a>
                        <a class="db-nav-link" href="/GiaoVien/Assignments/Create">
                            <span class="db-nav-icon">➕</span> Tạo bài tập
                        </a>
                        <a class="db-nav-link" href="/GiaoVien/ClassGrades/Classes">
                            <span class="db-nav-icon">📊</span> Bảng điểm lớp
                        </a>
                    </div>
                }

                @if (User.IsInRole("HocVien"))
                {
                    <div class="db-nav-group">
                        <a class="db-nav-link" href="/HocVien/Home">
                            <span class="db-nav-icon">⊞</span> Dashboard HV
                        </a>
                    </div>

                    <div class="db-nav-group">
                        <span class="db-nav-group-label">Học tập</span>
                        <a class="db-nav-link" href="/HocVien/MyClasses">
                            <span class="db-nav-icon">🏷️</span> Lớp tôi học
                        </a>
                        <a class="db-nav-link" href="/HocVien/MySchedule">
                            <span class="db-nav-icon">📅</span> Lịch học
                        </a>
                        <a class="db-nav-link" href="/HocVien/MyMaterials">
                            <span class="db-nav-icon">📁</span> Tài liệu
                        </a>
                        <a class="db-nav-link" href="/HocVien/MyAssignments">
                            <span class="db-nav-icon">📝</span> Bài tập
                        </a>
                        <a class="db-nav-link" href="/HocVien/MyGrades">
                            <span class="db-nav-icon">📊</span> Bảng điểm
                        </a>
                        <a class="db-nav-link" href="/HocVien/MyLearningProgress">
                            <span class="db-nav-icon">📈</span> Tiến độ học tập
                        </a>
                    </div>
                }

                <div class="db-nav-group">
                    <span class="db-nav-group-label">Tài khoản</span>
                    <a class="db-nav-link" href="/Account/ChangePassword">
                        <span class="db-nav-icon">🔑</span> Đổi mật khẩu
                    </a>
                </div>
            }
            else
            {
                <div class="db-nav-group">
                    <a class="db-nav-link" href="/">
                        <span class="db-nav-icon">🏠</span> Trang chủ
                    </a>
                </div>
            }
        </nav>

        <div class="db-sidebar-footer">
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <div class="db-user-info">
                    <div class="db-user-avatar">@initials</div>
                    <div class="db-user-detail">
                        <span class="db-user-name">@userName</span>
                        <span class="db-user-role">@userRole</span>
                    </div>
                </div>

                <form class="db-logout-form" asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="db-logout-btn">
                        <span>⏻</span> Đăng xuất
                    </button>
                </form>
            }
            else
            {
                <a class="db-login-btn" asp-area="" asp-controller="Account" asp-action="Login">
                    Đăng nhập
                </a>
            }
        </div>
    </aside>

    <div class="db-main-wrap">
        <main class="db-content">

            <div id="dbAlertZone">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="db-alert db-alert-success">
                        <span class="db-alert-icon">✓</span>
                        <span class="db-alert-text">@TempData["SuccessMessage"]</span>
                        <button class="db-alert-close" aria-label="Đóng">&#x2715;</button>
                    </div>
                }

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="db-alert db-alert-danger">
                        <span class="db-alert-icon">!</span>
                        <span class="db-alert-text">@TempData["ErrorMessage"]</span>
                        <button class="db-alert-close" aria-label="Đóng">&#x2715;</button>
                    </div>
                }
            </div>

            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/dashboardlayout.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
