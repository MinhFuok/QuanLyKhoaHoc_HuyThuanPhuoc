@using QLKH.Application.Interfaces.Services
@inject ISystemSettingService SystemSettingService

@{
    var systemSetting = await SystemSettingService.GetAsync();
    var siteName = systemSetting?.SiteName ?? "QLKH";
    var footerText = systemSetting?.FooterText ?? "© 2026 QLKH";
    var contactEmail = systemSetting?.ContactEmail ?? "support@qlkh.com";
    var contactPhone = systemSetting?.ContactPhone ?? "0123456789";
    var contactAddress = systemSetting?.ContactAddress ?? "Bình Dương";
    var facebookUrl = systemSetting?.FacebookUrl;
    var youtubeUrl = systemSetting?.YoutubeUrl;
    var tiktokUrl = systemSetting?.TiktokUrl;
    var xUrl = systemSetting?.XUrl;
    var phoneDigits = string.Concat((contactPhone ?? string.Empty).Where(char.IsDigit));
    var phoneContactHref = !string.IsNullOrWhiteSpace(phoneDigits) ? phoneDigits : "0123456789";

    var zaloFallbackUrl = "https://zalo.me/0123456789";
    var zaloContactUrlOverride = ViewData["ZaloContactUrl"] as string;
    var aiSupportUrlOverride = ViewData["AiSupportUrl"] as string;
    var zaloContactUrl = !string.IsNullOrWhiteSpace(zaloContactUrlOverride)
        ? zaloContactUrlOverride
        : !string.IsNullOrWhiteSpace(phoneDigits)
            ? $"https://zalo.me/{phoneDigits}"
            : zaloFallbackUrl;
    var aiSupportUrl = !string.IsNullOrWhiteSpace(aiSupportUrlOverride)
        ? aiSupportUrlOverride
        : Url.Action("Privacy", "Home") ?? "/Home/Privacy";
    var aiSupportMeta = "Hỗ trợ cùng Trần Đức Bo";
    var aiSupportTarget = aiSupportUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? "_blank" : null;
    var aiSupportRel = aiSupportTarget != null ? "noopener noreferrer" : null;

    var hideHeader = ViewData["HideHeader"] as bool? ?? false;
    var hideFooter = ViewData["HideFooter"] as bool? ?? false;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @siteName</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/QLKH.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/publiclayout.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)

    <link rel="stylesheet" href="~/css/mobile.css" asp-append-version="true" />
</head>
<body>

    @if (!hideHeader)
    {
        <header class="pl-header" id="pl-header">
            <div class="pl-night-sky pl-night-sky--header" aria-hidden="true">
                <div class="pl-night-sky__canvas">
                    <div class="pl-night-sky__stars pl-night-sky__stars--1"></div>
                    <div class="pl-night-sky__stars pl-night-sky__stars--2"></div>
                    <div class="pl-night-sky__stars pl-night-sky__stars--3"></div>
                    <div class="pl-night-sky__meteor pl-night-sky__meteor--1"></div>
                    <div class="pl-night-sky__meteor pl-night-sky__meteor--2"></div>
                    <div class="pl-night-sky__meteor pl-night-sky__meteor--3"></div>
                    <div class="pl-night-sky__moon"></div>
                </div>
            </div>

            <div class="pl-header__inner">

                <a href="/" class="pl-header__logo">
                    <span class="pl-header__logo-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path d="M12 3L3 8l9 5 9-5-9-5z" />
                            <path d="M3 16l9 5 9-5" />
                            <path d="M3 12l9 5 9-5" />
                        </svg>
                    </span>
                    <span class="pl-header__logo-name">@siteName</span>
                </a>

                <button class="pl-header__burger" id="pl-burger" aria-label="Menu" aria-expanded="false">
                    <span></span><span></span><span></span>
                </button>

                <nav class="pl-header__nav" id="pl-nav">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <span class="pl-header__greeting">
                            Xin chào, <strong>@User.Identity.Name</strong>
                        </span>
                        <div class="pl-header__divider"></div>
                        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="pl-header__form">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="pl-btn pl-btn--outline">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                                    <polyline points="16 17 21 12 16 7" />
                                    <line x1="21" y1="12" x2="9" y2="12" />
                                </svg>
                                Đăng xuất
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-area="" asp-controller="Account" asp-action="Login" class="pl-btn pl-btn--primary">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                                <polyline points="10 17 15 12 10 7" />
                                <line x1="15" y1="12" x2="3" y2="12" />
                            </svg>
                            Đăng nhập
                        </a>
                    }
                </nav>

            </div>
        </header>
    }

    <main class="pl-main">
        @RenderBody()
    </main>

    <div class="pl-floating-contact" id="pl-floating-contact">
        <aside class="pl-floating-contact__panel" id="pl-floating-panel" aria-label="Liên hệ nhanh" aria-hidden="false">
            <a href="@zaloContactUrl" target="_blank" rel="noopener noreferrer" class="pl-floating-contact__item pl-floating-contact__item--zalo">
                <span class="pl-floating-contact__item-icon pl-floating-contact__item-icon--zalo" aria-hidden="true">
                    <span class="pl-floating-contact__item-icon-label">Z</span>
                </span>
                <span class="pl-floating-contact__item-copy">
                    <span class="pl-floating-contact__item-title">Liên hệ Zalo</span>
                    <span class="pl-floating-contact__item-meta">@contactPhone</span>
                </span>
            </a>

            <a href="tel:@phoneContactHref" class="pl-floating-contact__item pl-floating-contact__item--phone">
                <span class="pl-floating-contact__item-icon pl-floating-contact__item-icon--phone" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.8 1.18h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 5.99 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z" />
                    </svg>
                </span>
                <span class="pl-floating-contact__item-copy">
                    <span class="pl-floating-contact__item-title">Liên hệ qua điện thoại</span>
                    <span class="pl-floating-contact__item-meta">@contactPhone</span>
                </span>
            </a>

            <button type="button"
                    class="pl-floating-contact__item pl-floating-contact__item--ai"
                    id="pl-ai-support-open"
                    aria-controls="pl-ai-chat"
                    aria-expanded="false">
                <span class="pl-floating-contact__item-icon pl-floating-contact__item-icon--ai" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 3v3" />
                        <path d="M6.75 5.25 8.9 7.4" />
                        <path d="M3 12h3" />
                        <path d="m6.75 18.75 2.15-2.15" />
                        <path d="M17.25 18.75 15.1 16.6" />
                        <path d="M18 12h3" />
                        <path d="M17.25 5.25 15.1 7.4" />
                        <circle cx="12" cy="12" r="4.2" />
                    </svg>
                </span>

                <span class="pl-floating-contact__item-copy">
                    <span class="pl-floating-contact__item-title">Chatbox hỗ trợ</span>
                    <span class="pl-floating-contact__item-meta">@aiSupportMeta</span>
                </span>
            </button>
        </aside>

        <div class="pl-floating-contact__tools">
            <button type="button" class="pl-floating-contact__toggle" id="pl-floating-toggle" aria-controls="pl-floating-panel" aria-expanded="true" aria-label="Mở hoặc đóng liên hệ nhanh">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 11.5a8.5 8.5 0 0 1-8.5 8.5H7l-4 3v-5.5A8.5 8.5 0 1 1 21 11.5Z" />
                </svg>
            </button>

            <button type="button" class="pl-floating-contact__scrolltop" id="pl-scroll-top" aria-label="Cuộn lên đầu trang">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="m18 15-6-6-6 6" />
                </svg>
            </button>
        </div>
    </div>
    <div class="pl-ai-chat" id="pl-ai-chat" data-ask-url="@Url.Action("Ask", "AiSupport", new { area = "" })" aria-hidden="true">
        <div class="pl-ai-chat__card" role="dialog" aria-modal="false" aria-labelledby="pl-ai-chat-title">
            <div class="pl-ai-chat__header">
                <div class="pl-ai-chat__brand">
                    <div class="pl-ai-chat__avatar" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="7" y="8" width="10" height="8" rx="2"></rect>
                            <path d="M12 4v3"></path>
                            <path d="M9 16v2"></path>
                            <path d="M15 16v2"></path>
                            <path d="M7 12H5"></path>
                            <path d="M19 12h-2"></path>
                            <circle cx="10" cy="12" r="1"></circle>
                            <circle cx="14" cy="12" r="1"></circle>
                            <path d="M10 14h4"></path>
                        </svg>
                    </div>
                    <div>
                        <div class="pl-ai-chat__title" id="pl-ai-chat-title">Chatbox Hỗ Trợ Tư Vấn</div>
                        <div class="pl-ai-chat__status">
                            <span></span>
                            Trần Đức Bo
                        </div>
                    </div>
                </div>

                <button type="button" class="pl-ai-chat__close" id="pl-ai-chat-close" aria-label="Đóng AI tư vấn">
                    ×
                </button>
            </div>

            <div class="pl-ai-chat__messages" id="pl-ai-chat-messages">
                <div class="pl-ai-chat__message pl-ai-chat__message--bot">
                    <div class="pl-ai-chat__message-avatar" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="7" y="8" width="10" height="8" rx="2"></rect>
                            <path d="M12 4v3"></path>
                            <path d="M9 16v2"></path>
                            <path d="M15 16v2"></path>
                            <path d="M7 12H5"></path>
                            <path d="M19 12h-2"></path>
                            <circle cx="10" cy="12" r="1"></circle>
                            <circle cx="14" cy="12" r="1"></circle>
                            <path d="M10 14h4"></path>
                        </svg>
                    </div>

                    <div class="pl-ai-chat__bubble">
                        Chào anh~ Em là Trần Đức Bo - Mèow Méow Meow Mèow Meo, trợ lý AI nhỏ xíu của QLKH nè. Anh muốn hỏi gì cũng được, từ cách dùng hệ thống, học tập, công nghệ đến chuyện thường ngày, em sẽ cố gắng trả lời thật dễ hiểu nha ✨
                    </div>
                </div>
            </div>

            <div class="pl-ai-chat__suggestions">
                <button type="button" data-ai-question="Học viên có thể xem bài tập ở đâu?">Bài tập</button>
                <button type="button" data-ai-question="Học viên xem tài liệu lớp học ở đâu?">Tài liệu</button>
                <button type="button" data-ai-question="Học viên xem bảng điểm như thế nào?">Bảng điểm</button>
            </div>

            <form class="pl-ai-chat__form" id="pl-ai-chat-form">
                @Html.AntiForgeryToken()

                <textarea id="pl-ai-chat-input"
                          class="pl-ai-chat__input"
                          rows="2"
                          maxlength="1000"
                          placeholder="Nhập câu hỏi..."></textarea>

                <button type="submit" class="pl-ai-chat__send" id="pl-ai-chat-send">
                    Gửi
                </button>
            </form>
        </div>
    </div>
    @if (!hideFooter)
    {
        <footer class="pl-footer">
            <div class="pl-night-sky pl-night-sky--footer" aria-hidden="true">
                <div class="pl-night-sky__canvas">
                    <div class="pl-night-sky__stars pl-night-sky__stars--1"></div>
                    <div class="pl-night-sky__stars pl-night-sky__stars--2"></div>
                    <div class="pl-night-sky__stars pl-night-sky__stars--3"></div>
                    <div class="pl-night-sky__meteor pl-night-sky__meteor--1"></div>
                    <div class="pl-night-sky__meteor pl-night-sky__meteor--2"></div>
                    <div class="pl-night-sky__meteor pl-night-sky__meteor--3"></div>
                    <div class="pl-night-sky__moon"></div>
                </div>
            </div>

            <div class="pl-footer__top">
                <div class="pl-footer__grid">

                    <div class="pl-footer__col pl-footer__col--brand">
                        <div class="pl-footer__head">
                            <a href="/" class="pl-footer__brand-logo">
                                @* <span class="pl-footer__brand-icon">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                        <path d="M12 3L3 8l9 5 9-5-9-5z" />
                                        <path d="M3 16l9 5 9-5" />
                                        <path d="M3 12l9 5 9-5" />
                                    </svg>
                                </span> *@
                                <span>@siteName</span>
                            </a>
                        </div>

                        <div class="pl-footer__body">
                            <p class="pl-footer__brand-desc">
                                Nền tảng quản lý và tổ chức các khóa học online, hỗ trợ học viên
                                học tập linh hoạt và thuận tiện mọi lúc mọi nơi.
                            </p>

                            <ul class="pl-footer__contact">
                                <li>
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.8 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 5.99 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.34 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
                                    </svg>
                                    <span>@contactPhone</span>
                                </li>
                                <li>
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                        <rect x="2" y="4" width="20" height="16" rx="2" />
                                        <path d="M22 7l-10 7L2 7" />
                                    </svg>
                                    <span>@contactEmail</span>
                                </li>
                                <li>
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                        <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z" />
                                        <circle cx="12" cy="10" r="3" />
                                    </svg>
                                    <span>@contactAddress</span>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <div class="pl-footer__col pl-footer__col--links">
                        <div class="pl-footer__head">
                            <h3 class="pl-footer__col-title">LIÊN KẾT</h3>
                        </div>
                        <div class="pl-footer__body">
                            <ul class="pl-footer__links">
                                <li><a href="/">Trang chủ</a></li>
                                <li><a asp-controller="Home" asp-action="About">Giới thiệu</a></li>
                                <li><a href="/Account/Login">Đăng nhập</a></li>
                                <li><a href="/#lien-he">Liên hệ</a></li>
                            </ul>
                        </div>
                    </div>

                    <div class="pl-footer__col pl-footer__col--links">
                        <div class="pl-footer__head">
                            <h3 class="pl-footer__col-title">KẾT NỐI</h3>
                        </div>
                        <div class="pl-footer__body">
                            <ul class="pl-footer__social-list">
                                @if (!string.IsNullOrWhiteSpace(facebookUrl))
                                {
                                    <li>
                                        <a href="@facebookUrl" target="_blank" rel="noopener" class="pl-footer__social-link">
                                            <span class="pl-footer__social-icon">
                                                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                                    <path d="M13.5 22v-8h2.7l.4-3h-3.1V9.1c0-.9.3-1.5 1.6-1.5H16.7V5c-.3 0-1.3-.1-2.4-.1-2.4 0-4.1 1.5-4.1 4.2V11H7.5v3h2.7v8h3.3z" />
                                                </svg>
                                            </span>
                                            <span>Facebook</span>
                                        </a>
                                    </li>
                                }

                                @if (!string.IsNullOrWhiteSpace(youtubeUrl))
                                {
                                    <li>
                                        <a href="@youtubeUrl" target="_blank" rel="noopener" class="pl-footer__social-link">
                                            <span class="pl-footer__social-icon">
                                                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                                    <path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.6 3.5 12 3.5 12 3.5s-7.6 0-9.4.6A3 3 0 0 0 .5 6.2 31.7 31.7 0 0 0 0 12a31.7 31.7 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.8.6 9.4.6 9.4.6s7.6 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.7 31.7 0 0 0 24 12a31.7 31.7 0 0 0-.5-5.8zM9.7 15.8V8.2L16 12l-6.3 3.8z" />
                                                </svg>
                                            </span>
                                            <span>YouTube</span>
                                        </a>
                                    </li>
                                }

                                @if (!string.IsNullOrWhiteSpace(tiktokUrl))
                                {
                                    <li>
                                        <a href="@tiktokUrl" target="_blank" rel="noopener" class="pl-footer__social-link">
                                            <span class="pl-footer__social-icon">
                                                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                                    <path d="M14.8 3c.2 1.7 1.2 3.3 2.8 4.2 1 .6 2 .9 3.2 1v2.8c-1.3 0-2.6-.3-3.8-.9-.5-.2-.9-.5-1.3-.8v6.3c0 3.4-2.7 6.1-6.1 6.1S3.5 19 3.5 15.6s2.7-6.1 6.1-6.1c.3 0 .6 0 .9.1v3c-.3-.1-.6-.1-.9-.1-1.7 0-3.1 1.4-3.1 3.1s1.4 3.1 3.1 3.1 3.1-1.4 3.1-3.1V3h2.1z" />
                                                </svg>
                                            </span>
                                            <span>TikTok</span>
                                        </a>
                                    </li>
                                }

                                @if (!string.IsNullOrWhiteSpace(xUrl))
                                {
                                    <li>
                                        <a href="@xUrl" target="_blank" rel="noopener" class="pl-footer__social-link">
                                            <span class="pl-footer__social-icon">
                                                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                                    <path d="M18.9 2H22l-6.8 7.8L23.2 22h-6.3l-4.9-6.5L6.4 22H3.3l7.3-8.3L.8 2h6.4l4.4 5.9L18.9 2zm-1.1 18h1.7L6.3 3.9H4.5L17.8 20z" />
                                                </svg>
                                            </span>
                                            <span>X (Twitter)</span>
                                        </a>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>

                    <div class="pl-footer__col pl-footer__col--links">
                        <div class="pl-footer__head">
                            <h3 class="pl-footer__col-title">HỖ TRỢ</h3>
                        </div>
                        <div class="pl-footer__body">
                            <ul class="pl-footer__links pl-footer__links--muted">
                                <li><a href="/"><span>Các câu hỏi thường gặp</span></a></li>
                                <li><a href="/"><span>Hướng dẫn đăng ký học</span></a></li>
                                <li><a href="/"><span>Liên hệ hỗ trợ học viên</span></a></li>
                                <li><a href="/"><span>A.I hỗ trợ thắc mắc</span></a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <div class="pl-footer__bottom">
                <div class="pl-footer__bottom-inner">
                    <span>@footerText</span>
                </div>
            </div>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/publiclayout.js" asp-append-version="true"></script>
    <script src="~/js/publiclayout-float-contact.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
