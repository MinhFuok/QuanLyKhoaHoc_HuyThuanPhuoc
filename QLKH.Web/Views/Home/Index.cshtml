@model QLKH.Web.Models.HomePageViewModel

@{
    ViewData["Title"] = "Trang chủ";
    Layout = "_PublicLayout";

    var siteName = Model.SystemSetting?.SiteName ?? "QLKH";
    var bannerTitle = Model.SystemSetting?.HomeBannerTitle ?? "Nền tảng quản lý khóa học online";
    var bannerSubtitle = Model.SystemSetting?.HomeBannerSubtitle ?? "Quản lý khóa học, lớp học và học viên trên một hệ thống tập trung, dễ vận hành và dễ mở rộng.";
    var contactEmail = Model.SystemSetting?.ContactEmail ?? "support@qlkh.com";
    var contactPhone = Model.SystemSetting?.ContactPhone ?? "0123456789";
    var contactAddress = Model.SystemSetting?.ContactAddress ?? "Bình Dương";
    var slides = Model.BannerSlides?.Where(x => x.IsActive).OrderBy(x => x.DisplayOrder).ToList()
                 ?? new List<QLKH.Domain.Entities.HomeBannerSlide>();

    string vaoHeThongUrl;

    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        if (User.IsInRole("Admin"))
        {
            vaoHeThongUrl = Url.Action("Index", "Home", new { area = "Admin" })!;
        }
        else if (User.IsInRole("HocVu"))
        {
            vaoHeThongUrl = Url.Action("Index", "Home", new { area = "HocVu" })!;
        }
        else if (User.IsInRole("GiaoVien"))
        {
            vaoHeThongUrl = Url.Action("Index", "Home", new { area = "GiaoVien" })!;
        }
        else if (User.IsInRole("HocVien"))
        {
            vaoHeThongUrl = Url.Action("Index", "Home", new { area = "HocVien" })!;
        }
        else
        {
            vaoHeThongUrl = Url.Action("Index", "Home", new { area = "" })!;
        }
    }
    else
    {
        vaoHeThongUrl = Url.Action("Login", "Account", new { area = "" })!;
    }
}

<div class="home-index">
    <div class="home-stars" aria-hidden="true">
        <div id="stars"></div>
        <div id="stars2"></div>
        <div id="stars3"></div>
    </div>

    <section class="home-shell home-hero">
        <div class="home-hero__content home-reveal">
            <span class="home-kicker">@siteName</span>
            <h1>@bannerTitle</h1>
            <p>@bannerSubtitle</p>

            <div class="home-actions">
                <a href="@vaoHeThongUrl" class="home-btn home-btn--primary">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 12h14" />
                        <path d="m13 6 6 6-6 6" />
                    </svg>
                    Vào hệ thống
                </a>

                <a href="#lien-he" class="home-btn home-btn--ghost" data-home-scroll>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15a4 4 0 0 1-4 4H8l-5 3V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4z" />
                    </svg>
                    Liên hệ tư vấn
                </a>
            </div>
        </div>

        <div class="home-hero__visual home-reveal">
            <div class="e-card playing home-main-card">
                <div class="image"></div>
                <div class="wave"></div>
                <div class="wave"></div>
                <div class="wave"></div>
                <div class="infotop">
                    <svg viewBox="0 0 24 24" class="icon" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M12 3 3 8l9 5 9-5-9-5Z" />
                        <path d="M3 12l9 5 9-5" />
                        <path d="M3 16l9 5 9-5" />
                    </svg>
                    <br />
                    Quản lý khóa học
                    <div class="name">@siteName.ToLower()</div>
                </div>
            </div>

            <div class="home-orbit-card">
                <span>Online</span>
                <strong>Course Manager</strong>
            </div>
        </div>
    </section>

    <section class="home-shell home-section">
        <div class="home-section__head home-reveal">
            <span class="home-kicker">Tính năng chính</span>
            <h2>Không gian quản lý gọn, rõ và sẵn sàng vận hành</h2>
        </div>

        <div class="home-card-grid">
            <article class="e-card playing home-feature-card home-reveal">
                <div class="image"></div>
                <div class="wave"></div>
                <div class="wave"></div>
                <div class="wave"></div>
                <div class="infotop">
                    <span class="home-card-icon">01</span>
                    Quản lý tập trung
                    <div class="name">khóa học • lớp học • học viên</div>
                </div>
            </article>

            <article class="e-card playing home-feature-card home-feature-card--teal home-reveal">
                <div class="image"></div>
                <div class="wave"></div>
                <div class="wave"></div>
                <div class="wave"></div>
                <div class="infotop">
                    <span class="home-card-icon">02</span>
                    Dễ vận hành
                    <div class="name">học vụ • quản trị • cấu hình</div>
                </div>
            </article>

            <article class="e-card playing home-feature-card home-feature-card--gold home-reveal">
                <div class="image"></div>
                <div class="wave"></div>
                <div class="wave"></div>
                <div class="wave"></div>
                <div class="infotop">
                    <span class="home-card-icon">03</span>
                    Học online
                    <div class="name">tài liệu • bài tập • tiến độ</div>
                </div>
            </article>

            <article class="e-card playing home-feature-card home-feature-card--rose home-reveal">
                <div class="image"></div>
                <div class="wave"></div>
                <div class="wave"></div>
                <div class="wave"></div>
                <div class="infotop">
                    <span class="home-card-icon">04</span>
                    Mở rộng dễ dàng
                    <div class="name">báo cáo • nghiệp vụ • dữ liệu</div>
                </div>
            </article>
        </div>
    </section>

    @if (slides.Any())
    {
        <section class="home-shell home-section home-section--slides">
            <div class="home-section__head home-reveal">
                <span class="home-kicker">Banner</span>
                <h2>Nội dung nổi bật từ hệ thống</h2>
            </div>

            <div class="home-carousel-wrap home-reveal">
                <div id="homeBannerCarousel" class="carousel slide home-carousel" data-bs-ride="carousel">
                    <div class="carousel-indicators home-carousel__indicators">
                        @for (int i = 0; i < slides.Count; i++)
                        {
                            <button type="button"
                                    data-bs-target="#homeBannerCarousel"
                                    data-bs-slide-to="@i"
                                    class="@(i == 0 ? "active" : "")"
                                    aria-current="@(i == 0 ? "true" : "false")"
                                    aria-label="Slide @(i + 1)">
                            </button>
                        }
                    </div>

                    <div class="carousel-inner">
                        @for (int i = 0; i < slides.Count; i++)
                        {
                            var slide = slides[i];

                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <img src="@slide.ImageUrl"
                                     class="d-block w-100 home-carousel__image"
                                     alt="@slide.AltText" />

                                @if (!string.IsNullOrWhiteSpace(slide.Title))
                                {
                                    <div class="carousel-caption home-carousel__caption">
                                        <h3>@slide.Title</h3>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <button class="carousel-control-prev home-carousel__control" type="button" data-bs-target="#homeBannerCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Trước</span>
                    </button>

                    <button class="carousel-control-next home-carousel__control" type="button" data-bs-target="#homeBannerCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Sau</span>
                    </button>
                </div>
            </div>
        </section>
    }

    <section class="home-shell home-section">
        <div class="home-section__head home-reveal">
            <span class="home-kicker">Vai trò sử dụng</span>
            <h2>Mỗi nhóm người dùng có đúng không gian làm việc của mình</h2>
        </div>

        <div class="home-role-grid">
            <article class="home-role home-reveal">
                <span class="home-role__badge">AD</span>
                <h3>Quản trị viên</h3>
                <p>Quản lý tài khoản nội bộ, phân quyền, cấu hình website và banner trang chủ.</p>
            </article>

            <article class="home-role home-reveal">
                <span class="home-role__badge home-role__badge--cyan">HV</span>
                <h3>Học vụ</h3>
                <p>Tổ chức khóa học, mở lớp, quản lý ghi danh và theo dõi tình trạng học viên.</p>
            </article>

            <article class="home-role home-reveal">
                <span class="home-role__badge home-role__badge--gold">GV</span>
                <h3>Giảng viên</h3>
                <p>Quản lý lớp học, tài liệu, bài tập, nộp bài và kết quả học tập.</p>
            </article>

            <article class="home-role home-reveal">
                <span class="home-role__badge home-role__badge--rose">HS</span>
                <h3>Học viên</h3>
                <p>Theo dõi lịch học, tài liệu, bài tập, điểm số và tiến độ học tập cá nhân.</p>
            </article>
        </div>
    </section>

    <section id="lien-he" class="home-shell home-section home-contact">
        <div class="home-contact__panel home-reveal">
            <div>
                <span class="home-kicker">Liên hệ</span>
                <h2>Bắt đầu vận hành hệ thống với @siteName</h2>
                <p>Nếu bạn cần tư vấn triển khai hoặc hỗ trợ sử dụng hệ thống, hãy liên hệ theo thông tin bên dưới.</p>
            </div>

            <div class="home-contact__list">
                <a class="home-contact__item" href="tel:@contactPhone">
                    <span>Điện thoại</span>
                    <strong>@contactPhone</strong>
                </a>
                <a class="home-contact__item" href="mailto:@contactEmail">
                    <span>Email</span>
                    <strong>@contactEmail</strong>
                </a>
                <div class="home-contact__item">
                    <span>Địa chỉ</span>
                    <strong>@contactAddress</strong>
                </div>
            </div>
        </div>
    </section>
</div>

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@500;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/index.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/index.js" asp-append-version="true"></script>
}
