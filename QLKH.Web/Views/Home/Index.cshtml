@model QLKH.Web.Models.HomePageViewModel

@{
    ViewData["Title"] = "Trang chủ";
    Layout = "_PublicLayout";

    var siteName = Model.SystemSetting?.SiteName ?? "QLKH";
    var bannerTitle = Model.SystemSetting?.HomeBannerTitle ?? "Nền tảng quản lý khóa học online";
    var bannerSubtitle = Model.SystemSetting?.HomeBannerSubtitle ?? "Quản lý khóa học, lớp học và học viên trên một hệ thống tập trung, dễ vận hành và dễ mở rộng.";
    var contactEmail = Model.SystemSetting?.ContactEmail ?? "support@qlkh.com";
    var contactPhone = Model.SystemSetting?.ContactPhone ?? "0123456789";
    var contactAddress = Model.SystemSetting?.ContactAddress ?? "Bình Dương";
    var slides = Model.BannerSlides?.Where(x => x.IsActive).OrderBy(x => x.DisplayOrder).ToList()
                 ?? new List<QLKH.Domain.Entities.HomeBannerSlide>();
}

<section class="container py-5">
    <div class="row align-items-center g-4">
        <div class="col-lg-6">
            <h1 class="display-5 fw-bold mb-3">
                @bannerTitle
            </h1>
            <p class="lead text-muted mb-4">
                @bannerSubtitle
            </p>
            <div class="d-flex flex-wrap gap-2">
                @{
                    string vaoHeThongUrl;

                    if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        if (User.IsInRole("Admin"))
                        {
                            vaoHeThongUrl = Url.Action("Index", "Home", new { area = "Admin" })!;
                        }
                        else if (User.IsInRole("HocVu"))
                        {
                            vaoHeThongUrl = Url.Action("Index", "Home", new { area = "HocVu" })!;
                        }
                        else if (User.IsInRole("GiaoVien"))
                        {
                            vaoHeThongUrl = Url.Action("Index", "Home", new { area = "GiaoVien" })!;
                        }
                        else if (User.IsInRole("HocVien"))
                        {
                            vaoHeThongUrl = Url.Action("Index", "Home", new { area = "HocVien" })!;
                        }
                        else
                        {
                            vaoHeThongUrl = Url.Action("Index", "Home", new { area = "" })!;
                        }
                    }
                    else
                    {
                        vaoHeThongUrl = Url.Action("Login", "Account", new { area = "" })!;
                    }
                }

                <a href="@vaoHeThongUrl" class="btn btn-primary btn-lg">
                    Vào hệ thống
                </a>

                <a href="#lien-he" class="btn btn-outline-secondary btn-lg">
                    Liên hệ tư vấn
                </a>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-4">
                    <div class="row g-3 text-center">
                        <div class="col-6">
                            <div class="p-3 rounded-4 bg-light h-100">
                                <h3 class="fw-bold mb-1">Quản lý tập trung</h3>
                                <p class="text-muted mb-0 small">
                                    Quản lý khóa học, lớp học, học viên và giảng viên trên cùng một hệ thống.
                                </p>
                            </div>
                        </div>

                        <div class="col-6">
                            <div class="p-3 rounded-4 bg-light h-100">
                                <h3 class="fw-bold mb-1">Dễ vận hành</h3>
                                <p class="text-muted mb-0 small">
                                    Học vụ và quản trị viên dễ dàng cấu hình và theo dõi dữ liệu.
                                </p>
                            </div>
                        </div>

                        <div class="col-6">
                            <div class="p-3 rounded-4 bg-light h-100">
                                <h3 class="fw-bold mb-1">Học online</h3>
                                <p class="text-muted mb-0 small">
                                    Phù hợp cho mô hình đào tạo trực tuyến, linh hoạt và thuận tiện.
                                </p>
                            </div>
                        </div>

                        <div class="col-6">
                            <div class="p-3 rounded-4 bg-light h-100">
                                <h3 class="fw-bold mb-1">Mở rộng dễ dàng</h3>
                                <p class="text-muted mb-0 small">
                                    Có thể phát triển thêm khóa học, báo cáo và các nghiệp vụ sau này.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@if (slides.Any())
{
    <section class="container pb-5">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-body p-0">
                <div id="homeBannerCarousel" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-indicators">
                        @for (int i = 0; i < slides.Count; i++)
                        {
                            <button type="button"
                                    data-bs-target="#homeBannerCarousel"
                                    data-bs-slide-to="@i"
                                    class="@(i == 0 ? "active" : "")"
                                    aria-current="@(i == 0 ? "true" : "false")"
                                    aria-label="Slide @(i + 1)">
                            </button>
                        }
                    </div>

                    <div class="carousel-inner">
                        @for (int i = 0; i < slides.Count; i++)
                        {
                            var slide = slides[i];

                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <img src="@slide.ImageUrl"
                                     class="d-block w-100"
                                     alt="@slide.AltText"
                                     style="height: 420px; object-fit: cover;" />

                                @if (!string.IsNullOrWhiteSpace(slide.Title))
                                {
                                    <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded-3 px-3 py-2">
                                        <h5 class="mb-0">@slide.Title</h5>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <button class="carousel-control-prev" type="button" data-bs-target="#homeBannerCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Trước</span>
                    </button>

                    <button class="carousel-control-next" type="button" data-bs-target="#homeBannerCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Sau</span>
                    </button>
                </div>
            </div>
        </div>
    </section>
}

<section class="container pb-5">
    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card h-100 border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h3 class="h4 fw-bold mb-3">Dành cho Quản trị viên</h3>
                    <p class="text-muted mb-0">
                        Quản lý tài khoản nội bộ, phân quyền, cấu hình website, banner trang chủ
                        và các thông tin vận hành chung của hệ thống.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card h-100 border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h3 class="h4 fw-bold mb-3">Dành cho Học vụ</h3>
                    <p class="text-muted mb-0">
                        Tổ chức khóa học, mở lớp học, quản lý ghi danh, theo dõi tình trạng học viên
                        và vận hành đào tạo hằng ngày.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card h-100 border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h3 class="h4 fw-bold mb-3">Dành cho Giảng viên và Học viên</h3>
                    <p class="text-muted mb-0">
                        Theo dõi lớp học, tài liệu, bài tập, tiến độ học tập và các tương tác cần thiết
                        trong môi trường học online.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="lien-he" class="container pb-5">
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4 p-lg-5">
            <div class="row g-4 align-items-center">
                <div class="col-lg-7">
                    <span class="badge bg-success-subtle text-success px-3 py-2 mb-3">
                        Thông tin liên hệ
                    </span>

                    <h2 class="fw-bold mb-3">
                        Bắt đầu vận hành hệ thống với @siteName
                    </h2>

                    <p class="text-muted mb-4">
                        Nếu bạn cần tư vấn triển khai, hỗ trợ sử dụng hệ thống hoặc muốn tìm hiểu thêm
                        về mô hình quản lý khóa học online, hãy liên hệ theo thông tin bên dưới.
                    </p>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="p-3 bg-light rounded-4 h-100">
                                <div class="fw-semibold mb-1">Điện thoại</div>
                                <div class="text-muted">@contactPhone</div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="p-3 bg-light rounded-4 h-100">
                                <div class="fw-semibold mb-1">Email</div>
                                <div class="text-muted">@contactEmail</div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="p-3 bg-light rounded-4 h-100">
                                <div class="fw-semibold mb-1">Địa chỉ</div>
                                <div class="text-muted">@contactAddress</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-5">
                    <div class="p-4 bg-light rounded-4">
                        <h3 class="h5 fw-bold mb-3">Tại sao bố cục này phù hợp?</h3>
                        <ul class="text-muted mb-0 ps-3">
                            <li class="mb-2">Những phần admin đang cấu hình được sẽ hiển thị rõ trên trang chủ.</li>
                            <li class="mb-2">Banner slide được dùng đúng mục đích, không bị thừa.</li>
                            <li class="mb-2">Thông tin liên hệ lấy trực tiếp từ cài đặt hệ thống.</li>
                            <li class="mb-2">Bỏ bớt nội dung cứng chưa gắn với dữ liệu thật.</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>