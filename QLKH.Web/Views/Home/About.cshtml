@{
    ViewData["Title"] = "Giới thiệu";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<section class="about-page">
    <div class="about-stars" aria-hidden="true">
        <div class="about-stars__layer about-stars__layer--1"></div>
        <div class="about-stars__layer about-stars__layer--2"></div>
        <div class="about-stars__layer about-stars__layer--3"></div>
    </div>

    <section class="about-hero">
        <div class="about-container">
            <div class="about-hero__content">
                <span class="about-kicker">GIỚI THIỆU HỆ THỐNG</span>
                <h1 class="about-title">Nền tảng Quản Lý Khóa Học Online QLKH</h1>
                <p class="about-subtitle">
                    QLKH là hệ thống hỗ trợ quản lý đào tạo trực tuyến theo hướng hiện đại, trực quan và dễ vận hành,
                    giúp kết nối quản trị viên, học vụ, giảng viên và học viên trên cùng một nền tảng thống nhất.
                </p>

                <div class="about-hero__actions">
                    <a href="@Url.Action("Index", "Home")" class="about-btn about-btn--primary">Về trang chủ</a>
                    <a href="@Url.Action("Index", "Home")#lien-he" class="about-btn about-btn--ghost">Liên hệ tư vấn</a>
                </div>
            </div>

            <div class="about-hero__visual">
                <div class="about-orb-card">
                    <div class="about-orb-card__glow"></div>
                    <div class="about-orb-card__inner">
                        <div class="about-orb-card__icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                <path d="M12 3L3 8l9 5 9-5-9-5z" />
                                <path d="M3 12l9 5 9-5" />
                                <path d="M3 16l9 5 9-5" />
                            </svg>
                        </div>
                        <h3>QLKH</h3>
                        <p>Quản lý tập trung • Vận hành rõ ràng • Học trực tuyến hiệu quả</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="about-section">
        <div class="about-container">
            <div class="about-grid about-grid--2">
                <article class="about-card">
                    <div class="about-card__icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path d="M4 19h16" />
                            <path d="M4 5h16v10H4z" />
                            <path d="M8 9h8" />
                        </svg>
                    </div>
                    <h2>Mục tiêu xây dựng</h2>
                    <p>
                        Hệ thống được xây dựng nhằm hỗ trợ số hóa quá trình quản lý đào tạo, từ khâu tổ chức khóa học,
                        phân công giảng dạy, quản lý học viên cho đến theo dõi tiến độ và kết quả học tập.
                    </p>
                    <p>
                        QLKH hướng tới việc tạo ra một môi trường quản lý tập trung, giảm thao tác thủ công,
                        nâng cao hiệu quả vận hành và cải thiện trải nghiệm sử dụng cho tất cả các vai trò trong hệ thống.
                    </p>
                </article>

                <article class="about-card">
                    <div class="about-card__icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2" />
                            <circle cx="10" cy="7" r="4" />
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                            <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                        </svg>
                    </div>
                    <h2>Đối tượng sử dụng</h2>
                    <ul class="about-list">
                        <li><strong>Quản trị viên:</strong> quản lý tài khoản, cấu hình hệ thống, vận hành tổng thể.</li>
                        <li><strong>Học vụ:</strong> tổ chức khóa học, lớp học, quản lý nghiệp vụ đào tạo.</li>
                        <li><strong>Giảng viên:</strong> quản lý tài liệu, bài tập, tiến độ giảng dạy.</li>
                        <li><strong>Học viên:</strong> theo dõi lịch học, tài liệu, bài tập và kết quả học tập.</li>
                    </ul>
                </article>
            </div>
        </div>
    </section>

    <section class="about-section about-section--alt">
        <div class="about-container">
            <div class="about-section__head">
                <span class="about-kicker">GIÁ TRỊ NỔI BẬT</span>
                <h2>Những điểm mạnh của nền tảng</h2>
                <p>Hệ thống được thiết kế để phù hợp với nhu cầu đào tạo trực tuyến và quản lý học tập tập trung.</p>
            </div>

            <div class="about-grid about-grid--3">
                <article class="about-feature">
                    <div class="about-feature__number">01</div>
                    <h3>Quản lý tập trung</h3>
                    <p>Toàn bộ dữ liệu khóa học, lớp học, tài khoản và hoạt động đào tạo được quản lý trên một hệ thống duy nhất.</p>
                </article>

                <article class="about-feature">
                    <div class="about-feature__number">02</div>
                    <h3>Vận hành rõ ràng</h3>
                    <p>Phân quyền theo từng vai trò, hỗ trợ xử lý nghiệp vụ minh bạch, dễ kiểm soát và thuận tiện mở rộng.</p>
                </article>

                <article class="about-feature">
                    <div class="about-feature__number">03</div>
                    <h3>Học trực tuyến hiệu quả</h3>
                    <p>Hỗ trợ tài liệu, bài tập, theo dõi tiến độ và kết quả học tập trên giao diện trực quan, dễ sử dụng.</p>
                </article>
            </div>
        </div>
    </section>

    <section class="about-section">
        <div class="about-container">
            <div class="about-section__head">
                <span class="about-kicker">LỘ TRÌNH PHÁT TRIỂN</span>
                <h2>Quá trình hình thành và hoàn thiện</h2>
            </div>

            <div class="about-timeline">
                <article class="about-timeline__item">
                    <div class="about-timeline__dot"></div>
                    <div class="about-timeline__content">
                        <span class="about-timeline__step">Giai đoạn 1</span>
                        <h3>Xây dựng nền tảng lõi</h3>
                        <p>Thiết kế cấu trúc hệ thống, tổ chức dữ liệu, phân quyền người dùng và triển khai các chức năng nền tảng.</p>
                    </div>
                </article>

                <article class="about-timeline__item">
                    <div class="about-timeline__dot"></div>
                    <div class="about-timeline__content">
                        <span class="about-timeline__step">Giai đoạn 2</span>
                        <h3>Hoàn thiện nghiệp vụ đào tạo</h3>
                        <p>Bổ sung quản lý khóa học, lớp học, học viên, tài liệu, bài tập và các thao tác phục vụ vận hành thực tế.</p>
                    </div>
                </article>

                <article class="about-timeline__item">
                    <div class="about-timeline__dot"></div>
                    <div class="about-timeline__content">
                        <span class="about-timeline__step">Giai đoạn 3</span>
                        <h3>Mở rộng trải nghiệm người dùng</h3>
                        <p>Tối ưu giao diện public, dashboard quản trị, liên hệ hỗ trợ, thông báo và các thành phần trực quan hơn.</p>
                    </div>
                </article>

                <article class="about-timeline__item">
                    <div class="about-timeline__dot"></div>
                    <div class="about-timeline__content">
                        <span class="about-timeline__step">Định hướng tiếp theo</span>
                        <h3>Tích hợp AI và báo cáo nâng cao</h3>
                        <p>Phát triển các tính năng AI tư vấn, hỗ trợ học viên, thống kê chuyên sâu và mở rộng khả năng tích hợp dữ liệu.</p>
                    </div>
                </article>
            </div>
        </div>
    </section>

    <section class="about-section">
        <div class="about-container">
            <div class="about-grid about-grid--2">
                <article class="about-card">
                    <div class="about-card__icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path d="M12 20h9" />
                            <path d="M12 4h9" />
                            <path d="M4 9h16" />
                            <path d="M4 15h16" />
                        </svg>
                    </div>
                    <h2>Công nghệ sử dụng</h2>
                    <ul class="about-list">
                        <li>ASP.NET Core MVC</li>
                        <li>Entity Framework Core</li>
                        <li>SQL Server</li>
                        <li>Razor Views</li>
                        <li>Kiến trúc phân tầng</li>
                    </ul>
                </article>

                <article class="about-card">
                    <div class="about-card__icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z" />
                        </svg>
                    </div>
                    <h2>Định hướng phát triển</h2>
                    <p>
                        Trong tương lai, hệ thống có thể tiếp tục mở rộng với các tính năng như báo cáo thống kê chuyên sâu,
                        hỗ trợ AI tư vấn, tích hợp thông báo thông minh, chatbot hỗ trợ học viên và đồng bộ dữ liệu đa nền tảng.
                    </p>
                </article>
            </div>
        </div>
    </section>
</section>

@section Styles {
    <style>
        .about-page {
            position: relative;
            min-height: 100vh;
            background: radial-gradient(circle at 18% -10%, rgba(99, 102, 241, 0.14), transparent 28%), radial-gradient(circle at 82% 0%, rgba(34, 211, 238, 0.10), transparent 24%), linear-gradient(180deg, #050505 0%, #030308 100%);
            color: #f8fafc;
            overflow: hidden;
        }

        .about-stars {
            position: absolute;
            inset: 0;
            pointer-events: none;
            overflow: hidden;
        }

        .about-stars__layer {
            position: absolute;
            inset: 0;
            background-repeat: repeat;
            opacity: .7;
        }

        .about-stars__layer--1 {
            background-image: radial-gradient(1px 1px at 10% 10%, #fff, transparent), radial-gradient(1px 1px at 30% 20%, #fff, transparent), radial-gradient(1px 1px at 50% 50%, #fff, transparent), radial-gradient(1px 1px at 70% 30%, #fff, transparent), radial-gradient(1px 1px at 90% 10%, #fff, transparent);
            background-size: 220px 220px;
        }

        .about-stars__layer--2 {
            background-image: radial-gradient(1.5px 1.5px at 20% 40%, #fff, transparent), radial-gradient(1.5px 1.5px at 60% 85%, #fff, transparent), radial-gradient(1.5px 1.5px at 85% 65%, #fff, transparent);
            background-size: 320px 320px;
            opacity: .45;
        }

        .about-stars__layer--3 {
            background-image: radial-gradient(2px 2px at 40% 70%, #fff, transparent), radial-gradient(2px 2px at 10% 80%, #fff, transparent), radial-gradient(2px 2px at 80% 40%, #fff, transparent);
            background-size: 420px 420px;
            opacity: .3;
        }

        .about-container {
            width: min(1180px, calc(100% - 32px));
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }

        .about-hero {
            padding: 76px 0 44px;
        }

            .about-hero .about-container {
                display: grid;
                grid-template-columns: 1.2fr .8fr;
                gap: 28px;
                align-items: center;
            }

        .about-kicker {
            display: inline-block;
            margin-bottom: 14px;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: .18em;
            color: rgba(255,255,255,.68);
        }

        .about-title {
            font-size: clamp(2rem, 4vw, 3.5rem);
            line-height: 1.12;
            margin-bottom: 18px;
            font-weight: 800;
        }

        .about-subtitle {
            font-size: 1.05rem;
            line-height: 1.85;
            color: rgba(255,255,255,.78);
            max-width: 760px;
        }

        .about-hero__actions {
            display: flex;
            gap: 14px;
            flex-wrap: wrap;
            margin-top: 28px;
        }

        .about-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 150px;
            padding: 12px 22px;
            border-radius: 999px;
            text-decoration: none;
            font-weight: 700;
            transition: all .25s ease;
        }

        .about-btn--primary {
            background: linear-gradient(135deg, #4f46e5, #22d3ee);
            color: #fff;
            box-shadow: 0 12px 28px rgba(79, 70, 229, .35);
        }

            .about-btn--primary:hover {
                transform: translateY(-2px);
                color: #fff;
            }

        .about-btn--ghost {
            border: 1px solid rgba(255,255,255,.14);
            background: rgba(255,255,255,.06);
            color: #fff;
        }

            .about-btn--ghost:hover {
                background: rgba(255,255,255,.10);
                color: #fff;
            }

        .about-hero__visual {
            display: flex;
            justify-content: center;
        }

        .about-orb-card {
            position: relative;
            width: min(360px, 100%);
            border-radius: 28px;
            padding: 22px;
            background: rgba(255,255,255,.06);
            border: 1px solid rgba(255,255,255,.10);
            box-shadow: 0 20px 50px rgba(0,0,0,.28);
            backdrop-filter: blur(10px);
            overflow: hidden;
        }

        .about-orb-card__glow {
            position: absolute;
            inset: -30% auto auto -10%;
            width: 240px;
            height: 240px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(79,70,229,.4), transparent 65%);
            filter: blur(12px);
        }

        .about-orb-card__inner {
            position: relative;
            z-index: 1;
            text-align: center;
            padding: 30px 18px;
        }

        .about-orb-card__icon {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 16px;
            background: linear-gradient(135deg, rgba(79,70,229,.25), rgba(34,211,238,.25));
            border: 1px solid rgba(255,255,255,.10);
        }

            .about-orb-card__icon svg {
                width: 28px;
                height: 28px;
                color: #fff;
            }

        .about-orb-card__inner h3 {
            font-size: 1.8rem;
            margin-bottom: 10px;
        }

        .about-orb-card__inner p {
            color: rgba(255,255,255,.76);
            line-height: 1.7;
        }

        .about-section {
            padding: 26px 0;
            position: relative;
            z-index: 1;
        }

        .about-section--alt {
            background: rgba(255,255,255,.03);
            border-top: 1px solid rgba(255,255,255,.06);
            border-bottom: 1px solid rgba(255,255,255,.06);
        }

        .about-section__head {
            text-align: center;
            margin-bottom: 28px;
        }

            .about-section__head h2 {
                font-size: 2rem;
                margin-bottom: 10px;
            }

            .about-section__head p {
                color: rgba(255,255,255,.72);
                line-height: 1.7;
            }

        .about-grid {
            display: grid;
            gap: 22px;
        }

        .about-grid--2 {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .about-grid--3 {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .about-card,
        .about-feature {
            background: rgba(255,255,255,.06);
            border: 1px solid rgba(255,255,255,.10);
            border-radius: 22px;
            padding: 24px;
            box-shadow: 0 10px 30px rgba(0,0,0,.18);
            backdrop-filter: blur(6px);
        }

        .about-card__icon {
            width: 52px;
            height: 52px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 16px;
            background: linear-gradient(135deg, rgba(79,70,229,.24), rgba(34,211,238,.18));
            border: 1px solid rgba(255,255,255,.10);
        }

            .about-card__icon svg {
                width: 22px;
                height: 22px;
                color: #fff;
            }

        .about-card h2,
        .about-feature h3 {
            margin-bottom: 14px;
            color: #fff;
        }

        .about-card p,
        .about-feature p,
        .about-list li {
            color: rgba(255,255,255,.78);
            line-height: 1.8;
        }

        .about-list {
            padding-left: 18px;
            margin: 0;
        }

        .about-feature__number {
            width: 46px;
            height: 46px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 14px;
            font-weight: 700;
            color: #fff;
            background: linear-gradient(135deg, #4f46e5, #22d3ee);
            box-shadow: 0 8px 20px rgba(79, 70, 229, .32);
        }

        .about-timeline {
            position: relative;
            display: grid;
            gap: 20px;
        }

            .about-timeline::before {
                content: "";
                position: absolute;
                left: 15px;
                top: 0;
                bottom: 0;
                width: 2px;
                background: linear-gradient(180deg, rgba(79,70,229,.9), rgba(34,211,238,.45));
            }

        .about-timeline__item {
            position: relative;
            display: grid;
            grid-template-columns: 30px 1fr;
            gap: 18px;
            align-items: start;
        }

        .about-timeline__dot {
            position: relative;
            z-index: 1;
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: linear-gradient(135deg, #4f46e5, #22d3ee);
            box-shadow: 0 0 0 6px rgba(79,70,229,.12);
        }

        .about-timeline__content {
            background: rgba(255,255,255,.05);
            border: 1px solid rgba(255,255,255,.08);
            border-radius: 18px;
            padding: 18px 20px;
        }

        .about-timeline__step {
            display: inline-block;
            margin-bottom: 8px;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: rgba(255,255,255,.62);
        }

        .about-timeline__content h3 {
            margin-bottom: 10px;
            font-size: 1.2rem;
        }

        .about-timeline__content p {
            color: rgba(255,255,255,.76);
            line-height: 1.75;
            margin: 0;
        }

        @@media (max-width: 980px) {
            .about-hero .about-container,
            .about-grid--2,
            .about-grid--3 {
                grid-template-columns: 1fr;
            }

            .about-hero {
                padding: 58px 0 34px;
            }

            .about-hero__visual {
                justify-content: flex-start;
            }
        }

        @@media (max-width: 640px) {
            .about-container {
                width: min(1180px, calc(100% - 20px));
            }

            .about-title {
                font-size: 2rem;
            }

            .about-subtitle,
            .about-card p,
            .about-feature p,
            .about-list li,
            .about-timeline__content p {
                line-height: 1.7;
            }

            .about-card,
            .about-feature,
            .about-timeline__content {
                padding: 18px;
            }

            .about-hero__actions {
                gap: 10px;
            }

            .about-btn {
                width: 100%;
            }
        }
    </style>
}