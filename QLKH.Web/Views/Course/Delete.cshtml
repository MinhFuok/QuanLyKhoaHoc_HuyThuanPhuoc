@model QLKH.Domain.Entities.Course

@{
    ViewData["Title"] = "Xóa khóa học";
}

<h2>Xóa khóa học</h2>

<h4>Bạn có chắc muốn xóa khóa học này không?</h4>

<div>
    <dl class="row">
        <dt class="col-sm-3">Mã khóa học</dt>
        <dd class="col-sm-9">@Model.CourseCode</dd>

        <dt class="col-sm-3">Tên khóa học</dt>
        <dd class="col-sm-9">@Model.CourseName</dd>

        <dt class="col-sm-3">Mô tả</dt>
        <dd class="col-sm-9">@Model.Description</dd>

        <dt class="col-sm-3">Thời lượng</dt>
        <dd class="col-sm-9">@Model.DurationInMonths tháng</dd>

        <dt class="col-sm-3">Học phí</dt>
        <dd class="col-sm-9">@Model.Fee.ToString("N0")</dd>

        <dt class="col-sm-3">Trạng thái</dt>
        <dd class="col-sm-9">@Model.Status</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Xóa</button>
        <a asp-action="Index" class="btn btn-secondary">Hủy</a>
    </form>
</div>