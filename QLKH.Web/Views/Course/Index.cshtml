@model IEnumerable<QLKH.Domain.Entities.Course>

@{
    ViewData["Title"] = "Danh sách khóa học";
    Layout = "~/Views/Shared/_DashBoardLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/AdminProfession.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboardlayout.css" />
}

<div class="course-page course-index">

    <div class="cp-header">
        <div class="cp-header-left">
            <h1 class="cp-title">Danh sách khóa học</h1>
            <p class="cp-subtitle">Quản lý toàn bộ khóa học trong hệ thống</p>
        </div>
        @if (User.IsInRole("Admin") || User.IsInRole("HocVu"))
        {
            <a asp-action="Create" class="cp-btn cp-btn--primary">
                <span>＋</span> Thêm mới
            </a>
        }
    </div>

    <div class="cp-table-wrap">
        <table class="cp-table" id="courseTable">
            <thead>
                <tr>
                    <th>Mã khóa học</th>
                    <th>Tên khóa học</th>
                    <th>Thời lượng</th>
                    <th>Học phí</th>
                    <th>Trạng thái</th>
                    <th class="cp-col-action">Chức năng</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="cp-row">
                        <td><span class="cp-code">@item.CourseCode</span></td>
                        <td class="cp-name">@item.CourseName</td>
                        <td>@item.DurationInMonths tháng</td>
                        <td class="cp-fee">@item.Fee.ToString("N0") ₫</td>
                        <td>
                            <span class="cp-badge cp-badge--@item.Status.ToString().ToLower()">
                                @item.Status
                            </span>
                        </td>
                        <td class="cp-actions">
                            <a asp-action="Details" asp-route-id="@item.Id" class="cp-btn cp-btn--info cp-btn--sm">Chi tiết</a>
                            @if (User.IsInRole("Admin") || User.IsInRole("HocVu"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="cp-btn cp-btn--warning cp-btn--sm">Sửa</a>
                            }
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Delete" asp-route-id="@item.Id" class="cp-btn cp-btn--danger cp-btn--sm">Xóa</a>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="cp-empty">Chưa có khóa học nào.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/AdminProfession.js" asp-append-version="true"></script>
}

