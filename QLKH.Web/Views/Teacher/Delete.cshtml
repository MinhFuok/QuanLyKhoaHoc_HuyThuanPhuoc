@model QLKH.Domain.Entities.Teacher

@{
    ViewData["Title"] = "Xóa giảng viên";
}

@section Styles {
    <link rel="stylesheet" href="~/css/AdminProfession.css" asp-append-version="true" />
}

<div class="course-page admin-profession-page teacher-page">
    <div class="cp-header">
        <div class="cp-header-left">
            <h1 class="cp-title">Xóa giảng viên</h1>
            <p class="cp-subtitle">Kiểm tra kỹ thông tin trước khi xác nhận xóa.</p>
        </div>
    </div>

    <div class="cp-delete-card">
        <div class="cp-delete-warning">
            <div class="cp-delete-warning-icon">!</div>
            <div>
                <strong>Bạn có chắc muốn xóa giảng viên này không?</strong>
                <p>Hành động này có thể ảnh hưởng đến lớp học, lịch dạy và các nghiệp vụ liên quan.</p>
            </div>
        </div>

        <div class="cp-detail-body">
            <div class="cp-detail-row">
                <div class="cp-detail-label">Mã giảng viên</div>
                <div class="cp-detail-value"><span class="cp-code">@Model.TeacherCode</span></div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Họ tên</div>
                <div class="cp-detail-value"><strong>@Model.FullName</strong></div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Email</div>
                <div class="cp-detail-value">@Model.Email</div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Số điện thoại</div>
                <div class="cp-detail-value">@Model.PhoneNumber</div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Chuyên môn</div>
                <div class="cp-detail-value">@Model.Specialization</div>
            </div>
        </div>

        <form asp-action="Delete" method="post" id="deleteForm" data-delete-label="giảng viên">
            <input type="hidden" asp-for="Id" />
            <div class="cp-delete-actions">
                <button type="submit" class="cp-btn cp-btn--danger">Xóa giảng viên</button>
                <a asp-action="Index" class="cp-btn cp-btn--ghost">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/AdminProfession.js" asp-append-version="true"></script>
}
