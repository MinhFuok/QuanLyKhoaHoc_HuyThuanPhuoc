@{
    ViewData["Title"] = "Xác nhận gửi email";
    Layout = "_PublicLayout";
}

<link rel="stylesheet" href="~/css/account.css" />

<div class="login-page">
    <div style="max-width:420px; width:100%;">
        <div class="card login-card">
            <div class="card-header text-center">
                <h3>Xác nhận gửi email<span>Forgot Password Confirmation</span></h3>
            </div>
            <div class="card-body">

                <div class="confirm-icon">✉️</div>

                <p class="confirm-text">
                    Nếu email tồn tại trong hệ thống, link đặt lại mật khẩu đã được gửi tới hộp thư của bạn.
                </p>

                <p class="confirm-sub">
                    Vui lòng kiểm tra hộp thư đến hoặc thư mục spam.
                </p>

                <div class="mb-3 text-center forgot-link">
                    <a href="/Account/Login">← Quay lại đăng nhập</a>
                </div>

            </div>
        </div>
    </div>
</div>

<style>
    .confirm-icon {
        text-align: center;
        font-size: 3rem;
        margin-bottom: 1rem;
        animation: floatIcon 3s ease-in-out infinite;
    }

    @@keyframes floatIcon {
        0%, 100% { transform: translateY(0);    }
        50%       { transform: translateY(-8px); }
    }

    .confirm-text {
        color: #d0f0d0;
        font-family: monospace;
        font-size: 0.92rem;
        text-align: center;
        line-height: 1.6;
        border: 1px solid rgba(0, 255, 128, 0.25);
        border-radius: 6px;
        padding: 1rem;
        background: rgba(0, 255, 128, 0.06);
        margin-bottom: 0.75rem;
    }

    .confirm-sub {
        color: #8a9bb0;
        font-family: monospace;
        font-size: 0.78rem;
        text-align: center;
        margin-bottom: 1.2rem;
    }
</style>

@section Scripts {
    <script src="~/js/account.js"></script>
}