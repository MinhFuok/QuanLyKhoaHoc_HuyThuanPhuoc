@model QLKH.Web.Models.Account.ChangePasswordViewModel

@{
    ViewData["Title"] = "Đổi mật khẩu";
    Layout = "_DashboardLayout";
}

<link rel="stylesheet" href="~/css/account.css" />

<div class="login-page">
    <div style="max-width:420px; width:100%;">
        <div class="card login-card">
            <div class="card-header text-center">
                <h3>Đổi mật khẩu<span>CHANGE PASSWORD</span></h3>
            </div>

            <div class="card-body">
                <form asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="CurrentPassword" class="form-label">Mật khẩu hiện tại</label>
                        <input asp-for="CurrentPassword"
                               type="password"
                               class="form-control" />
                        <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label">Mật khẩu mới</label>
                        <input asp-for="NewPassword"
                               type="password"
                               class="form-control" />
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label">Xác nhận mật khẩu</label>
                        <input asp-for="ConfirmPassword"
                               type="password"
                               class="form-control" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn-login" style="margin-top: 25px;">
                        Đổi mật khẩu
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/js/account.js"></script>
}
@section Styles {
    <style>
        html,
        body {
            height: 100%;
            overflow: hidden !important;
        }

        body {
            background: radial-gradient(circle at top left, rgba(59, 130, 246, 0.25), transparent 30%), radial-gradient(circle at bottom right, rgba(168, 85, 247, 0.22), transparent 35%), linear-gradient(135deg, #020617 0%, #0f172a 45%, #111827 100%) !important;
        }

        .dashboard-main,
        .dashboard-content,
        .db-main,
        .db-main-wrap,
        .db-content {
            background: transparent !important;
        }

        .dashboard-content,
        .db-content {
            height: 100vh !important;
            min-height: 100vh !important;
            max-height: 100vh !important;
            padding: 0 !important;
            margin: 0 !important;
            overflow: hidden !important;
            box-sizing: border-box !important;
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
        }

        .login-page {
            width: 100%;
            min-height: 0 !important;
            height: auto !important;
            padding: 0 !important;
            margin: 0 !important;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .login-page > div {
                max-width: 360px !important;
                width: 100% !important;
            }

        .login-card {
            margin: 0 !important;
            border-radius: 20px !important;
            overflow: hidden !important;
        }

            .login-card .card-header {
                padding: 16px 20px 14px !important;
            }

                .login-card .card-header h3 {
                    margin: 0 !important;
                    font-size: 1.1rem !important;
                    line-height: 1.15 !important;
                    font-weight: 900 !important;
                }

                    .login-card .card-header h3 span {
                        display: block !important;
                        margin-top: 4px !important;
                        font-size: 1.4rem !important;
                        line-height: 1.05 !important;
                        letter-spacing: 0.08em !important;
                    }

            .login-card .card-body {
                padding: 20px 22px 22px !important;
            }

            .login-card .mb-3 {
                margin-bottom: 11px !important;
            }

            .login-card .form-label {
                margin-bottom: 5px !important;
                font-size: 0.86rem !important;
                font-weight: 800 !important;
            }

            .login-card .form-control {
                height: 39px !important;
                min-height: 39px !important;
                border-radius: 12px !important;
                padding: 8px 12px !important;
                font-size: 0.9rem !important;
            }

            .login-card .text-danger {
                display: block;
                margin-top: 3px !important;
                font-size: 0.72rem !important;
                line-height: 1.2 !important;
            }

            .login-card .btn-login {
                width: 100% !important;
                height: 40px !important;
                min-height: 40px !important;
                margin-top: 12px !important;
                border-radius: 12px !important;
                font-size: 0.9rem !important;
                font-weight: 900 !important;
            }

        @@media (max-width: 768px) {
            .dashboard-content,
            .db-content {
                height: 100dvh !important;
                min-height: 100dvh !important;
                max-height: 100dvh !important;
                padding: 62px 10px 10px !important;
            }

            .login-page > div {
                max-width: 310px !important;
            }

            .login-card .card-header {
                padding: 12px 15px 10px !important;
            }

                .login-card .card-header h3 {
                    font-size: 1rem !important;
                }

                    .login-card .card-header h3 span {
                        font-size: 1.15rem !important;
                    }

            .login-card .card-body {
                padding: 14px 15px 16px !important;
            }

            .login-card .mb-3 {
                margin-bottom: 8px !important;
            }

            .login-card .form-label {
                margin-bottom: 4px !important;
                font-size: 0.78rem !important;
            }

            .login-card .form-control {
                height: 36px !important;
                min-height: 36px !important;
                font-size: 0.86rem !important;
            }

            .login-card .btn-login {
                height: 38px !important;
                min-height: 38px !important;
                margin-top: 9px !important;
            }
        }
    </style>
}