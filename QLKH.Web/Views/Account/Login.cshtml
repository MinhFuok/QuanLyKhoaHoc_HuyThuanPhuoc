@model QLKH.Web.Models.Account.LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_PublicLayout";
    ViewData["HideHeader"] = true;
    ViewData["HideFooter"] = true;
}

<link rel="stylesheet" href="~/css/account.css" />

<div class="login-page">
    <div style="max-width:420px; width:100%;">
        <div class="card login-card">
            <div class="card-header text-center">
                <h3>Đăng nhập hệ thống<span>LOGIN</span></h3>
            </div>
            <div class="card-body">
                <form asp-action="Login" method="post">
                    <input asp-for="ReturnUrl" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" placeholder="email@example.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Mật khẩu</label>
                        <input asp-for="Password" class="form-control" placeholder="••••••••" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-2">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label">Ghi nhớ đăng nhập</label>
                    </div>

                    <div class="mb-3 text-end forgot-link">
                        <a href="/Account/ForgotPassword">Quên mật khẩu?</a>
                    </div>

                    <button type="submit" class="btn-login">Đăng nhập</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/account.js"></script>
}