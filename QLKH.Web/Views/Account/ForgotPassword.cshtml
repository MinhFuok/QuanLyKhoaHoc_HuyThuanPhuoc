@model QLKH.Web.Models.Account.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "_PublicLayout";
    ViewData["HideHeader"] = true;
    ViewData["HideFooter"] = true;
}

<link rel="stylesheet" href="~/css/account.css" />

<div class="login-page">
    <div style="max-width:420px; width:100%;">
        <div class="card login-card">
            <div class="card-header text-center">
                <h3>Quên mật khẩu<span>Forgot Password</span></h3>
            </div>
            <div class="card-body">
                <form asp-action="ForgotPassword" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" placeholder="email@example.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3 text-end forgot-link">
                        <a href="/Account/Login">← Quay lại đăng nhập</a>
                    </div>

                    <button type="submit" class="btn-login">
                        Gửi link đặt lại mật khẩu
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/account.js"></script>
}