@{
    ViewData["Title"] = "AI Tư vấn hỗ trợ";
    Layout = "~/Views/Shared/_DashBoardLayout.cshtml";
}

<div class="ai-support-page">
    <div class="ai-support-hero card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <div class="page-eyebrow">QLKH AI SUPPORT</div>
                    <h2 class="page-title mb-2">AI TƯ VẤN HỖ TRỢ</h2>
                    <p class="page-subtitle mb-0">
                        Hỏi nhanh các vấn đề liên quan đến lớp học, bài tập, tài liệu, bảng điểm và cách sử dụng hệ thống.
                    </p>
                </div>

                <a href="javascript:history.back()" class="btn btn-outline-primary hero-action-btn">
                    ← Quay lại
                </a>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-xl-8">
            <div class="card border-0 shadow-sm chat-card">
                <div class="chat-header">
                    <div class="chat-avatar">AI</div>
                    <div>
                        <div class="chat-title">Trợ lý QLKH</div>
                        <div class="chat-status">
                            <span class="status-dot"></span>
                            Sẵn sàng hỗ trợ
                        </div>
                    </div>
                </div>

                <div id="chatMessages" class="chat-messages">
                    <div class="message-row bot">
                        <div class="message-bubble">
                            Xin chào! Mình là AI tư vấn hỗ trợ của QLKH. Bạn có thể hỏi mình cách xem bài tập, tài liệu, bảng điểm, lịch học hoặc cách sử dụng hệ thống.
                        </div>
                    </div>
                </div>

                <form id="aiChatForm" class="chat-form">
                    @Html.AntiForgeryToken()

                    <textarea id="messageInput"
                              class="chat-input"
                              rows="2"
                              maxlength="1000"
                              placeholder="Nhập câu hỏi của bạn..."></textarea>

                    <button type="submit" id="sendButton" class="btn btn-primary send-btn">
                        Gửi
                    </button>
                </form>
            </div>
        </div>

        <div class="col-12 col-xl-4">
            <div class="card border-0 shadow-sm suggestion-card mb-4">
                <div class="card-header bg-white border-0 p-4 pb-2">
                    <h5 class="section-title mb-1">Câu hỏi gợi ý</h5>
                </div>

                <div class="card-body p-4">
                    <div class="suggestion-list">
                        <button type="button" class="suggestion-item" data-question="Học viên xem bài tập ở đâu?">
                            Học viên xem bài tập ở đâu?
                        </button>

                        <button type="button" class="suggestion-item" data-question="Giáo viên tạo bài tập như thế nào?">
                            Giáo viên tạo bài tập như thế nào?
                        </button>

                        <button type="button" class="suggestion-item" data-question="Tôi xem tài liệu lớp học ở đâu?">
                            Tôi xem tài liệu lớp học ở đâu?
                        </button>

                        <button type="button" class="suggestion-item" data-question="Học viên xem bảng điểm như thế nào?">
                            Học viên xem bảng điểm như thế nào?
                        </button>

                        <button type="button" class="suggestion-item" data-question="Lớp đã kết thúc thì có đánh giá giáo viên được không?">
                            Lớp đã kết thúc thì có đánh giá giáo viên được không?
                        </button>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm note-card">
                <div class="card-body p-4">
                    <div class="note-icon">💡</div>
                    <h5 class="note-title">Lưu ý</h5>
                    <p class="note-desc mb-0">
                        AI chỉ hỗ trợ tư vấn thao tác sử dụng hệ thống QLKH. Với lỗi tài khoản, học phí, chứng chỉ hoặc vấn đề cần xác minh, vui lòng liên hệ Zalo/Số điện thoại hỗ trợ.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .ai-support-page {
            animation: fadeInPage 0.25s ease-in-out;
        }

        @@keyframes fadeInPage {
            from {
                opacity: 0;
                transform: translateY(6px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .ai-support-hero {
            border-radius: 22px;
            background: linear-gradient(135deg, #f4f8ff 0%, #ffffff 60%, #f8fbff 100%);
            overflow: hidden;
        }

        .page-eyebrow {
            font-size: 0.78rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            color: #3b82f6;
            text-transform: uppercase;
            margin-bottom: 6px;
        }

        .page-title {
            font-size: 2rem;
            font-weight: 800;
            color: #172554;
        }

        .page-subtitle {
            color: #64748b;
            font-weight: 500;
            max-width: 720px;
        }

        .hero-action-btn {
            border-radius: 14px;
            font-weight: 800;
            padding: 12px 16px;
            white-space: nowrap;
        }

        .chat-card,
        .suggestion-card,
        .note-card {
            border-radius: 20px;
            overflow: hidden;
        }

        .chat-header {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 20px 22px;
            border-bottom: 1px solid #e2e8f0;
            background: #ffffff;
        }

        .chat-avatar {
            width: 48px;
            height: 48px;
            border-radius: 16px;
            background: linear-gradient(135deg, #2563eb, #4f46e5);
            color: #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 900;
        }

        .chat-title {
            font-weight: 900;
            color: #0f172a;
            font-size: 1.05rem;
        }

        .chat-status {
            color: #64748b;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 7px;
        }

        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 999px;
            background: #22c55e;
            display: inline-block;
        }

        .chat-messages {
            min-height: 430px;
            max-height: 560px;
            overflow-y: auto;
            padding: 22px;
            background: #f8fafc;
        }

        .message-row {
            display: flex;
            margin-bottom: 14px;
        }

        .message-row.user {
            justify-content: flex-end;
        }

        .message-row.bot {
            justify-content: flex-start;
        }

        .message-bubble {
            max-width: 78%;
            padding: 13px 15px;
            border-radius: 18px;
            line-height: 1.55;
            font-weight: 500;
            white-space: pre-wrap;
            word-break: break-word;
        }

        .message-row.bot .message-bubble {
            background: #ffffff;
            color: #0f172a;
            border: 1px solid #e2e8f0;
            border-top-left-radius: 6px;
        }

        .message-row.user .message-bubble {
            background: linear-gradient(135deg, #2563eb, #4f46e5);
            color: #ffffff;
            border-top-right-radius: 6px;
        }

        .message-bubble.loading {
            color: #64748b;
            font-style: italic;
        }

        .chat-form {
            display: flex;
            gap: 12px;
            padding: 18px;
            background: #ffffff;
            border-top: 1px solid #e2e8f0;
        }

        .chat-input {
            flex: 1;
            resize: none;
            border-radius: 16px;
            border: 1px solid #dbe3ef;
            padding: 13px 14px;
            color: #0f172a;
            font-weight: 600;
            outline: none;
            transition: all 0.18s ease-in-out;
        }

        .chat-input:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 0.2rem rgba(59, 130, 246, 0.12);
        }

        .send-btn {
            border-radius: 14px;
            font-weight: 900;
            padding: 0 22px;
            box-shadow: 0 10px 24px rgba(37, 99, 235, 0.18);
        }

        .section-title {
            font-weight: 800;
            color: #172554;
        }

        .suggestion-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .suggestion-item {
            text-align: left;
            border: 1px solid #dbe3ef;
            background: #f8fafc;
            color: #0f172a;
            border-radius: 14px;
            padding: 12px 14px;
            font-weight: 700;
            transition: all 0.18s ease-in-out;
        }

        .suggestion-item:hover {
            background: #eff6ff;
            border-color: #93c5fd;
            color: #1d4ed8;
        }

        .note-card {
            background: linear-gradient(135deg, #eef4ff 0%, #ffffff 100%);
        }

        .note-icon {
            width: 48px;
            height: 48px;
            border-radius: 16px;
            background: #dbeafe;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            margin-bottom: 14px;
        }

        .note-title {
            font-weight: 800;
            color: #172554;
            margin-bottom: 8px;
        }

        .note-desc {
            color: #64748b;
            line-height: 1.55;
        }

        @@media (max-width: 767.98px) {
            .page-title {
                font-size: 1.6rem;
            }

            .hero-action-btn {
                width: 100%;
            }

            .chat-messages {
                min-height: 360px;
                max-height: 460px;
                padding: 16px;
            }

            .message-bubble {
                max-width: 92%;
            }

            .chat-form {
                flex-direction: column;
            }

            .send-btn {
                width: 100%;
                padding: 12px 18px;
            }
        }
    </style>
}

@section Scripts {
    <script>
        (function () {
            const form = document.getElementById('aiChatForm');
            const input = document.getElementById('messageInput');
            const sendButton = document.getElementById('sendButton');
            const chatMessages = document.getElementById('chatMessages');
            const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
            const suggestionButtons = document.querySelectorAll('.suggestion-item');

            function appendMessage(type, text, extraClass) {
                const row = document.createElement('div');
                row.className = 'message-row ' + type;

                const bubble = document.createElement('div');
                bubble.className = 'message-bubble' + (extraClass ? ' ' + extraClass : '');
                bubble.textContent = text;

                row.appendChild(bubble);
                chatMessages.appendChild(row);
                chatMessages.scrollTop = chatMessages.scrollHeight;

                return row;
            }

            async function sendMessage(message) {
                const question = message.trim();

                if (!question) {
                    return;
                }

                appendMessage('user', question);
                input.value = '';

                const loadingRow = appendMessage('bot', 'AI đang trả lời...', 'loading');

                sendButton.disabled = true;
                input.disabled = true;

                try {
                    const response = await fetch('@Url.Action("Ask", "AiSupport")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': tokenInput ? tokenInput.value : ''
                        },
                        body: JSON.stringify({
                            message: question
                        })
                    });

                    const result = await response.json();

                    loadingRow.remove();

                    if (result.success) {
                        appendMessage('bot', result.answer);
                    } else {
                        appendMessage('bot', result.errorMessage || 'AI chưa phản hồi được. Vui lòng thử lại sau.');
                    }
                } catch (error) {
                    loadingRow.remove();
                    appendMessage('bot', 'Không thể kết nối tới AI. Vui lòng thử lại sau.');
                } finally {
                    sendButton.disabled = false;
                    input.disabled = false;
                    input.focus();
                }
            }

            form.addEventListener('submit', function (event) {
                event.preventDefault();
                sendMessage(input.value);
            });

            input.addEventListener('keydown', function (event) {
                if (event.key === 'Enter' && !event.shiftKey) {
                    event.preventDefault();
                    sendMessage(input.value);
                }
            });

            suggestionButtons.forEach(function (button) {
                button.addEventListener('click', function () {
                    const question = button.getAttribute('data-question') || '';
                    sendMessage(question);
                });
            });
        })();
    </script>
}