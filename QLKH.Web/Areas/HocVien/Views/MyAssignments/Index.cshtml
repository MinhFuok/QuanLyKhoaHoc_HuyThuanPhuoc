@model IEnumerable<QLKH.Domain.Entities.Assignment>
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Bài tập lớp tôi học";
    Layout = "~/Views/Shared/_DashBoardLayout.cshtml";

    var today = DateTime.Today;
    var assignments = Model?.ToList() ?? new List<QLKH.Domain.Entities.Assignment>();

    var classRoomOptions = ViewBag.ClassRoomOptions as List<SelectListItem>
        ?? new List<SelectListItem>();

    int? selectedClassRoomId = ViewBag.SelectedClassRoomId as int?;

    var totalAssignments = assignments.Count;
    var activeAssignments = assignments.Count(x => x.DueDate.Date >= today);
    var dueSoonAssignments = assignments.Count(x => x.DueDate.Date >= today && x.DueDate.Date <= today.AddDays(3));
    var overdueAssignments = assignments.Count(x => x.DueDate.Date < today);
    var submittedAssignmentIds = (ViewBag.SubmittedAssignmentIds as IEnumerable<int>)?.ToHashSet()
        ?? new HashSet<int>();
}

<div class="student-assignments-page">

    <!-- Header -->
    <div class="assignments-hero card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <h2 class="page-title mb-2">BÀI TẬP</h2>
                    <div class="page-eyebrow">HỌC TẬP</div>
                </div>
            </div>
        </div>
    </div>

    <!-- KPI -->
    <div class="row g-4 mb-4">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="assignment-stat-card stat-total card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-icon">📚</div>
                    <div>
                        <div class="stat-label">Tổng bài tập</div>
                        <div class="stat-value">@totalAssignments</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="assignment-stat-card stat-active card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-icon">✅</div>
                    <div>
                        <div class="stat-label">Còn hạn nộp</div>
                        <div class="stat-value">@activeAssignments</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="assignment-stat-card stat-due-soon card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-icon">⏳</div>
                    <div>
                        <div class="stat-label">Sắp hết hạn</div>
                        <div class="stat-value">@dueSoonAssignments</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="assignment-stat-card stat-overdue card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-icon">⚠️</div>
                    <div>
                        <div class="stat-label">Đã quá hạn</div>
                        <div class="stat-value">@overdueAssignments</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Content -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 p-4 pb-2">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <h5 class="section-title mb-1">Danh sách bài tập</h5>
                </div>

                <div class="assignment-filter-note">
                    <span class="status-dot active"></span> Còn hạn
                    <span class="status-dot due-soon ms-3"></span> Sắp hết hạn
                    <span class="status-dot overdue ms-3"></span> Quá hạn
                </div>
            </div>
        </div>

        <div class="card-body p-4">
            <form asp-area="HocVien"
                  asp-controller="MyAssignments"
                  asp-action="Index"
                  method="get"
                  class="assignment-filter-form mb-4">

                <div class="assignment-filter-field">
                    <select name="classRoomId" class="form-select assignment-class-select">
                        <option value="">-- Tất cả lớp --</option>

                        @foreach (var option in classRoomOptions)
                        {
                            var isSelected = selectedClassRoomId.HasValue &&
                            option.Value == selectedClassRoomId.Value.ToString();

                            if (isSelected)
                            {
                                <option value="@option.Value" selected="selected">@option.Text</option>
                            }
                            else
                            {
                                <option value="@option.Value">@option.Text</option>
                            }
                        }
                    </select>
                </div>

                <div class="assignment-filter-actions">
                    <button type="submit" class="btn btn-primary">
                        Lọc
                    </button>

                    <a asp-area="HocVien"
                       asp-controller="MyAssignments"
                       asp-action="Index"
                       class="btn btn-outline-secondary">
                        X
                    </a>
                </div>
            </form>

            @if (!assignments.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">📭</div>
                    <h5>Chưa có bài tập nào</h5>
                    <p>
                        Hiện tại chưa có bài tập nào cho các lớp bạn đang học.
                        Khi giáo viên giao bài, danh sách bài tập sẽ hiển thị tại đây.
                    </p>
                </div>
            }
            else
            {
                <div class="table-responsive assignment-table-wrap">
                    <table class="table assignment-table align-middle mb-0">
                        <colgroup>
                            <col style="width: 23%;" />
                            <col style="width: 12%;" />
                            <col style="width: 14%;" />
                            <col style="width: 15%;" />
                            <col style="width: 11%;" />
                            <col style="width: 10%;" />
                            <col style="width: 15%;" />
                        </colgroup>

                        <thead>
                            <tr>
                                <th class="text-center">Bài tập</th>
                                <th class="text-center">Lớp</th>
                                <th class="text-center">Khóa học</th>
                                <th class="text-center">Giáo viên</th>
                                <th class="text-center">Hạn nộp</th>
                                <th class="text-center">Trạng thái</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in assignments.OrderBy(x => x.DueDate))
                            {
                                var dueStatusText = "";
                                var dueStatusClass = "";
                                var isSubmitted = submittedAssignmentIds.Contains(item.Id);

                                if (item.DueDate.Date < today)
                                {
                                    dueStatusText = "Quá hạn";
                                    dueStatusClass = "badge-overdue";
                                }
                                else if (item.DueDate.Date <= today.AddDays(3))
                                {
                                    dueStatusText = "Sắp hết hạn";
                                    dueStatusClass = "badge-due-soon";
                                }
                                else
                                {
                                    dueStatusText = "Còn hạn";
                                    dueStatusClass = "badge-active";
                                }

                            <tr>
                                <td>
                                    <div class="assignment-main">
                                        <div class="assignment-icon">📝</div>
                                        <div class="assignment-main-content">
                                            <div class="assignment-title">@item.Title</div>
                                            <div class="assignment-desc">
                                                @(string.IsNullOrWhiteSpace(item.Description)
                                                                                            ? "Không có mô tả"
                                                                                            : item.Description)
                                        </div>
                                    </div>
                                </div>
                            </td>

                                    <td>
                                        <div class="class-name">
                                            @(item.ClassRoom?.ClassName ?? "Chưa có lớp")
                                        </div>
                                        <div class="class-small">
                                            Mã lớp: @(item.ClassRoom?.ClassCode ?? "N/A")
                                        </div>
                                    </td>

                                    <td>
                                        <div class="course-name">
                                            @(item.ClassRoom?.Course?.CourseName ?? "Chưa có khóa học")
                                        </div>
                                    </td>

                                    <td>
                                        <div class="teacher-name">
                                            @(item.ClassRoom?.Teacher?.FullName ?? "Chưa cập nhật")
                                        </div>
                                    </td>

                                    <td>
                                        <div class="date-block">
                                            <div class="date-main">@item.DueDate.ToString("dd/MM/yyyy")</div>
                                            <div class="date-small">@item.DueDate.ToString("HH:mm")</div>
                                            <span class="assignment-status @dueStatusClass">@dueStatusText</span>
                                        </div>
                                    </td>

                                    <td class="text-center">
                                @if (isSubmitted)
                                        {
                                            <span class="submit-status submit-done">Đã nộp</span>
                                        }
                                        else
                                        {
                                            <span class="submit-status submit-pending">Chưa nộp</span>
                                        }
                                    </td>

                                    <td class="text-center">
                                        <div class="action-group action-group-center">
                                            @if (isSubmitted)
                                            {
                                                <a asp-area="HocVien"
                                                   asp-controller="MySubmissions"
                                                   asp-action="Submit"
                                                   asp-route-assignmentId="@item.Id"
                                                   class="btn btn-sm btn-outline-warning">
                                                    Sửa
                                                </a>
                                                <a asp-area="HocVien"
                                                   asp-controller="MySubmissionResults"
                                                   asp-action="Details"
                                                   asp-route-assignmentId="@item.Id"
                                                   class="btn btn-sm btn-outline-primary">
                                                    Kết quả
                                                </a>
                                            }
                                            else
                                            {
                                                <a asp-area="HocVien"
                                                   asp-controller="MySubmissions"
                                                   asp-action="Submit"
                                                   asp-route-assignmentId="@item.Id"
                                                   class="btn btn-sm btn-primary">
                                                    Nộp bài
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                                                }
                        </tbody>
                    </table>
                </div>

                <div class="assignment-summary mt-3">
                    <span>Tổng bài tập: <strong>@totalAssignments</strong></span>
                    <span>Còn hạn: <strong>@activeAssignments</strong></span>
                    <span>Sắp hết hạn: <strong>@dueSoonAssignments</strong></span>
                    <span>Quá hạn: <strong>@overdueAssignments</strong></span>
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <style>
        .student-assignments-page {
            animation: fadeInPage 0.25s ease-in-out;
        }

        @@keyframes fadeInPage {
            from {
                opacity: 0;
                transform: translateY(6px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .assignments-hero {
            border-radius: 22px;
            background: linear-gradient(135deg, #f4f8ff 0%, #ffffff 60%, #f8fbff 100%);
            overflow: hidden;
        }

        .page-eyebrow {
            font-size: 0.78rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            color: #3b82f6;
            text-transform: uppercase;
            margin-bottom: 6px;
        }

        .page-title {
            font-size: 2rem;
            font-weight: 800;
            color: #172554;
        }

        .hero-badge {
            min-width: 210px;
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 18px;
            border-radius: 18px;
            background: #ffffff;
            border: 1px solid #e5e7eb;
            box-shadow: 0 10px 25px rgba(15, 23, 42, 0.06);
        }

        .hero-badge-icon {
            width: 48px;
            height: 48px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #eff6ff;
            font-size: 1.4rem;
        }

        .hero-badge-label {
            color: #64748b;
            font-size: 0.9rem;
        }

        .hero-badge-value {
            color: #172554;
            font-size: 1.7rem;
            font-weight: 800;
            line-height: 1;
        }

        .assignment-stat-card {
            border-radius: 20px;
            overflow: hidden;
        }

            .assignment-stat-card .card-body {
                display: flex;
                align-items: center;
                gap: 16px;
                padding: 20px;
            }

        .stat-icon {
            width: 52px;
            height: 52px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.45rem;
            flex-shrink: 0;
        }

        .stat-total {
            background: linear-gradient(135deg, #eef4ff 0%, #ffffff 100%);
            border-left: 5px solid #2563eb !important;
        }

            .stat-total .stat-icon {
                background: #dbeafe;
            }

        .stat-active {
            background: linear-gradient(135deg, #ecfdf5 0%, #ffffff 100%);
            border-left: 5px solid #16a34a !important;
        }

            .stat-active .stat-icon {
                background: #dcfce7;
            }

        .stat-due-soon {
            background: linear-gradient(135deg, #fff7ed 0%, #ffffff 100%);
            border-left: 5px solid #f59e0b !important;
        }

            .stat-due-soon .stat-icon {
                background: #ffedd5;
            }

        .stat-overdue {
            background: linear-gradient(135deg, #fff1f2 0%, #ffffff 100%);
            border-left: 5px solid #e11d48 !important;
        }

            .stat-overdue .stat-icon {
                background: #ffe4e6;
            }

        .stat-label {
            color: #64748b;
            font-weight: 600;
            font-size: 0.93rem;
            margin-bottom: 4px;
        }

        .stat-value {
            color: #0f172a;
            font-size: 2rem;
            font-weight: 800;
            line-height: 1;
        }

        .section-title {
            font-weight: 800;
            color: #172554;
        }

        .assignment-filter-note {
            color: #64748b;
            font-size: 0.9rem;
            white-space: nowrap;
        }

        .status-dot {
            display: inline-block;
            width: 9px;
            height: 9px;
            border-radius: 50%;
            margin-right: 5px;
        }

            .status-dot.active {
                background: #16a34a;
            }

            .status-dot.due-soon {
                background: #f59e0b;
            }

            .status-dot.overdue {
                background: #e11d48;
            }

        .assignment-table-wrap {
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            overflow: hidden;
        }

        .assignment-table {
            background: #ffffff;
            width: 100%;
            table-layout: fixed;    
        }

            .assignment-table thead th {
                background: #f8fafc;
                color: #475569;
                font-size: 0.85rem;
                text-transform: uppercase;
                letter-spacing: 0.04em;
                border-bottom: 1px solid #e5e7eb;
                padding: 14px 16px;
                white-space: nowrap;
            }

            .assignment-table tbody td {
                padding: 16px;
                border-bottom: 1px solid #eef2f7;
                vertical-align: middle;
            }

            .assignment-table tbody tr:last-child td {
                border-bottom: none;
            }

            .assignment-table tbody tr {
                transition: all 0.18s ease-in-out;
            }

                .assignment-table tbody tr:hover {
                    background: #f8fbff;
                }

        .assignment-main {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            min-width: 0;
        }

        .assignment-main-content {
            min-width: 0;
            flex: 1;
        }

        .assignment-icon {
            width: 44px;
            height: 44px;
            border-radius: 14px;
            background: #eff6ff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            flex-shrink: 0;
        }

        .assignment-title,
        .class-name {
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 3px;
        }

        .assignment-desc {
            color: #64748b;
            font-size: 0.88rem;
            line-height: 1.45;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .class-small {
            color: #64748b;
            font-size: 0.88rem;
            white-space: nowrap;
        }

        .course-name,
        .teacher-name {
            color: #334155;
            font-weight: 600;
            min-width: 0;
            word-break: break-word;
        }

        .date-block {
            display: flex;
            flex-direction: column;
            gap: 4px;
            min-width: 0;
        }

        .date-main {
            color: #334155;
            font-weight: 800;
            white-space: nowrap;
        }

        .date-small {
            color: #64748b;
            font-size: 0.88rem;
            font-weight: 600;
        }

        .assignment-status {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: fit-content;
            padding: 7px 11px;
            border-radius: 999px;
            font-weight: 800;
            font-size: 0.82rem;
            white-space: nowrap;
            margin-top: 3px;
        }

        submit-status {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: fit-content;
            padding: 7px 11px;
            border-radius: 999px;
            font-weight: 800;
            font-size: 0.82rem;
            white-space: nowrap;
        }

        .submit-done {
            color: #166534;
            background: #dcfce7;
        }

        .submit-pending {
            color: #92400e;
            background: #ffedd5;
        }
        .badge-active {
            color: #166534;
            background: #dcfce7;
        }

        .badge-due-soon {
            color: #92400e;
            background: #ffedd5;
        }

        .badge-overdue {
            color: #be123c;
            background: #ffe4e6;
        }

        .action-group {
            display: flex;
            justify-content: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .action-group-center {
            justify-content: center;
        }

            .action-group .btn {
                border-radius: 10px;
                font-weight: 700;
                padding: 7px 11px;
            }

        .assignment-summary {
            display: flex;
            justify-content: flex-end;
            gap: 14px;
            flex-wrap: wrap;
            color: #64748b;
            font-size: 0.92rem;
        }

            .assignment-summary strong {
                color: #172554;
            }

        .empty-state {
            text-align: center;
            padding: 50px 20px;
            background: #f8fafc;
            border: 1px dashed #cbd5e1;
            border-radius: 18px;
        }

        .empty-icon {
            font-size: 3rem;
            margin-bottom: 12px;
        }

        .empty-state h5 {
            color: #172554;
            font-weight: 800;
            margin-bottom: 8px;
        }

        .empty-state p {
            color: #64748b;
            max-width: 520px;
            margin: 0 auto;
        }

        @@media (max-width: 1199.98px) {
            .assignment-filter-note {
                white-space: normal;
            }
        }

        @@media (max-width: 767.98px) {
            .page-title {
                font-size: 1.6rem;
            }

            .hero-badge {
                width: 100%;
            }

            .assignment-stat-card .card-body {
                padding: 16px;
            }

            .stat-value {
                font-size: 1.7rem;
            }

            .action-group {
                justify-content: flex-start;
            }

            .assignment-summary {
                justify-content: flex-start;
            }
        }

        .assignment-filter-form {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 12px;
            align-items: end;
            padding: 16px;
            border: 1px solid #e5e7eb;
            border-radius: 16px;
            background: #f8fafc;
        }

        .assignment-filter-field label {
            display: block;
            margin-bottom: 6px;
            color: #334155;
            font-size: 0.9rem;
            font-weight: 800;
        }

        .assignment-class-select {
            min-height: 42px;
            border-radius: 12px;
            font-weight: 700;
            color: #0f172a;
        }

        .assignment-filter-actions {
            display: flex;
            gap: 8px;
        }

            .assignment-filter-actions .btn {
                min-height: 42px;
                border-radius: 12px;
                font-weight: 800;
                white-space: nowrap;
            }

        @@media (max-width: 767.98px) {
            .assignment-filter-form {
                grid-template-columns: 1fr;
            }

            .assignment-filter-actions {
                flex-direction: column;
            }

                .assignment-filter-actions .btn {
                    width: 100%;
                }
        }
    </style>
}