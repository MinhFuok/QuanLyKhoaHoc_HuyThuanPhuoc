@model QLKH.Domain.Entities.Submission?
@using QLKH.Domain.Entities

@{
    ViewData["Title"] = "Kết quả bài nộp";
    var assignment = ViewBag.Assignment as Assignment;
}

<h2>Kết quả bài nộp</h2>

@if (assignment != null)
{
    <div class="mb-3">
        <p><strong>Lớp:</strong> @assignment.ClassRoom?.ClassName</p>
        <p><strong>Khóa học:</strong> @assignment.ClassRoom?.Course?.CourseName</p>
        <p><strong>Bài tập:</strong> @assignment.Title</p>
        <p><strong>Mô tả:</strong> @assignment.Description</p>
        <p><strong>Hạn nộp:</strong> @assignment.DueDate.ToString("dd/MM/yyyy")</p>
    </div>
}

@if (Model == null)
{
    <div class="alert alert-warning">
        Bạn chưa nộp bài cho assignment này.
    </div>
}
else
{
    <div class="card p-3">
        <p><strong>Thời gian nộp:</strong> @Model.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</p>

        <div class="mb-3">
            <label class="form-label"><strong>Nội dung bài nộp</strong></label>
            <div class="form-control" style="min-height: 120px; white-space: pre-wrap;">@Model.SubmissionText</div>
        </div>
        <div class="mb-3">
            <label class="form-label"><strong>File đã nộp</strong></label>
            @if (!string.IsNullOrWhiteSpace(Model.FilePath))
            {
                <div>
                    <a href="@Model.FilePath" target="_blank">Mở file bài nộp</a>
                </div>
            }
            else
            {
                <div class="form-control">Không có file đính kèm</div>
            }
        </div>
        <p><strong>Điểm:</strong> @(Model.Score?.ToString("0.##") ?? "Chưa chấm")</p>

        <div class="mb-3">
            <label class="form-label"><strong>Nhận xét của giáo viên</strong></label>
            <div class="form-control" style="min-height: 100px; white-space: pre-wrap;">@(string.IsNullOrWhiteSpace(Model.Feedback) ? "Chưa có nhận xét" : Model.Feedback)</div>
        </div>
    </div>
}