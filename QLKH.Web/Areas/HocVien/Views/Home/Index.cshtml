@{
    ViewData["Title"] = "Dashboard Học viên";
    Layout = "~/Views/Shared/_DashBoardLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-2">Dashboard Học viên</h2>
        <p class="text-muted mb-0">
            Theo dõi nhanh tình trạng học tập, chứng chỉ và mức độ hoàn thành khóa học của bạn.
        </p>
    </div>

    <!-- Tổng quan -->
    <div class="row g-4 mb-4">
        <div class="col-md-6 col-xl-4">
            <a href="/HocVien/MyCertificates" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 dashboard-stat-card stat-blue">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <div class="stat-label">Chứng chỉ của tôi</div>
                                <div class="stat-value">0</div>
                            </div>
                            <div class="stat-icon">
                                <i class="fas fa-award"></i>
                            </div>
                        </div>
                        <div class="stat-desc">
                            Tổng số chứng chỉ đã được cập nhật cho tài khoản của bạn.
                        </div>
                        <div class="stat-link mt-3">Xem chi tiết →</div>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-6 col-xl-4">
            <a href="/HocVien/MyCertificates" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 dashboard-stat-card stat-green">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <div class="stat-label">Chứng chỉ đã xác nhận</div>
                                <div class="stat-value">0</div>
                            </div>
                            <div class="stat-icon">
                                <i class="fas fa-check-circle"></i>
                            </div>
                        </div>
                        <div class="stat-desc">
                            Các chứng chỉ đã được xác nhận và hiển thị trong hồ sơ học tập.
                        </div>
                        <div class="stat-link mt-3">Xem chi tiết →</div>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-6 col-xl-4">
            <a href="/HocVien/MyLearningProgress" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 dashboard-stat-card stat-orange">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <div class="stat-label">Hoàn thành khóa học</div>
                                <div class="stat-value">Xem</div>
                            </div>
                            <div class="stat-icon">
                                <i class="fas fa-graduation-cap"></i>
                            </div>
                        </div>
                        <div class="stat-desc">
                            Theo dõi mức độ hoàn thành khóa học và tiến độ học tập hiện tại.
                        </div>
                        <div class="stat-link mt-3">Xem chi tiết →</div>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <!-- Sơ đồ tiến độ + trạng thái -->
    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h5 class="fw-bold mb-1">Sơ đồ tiến độ học tập</h5>
                            <p class="text-muted mb-0">Mô phỏng hành trình học tập của học viên trong hệ thống.</p>
                        </div>
                        <a href="/HocVien/MyLearningProgress" class="btn btn-outline-success btn-sm">
                            Xem tiến độ
                        </a>
                    </div>

                    <div class="learning-flow">
                        <div class="flow-step active">
                            <div class="flow-circle">1</div>
                            <div class="flow-title">Ghi danh</div>
                            <div class="flow-text">Đã vào lớp học</div>
                        </div>

                        <div class="flow-line active"></div>

                        <div class="flow-step active">
                            <div class="flow-circle">2</div>
                            <div class="flow-title">Học tập</div>
                            <div class="flow-text">Đang theo học</div>
                        </div>

                        <div class="flow-line active"></div>

                        <div class="flow-step current">
                            <div class="flow-circle">3</div>
                            <div class="flow-title">Bài tập</div>
                            <div class="flow-text">Đang hoàn thiện</div>
                        </div>

                        <div class="flow-line"></div>

                        <div class="flow-step">
                            <div class="flow-circle">4</div>
                            <div class="flow-title">Hoàn thành</div>
                            <div class="flow-text">Chưa đạt</div>
                        </div>

                        <div class="flow-line"></div>

                        <div class="flow-step">
                            <div class="flow-circle">5</div>
                            <div class="flow-title">Chứng chỉ</div>
                            <div class="flow-text">Chưa cấp</div>
                        </div>
                    </div>

                    <div class="mt-4">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="fw-semibold">Mức độ hoàn thành tổng quan</span>
                            <span class="fw-bold text-success">60%</span>
                        </div>
                        <div class="progress" style="height: 12px; border-radius: 999px;">
                            <div class="progress-bar bg-success" role="progressbar" style="width: 60%; border-radius: 999px;"
                                 aria-valuenow="60" aria-valuemin="0" aria-valuemax="100">
                            </div>
                        </div>
                        <div class="mt-2 text-muted small">
                            Bạn đang ở giai đoạn giữa của quá trình học. Hãy tiếp tục hoàn thành bài tập và theo dõi tiến độ thường xuyên.
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Trạng thái học tập hiện tại</h5>

                    <div class="status-box mb-3">
                        <div class="status-title">Tài khoản học tập</div>
                        <div class="status-badge bg-success-subtle text-success">Đang hoạt động</div>
                    </div>

                    <div class="status-box mb-3">
                        <div class="status-title">Tiến độ hiện tại</div>
                        <div class="status-badge bg-warning-subtle text-warning">Đang học</div>
                    </div>

                    <div class="status-box mb-3">
                        <div class="status-title">Chứng chỉ</div>
                        <div class="status-badge bg-secondary-subtle text-secondary">Chưa có</div>
                    </div>

                    <div class="status-box">
                        <div class="status-title">Khuyến nghị</div>
                        <div class="text-muted small mt-1">
                            Ưu tiên hoàn thành các bài tập còn thiếu để tăng tỉ lệ hoàn thành khóa học.
                        </div>
                    </div>

                    <hr class="my-4" />

                    <h6 class="fw-bold mb-3">Tổng quan nhanh</h6>
                    <div class="quick-summary">
                        <div class="quick-item">
                            <span>Khóa đã hoàn thành</span>
                            <strong>0</strong>
                        </div>
                        <div class="quick-item">
                            <span>Chứng chỉ đã xác nhận</span>
                            <strong>0</strong>
                        </div>
                        <div class="quick-item">
                            <span>Tiến độ trung bình</span>
                            <strong>60%</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Gợi ý -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <h5 class="fw-bold mb-3">Gợi ý thao tác tiếp theo</h5>
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="hint-box">
                        <div class="hint-title">Chứng chỉ</div>
                        <div class="hint-text">
                            Bấm vào khối <strong>Chứng chỉ của tôi</strong> để xem toàn bộ danh sách chứng chỉ hiện có.
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="hint-box">
                        <div class="hint-title">Hoàn thành khóa học</div>
                        <div class="hint-text">
                            Theo dõi chi tiết trạng thái hoàn thành và tiến độ học ở khối <strong>Hoàn thành khóa học</strong>.
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="hint-box">
                        <div class="hint-title">Tiến độ học tập</div>
                        <div class="hint-text">
                            Kiểm tra sơ đồ tiến độ để biết bạn đang ở giai đoạn nào trong hành trình học tập.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .dashboard-stat-card {
        border-radius: 18px;
        transition: all 0.2s ease;
        overflow: hidden;
    }

        .dashboard-stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 0.75rem 1.5rem rgba(0,0,0,.08) !important;
        }

    .stat-blue {
        border-left: 5px solid #0d6efd;
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
    }

    .stat-green {
        border-left: 5px solid #198754;
        background: linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
    }

    .stat-orange {
        border-left: 5px solid #f59f00;
        background: linear-gradient(180deg, #ffffff 0%, #fffaf2 100%);
    }

    .stat-label {
        font-size: 1rem;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 8px;
    }

    .stat-value {
        font-size: 2.2rem;
        font-weight: 800;
        line-height: 1;
        color: #111827;
    }

    .stat-desc {
        color: #6b7280;
        font-size: 0.95rem;
        line-height: 1.6;
    }

    .stat-link {
        color: #2563eb;
        font-weight: 600;
        font-size: 0.95rem;
    }

    .stat-icon {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        background: #f3f4f6;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        color: #374151;
    }

    .learning-flow {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0;
        flex-wrap: wrap;
    }

    .flow-step {
        text-align: center;
        min-width: 110px;
        position: relative;
    }

    .flow-circle {
        width: 46px;
        height: 46px;
        border-radius: 50%;
        margin: 0 auto 10px auto;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        background: #e5e7eb;
        color: #6b7280;
    }

    .flow-title {
        font-weight: 700;
        color: #1f2937;
        font-size: 0.95rem;
    }

    .flow-text {
        font-size: 0.85rem;
        color: #6b7280;
        margin-top: 4px;
    }

    .flow-line {
        flex: 1;
        height: 4px;
        background: #e5e7eb;
        margin: 0 8px;
        min-width: 35px;
        border-radius: 999px;
        transform: translateY(-18px);
    }

    .flow-step.active .flow-circle,
    .flow-step.current .flow-circle {
        background: #198754;
        color: #fff;
    }

    .flow-line.active {
        background: #198754;
    }

    .flow-step.current .flow-circle {
        box-shadow: 0 0 0 5px rgba(25, 135, 84, 0.15);
    }

    .status-box {
        padding: 14px 16px;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        background: #fff;
    }

    .status-title {
        font-weight: 600;
        color: #1f2937;
    }

    .status-badge {
        display: inline-block;
        margin-top: 8px;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 0.85rem;
        font-weight: 700;
    }

    .quick-summary {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .quick-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px dashed #e5e7eb;
    }

        .quick-item:last-child {
            border-bottom: none;
        }

        .quick-item span {
            color: #6b7280;
        }

        .quick-item strong {
            color: #111827;
        }

    .hint-box {
        height: 100%;
        padding: 16px;
        border-radius: 14px;
        background: #f8fafc;
        border: 1px solid #e5e7eb;
    }

    .hint-title {
        font-weight: 700;
        margin-bottom: 8px;
        color: #111827;
    }

    .hint-text {
        color: #6b7280;
        font-size: 0.95rem;
        line-height: 1.6;
    }

    @@media (max-width: 991.98px) {
        .learning-flow {
            flex-direction: column;
            align-items: stretch;
            gap: 16px;
        }

        .flow-line {
            width: 4px;
            height: 26px;
            margin: 0 auto;
            transform: none;
            min-width: auto;
        }

        .flow-step {
            min-width: auto;
        }
    }
</style>