@model IEnumerable<QLKH.Domain.Entities.ClassRoom>
@using System.Linq

@{
    ViewData["Title"] = "Lớp học của tôi";
    Layout = "~/Views/Shared/_DashBoardLayout.cshtml";

    var today = DateTime.Today;
    var classes = Model?.ToList() ?? new List<QLKH.Domain.Entities.ClassRoom>();

    var reviewedClassIds = (ViewBag.ReviewedClassIds as IEnumerable<int>
        ?? Enumerable.Empty<int>())
        .ToHashSet();

    var totalClasses = classes.Count;
    var activeClasses = classes.Count(x => x.StartDate.Date <= today && x.EndDate.Date >= today);
    var upcomingClasses = classes.Count(x => x.StartDate.Date > today);
    var endedClasses = classes.Count(x => x.EndDate.Date < today);

    var activeClassList = classes
        .Where(x => x.StartDate.Date <= today && x.EndDate.Date >= today)
        .OrderBy(x => x.EndDate)
        .ToList();

    var upcomingClassList = classes
        .Where(x => x.StartDate.Date > today)
        .OrderBy(x => x.StartDate)
        .ToList();

    var endedClassList = classes
        .Where(x => x.EndDate.Date < today)
        .OrderByDescending(x => x.EndDate)
        .ToList();

    var currentTab = Context.Request.Query["tab"].ToString();
    if (string.IsNullOrWhiteSpace(currentTab))
    {
        currentTab = "active";
    }

    var displayClasses = currentTab switch
    {
        "upcoming" => upcomingClassList,
        "ended" => endedClassList,
        _ => activeClassList
    };
}

<div class="student-classes-page">

    <!-- Header -->
    <div class="classes-hero card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <h2 class="page-title mb-2">LỚP HỌC CỦA TÔI</h2>
                    <div class="page-eyebrow">HỌC TẬP</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Content -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 p-4 pb-2">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <h5 class="section-title mb-1">Danh sách lớp học</h5>
                </div>

                <div class="class-filter-note">
                    <span class="status-dot active"></span> Đang diễn ra
                    <span class="status-dot upcoming ms-3"></span> Sắp diễn ra
                    <span class="status-dot ended ms-3"></span> Đã kết thúc
                </div>
            </div>
        </div>

        <div class="card-body p-4">
            <div class="class-tabs mb-4">
                <a asp-area="HocVien"
                   asp-controller="MyClasses"
                   asp-action="Index"
                   asp-route-tab="active"
                   class="class-tab @(currentTab == "active" ? "active" : "")">
                    <span>Đang diễn ra</span>
                    <strong>@activeClasses</strong>
                </a>

                <a asp-area="HocVien"
                   asp-controller="MyClasses"
                   asp-action="Index"
                   asp-route-tab="upcoming"
                   class="class-tab @(currentTab == "upcoming" ? "active" : "")">
                    <span>Sắp diễn ra</span>
                    <strong>@upcomingClasses</strong>
                </a>

                <a asp-area="HocVien"
                   asp-controller="MyClasses"
                   asp-action="Index"
                   asp-route-tab="ended"
                   class="class-tab @(currentTab == "ended" ? "active" : "")">
                    <span>Đã kết thúc</span>
                    <strong>@endedClasses</strong>
                </a>
            </div>

            @if (!classes.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">📭</div>
                    <h5>Chưa có lớp học nào</h5>
                    <p>
                        Hiện tại bạn chưa được ghi danh vào lớp nào.
                        Khi được ghi danh, danh sách lớp học sẽ hiển thị tại đây.
                    </p>
                </div>
            }
            else if (!displayClasses.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">📭</div>

                    @if (currentTab == "upcoming")
                    {
                        <h5>Chưa có lớp sắp diễn ra</h5>
                        <p>
                            Các lớp có ngày bắt đầu trong tương lai sẽ được hiển thị tại đây.
                        </p>
                    }
                    else if (currentTab == "ended")
                    {
                        <h5>Chưa có lớp đã kết thúc</h5>
                        <p>
                            Các lớp đã hoàn thành thời gian học sẽ được hiển thị tại đây.
                        </p>
                    }
                    else
                    {
                        <h5>Chưa có lớp đang diễn ra</h5>
                        <p>
                            Các lớp đang trong thời gian học sẽ được hiển thị tại đây.
                        </p>
                    }
                </div>
            }
            else
            {
                <div class="table-responsive class-table-wrap">
                    <table class="table class-table align-middle mb-0">
                        <colgroup>
                            <col style="width: 9%;" />
                            <col style="width: 17%;" />
                            <col style="width: 17%;" />
                            <col style="width: 15%;" />
                            <col style="width: 10%;" />
                            <col style="width: 10%;" />
                            <col style="width: 6%;" />
                            <col style="width: 16%;" />
                        </colgroup>

                        <thead>
                            <tr>
                                <th class="text-center">Mã lớp</th>
                                <th class="text-center">Tên lớp</th>
                                <th class="text-center">Khóa học</th>
                                <th class="text-center">Giáo viên</th>
                                <th class="text-center">Bắt đầu</th>
                                <th class="text-center">Kết thúc</th>
                                <th class="text-center">Sĩ số</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in displayClasses)
                            {
                                var statusText = "";
                                var statusClass = "";

                                if (item.StartDate.Date > today)
                                {
                                    statusText = "Sắp diễn ra";
                                    statusClass = "badge-upcoming";
                                }
                                else if (item.EndDate.Date < today)
                                {
                                    statusText = "Đã kết thúc";
                                    statusClass = "badge-ended";
                                }
                                else
                                {
                                    statusText = "Đang diễn ra";
                                    statusClass = "badge-active";
                                }

                                <tr>
                                    <td>
                                        <span class="class-code">@item.ClassCode</span>
                                    </td>

                                    <td>
                                        <div class="class-name">@item.ClassName</div>
                                        <span class="class-status @statusClass">@statusText</span>
                                    </td>

                                    <td>
                                        <div class="course-name">
                                            @(item.Course?.CourseName ?? "Chưa cập nhật")
                                        </div>
                                    </td>

                                    <td>
                                        <div class="teacher-name">
                                            @(item.Teacher?.FullName ?? "Chưa cập nhật")
                                        </div>
                                    </td>

                                    <td>
                                        <div class="date-block">
                                            <span>@item.StartDate.ToString("dd/MM/yyyy")</span>
                                        </div>
                                    </td>

                                    <td>
                                        <div class="date-block">
                                            <span>@item.EndDate.ToString("dd/MM/yyyy")</span>
                                        </div>
                                    </td>

                                    <td class="text-center">
                                        <span class="capacity-pill">@item.MaxStudents</span>
                                    </td>

                                    <td class="text-center">
                                        @if (item.EndDate.Date <= today)
                                        {
                                            if (reviewedClassIds.Contains(item.Id))
                                            {
                                                <div class="class-action-group class-action-group-center">
                                                    <span class="completed-class-message">
                                                        Đã hoàn thành
                                                    </span>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="class-action-group class-action-group-center">
                                                    <a asp-area="HocVien"
                                                       asp-controller="TeacherReviews"
                                                       asp-action="Edit"
                                                       asp-route-classRoomId="@item.Id"
                                                       class="btn btn-sm btn-primary action-btn action-btn-review">
                                                        Đánh giá
                                                    </a>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="class-action-group class-action-icons">
                                                <a asp-area="HocVien"
                                                   asp-controller="MyAssignments"
                                                   asp-action="Index"
                                                   asp-route-classRoomId="@item.Id"
                                                   class="btn btn-sm btn-outline-primary action-btn icon-action-btn"
                                                   data-tooltip="Bài tập"
                                                   aria-label="Bài tập">
                                                    <svg viewBox="0 0 24 24" class="action-svg" aria-hidden="true">
                                                        <path d="M8 6H16M8 10H16M8 14H13" />
                                                        <path d="M7 3H17C18.1046 3 19 3.89543 19 5V19C19 20.1046 18.1046 21 17 21H7C5.89543 21 5 20.1046 5 19V5C5 3.89543 5.89543 3 7 3Z" />
                                                    </svg>
                                                </a>

                                                <a asp-area="HocVien"
                                                   asp-controller="MyGrades"
                                                   asp-action="Index"
                                                   asp-route-className="@item.ClassName"
                                                   class="btn btn-sm btn-outline-success action-btn icon-action-btn"
                                                   data-tooltip="Bảng điểm"
                                                   aria-label="Bảng điểm">
                                                    <svg viewBox="0 0 24 24" class="action-svg" aria-hidden="true">
                                                        <path d="M7 20V10" />
                                                        <path d="M12 20V4" />
                                                        <path d="M17 20V14" />
                                                        <path d="M4 20H20" />
                                                    </svg>
                                                </a>

                                                <a asp-area="HocVien"
                                                   asp-controller="MyMaterials"
                                                   asp-action="Index"
                                                   asp-route-classRoomId="@item.Id"
                                                   class="btn btn-sm btn-outline-secondary action-btn icon-action-btn"
                                                   data-tooltip="Tài liệu"
                                                   aria-label="Tài liệu">
                                                    <svg viewBox="0 0 24 24" class="action-svg" aria-hidden="true">
                                                        <path d="M3 7C3 5.89543 3.89543 5 5 5H9L11 7H19C20.1046 7 21 7.89543 21 9V18C21 19.1046 20.1046 20 19 20H5C3.89543 20 3 19.1046 3 18V7Z" />
                                                    </svg>
                                                </a>
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="class-summary mt-3">
                    <span>Tổng lớp: <strong>@totalClasses</strong></span>
                    <span>Đang diễn ra: <strong>@activeClasses</strong></span>
                    <span>Sắp diễn ra: <strong>@upcomingClasses</strong></span>
                    <span>Đã kết thúc: <strong>@endedClasses</strong></span>
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <style>
        .action-btn {
            border-radius: 10px;
            font-weight: 800;
            padding: 7px 10px;
            white-space: nowrap;
            font-size: 0.82rem;
        }

        .class-action-group {
            display: grid;
            grid-template-columns: 1fr;
            gap: 7px;
            min-width: 120px;
        }

        .class-action-icons {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            min-width: 120px;
        }

        .icon-action-btn {
            position: relative;
            width: 34px !important;
            height: 34px;
            min-width: 34px;
            padding: 0 !important;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .action-svg {
            width: 17px;
            height: 17px;
            fill: none;
            stroke: currentColor;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .icon-action-btn::after {
            content: attr(data-tooltip);
            position: absolute;
            left: 50%;
            bottom: calc(100% + 9px);
            transform: translateX(-50%) translateY(4px);
            padding: 7px 9px;
            border-radius: 8px;
            background: rgba(15, 23, 42, 0.96);
            color: #ffffff;
            font-size: 0.75rem;
            font-weight: 700;
            white-space: nowrap;
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
            transition: all 0.16s ease;
            z-index: 20;
        }

        .icon-action-btn::before {
            content: "";
            position: absolute;
            left: 50%;
            bottom: calc(100% + 4px);
            transform: translateX(-50%);
            border-width: 5px;
            border-style: solid;
            border-color: rgba(15, 23, 42, 0.96) transparent transparent transparent;
            opacity: 0;
            visibility: hidden;
            transition: all 0.16s ease;
            z-index: 19;
        }

        .icon-action-btn:hover::after,
        .icon-action-btn:hover::before {
            opacity: 1;
            visibility: visible;
            transform: translateX(-50%) translateY(0);
        }

        .class-action-group-center {
            display: flex;
            justify-content: center;
        }

        .class-action-group .action-btn {
            width: 100%;
        }

        .action-btn-review {
            min-width: 92px;
        }

        .completed-class-message {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 155px;
            padding: 8px 10px;
            border-radius: 999px;
            background: #dcfce7;
            color: #166534;
            font-weight: 800;
            font-size: 0.78rem;
            line-height: 1.25;
            text-align: center;
        }

        .class-tabs {
            display: inline-flex;
            gap: 8px;
            padding: 6px;
            border-radius: 16px;
            background: #f1f5f9;
            border: 1px solid #e5e7eb;
            flex-wrap: wrap;
        }

        .class-tab {
            min-width: 165px;
            display: inline-flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 10px 14px;
            border-radius: 12px;
            color: #475569;
            text-decoration: none;
            font-weight: 800;
            transition: all 0.18s ease-in-out;
        }

            .class-tab:hover {
                color: #1d4ed8;
                background: #ffffff;
            }

            .class-tab.active {
                color: #ffffff;
                background: #2563eb;
                box-shadow: 0 8px 18px rgba(37, 99, 235, 0.22);
            }

            .class-tab strong {
                min-width: 28px;
                height: 24px;
                padding: 0 8px;
                border-radius: 999px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                background: rgba(255, 255, 255, 0.85);
                color: #1d4ed8;
                font-size: 0.82rem;
            }

            .class-tab.active strong {
                background: rgba(255, 255, 255, 0.95);
                color: #1d4ed8;
            }

        .student-classes-page {
            animation: fadeInPage 0.25s ease-in-out;
        }

        @@keyframes fadeInPage {
            from {
                opacity: 0;
                transform: translateY(6px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .classes-hero {
            border-radius: 22px;
            background: linear-gradient(135deg, #f4f8ff 0%, #ffffff 60%, #f8fbff 100%);
            overflow: hidden;
        }

        .page-eyebrow {
            font-size: 0.78rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            color: #3b82f6;
            text-transform: uppercase;
            margin-bottom: 6px;
        }

        .page-title {
            font-size: 2rem;
            font-weight: 800;
            color: #172554;
        }

        .class-stat-card {
            border-radius: 20px;
            overflow: hidden;
        }

            .class-stat-card .card-body {
                display: flex;
                align-items: center;
                gap: 16px;
                padding: 20px;
            }

        .stat-icon {
            width: 52px;
            height: 52px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.45rem;
            flex-shrink: 0;
        }

        .stat-total {
            background: linear-gradient(135deg, #eef4ff 0%, #ffffff 100%);
            border-left: 5px solid #2563eb !important;
        }

            .stat-total .stat-icon {
                background: #dbeafe;
            }

        .stat-active {
            background: linear-gradient(135deg, #ecfdf5 0%, #ffffff 100%);
            border-left: 5px solid #16a34a !important;
        }

            .stat-active .stat-icon {
                background: #dcfce7;
            }

        .stat-upcoming {
            background: linear-gradient(135deg, #fff7ed 0%, #ffffff 100%);
            border-left: 5px solid #f59e0b !important;
        }

            .stat-upcoming .stat-icon {
                background: #ffedd5;
            }

        .stat-ended {
            background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);
            border-left: 5px solid #64748b !important;
        }

            .stat-ended .stat-icon {
                background: #e2e8f0;
            }

        .stat-label {
            color: #64748b;
            font-weight: 600;
            font-size: 0.93rem;
            margin-bottom: 4px;
        }

        .stat-value {
            color: #0f172a;
            font-size: 2rem;
            font-weight: 800;
            line-height: 1;
        }

        .section-title {
            font-weight: 800;
            color: #172554;
        }

        .class-filter-note {
            color: #64748b;
            font-size: 0.9rem;
            white-space: nowrap;
        }

        .status-dot {
            display: inline-block;
            width: 9px;
            height: 9px;
            border-radius: 50%;
            margin-right: 5px;
        }

            .status-dot.active {
                background: #16a34a;
            }

            .status-dot.upcoming {
                background: #f59e0b;
            }

            .status-dot.ended {
                background: #64748b;
            }

        .class-table-wrap {
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            overflow: hidden;
        }

        .class-table {
            background: #ffffff;
            width: 100%;
            table-layout: fixed;
        }

            .class-table thead th {
                background: #f8fafc;
                color: #475569;
                font-size: 0.85rem;
                text-transform: uppercase;
                letter-spacing: 0.04em;
                border-bottom: 1px solid #e5e7eb;
                padding: 14px 16px;
                white-space: nowrap;
            }

            .class-table tbody td {
                padding: 16px;
                border-bottom: 1px solid #eef2f7;
                vertical-align: middle;
            }

            .class-table tbody tr:last-child td {
                border-bottom: none;
            }

            .class-table tbody tr {
                transition: all 0.18s ease-in-out;
            }

                .class-table tbody tr:hover {
                    background: #f8fbff;
                }

        .class-code {
            display: inline-flex;
            align-items: center;
            padding: 7px 10px;
            border-radius: 999px;
            background: #eff6ff;
            color: #1d4ed8;
            font-weight: 800;
            font-size: 0.88rem;
            white-space: nowrap;
        }

        .class-name {
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 5px;
            word-break: break-word;
        }

        .course-name,
        .teacher-name {
            color: #334155;
            font-weight: 600;
            word-break: break-word;
        }

        .date-block {
            color: #334155;
            font-weight: 800;
            white-space: nowrap;
        }

        .class-status {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: fit-content;
            padding: 6px 10px;
            border-radius: 999px;
            font-weight: 800;
            font-size: 0.78rem;
            white-space: nowrap;
        }

        .badge-active {
            color: #166534;
            background: #dcfce7;
        }

        .badge-upcoming {
            color: #92400e;
            background: #ffedd5;
        }

        .badge-ended {
            color: #475569;
            background: #e2e8f0;
        }

        .capacity-pill {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 38px;
            padding: 7px 9px;
            border-radius: 999px;
            background: #f1f5f9;
            color: #475569;
            font-weight: 900;
            font-size: 0.86rem;
        }

        .class-summary {
            display: flex;
            justify-content: flex-end;
            gap: 14px;
            flex-wrap: wrap;
            color: #64748b;
            font-size: 0.92rem;
        }

            .class-summary strong {
                color: #172554;
            }

        .empty-state {
            text-align: center;
            padding: 50px 20px;
            background: #f8fafc;
            border: 1px dashed #cbd5e1;
            border-radius: 18px;
        }

        .empty-icon {
            font-size: 3rem;
            margin-bottom: 12px;
        }

        .empty-state h5 {
            color: #172554;
            font-weight: 800;
            margin-bottom: 8px;
        }

        .empty-state p {
            color: #64748b;
            max-width: 520px;
            margin: 0 auto;
        }

        @@media (max-width: 1199.98px) {
            .class-filter-note {
                white-space: normal;
            }

            .class-table {
                min-width: 1080px;
            }

            .class-table-wrap {
                overflow-x: auto;
            }
        }

        @@media (max-width: 767.98px) {
            .page-title {
                font-size: 1.6rem;
            }

            .class-stat-card .card-body {
                padding: 16px;
            }

            .stat-value {
                font-size: 1.7rem;
            }

            .class-summary {
                justify-content: flex-start;
            }

            .class-tabs {
                width: 100%;
                display: grid;
                grid-template-columns: 1fr;
            }

            .class-tab {
                width: 100%;
            }
        }
    </style>
}