@model IEnumerable<QLKH.Domain.Entities.ClassRoom>

@{
    ViewData["Title"] = "Lớp tôi học";
    Layout = "~/Views/Shared/_DashBoardLayout.cshtml";

    var today = DateTime.Today;
    var classes = Model?.ToList() ?? new List<QLKH.Domain.Entities.ClassRoom>();

    var totalClasses = classes.Count;
    var activeClasses = classes.Count(x => x.StartDate.Date <= today && x.EndDate.Date >= today);
    var upcomingClasses = classes.Count(x => x.StartDate.Date > today);
    var endedClasses = classes.Count(x => x.EndDate.Date < today);
}

<div class="student-classes-page">

    <!-- Header -->
    <div class="classes-hero card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <h2 class="page-title mb-2">LỚP HỌC</h2>
                    <div class="page-eyebrow">HỌC TẬP</div>
                </div>
            </div>
        </div>
    </div>

    <!-- KPI -->
    <div class="row g-4 mb-4">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="class-stat-card stat-total card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-icon">🎓</div>
                    <div>
                        <div class="stat-label">Tổng lớp học</div>
                        <div class="stat-value">@totalClasses</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="class-stat-card stat-active card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-icon">✅</div>
                    <div>
                        <div class="stat-label">Đang học</div>
                        <div class="stat-value">@activeClasses</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="class-stat-card stat-upcoming card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-icon">⏳</div>
                    <div>
                        <div class="stat-label">Sắp học</div>
                        <div class="stat-value">@upcomingClasses</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="class-stat-card stat-ended card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-icon">🏁</div>
                    <div>
                        <div class="stat-label">Đã kết thúc</div>
                        <div class="stat-value">@endedClasses</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Content -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 p-4 pb-2">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <h5 class="section-title mb-1">Danh sách lớp học</h5>
                </div>

                <div class="class-filter-note">
                    <span class="status-dot active"></span> Đang học
                    <span class="status-dot upcoming ms-3"></span> Sắp học
                    <span class="status-dot ended ms-3"></span> Đã kết thúc
                </div>
            </div>
        </div>

        <div class="card-body p-4">
            @if (!classes.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">📭</div>
                    <h5>Chưa có lớp học nào</h5>
                    <p>
                        Hiện tại bạn chưa được ghi danh vào lớp nào.
                        Khi được ghi danh, danh sách lớp học sẽ hiển thị tại đây.
                    </p>
                </div>
            }
            else
            {
                <div class="table-responsive class-table-wrap">
                    <table class="table class-table align-middle mb-0">
                        <colgroup>
                            <col style="width: 10%;" />
                            <col style="width: 18%;" />
                            <col style="width: 18%;" />
                            <col style="width: 16%;" />
                            <col style="width: 11%;" />
                            <col style="width: 11%;" />
                            <col style="width: 6%;" />
                            <col style="width: 10%;" />
                        </colgroup>

                        <thead>
                            <tr>
                                <th>Mã lớp</th>
                                <th>Tên lớp</th>
                                <th>Khóa học</th>
                                <th>Giáo viên</th>
                                <th>Bắt đầu</th>
                                <th>Kết thúc</th>
                                <th class="text-center">Sĩ số</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in classes.OrderBy(x => x.StartDate))
                            {
                                var statusText = "";
                                var statusClass = "";

                                if (item.StartDate.Date > today)
                                {
                                    statusText = "Sắp học";
                                    statusClass = "badge-upcoming";
                                }
                                else if (item.EndDate.Date < today)
                                {
                                    statusText = "Đã kết thúc";
                                    statusClass = "badge-ended";
                                }
                                else
                                {
                                    statusText = "Đang học";
                                    statusClass = "badge-active";
                                }

                                <tr>
                                    <td>
                                        <span class="class-code">@item.ClassCode</span>
                                    </td>

                                    <td>
                                        <div class="class-name">@item.ClassName</div>
                                        <span class="class-status @statusClass">@statusText</span>
                                    </td>

                                    <td>
                                        <div class="course-name">
                                            @(item.Course?.CourseName ?? "Chưa cập nhật")
                                        </div>
                                    </td>

                                    <td>
                                        <div class="teacher-name">
                                            @(item.Teacher?.FullName ?? "Chưa cập nhật")
                                        </div>
                                    </td>

                                    <td>
                                        <div class="date-block">
                                            <span>@item.StartDate.ToString("dd/MM/yyyy")</span>
                                        </div>
                                    </td>

                                    <td>
                                        <div class="date-block">
                                            <span>@item.EndDate.ToString("dd/MM/yyyy")</span>
                                        </div>
                                    </td>

                                    <td class="text-center">
                                        <span class="capacity-pill">@item.MaxStudents</span>
                                    </td>
                                    <td class="text-center">
                                        @if (item.EndDate.Date <= DateTime.Today)
                                        {
                                            <a asp-area="HocVien"
                                               asp-controller="TeacherReviews"
                                               asp-action="Edit"
                                               asp-route-classRoomId="@item.Id"
                                               class="btn btn-sm btn-primary action-btn">
                                                Đánh giá
                                            </a>
                                        }
                                        else
                                        {
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-secondary action-btn"
                                                    disabled>
                                                Chưa mở
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="class-summary mt-3">
                    <span>Tổng lớp: <strong>@totalClasses</strong></span>
                    <span>Đang học: <strong>@activeClasses</strong></span>
                    <span>Sắp học: <strong>@upcomingClasses</strong></span>
                    <span>Đã kết thúc: <strong>@endedClasses</strong></span>
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <style>
        .action-btn {
            border-radius: 10px;
            font-weight: 800;
            padding: 7px 10px;
            white-space: nowrap;
            font-size: 0.82rem;
        }
        .student-classes-page {
            animation: fadeInPage 0.25s ease-in-out;
        }

        @@keyframes fadeInPage {
            from {
                opacity: 0;
                transform: translateY(6px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .classes-hero {
            border-radius: 22px;
            background: linear-gradient(135deg, #f4f8ff 0%, #ffffff 60%, #f8fbff 100%);
            overflow: hidden;
        }

        .page-eyebrow {
            font-size: 0.78rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            color: #3b82f6;
            text-transform: uppercase;
            margin-bottom: 6px;
        }

        .page-title {
            font-size: 2rem;
            font-weight: 800;
            color: #172554;
        }

        .class-stat-card {
            border-radius: 20px;
            overflow: hidden;
        }

            .class-stat-card .card-body {
                display: flex;
                align-items: center;
                gap: 16px;
                padding: 20px;
            }

        .stat-icon {
            width: 52px;
            height: 52px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.45rem;
            flex-shrink: 0;
        }

        .stat-total {
            background: linear-gradient(135deg, #eef4ff 0%, #ffffff 100%);
            border-left: 5px solid #2563eb !important;
        }

            .stat-total .stat-icon {
                background: #dbeafe;
            }

        .stat-active {
            background: linear-gradient(135deg, #ecfdf5 0%, #ffffff 100%);
            border-left: 5px solid #16a34a !important;
        }

            .stat-active .stat-icon {
                background: #dcfce7;
            }

        .stat-upcoming {
            background: linear-gradient(135deg, #fff7ed 0%, #ffffff 100%);
            border-left: 5px solid #f59e0b !important;
        }

            .stat-upcoming .stat-icon {
                background: #ffedd5;
            }

        .stat-ended {
            background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);
            border-left: 5px solid #64748b !important;
        }

            .stat-ended .stat-icon {
                background: #e2e8f0;
            }

        .stat-label {
            color: #64748b;
            font-weight: 600;
            font-size: 0.93rem;
            margin-bottom: 4px;
        }

        .stat-value {
            color: #0f172a;
            font-size: 2rem;
            font-weight: 800;
            line-height: 1;
        }

        .section-title {
            font-weight: 800;
            color: #172554;
        }

        .class-filter-note {
            color: #64748b;
            font-size: 0.9rem;
            white-space: nowrap;
        }

        .status-dot {
            display: inline-block;
            width: 9px;
            height: 9px;
            border-radius: 50%;
            margin-right: 5px;
        }

            .status-dot.active {
                background: #16a34a;
            }

            .status-dot.upcoming {
                background: #f59e0b;
            }

            .status-dot.ended {
                background: #64748b;
            }

        .class-table-wrap {
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            overflow: hidden;
        }

        .class-table {
            background: #ffffff;
            width: 100%;
            table-layout: fixed;
        }

            .class-table thead th {
                background: #f8fafc;
                color: #475569;
                font-size: 0.85rem;
                text-transform: uppercase;
                letter-spacing: 0.04em;
                border-bottom: 1px solid #e5e7eb;
                padding: 14px 16px;
                white-space: nowrap;
            }

            .class-table tbody td {
                padding: 16px;
                border-bottom: 1px solid #eef2f7;
                vertical-align: middle;
            }

            .class-table tbody tr:last-child td {
                border-bottom: none;
            }

            .class-table tbody tr {
                transition: all 0.18s ease-in-out;
            }

                .class-table tbody tr:hover {
                    background: #f8fbff;
                }

        .class-code {
            display: inline-flex;
            align-items: center;
            padding: 7px 10px;
            border-radius: 999px;
            background: #eff6ff;
            color: #1d4ed8;
            font-weight: 800;
            font-size: 0.88rem;
            white-space: nowrap;
        }

        .class-name {
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 5px;
            word-break: break-word;
        }

        .course-name,
        .teacher-name {
            color: #334155;
            font-weight: 600;
            word-break: break-word;
        }

        .date-block {
            color: #334155;
            font-weight: 800;
            white-space: nowrap;
        }

        .class-status {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: fit-content;
            padding: 6px 10px;
            border-radius: 999px;
            font-weight: 800;
            font-size: 0.78rem;
            white-space: nowrap;
        }

        .badge-active {
            color: #166534;
            background: #dcfce7;
        }

        .badge-upcoming {
            color: #92400e;
            background: #ffedd5;
        }

        .badge-ended {
            color: #475569;
            background: #e2e8f0;
        }

        .capacity-pill {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 38px;
            padding: 7px 9px;
            border-radius: 999px;
            background: #f1f5f9;
            color: #475569;
            font-weight: 900;
            font-size: 0.86rem;
        }

        .class-summary {
            display: flex;
            justify-content: flex-end;
            gap: 14px;
            flex-wrap: wrap;
            color: #64748b;
            font-size: 0.92rem;
        }

            .class-summary strong {
                color: #172554;
            }

        .empty-state {
            text-align: center;
            padding: 50px 20px;
            background: #f8fafc;
            border: 1px dashed #cbd5e1;
            border-radius: 18px;
        }

        .empty-icon {
            font-size: 3rem;
            margin-bottom: 12px;
        }

        .empty-state h5 {
            color: #172554;
            font-weight: 800;
            margin-bottom: 8px;
        }

        .empty-state p {
            color: #64748b;
            max-width: 520px;
            margin: 0 auto;
        }

        @@media (max-width: 1199.98px) {
            .class-filter-note {
                white-space: normal;
            }

            .class-table {
                min-width: 980px;
            }

            .class-table-wrap {
                overflow-x: auto;
            }
        }

        @@media (max-width: 767.98px) {
            .page-title {
                font-size: 1.6rem;
            }

            .class-stat-card .card-body {
                padding: 16px;
            }

            .stat-value {
                font-size: 1.7rem;
            }

            .class-summary {
                justify-content: flex-start;
            }
        }
    </style>
}