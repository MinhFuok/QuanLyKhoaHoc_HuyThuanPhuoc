@model IEnumerable<QLKH.Domain.Entities.ClassSchedule>
@using System.Globalization
@using System.Linq

@{
    ViewData["Title"] = "Lịch học của tôi";
    Layout = "~/Views/Shared/_DashBoardLayout.cshtml";

    var schedules = Model?.OrderBy(x => x.StudyDate).ThenBy(x => x.StartTime).ToList()
                    ?? new List<QLKH.Domain.Entities.ClassSchedule>();

    var today = DateTime.Today;

    var totalSchedules = schedules.Count;
    var todaySchedules = schedules.Count(x => x.StudyDate.Date == today);
    var upcomingSchedules = schedules.Count(x => x.StudyDate.Date >= today);
    var totalClasses = schedules
        .Where(x => x.ClassRoomId > 0)
        .Select(x => x.ClassRoomId)
        .Distinct()
        .Count();

    var viCulture = new CultureInfo("vi-VN");
    var calendar = viCulture.Calendar;
    var weekRule = CalendarWeekRule.FirstFourDayWeek;
    var firstDayOfWeek = DayOfWeek.Monday;

    int GetWeekNumber(DateTime date)
    {
        return calendar.GetWeekOfYear(date, weekRule, firstDayOfWeek);
    }

    DateTime GetStartOfWeek(DateTime date)
    {
        int diff = (7 + (date.DayOfWeek - DayOfWeek.Monday)) % 7;
        return date.Date.AddDays(-1 * diff);
    }

    string GetDayLabel(int dayIndex)
    {
        return dayIndex switch
        {
            0 => "Thứ 2",
            1 => "Thứ 3",
            2 => "Thứ 4",
            3 => "Thứ 5",
            4 => "Thứ 6",
            5 => "Thứ 7",
            6 => "Chủ nhật",
            _ => ""
        };
    }

    string GetSessionLabel(TimeSpan startTime)
    {
        if (startTime.Hours < 12)
        {
            return "BUỔI<br>SÁNG";
        }

        return "BUỔI<br>CHIỀU";
    }

    var currentWeekStart = GetStartOfWeek(today);

    var weeklySchedules = schedules
        .GroupBy(x => new
        {
            Year = x.StudyDate.Year,
            Week = GetWeekNumber(x.StudyDate),
            WeekStart = GetStartOfWeek(x.StudyDate)
        })
        .OrderBy(g => g.Key.WeekStart)
        .ToList();

    var allWeekStarts = weeklySchedules
        .Select(x => x.Key.WeekStart)
        .ToList();

    if (!allWeekStarts.Contains(currentWeekStart))
    {
        allWeekStarts.Add(currentWeekStart);
    }

    allWeekStarts = allWeekStarts
        .Distinct()
        .OrderBy(x => x)
        .ToList();

    var allWeeks = allWeekStarts
        .Select(weekStart => new
        {
            WeekStart = weekStart,
            WeekEnd = weekStart.AddDays(6),
            WeekNumber = GetWeekNumber(weekStart),
            Items = schedules
                .Where(x => GetStartOfWeek(x.StudyDate) == weekStart)
                .OrderBy(x => x.StudyDate)
                .ThenBy(x => x.StartTime)
                .ToList()
        })
        .ToList();

    var defaultWeekIndex = allWeeks.FindIndex(x => x.WeekStart == currentWeekStart);

    if (defaultWeekIndex < 0)
    {
        defaultWeekIndex = 0;
    }
}

<div class="student-schedules-page">

    <!-- Header -->
    <div class="schedules-hero card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <h2 class="page-title mb-2">LỊCH HỌC</h2>
                    <div class="page-eyebrow">HỌC TẬP</div>
                </div>

                <div class="hero-badge">
                    <div class="hero-badge-icon">📅</div>
                    <div>
                        <div class="hero-badge-label">Tổng buổi học</div>
                        <div class="hero-badge-value">@totalSchedules</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- KPI -->
    <div class="row g-4 mb-4">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="schedule-stat-card stat-total card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-icon">📚</div>
                    <div>
                        <div class="stat-label">Tổng buổi học</div>
                        <div class="stat-value">@totalSchedules</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="schedule-stat-card stat-today card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-icon">📍</div>
                    <div>
                        <div class="stat-label">Lịch hôm nay</div>
                        <div class="stat-value">@todaySchedules</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="schedule-stat-card stat-upcoming card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-icon">⏳</div>
                    <div>
                        <div class="stat-label">Sắp diễn ra</div>
                        <div class="stat-value">@upcomingSchedules</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="schedule-stat-card stat-class card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-icon">🎓</div>
                    <div>
                        <div class="stat-label">Số lớp đang học</div>
                        <div class="stat-value">@totalClasses</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (!schedules.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="empty-state">
                    <div class="empty-icon">📭</div>
                    <h5>Hiện tại bạn chưa có lịch học nào</h5>
                    <p>
                        Khi bạn được ghi danh vào lớp có lịch học, thời khóa biểu sẽ hiển thị tại đây theo từng tuần.
                    </p>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Week navigation -->
        <div class="week-nav-card card border-0 shadow-sm mb-4">
            <div class="card-body p-3 p-lg-4">
                <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                    <div>
                        <h5 class="section-title mb-1">Thời khóa biểu theo tuần</h5>
                        <div class="section-subtitle">
                            Sử dụng nút mũi tên để chuyển qua tuần trước hoặc tuần sau.
                        </div>
                    </div>

                    <div class="week-nav-actions">
                        <button type="button" class="btn btn-outline-primary week-nav-btn" id="prevWeekBtn">
                            ← Tuần trước
                        </button>

                        <button type="button" class="btn btn-primary week-nav-current" id="currentWeekBtn">
                            Tuần hiện tại
                        </button>

                        <button type="button" class="btn btn-outline-primary week-nav-btn" id="nextWeekBtn">
                            Tuần sau →
                        </button>
                    </div>
                </div>
            </div>
        </div>

        @for (var weekIndex = 0; weekIndex < allWeeks.Count; weekIndex++)
        {
            var week = allWeeks[weekIndex];
            var weekStart = week.WeekStart;
            var weekEnd = week.WeekEnd;
            var weekItems = week.Items;

            var timeSlots = weekItems
            .Select(x => new
            {
                x.StartTime,
                x.EndTime
            })
            .Distinct()
            .OrderBy(x => x.StartTime)
            .ToList();

            var isCurrentWeek = weekStart == currentWeekStart;

            <div class="week-panel @(weekIndex == defaultWeekIndex ? "active" : "")"
                 data-week-index="@weekIndex"
                 data-week-start="@weekStart.ToString("yyyy-MM-dd")"
                 data-current-week="@(isCurrentWeek ? "true" : "false")">
                <div class="card border-0 shadow-sm mb-4 week-card">
                    <div class="card-header bg-white border-0 p-4 pb-2">
                        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                            <div>
                                <h5 class="section-title mb-1">
                                    Tuần @week.WeekNumber

                                    @if (isCurrentWeek)
                                    {
                                        <span class="current-week-pill">Tuần hiện tại</span>
                                    }
                                </h5>

                                <div class="section-subtitle">
                                    Từ @weekStart.ToString("dd/MM/yyyy") đến @weekEnd.ToString("dd/MM/yyyy")
                                </div>
                            </div>

                            <div class="week-badge">
                                <span>@weekItems.Count buổi học</span>
                            </div>
                        </div>
                    </div>

                    <div class="card-body p-4">
                        @if (!weekItems.Any())
                        {
                            <div class="empty-state">
                                <div class="empty-icon">🗓️</div>
                                <h5>Tuần này chưa có lịch học</h5>
                                <p>
                                    Không có buổi học nào trong khoảng thời gian từ
                                    @weekStart.ToString("dd/MM/yyyy") đến @weekEnd.ToString("dd/MM/yyyy").
                                </p>
                            </div>
                        }
                        else
                        {
                            <div class="timetable-wrap">
                                <table class="table timetable-table align-middle mb-0">
                                    <thead>
                                        <tr>
                                            <th class="time-col">Buổi</th>

                                            @for (int dayIndex = 0; dayIndex < 7; dayIndex++)
                                            {
                                                var currentDate = weekStart.AddDays(dayIndex);
                                                var isToday = currentDate.Date == today;

                                                <th class="day-col @(isToday ? "today-header" : "")">
                                                    <div class="day-name">@GetDayLabel(dayIndex)</div>
                                                    <div class="day-date">@currentDate.ToString("dd/MM")</div>
                                                </th>
                                            }
                                        </tr>
                                    </thead>

                                    <tbody>
                                        @foreach (var slot in timeSlots)
                                        {
                                            <tr>
                                                <td class="time-slot-cell">
                                                    <div class="time-slot-main">
                                                        @Html.Raw(GetSessionLabel(slot.StartTime))
                                                    </div>
                                                </td>

                                                @for (int dayIndex = 0; dayIndex < 7; dayIndex++)
                                                {
                                                    var currentDate = weekStart.AddDays(dayIndex);

                                                    var lessonsInCell = weekItems
                                                    .Where(x =>
                                                    x.StudyDate.Date == currentDate.Date &&
                                                    x.StartTime == slot.StartTime &&
                                                    x.EndTime == slot.EndTime)
                                                    .OrderBy(x => x.StartTime)
                                                    .ToList();

                                                    var isTodayCell = currentDate.Date == today;

                                                    <td class="timetable-cell @(isTodayCell ? "today-cell" : "")">
                                                        @if (lessonsInCell.Any())
                                                        {
                                                            @foreach (var lesson in lessonsInCell)
                                                            {
                                                                <div class="lesson-card">
                                                                    <div class="lesson-meta">
                                                                        <span class="lesson-chip class-chip">
                                                                            Lớp: @(lesson.ClassRoom?.ClassName ?? "Chưa có lớp")
                                                                        </span>
                                                                    </div>

                                                                    <div class="lesson-course">
                                                                        Khóa: @(lesson.ClassRoom?.Course?.CourseName ?? "Chưa có khóa học")
                                                                    </div>

                                                                    <div class="teacher-info">
                                                                        GV: @(lesson.ClassRoom?.Teacher?.FullName ?? "Chưa cập nhật")
                                                                    </div>

                                                                    <div class="lesson-info">
                                                                        <span>🕒 @lesson.StartTime.ToString(@"hh\:mm") - @lesson.EndTime.ToString(@"hh\:mm")</span>
                                                                    </div>

                                                                    <div class="teams-code-row">
                                                                        <span class="teams-code-label">💻 Teams code</span>
                                                                        <span class="teams-code-value">
                                                                            @(string.IsNullOrWhiteSpace(lesson.RoomName)
                                                                                                                            ? "Chưa cập nhật"
                                                                                                                            : lesson.RoomName)
                                            </span>
                                        </div>
                                    </div>
                                                                        }
                                                        }
                                                        else
                                                        {
                                                            <div class="empty-slot">--</div>
                                                        }
                                                    </td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>

