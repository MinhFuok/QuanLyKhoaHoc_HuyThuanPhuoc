@model QLKH.Application.ViewModels.TeacherGradeOverviewViewModel
@using System.Linq

@{
    ViewData["Title"] = "Bảng điểm lớp";
    Layout = "~/Views/Shared/_DashBoardLayout.cshtml";

    var students = (Model?.Students
        ?? Enumerable.Empty<QLKH.Application.ViewModels.TeacherGradeStudentRowViewModel>())
        .ToList();

    var assignments = (Model?.Assignments
        ?? Enumerable.Empty<QLKH.Application.ViewModels.TeacherGradeAssignmentViewModel>())
        .ToList();

    var totalStudents = students.Count;
    var totalAssignments = assignments.Count;

    var totalGradeCells = totalStudents * totalAssignments;

    var gradedCells = 0;

    if (students.Any() && assignments.Any())
    {
        foreach (var student in students)
        {
            foreach (var assignment in assignments)
            {
                if (student.ScoresByAssignmentId.ContainsKey(assignment.AssignmentId)
                    && student.ScoresByAssignmentId[assignment.AssignmentId].HasValue)
                {
                    gradedCells++;
                }
            }
        }
    }

    var ungradedCells = totalGradeCells - gradedCells;
    var completionRate = totalGradeCells == 0 ? 0 : Math.Round((double)gradedCells * 100 / totalGradeCells, 1);
}

<div class="teacher-grades-page">

    <!-- Header -->
    <div class="grades-hero card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <h2 class="page-title mb-2">BẢNG ĐIỂM</h2>
                    <div class="page-eyebrow">GIẢNG DẠY</div>
                </div>

                <div class="d-flex flex-column flex-sm-row gap-2 align-items-stretch align-items-sm-center">
                    <a asp-area="GiaoVien"
                       asp-controller="ClassGrades"
                       asp-action="Classes"
                       class="btn btn-outline-primary hero-action-btn">
                        ← Quay lại 
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Class Info -->
    <div class="card border-0 shadow-sm class-info-card mb-4">
        <div class="card-header bg-white border-0 p-4 pb-2">
            <h5 class="section-title mb-1">Thông tin lớp</h5>
        </div>

        <div class="card-body p-4">
            <div class="class-info-grid">
                <div class="info-item">
                    <div class="info-label">Lớp</div>
                    <div class="info-value">@(Model?.ClassName ?? "Chưa có")</div>
                </div>

                <div class="info-item">
                    <div class="info-label">Khóa học</div>
                    <div class="info-value">@(Model?.CourseName ?? "Chưa có")</div>
                </div>

                <div class="info-item">
                    <div class="info-label">Số học viên</div>
                    <div class="info-value">@totalStudents</div>
                </div>

                <div class="info-item">
                    <div class="info-label">Số bài tập</div>
                    <div class="info-value">@totalAssignments</div>
                </div>
            </div>
        </div>
    </div>

    <!-- KPI -->
    <div class="row g-4 mb-4">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="grade-stat-card stat-total card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-icon">👥</div>
                    <div>
                        <div class="stat-label">Tổng học viên</div>
                        <div class="stat-value">@totalStudents</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="grade-stat-card stat-assignment card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-icon">📝</div>
                    <div>
                        <div class="stat-label">Tổng bài tập</div>
                        <div class="stat-value">@totalAssignments</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="grade-stat-card stat-graded card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-icon">✅</div>
                    <div>
                        <div class="stat-label">Ô điểm đã chấm</div>
                        <div class="stat-value">@gradedCells</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="grade-stat-card stat-rate card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-icon">📊</div>
                    <div>
                        <div class="stat-label">Hoàn thành điểm</div>
                        <div class="stat-value">@completionRate%</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Content -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 p-4 pb-2">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <h5 class="section-title mb-1">Bảng điểm học viên</h5>
                </div>

                <div class="grade-filter-note">
                    <span class="status-dot good"></span> Đạt tốt
                    <span class="status-dot average ms-3"></span> Trung bình
                    <span class="status-dot low ms-3"></span> Cần cải thiện
                    <span class="status-dot empty ms-3"></span> Chưa có điểm
                </div>
            </div>
        </div>

        <div class="card-body p-4">
            @if (!assignments.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">📭</div>
                    <h5>Lớp này chưa có bài tập nào</h5>
                    <p>
                        Khi giáo viên tạo bài tập và học viên nộp bài, điểm sẽ được tổng hợp tại đây.
                    </p>

                    <a asp-area="GiaoVien"
                       asp-controller="Assignments"
                       asp-action="Create"
                       class="btn btn-primary mt-3">
                        + Tạo bài tập
                    </a>
                </div>
            }
            else if (!students.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">👥</div>
                    <h5>Lớp này chưa có học viên nào</h5>
                    <p>
                        Hiện chưa có học viên trong lớp nên chưa thể hiển thị bảng điểm.
                    </p>
                </div>
            }
            else
            {
                <div class="table-responsive grade-table-wrap">
                    <table class="table grade-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="sticky-student-code text-center">Mã học viên</th>
                                <th class="sticky-student-name text-center">Họ tên</th>

                                @foreach (var assignment in assignments)
                                {
                                    <th >
                                        <div class="assignment-header">
                                            @assignment.AssignmentTitle
                                        </div>
                                    </th>
                                }
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var student in students)
                            {
                                <tr>
                                    <td>
                                        <span class="student-code">@student.StudentCode</span>
                                    </td>

                                    <td>
                                        <div class="student-main">
                                            <div class="student-avatar">
                                                @{
                                                    var displayName = student.StudentName ?? "";
                                                    var avatarText = string.IsNullOrWhiteSpace(displayName)
                                                    ? "HV"
                                                    : displayName.Trim()[0].ToString().ToUpper();
                                                }

                                                @avatarText
                                    </div>

                                            <div>
                                                <div class="student-name">@student.StudentName</div>
                                            </div>
                                        </div>
                                    </td>

                            @foreach (var assignment in assignments)
                                    {
                                        var score = student.ScoresByAssignmentId.ContainsKey(assignment.AssignmentId)
                                        ? student.ScoresByAssignmentId[assignment.AssignmentId]
                                        : null;

                                        var scoreClass = "";

                                        if (score.HasValue)
                                        {
                                            if (score.Value >= 8)
                                            {
                                                scoreClass = "score-good";
                                            }
                                            else if (score.Value >= 5)
                                            {
                                                scoreClass = "score-average";
                                            }
                                            else
                                            {
                                                scoreClass = "score-low";
                                            }
                                        }

                                        <td>
                                            @if (score.HasValue)
                                            {
                                                <span class="score-pill @scoreClass">
                                                    @score.Value.ToString("0.##")
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="score-empty">--</span>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="grade-summary mt-3">
                    <span>Tổng ô điểm: <strong>@totalGradeCells</strong></span>
                    <span>Đã có điểm: <strong>@gradedCells</strong></span>
                    <span>Chưa có điểm: <strong>@ungradedCells</strong></span>
                    <span>Hoàn thành: <strong>@completionRate%</strong></span>
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <style>
        .teacher-grades-page {
            animation: fadeInPage 0.25s ease-in-out;
        }

        @@keyframes fadeInPage {
            from {
                opacity: 0;
                transform: translateY(6px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .grades-hero {
            border-radius: 22px;
            background: linear-gradient(135deg, #f4f8ff 0%, #ffffff 60%, #f8fbff 100%);
            overflow: hidden;
        }

        .page-eyebrow {
            font-size: 0.78rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            color: #3b82f6;
            text-transform: uppercase;
            margin-bottom: 6px;
        }

        .page-title {
            font-size: 2rem;
            font-weight: 800;
            color: #172554;
        }

        .hero-action-btn {
            border-radius: 14px;
            font-weight: 800;
            padding: 12px 16px;
            white-space: nowrap;
        }

        .hero-badge {
            min-width: 210px;
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 18px;
            border-radius: 18px;
            background: #ffffff;
            border: 1px solid #e5e7eb;
            box-shadow: 0 10px 25px rgba(15, 23, 42, 0.06);
        }

        .hero-badge-icon {
            width: 48px;
            height: 48px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #eff6ff;
            font-size: 1.4rem;
        }

        .hero-badge-label {
            color: #64748b;
            font-size: 0.9rem;
        }

        .hero-badge-value {
            color: #172554;
            font-size: 1.7rem;
            font-weight: 800;
            line-height: 1;
        }

        .class-info-card,
        .grade-stat-card {
            border-radius: 20px;
            overflow: hidden;
        }

        .class-info-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 14px;
        }

        .info-item {
            padding: 14px 16px;
            border-radius: 16px;
            background: #f8fafc;
            border: 1px solid #e5e7eb;
        }

        .info-label {
            color: #64748b;
            font-size: 0.88rem;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .info-value {
            color: #0f172a;
            font-weight: 800;
            word-break: break-word;
        }

        .grade-stat-card .card-body {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 20px;
        }

        .stat-icon {
            width: 52px;
            height: 52px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.45rem;
            flex-shrink: 0;
        }

        .stat-total {
            background: linear-gradient(135deg, #eef4ff 0%, #ffffff 100%);
            border-left: 5px solid #2563eb !important;
        }

            .stat-total .stat-icon {
                background: #dbeafe;
            }

        .stat-assignment {
            background: linear-gradient(135deg, #fff7ed 0%, #ffffff 100%);
            border-left: 5px solid #f59e0b !important;
        }

            .stat-assignment .stat-icon {
                background: #ffedd5;
            }

        .stat-graded {
            background: linear-gradient(135deg, #ecfdf5 0%, #ffffff 100%);
            border-left: 5px solid #16a34a !important;
        }

            .stat-graded .stat-icon {
                background: #dcfce7;
            }

        .stat-rate {
            background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);
            border-left: 5px solid #64748b !important;
        }

            .stat-rate .stat-icon {
                background: #e2e8f0;
            }

        .stat-label {
            color: #64748b;
            font-weight: 600;
            font-size: 0.93rem;
            margin-bottom: 4px;
        }

        .stat-value {
            color: #0f172a;
            font-size: 2rem;
            font-weight: 800;
            line-height: 1;
        }

        .section-title {
            font-weight: 800;
            color: #172554;
        }

        .grade-filter-note {
            color: #64748b;
            font-size: 0.9rem;
            white-space: nowrap;
        }

        .status-dot {
            display: inline-block;
            width: 9px;
            height: 9px;
            border-radius: 50%;
            margin-right: 5px;
        }

            .status-dot.good {
                background: #16a34a;
            }

            .status-dot.average {
                background: #f59e0b;
            }

            .status-dot.low {
                background: #e11d48;
            }

            .status-dot.empty {
                background: #94a3b8;
            }

        .grade-table-wrap {
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            overflow: auto;
            max-height: 620px;
        }

        .grade-table {
            background: #ffffff;
            min-width: 900px;
        }

            .grade-table thead th {
                position: sticky;
                top: 0;
                z-index: 2;
                background: #f8fafc;
                color: #475569;
                font-size: 0.85rem;
                text-transform: uppercase;
                letter-spacing: 0.04em;
                border-bottom: 1px solid #e5e7eb;
                padding: 14px 16px;
                white-space: nowrap;
                vertical-align: middle;
            }

            .grade-table tbody td {
                padding: 16px;
                border-bottom: 1px solid #eef2f7;
                vertical-align: middle;
                white-space: nowrap;
            }

            .grade-table tbody tr:last-child td {
                border-bottom: none;
            }

            .grade-table tbody tr {
                transition: all 0.18s ease-in-out;
            }

                .grade-table tbody tr:hover {
                    background: #f8fbff;
                }

        .assignment-header {
            max-width: 180px;
            white-space: normal;
            line-height: 1.35;
            font-weight: 800;
        }

        .student-code {
            display: inline-flex;
            align-items: center;
            padding: 7px 10px;
            border-radius: 999px;
            background: #eff6ff;
            color: #1d4ed8;
            font-weight: 800;
            font-size: 0.88rem;
            white-space: nowrap;
        }

        .student-main {
            display: flex;
            align-items: center;
            gap: 12px;
            min-width: 210px;
        }

        .student-avatar {
            width: 42px;
            height: 42px;
            border-radius: 14px;
            background: #eff6ff;
            color: #1d4ed8;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 900;
            flex-shrink: 0;
        }

        .student-name {
            font-weight: 800;
            color: #0f172a;
            white-space: nowrap;
        }

        .score-pill {
            display: inline-flex;
            min-width: 48px;
            justify-content: center;
            padding: 7px 11px;
            border-radius: 999px;
            font-weight: 900;
        }

        .score-good {
            color: #166534;
            background: #dcfce7;
        }

        .score-average {
            color: #92400e;
            background: #ffedd5;
        }

        .score-low {
            color: #be123c;
            background: #ffe4e6;
        }

        .score-empty {
            display: inline-flex;
            min-width: 48px;
            justify-content: center;
            padding: 7px 11px;
            border-radius: 999px;
            background: #f1f5f9;
            color: #94a3b8;
            font-weight: 900;
        }

        .grade-summary {
            display: flex;
            justify-content: flex-end;
            gap: 14px;
            flex-wrap: wrap;
            color: #64748b;
            font-size: 0.92rem;
        }

            .grade-summary strong {
                color: #172554;
            }

        .empty-state {
            text-align: center;
            padding: 50px 20px;
            background: #f8fafc;
            border: 1px dashed #cbd5e1;
            border-radius: 18px;
        }

        .empty-icon {
            font-size: 3rem;
            margin-bottom: 12px;
        }

        .empty-state h5 {
            color: #172554;
            font-weight: 800;
            margin-bottom: 8px;
        }

        .empty-state p {
            color: #64748b;
            max-width: 560px;
            margin: 0 auto;
        }

        @@media (max-width: 1199.98px) {
            .class-info-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .grade-filter-note {
                white-space: normal;
            }
        }

        @@media (max-width: 767.98px) {
            .page-title {
                font-size: 1.6rem;
            }

            .hero-action-btn,
            .hero-badge {
                width: 100%;
            }

            .class-info-grid {
                grid-template-columns: 1fr;
            }

            .grade-stat-card .card-body {
                padding: 16px;
            }

            .stat-value {
                font-size: 1.7rem;
            }

            .grade-summary {
                justify-content: flex-start;
            }
        }
    </style>
}