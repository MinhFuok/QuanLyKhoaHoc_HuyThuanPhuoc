@model IEnumerable<QLKH.Domain.Entities.ClassRoom>
@using System.Linq

@{
    ViewData["Title"] = "Danh Sách Bảng điểm";
    Layout = "~/Views/Shared/_DashBoardLayout.cshtml";

    var today = DateTime.Today;
    var allClasses = Model?.ToList() ?? new List<QLKH.Domain.Entities.ClassRoom>();

    int? selectedClassRoomId = null;
    var classRoomIdQuery = Context.Request.Query["classRoomId"].ToString();

    if (int.TryParse(classRoomIdQuery, out var parsedClassRoomId) && parsedClassRoomId > 0)
    {
        selectedClassRoomId = parsedClassRoomId;
    }

    var classRoomOptions = allClasses
        .OrderBy(x => x.ClassCode)
        .Select(x => new
        {
            Id = x.Id,
            Text = $"{x.ClassCode} - {x.ClassName}"
        })
        .ToList();

    var classes = allClasses;

    if (selectedClassRoomId.HasValue)
    {
        classes = classes
            .Where(x => x.Id == selectedClassRoomId.Value)
            .ToList();
    }

    var totalClasses = classes.Count;
    var activeClasses = classes.Count(x => x.StartDate.Date <= today && x.EndDate.Date >= today);
    var upcomingClasses = classes.Count(x => x.StartDate.Date > today);
    var endedClasses = classes.Count(x => x.EndDate.Date < today);
}

<div class="teacher-grade-classes-page">

    <!-- Header -->
    <div class="grade-classes-hero card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <h2 class="page-title mb-2">BẢNG ĐIỂM</h2>
                    <div class="page-eyebrow">GIẢNG DẠY</div>
                </div>
            </div>
        </div>
    </div>

    <!-- KPI -->
    <div class="row g-4 mb-4">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="grade-class-stat-card stat-total card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-icon">📚</div>
                    <div>
                        <div class="stat-label">Tổng lớp phụ trách</div>
                        <div class="stat-value">@totalClasses</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="grade-class-stat-card stat-active card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-icon">✅</div>
                    <div>
                        <div class="stat-label">Lớp đang học</div>
                        <div class="stat-value">@activeClasses</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="grade-class-stat-card stat-upcoming card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-icon">⏳</div>
                    <div>
                        <div class="stat-label">Lớp sắp học</div>
                        <div class="stat-value">@upcomingClasses</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="grade-class-stat-card stat-ended card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-icon">🏁</div>
                    <div>
                        <div class="stat-label">Lớp đã kết thúc</div>
                        <div class="stat-value">@endedClasses</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Content -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 p-4 pb-2">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <h5 class="section-title mb-1">Danh sách bảng điểm lớp</h5>
                </div>

                <div class="class-filter-note">
                    <span class="status-dot active"></span> Đang học
                    <span class="status-dot upcoming ms-3"></span> Sắp học
                    <span class="status-dot ended ms-3"></span> Đã kết thúc
                </div>
            </div>
        </div>

        <div class="card-body p-4">

            <!-- Filter -->
            <form asp-area="GiaoVien"
                  asp-controller="ClassGrades"
                  asp-action="Classes"
                  method="get"
                  class="grade-class-filter-form mb-4">

                <div class="grade-class-filter-field">
                    <select name="classRoomId" class="form-select grade-class-select">
                        <option value="">-- Tất cả lớp --</option>

                        @foreach (var option in classRoomOptions)
                        {
                            var isSelected = selectedClassRoomId.HasValue &&
                            option.Id == selectedClassRoomId.Value;

                            if (isSelected)
                            {
                                <option value="@option.Id" selected="selected">@option.Text</option>
                            }
                            else
                            {
                                <option value="@option.Id">@option.Text</option>
                            }
                        }
                    </select>
                </div>

                <div class="grade-class-filter-actions">
                    <button type="submit" class="btn btn-primary">
                        Lọc
                    </button>

                    <a asp-area="GiaoVien"
                       asp-controller="ClassGrades"
                       asp-action="Classes"
                       class="btn btn-outline-secondary">
                        Bỏ lọc
                    </a>
                </div>
            </form>

            @if (!allClasses.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">📭</div>
                    <h5>Chưa có lớp để xem bảng điểm</h5>
                    <p>
                        Hiện tại bạn chưa có lớp nào được phân công hoặc chưa có dữ liệu lớp để xem bảng điểm.
                    </p>
                </div>
            }
            else if (!classes.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">📭</div>
                    <h5>Không tìm thấy lớp đã chọn</h5>
                    <p>
                        Lớp này không còn trong danh sách lớp bạn phụ trách. Vui lòng chọn lại lớp khác.
                    </p>

                    <a asp-area="GiaoVien"
                       asp-controller="ClassGrades"
                       asp-action="Classes"
                       class="btn btn-primary mt-3">
                        x
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive grade-class-table-wrap">
                    <table class="table grade-class-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="text-center">Mã lớp</th>
                                <th class="text-center">Tên lớp</th>
                                <th class="text-center">Khóa học</th>
                                <th class="text-center">Thời gian</th>
                                <th class="text-center">Trạng thái</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in classes.OrderBy(x => x.StartDate))
                            {
                                var statusText = "";
                                var statusClass = "";

                                if (item.StartDate.Date > today)
                                {
                                    statusText = "Sắp học";
                                    statusClass = "badge-upcoming";
                                }
                                else if (item.EndDate.Date < today)
                                {
                                    statusText = "Đã kết thúc";
                                    statusClass = "badge-ended";
                                }
                                else
                                {
                                    statusText = "Đang học";
                                    statusClass = "badge-active";
                                }

                                <tr>
                                    <td>
                                        <span class="class-code">@item.ClassCode</span>
                                    </td>

                                    <td>
                                        <div class="class-name">@item.ClassName</div>
                                        <div class="class-small">
                                            GV: @(item.Teacher?.FullName ?? "Chưa cập nhật")
                                        </div>
                                    </td>

                                    <td>
                                        <div class="course-name">
                                            @(item.Course?.CourseName ?? "Chưa có khóa học")
                                        </div>
                                    </td>

                                    <td>
                                        <div class="date-range">
                                            <span>@item.StartDate.ToString("dd/MM/yyyy")</span>
                                            <span class="date-arrow">→</span>
                                            <span>@item.EndDate.ToString("dd/MM/yyyy")</span>
                                        </div>
                                    </td>

                                    <td>
                                        <span class="class-status @statusClass">@statusText</span>
                                    </td>

                                    <td class="text-end">
                                        <div class="action-group">
                                            <a asp-area="GiaoVien"
                                               asp-controller="ClassGrades"
                                               asp-action="Index"
                                               asp-route-classRoomId="@item.Id"
                                               class="btn btn-sm btn-primary">
                                                Xem bảng điểm
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="grade-class-summary mt-3">
                    <span>Đang hiển thị: <strong>@totalClasses</strong></span>
                    <span>Đang học: <strong>@activeClasses</strong></span>
                    <span>Sắp học: <strong>@upcomingClasses</strong></span>
                    <span>Đã kết thúc: <strong>@endedClasses</strong></span>
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <style>
        .teacher-grade-classes-page {
            animation: fadeInPage 0.25s ease-in-out;
        }

        @@keyframes fadeInPage {
            from {
                opacity: 0;
                transform: translateY(6px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .grade-classes-hero {
            border-radius: 22px;
            background: linear-gradient(135deg, #f4f8ff 0%, #ffffff 60%, #f8fbff 100%);
            overflow: hidden;
        }

        .page-eyebrow {
            font-size: 0.78rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            color: #3b82f6;
            text-transform: uppercase;
            margin-bottom: 6px;
        }

        .page-title {
            font-size: 2rem;
            font-weight: 800;
            color: #172554;
        }

        .hero-badge {
            min-width: 210px;
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 18px;
            border-radius: 18px;
            background: #ffffff;
            border: 1px solid #e5e7eb;
            box-shadow: 0 10px 25px rgba(15, 23, 42, 0.06);
        }

        .hero-badge-icon {
            width: 48px;
            height: 48px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #eff6ff;
            font-size: 1.4rem;
        }

        .hero-badge-label {
            color: #64748b;
            font-size: 0.9rem;
        }

        .hero-badge-value {
            color: #172554;
            font-size: 1.7rem;
            font-weight: 800;
            line-height: 1;
        }

        .grade-class-stat-card {
            border-radius: 20px;
            overflow: hidden;
        }

            .grade-class-stat-card .card-body {
                display: flex;
                align-items: center;
                gap: 16px;
                padding: 20px;
            }

        .stat-icon {
            width: 52px;
            height: 52px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.45rem;
            flex-shrink: 0;
        }

        .stat-total {
            background: linear-gradient(135deg, #eef4ff 0%, #ffffff 100%);
            border-left: 5px solid #2563eb !important;
        }

            .stat-total .stat-icon {
                background: #dbeafe;
            }

        .stat-active {
            background: linear-gradient(135deg, #ecfdf5 0%, #ffffff 100%);
            border-left: 5px solid #16a34a !important;
        }

            .stat-active .stat-icon {
                background: #dcfce7;
            }

        .stat-upcoming {
            background: linear-gradient(135deg, #fff7ed 0%, #ffffff 100%);
            border-left: 5px solid #f59e0b !important;
        }

            .stat-upcoming .stat-icon {
                background: #ffedd5;
            }

        .stat-ended {
            background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);
            border-left: 5px solid #64748b !important;
        }

            .stat-ended .stat-icon {
                background: #e2e8f0;
            }

        .stat-label {
            color: #64748b;
            font-weight: 600;
            font-size: 0.93rem;
            margin-bottom: 4px;
        }

        .stat-value {
            color: #0f172a;
            font-size: 2rem;
            font-weight: 800;
            line-height: 1;
        }

        .section-title {
            font-weight: 800;
            color: #172554;
        }

        .class-filter-note {
            color: #64748b;
            font-size: 0.9rem;
            white-space: nowrap;
        }

        .status-dot {
            display: inline-block;
            width: 9px;
            height: 9px;
            border-radius: 50%;
            margin-right: 5px;
        }

            .status-dot.active {
                background: #16a34a;
            }

            .status-dot.upcoming {
                background: #f59e0b;
            }

            .status-dot.ended {
                background: #64748b;
            }

        .grade-class-filter-form {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 12px;
            align-items: end;
            padding: 16px;
            border: 1px solid #e5e7eb;
            border-radius: 16px;
            background: #f8fafc;
        }

        .grade-class-filter-field label {
            display: block;
            margin-bottom: 6px;
            color: #334155;
            font-size: 0.9rem;
            font-weight: 800;
        }

        .grade-class-select {
            min-height: 42px;
            border-radius: 12px;
            font-weight: 700;
            color: #0f172a;
        }

        .grade-class-filter-actions {
            display: flex;
            gap: 8px;
        }

            .grade-class-filter-actions .btn {
                min-height: 42px;
                border-radius: 12px;
                font-weight: 800;
                white-space: nowrap;
            }

        .grade-class-table-wrap {
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            overflow: hidden;
        }

        .grade-class-table {
            background: #ffffff;
        }

            .grade-class-table thead th {
                background: #f8fafc;
                color: #475569;
                font-size: 0.85rem;
                text-transform: uppercase;
                letter-spacing: 0.04em;
                border-bottom: 1px solid #e5e7eb;
                padding: 14px 16px;
                white-space: nowrap;
            }

            .grade-class-table tbody td {
                padding: 16px;
                border-bottom: 1px solid #eef2f7;
                vertical-align: middle;
            }

            .grade-class-table tbody tr:last-child td {
                border-bottom: none;
            }

            .grade-class-table tbody tr {
                transition: all 0.18s ease-in-out;
            }

                .grade-class-table tbody tr:hover {
                    background: #f8fbff;
                }

        .class-code {
            display: inline-flex;
            align-items: center;
            padding: 7px 10px;
            border-radius: 999px;
            background: #eff6ff;
            color: #1d4ed8;
            font-weight: 800;
            font-size: 0.88rem;
            white-space: nowrap;
        }

        .class-name {
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 3px;
        }

        .class-small {
            color: #64748b;
            font-size: 0.88rem;
        }

        .course-name {
            color: #334155;
            font-weight: 600;
            min-width: 150px;
        }

        .date-range {
            display: flex;
            align-items: center;
            gap: 6px;
            color: #334155;
            font-weight: 600;
            white-space: nowrap;
        }

        .date-arrow {
            color: #94a3b8;
        }

        .class-status {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 7px 11px;
            border-radius: 999px;
            font-weight: 800;
            font-size: 0.82rem;
            white-space: nowrap;
        }

        .badge-active {
            color: #166534;
            background: #dcfce7;
        }

        .badge-upcoming {
            color: #92400e;
            background: #ffedd5;
        }

        .badge-ended {
            color: #475569;
            background: #e2e8f0;
        }

        .action-group {
            display: flex;
            justify-content: flex-end;
            gap: 8px;
            flex-wrap: wrap;
        }

            .action-group .btn {
                border-radius: 10px;
                font-weight: 700;
                padding: 7px 11px;
            }

        .grade-class-summary {
            display: flex;
            justify-content: flex-end;
            gap: 14px;
            flex-wrap: wrap;
            color: #64748b;
            font-size: 0.92rem;
        }

            .grade-class-summary strong {
                color: #172554;
            }

        .empty-state {
            text-align: center;
            padding: 50px 20px;
            background: #f8fafc;
            border: 1px dashed #cbd5e1;
            border-radius: 18px;
        }

        .empty-icon {
            font-size: 3rem;
            margin-bottom: 12px;
        }

        .empty-state h5 {
            color: #172554;
            font-weight: 800;
            margin-bottom: 8px;
        }

        .empty-state p {
            color: #64748b;
            max-width: 560px;
            margin: 0 auto;
        }

        @@media (max-width: 1199.98px) {
            .class-filter-note {
                white-space: normal;
            }

            .grade-class-table {
                min-width: 980px;
            }

            .grade-class-table-wrap {
                overflow-x: auto;
            }
        }

        @@media (max-width: 767.98px) {
            .page-title {
                font-size: 1.6rem;
            }

            .hero-badge {
                width: 100%;
            }

            .grade-class-stat-card .card-body {
                padding: 16px;
            }

            .stat-value {
                font-size: 1.7rem;
            }

            .action-group {
                justify-content: flex-start;
            }

            .grade-class-summary {
                justify-content: flex-start;
            }

            .grade-class-filter-form {
                grid-template-columns: 1fr;
            }

            .grade-class-filter-actions {
                flex-direction: column;
            }

                .grade-class-filter-actions .btn {
                    width: 100%;
                }
        }
    </style>
}