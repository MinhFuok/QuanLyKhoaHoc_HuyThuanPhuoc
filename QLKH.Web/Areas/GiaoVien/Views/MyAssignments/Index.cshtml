@model IEnumerable<QLKH.Domain.Entities.Assignment>

@{
    ViewData["Title"] = "Bài tập";
    Layout = "~/Views/Shared/_DashBoardLayout.cshtml";

    var today = DateTime.Today;

    var allAssignments = Model?.ToList() ?? new List<QLKH.Domain.Entities.Assignment>();

    int? selectedClassRoomId = null;
    var classRoomIdQuery = Context.Request.Query["classRoomId"].ToString();

    if (int.TryParse(classRoomIdQuery, out var parsedClassRoomId) && parsedClassRoomId > 0)
    {
        selectedClassRoomId = parsedClassRoomId;
    }

    var classRoomOptions = allAssignments
        .Where(x => x.ClassRoom != null)
        .GroupBy(x => x.ClassRoomId)
        .Select(g =>
        {
            var first = g.First();
            return new
            {
                Id = first.ClassRoomId,
                Text = $"{first.ClassRoom!.ClassCode} - {first.ClassRoom.ClassName}"
            };
        })
        .OrderBy(x => x.Text)
        .ToList();

    var assignments = allAssignments;

    if (selectedClassRoomId.HasValue)
    {
        assignments = assignments
            .Where(x => x.ClassRoomId == selectedClassRoomId.Value)
            .ToList();
    }

    var totalAssignments = assignments.Count;
    var activeAssignments = assignments.Count(x => x.DueDate.Date >= today);
    var dueSoonAssignments = assignments.Count(x => x.DueDate.Date >= today && x.DueDate.Date <= today.AddDays(3));
    var overdueAssignments = assignments.Count(x => x.DueDate.Date < today);
    var createdThisMonthAssignments = assignments.Count(x =>
        x.CreatedAt.Month == today.Month &&
        x.CreatedAt.Year == today.Year);
}

<div class="teacher-assignments-page">

    <!-- Header -->
    <div class="assignments-hero card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <h2 class="page-title mb-2">BÀI TẬP</h2>
                    <div class="page-eyebrow">GIẢNG DẠY</div>
                </div>

                <div class="d-flex flex-column flex-sm-row gap-2 align-items-stretch align-items-sm-center">
                    <a asp-area="GiaoVien"
                       asp-controller="Assignments"
                       asp-action="Create"
                       class="btn btn-primary hero-action-btn">
                        + Bài tập mới
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- KPI -->
    <div class="row g-4 mb-4">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="assignment-stat-card stat-total card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-icon">📚</div>
                    <div>
                        <div class="stat-label">Tổng bài tập</div>
                        <div class="stat-value">@totalAssignments</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="assignment-stat-card stat-active card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-icon">✅</div>
                    <div>
                        <div class="stat-label">Còn hạn nộp</div>
                        <div class="stat-value">@activeAssignments</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="assignment-stat-card stat-due-soon card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-icon">⏳</div>
                    <div>
                        <div class="stat-label">Sắp hết hạn</div>
                        <div class="stat-value">@dueSoonAssignments</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="assignment-stat-card stat-overdue card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="stat-icon">⚠️</div>
                    <div>
                        <div class="stat-label">Đã quá hạn</div>
                        <div class="stat-value">@overdueAssignments</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Content -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 p-4 pb-2">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <h5 class="section-title mb-1">Danh sách bài tập</h5>
                </div>

                <div class="assignment-filter-note">
                    <span class="status-dot active"></span> Còn hạn
                    <span class="status-dot due-soon ms-3"></span> Sắp hết hạn
                    <span class="status-dot overdue ms-3"></span> Quá hạn
                </div>
            </div>
        </div>

        <div class="card-body p-4">

            <!-- Filter -->
            <form asp-area="GiaoVien"
                  asp-controller="MyAssignments"
                  asp-action="Index"
                  method="get"
                  class="assignment-filter-form mb-4">

                <div class="assignment-filter-field">
                    <select name="classRoomId" class="form-select assignment-class-select">
                        <option value="">-- Tất cả lớp --</option>

                        @foreach (var option in classRoomOptions)
                        {
                            var isSelected = selectedClassRoomId.HasValue &&
                            option.Id == selectedClassRoomId.Value;

                            if (isSelected)
                            {
                                <option value="@option.Id" selected="selected">@option.Text</option>
                            }
                            else
                            {
                                <option value="@option.Id">@option.Text</option>
                            }
                        }
                    </select>
                </div>

                <div class="assignment-filter-actions">
                    <button type="submit" class="btn btn-primary">
                        Lọc
                    </button>

                    <a asp-area="GiaoVien"
                       asp-controller="MyAssignments"
                       asp-action="Index"
                       class="btn btn-outline-secondary">
                        x
                    </a>
                </div>
            </form>

            @if (!allAssignments.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">📭</div>
                    <h5>Chưa có bài tập nào</h5>
                    <p>
                        Hiện tại chưa có bài tập nào cho các lớp bạn đang phụ trách.
                        Bạn có thể tạo bài tập mới để giao cho học viên.
                    </p>

                    <a asp-area="GiaoVien"
                       asp-controller="Assignments"
                       asp-action="Create"
                       class="btn btn-primary mt-3">
                        + Tạo bài tập đầu tiên
                    </a>
                </div>
            }
            else if (!assignments.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">📭</div>
                    <h5>Không có bài tập trong lớp đã chọn</h5>
                    <p>
                        Lớp này hiện chưa có bài tập nào. Bạn có thể chọn lớp khác hoặc tạo bài tập mới.
                    </p>

                    <a asp-area="GiaoVien"
                       asp-controller="Assignments"
                       asp-action="Create"
                       asp-route-classRoomId="@selectedClassRoomId"
                       class="btn btn-primary mt-3">
                        + Tạo bài tập cho lớp này
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive assignment-table-wrap">
                    <table class="table assignment-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="text-center">Bài tập</th>
                                <th class="text-center">Lớp</th>
                                <th class="text-center">Khóa học</th>
                                <th class="text-center">Hạn nộp</th>
                                <th class="text-center">Ngày tạo</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in assignments.OrderBy(x => x.DueDate))
                            {
                                var dueStatusText = "";
                                var dueStatusClass = "";

                                if (item.DueDate.Date < today)
                                {
                                    dueStatusText = "Quá hạn";
                                    dueStatusClass = "badge-overdue";
                                }
                                else if (item.DueDate.Date <= today.AddDays(3))
                                {
                                    dueStatusText = "Sắp hết hạn";
                                    dueStatusClass = "badge-due-soon";
                                }
                                else
                                {
                                    dueStatusText = "Còn hạn";
                                    dueStatusClass = "badge-active";
                                }

                            <tr>
                                <td>
                                    <div class="assignment-main">
                                        <div class="assignment-icon">📝</div>
                                        <div>
                                            <div class="assignment-title">@item.Title</div>
                                            <div class="assignment-desc">
                                                @(string.IsNullOrWhiteSpace(item.Description)
                                                                                            ? "Không có mô tả"
                                                                                            : item.Description)
                                        </div>
                                    </div>
                                </div>
                            </td>

                                    <td>
                                        <div class="class-name">
                                            @(item.ClassRoom?.ClassName ?? "Chưa có lớp")
                                        </div>
                                        <div class="class-small">
                                            Mã lớp: @(item.ClassRoom?.ClassCode ?? "N/A")
                                        </div>
                                    </td>

                                    <td>
                                        <div class="course-name">
                                            @(item.ClassRoom?.Course?.CourseName ?? "Chưa có khóa học")
                                        </div>
                                    </td>

                                    <td>
                                        <div class="date-block">
                                            <div class="date-main">@item.DueDate.ToString("dd/MM/yyyy")</div>
                                            <div class="date-small">@item.DueDate.ToString("HH:mm")</div>
                                            <span class="assignment-status @dueStatusClass">@dueStatusText</span>
                                        </div>
                                    </td>

                                    <td>
                                        <div class="created-date">
                                            <span>@item.CreatedAt.ToString("dd/MM/yyyy")</span>
                                            <small>@item.CreatedAt.ToString("HH:mm")</small>
                                        </div>
                                    </td>

                                    <td class="text-end">
                                        <div class="action-group">
                                            <a asp-area="GiaoVien"
                                               asp-controller="Assignments"
                                               asp-action="Edit"
                                               asp-route-id="@item.Id"
                                               class="btn btn-sm btn-outline-warning">
                                                Sửa
                                            </a>

                                            <a asp-area="GiaoVien"
                                               asp-controller="AssignmentSubmissions"
                                               asp-action="Index"
                                               asp-route-assignmentId="@item.Id"
                                               class="btn btn-sm btn-primary">
                                                Xem bài nộp
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                                }
                        </tbody>
                    </table>
                </div>

                <div class="assignment-summary mt-3">
                    <span>Tạo trong tháng này: <strong>@createdThisMonthAssignments</strong></span>
                    <span>Tổng bài tập: <strong>@totalAssignments</strong></span>
                    <span>Quá hạn: <strong>@overdueAssignments</strong></span>
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <style>
        .teacher-assignments-page {
            animation: fadeInPage 0.25s ease-in-out;
        }

        @@keyframes fadeInPage {
            from {
                opacity: 0;
                transform: translateY(6px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .assignments-hero {
            border-radius: 22px;
            background: linear-gradient(135deg, #f4f8ff 0%, #ffffff 60%, #f8fbff 100%);
            overflow: hidden;
        }

        .page-eyebrow {
            font-size: 0.78rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            color: #3b82f6;
            text-transform: uppercase;
            margin-bottom: 6px;
        }

        .page-title {
            font-size: 2rem;
            font-weight: 800;
            color: #172554;
        }

        .hero-action-btn {
            border-radius: 14px;
            font-weight: 800;
            padding: 12px 16px;
            white-space: nowrap;
            box-shadow: 0 10px 24px rgba(37, 99, 235, 0.18);
        }

        .hero-badge {
            min-width: 210px;
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 18px;
            border-radius: 18px;
            background: #ffffff;
            border: 1px solid #e5e7eb;
            box-shadow: 0 10px 25px rgba(15, 23, 42, 0.06);
        }

        .hero-badge-icon {
            width: 48px;
            height: 48px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #eff6ff;
            font-size: 1.4rem;
        }

        .hero-badge-label {
            color: #64748b;
            font-size: 0.9rem;
        }

        .hero-badge-value {
            color: #172554;
            font-size: 1.7rem;
            font-weight: 800;
            line-height: 1;
        }

        .assignment-stat-card {
            border-radius: 20px;
            overflow: hidden;
        }

            .assignment-stat-card .card-body {
                display: flex;
                align-items: center;
                gap: 16px;
                padding: 20px;
            }

        .stat-icon {
            width: 52px;
            height: 52px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.45rem;
            flex-shrink: 0;
        }

        .stat-total {
            background: linear-gradient(135deg, #eef4ff 0%, #ffffff 100%);
            border-left: 5px solid #2563eb !important;
        }

            .stat-total .stat-icon {
                background: #dbeafe;
            }

        .stat-active {
            background: linear-gradient(135deg, #ecfdf5 0%, #ffffff 100%);
            border-left: 5px solid #16a34a !important;
        }

            .stat-active .stat-icon {
                background: #dcfce7;
            }

        .stat-due-soon {
            background: linear-gradient(135deg, #fff7ed 0%, #ffffff 100%);
            border-left: 5px solid #f59e0b !important;
        }

            .stat-due-soon .stat-icon {
                background: #ffedd5;
            }

        .stat-overdue {
            background: linear-gradient(135deg, #fff1f2 0%, #ffffff 100%);
            border-left: 5px solid #e11d48 !important;
        }

            .stat-overdue .stat-icon {
                background: #ffe4e6;
            }

        .stat-label {
            color: #64748b;
            font-weight: 600;
            font-size: 0.93rem;
            margin-bottom: 4px;
        }

        .stat-value {
            color: #0f172a;
            font-size: 2rem;
            font-weight: 800;
            line-height: 1;
        }

        .section-title {
            font-weight: 800;
            color: #172554;
        }

        .assignment-filter-note {
            color: #64748b;
            font-size: 0.9rem;
            white-space: nowrap;
        }

        .status-dot {
            display: inline-block;
            width: 9px;
            height: 9px;
            border-radius: 50%;
            margin-right: 5px;
        }

            .status-dot.active {
                background: #16a34a;
            }

            .status-dot.due-soon {
                background: #f59e0b;
            }

            .status-dot.overdue {
                background: #e11d48;
            }

        .assignment-filter-form {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 12px;
            align-items: end;
            padding: 16px;
            border: 1px solid #e5e7eb;
            border-radius: 16px;
            background: #f8fafc;
        }

        .assignment-filter-field label {
            display: block;
            margin-bottom: 6px;
            color: #334155;
            font-size: 0.9rem;
            font-weight: 800;
        }

        .assignment-class-select {
            min-height: 42px;
            border-radius: 12px;
            font-weight: 700;
            color: #0f172a;
        }

        .assignment-filter-actions {
            display: flex;
            gap: 8px;
        }

            .assignment-filter-actions .btn {
                min-height: 42px;
                border-radius: 12px;
                font-weight: 800;
                white-space: nowrap;
            }

        .assignment-table-wrap {
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            overflow: hidden;
        }

        .assignment-table {
            background: #ffffff;
        }

            .assignment-table thead th {
                background: #f8fafc;
                color: #475569;
                font-size: 0.85rem;
                text-transform: uppercase;
                letter-spacing: 0.04em;
                border-bottom: 1px solid #e5e7eb;
                padding: 14px 16px;
                white-space: nowrap;
            }

            .assignment-table tbody td {
                padding: 16px;
                border-bottom: 1px solid #eef2f7;
                vertical-align: middle;
            }

            .assignment-table tbody tr:last-child td {
                border-bottom: none;
            }

            .assignment-table tbody tr {
                transition: all 0.18s ease-in-out;
            }

                .assignment-table tbody tr:hover {
                    background: #f8fbff;
                }

        .assignment-main {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            min-width: 280px;
        }

        .assignment-icon {
            width: 44px;
            height: 44px;
            border-radius: 14px;
            background: #eff6ff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            flex-shrink: 0;
        }

        .assignment-title,
        .class-name {
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 3px;
        }

        .assignment-desc {
            color: #64748b;
            font-size: 0.88rem;
            max-width: 360px;
            line-height: 1.45;
        }

        .class-small {
            color: #64748b;
            font-size: 0.88rem;
            white-space: nowrap;
        }

        .course-name {
            color: #334155;
            font-weight: 600;
            min-width: 150px;
        }

        .date-block {
            display: flex;
            flex-direction: column;
            gap: 4px;
            min-width: 120px;
        }

        .date-main {
            color: #334155;
            font-weight: 800;
            white-space: nowrap;
        }

        .date-small {
            color: #64748b;
            font-size: 0.88rem;
            font-weight: 600;
        }

        .assignment-status {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: fit-content;
            padding: 7px 11px;
            border-radius: 999px;
            font-weight: 800;
            font-size: 0.82rem;
            white-space: nowrap;
            margin-top: 3px;
        }

        .badge-active {
            color: #166534;
            background: #dcfce7;
        }

        .badge-due-soon {
            color: #92400e;
            background: #ffedd5;
        }

        .badge-overdue {
            color: #be123c;
            background: #ffe4e6;
        }

        .created-date {
            color: #334155;
            font-weight: 700;
            white-space: nowrap;
        }

            .created-date small {
                display: block;
                color: #64748b;
                font-weight: 600;
                margin-top: 2px;
            }

        .action-group {
            display: flex;
            justify-content: flex-end;
            gap: 8px;
            flex-wrap: wrap;
        }

            .action-group .btn {
                border-radius: 10px;
                font-weight: 700;
                padding: 7px 11px;
            }

        .assignment-summary {
            display: flex;
            justify-content: flex-end;
            gap: 14px;
            flex-wrap: wrap;
            color: #64748b;
            font-size: 0.92rem;
        }

            .assignment-summary strong {
                color: #172554;
            }

        .empty-state {
            text-align: center;
            padding: 50px 20px;
            background: #f8fafc;
            border: 1px dashed #cbd5e1;
            border-radius: 18px;
        }

        .empty-icon {
            font-size: 3rem;
            margin-bottom: 12px;
        }

        .empty-state h5 {
            color: #172554;
            font-weight: 800;
            margin-bottom: 8px;
        }

        .empty-state p {
            color: #64748b;
            max-width: 520px;
            margin: 0 auto;
        }

        @@media (max-width: 1199.98px) {
            .assignment-filter-note {
                white-space: normal;
            }

            .assignment-table {
                min-width: 980px;
            }

            .assignment-table-wrap {
                overflow-x: auto;
            }
        }

        @@media (max-width: 767.98px) {
            .page-title {
                font-size: 1.6rem;
            }

            .hero-action-btn,
            .hero-badge {
                width: 100%;
            }

            .assignment-stat-card .card-body {
                padding: 16px;
            }

            .stat-value {
                font-size: 1.7rem;
            }

            .action-group {
                justify-content: flex-start;
            }

            .assignment-summary {
                justify-content: flex-start;
            }

            .assignment-filter-form {
                grid-template-columns: 1fr;
            }

            .assignment-filter-actions {
                flex-direction: column;
            }

                .assignment-filter-actions .btn {
                    width: 100%;
                }
        }
    </style>
}