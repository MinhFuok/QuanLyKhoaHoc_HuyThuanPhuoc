@model QLKH.Domain.Entities.Assignment
@using QLKH.Domain.Entities
@using System.Linq

@{
    ViewData["Title"] = "Sửa bài tập";
    Layout = "~/Views/Shared/_DashBoardLayout.cshtml";

    var myClasses = ViewBag.MyClasses as IEnumerable<ClassRoom> ?? Enumerable.Empty<ClassRoom>();
    var classList = myClasses.ToList();
}

<div class="teacher-assignment-edit-page">

    <!-- Header -->
    <div class="assignments-edit-hero card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <h2 class="page-title mb-2">SỬA BÀI TẬP</h2>
                    <div class="page-eyebrow">GIẢNG DẠY</div>
                </div>

                <div class="d-flex flex-column flex-sm-row gap-2 align-items-stretch align-items-sm-center">
                    <a asp-area="GiaoVien"
                       asp-controller="MyAssignments"
                       asp-action="Index"
                       class="btn btn-outline-primary hero-action-btn">
                        ← Quay lại
                    </a>

                    <div class="hero-badge">
                        <div class="hero-badge-icon">📝</div>
                        <div>
                            <div class="hero-badge-label">Mã bài tập</div>
                            <div class="hero-badge-value">#@Model.Id</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Alert -->
    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-danger custom-alert shadow-sm border-0 mb-4">
            <div class="alert-icon">⚠️</div>
            <div>
                <strong>Không thể cập nhật bài tập!</strong>
                <div>@ViewBag.ErrorMessage</div>
            </div>
        </div>
    }

    <!-- Form -->
    <div class="row g-4">
        <div class="col-12 col-xl-8">
            <div class="card border-0 shadow-sm form-card">
                <div class="card-header bg-white border-0 p-4 pb-2">
                    <h5 class="section-title mb-1">Thông tin bài tập</h5>
                    <p class="section-subtitle mb-0">
                        Cập nhật lớp, tiêu đề, mô tả hoặc hạn nộp của bài tập.
                    </p>
                </div>

                <div class="card-body p-4">
                    <form method="post" class="assignment-edit-form">
                        @Html.AntiForgeryToken()

                        <input type="hidden" name="id" value="@Model.Id" />

                        <div class="mb-4">
                            <label class="form-label custom-label">
                                Chọn lớp <span class="required">*</span>
                            </label>

                            <select name="classRoomId" class="form-select custom-control" required>
                                <option value="">-- Chọn lớp muốn giao bài tập --</option>
                                @foreach (var item in classList.OrderBy(x => x.StartDate))
                                {
                                    var statusText = "";

                                    if (item.StartDate.Date > DateTime.Today)
                                    {
                                        statusText = "Sắp học";
                                    }
                                    else if (item.EndDate.Date < DateTime.Today)
                                    {
                                        statusText = "Đã kết thúc";
                                    }
                                    else
                                    {
                                        statusText = "Đang học";
                                    }

                                    if (item.Id == Model.ClassRoomId)
                                    {
                                        <option value="@item.Id" selected>
                                            @item.ClassName (@item.ClassCode) - @statusText
                                        </option>
                                    }
                                    else
                                    {
                                        <option value="@item.Id">
                                            @item.ClassName (@item.ClassCode) - @statusText
                                        </option>
                                    }
                                }
                            </select>

                            <div class="form-hint">
                                Chỉ được chọn các lớp bạn đang được phân công giảng dạy.
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label custom-label">
                                Tiêu đề bài tập <span class="required">*</span>
                            </label>

                            <input type="text"
                                   name="title"
                                   class="form-control custom-control"
                                   value="@Model.Title"
                                   maxlength="200"
                                   required />

                            <div class="form-hint">
                                Nên đặt tiêu đề ngắn gọn, dễ hiểu cho học viên.
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-12 col-md-6">
                                <label class="form-label custom-label">
                                    Hạn nộp <span class="required">*</span>
                                </label>

                                <input type="datetime-local"
                                       name="dueDate"
                                       class="form-control custom-control"
                                       value="@Model.DueDate.ToString("yyyy-MM-ddTHH:mm")"
                                       required />
                            </div>

                            <div class="col-12 col-md-6">
                                <label class="form-label custom-label">
                                    Ngày tạo
                                </label>

                                <input type="text"
                                       class="form-control custom-control readonly-control"
                                       value="@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")"
                                       readonly />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label custom-label">Mô tả bài tập</label>

                            <textarea name="description"
                                      class="form-control custom-control"
                                      rows="6">@Model.Description</textarea>
                        </div>

                        <div class="form-actions">
                            <a asp-area="GiaoVien"
                               asp-controller="MyAssignments"
                               asp-action="Index"
                               class="btn btn-outline-secondary">
                                Hủy
                            </a>

                            <button type="submit" class="btn btn-primary submit-btn">
                                Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Right note -->
        <div class="col-12 col-xl-4">
            <div class="card border-0 shadow-sm note-card mb-4">
                <div class="card-header bg-white border-0 p-4 pb-2">
                    <h5 class="section-title mb-1">Lưu ý khi sửa bài tập</h5>
                </div>

                <div class="card-body p-4">
                    <div class="note-list">
                        <div class="note-item">
                            <div class="note-icon">✅</div>
                            <div>
                                <div class="note-title">Kiểm tra đúng lớp</div>
                                <div class="note-desc">
                                    Nếu đổi lớp, bài tập sẽ chuyển sang lớp mới được chọn.
                                </div>
                            </div>
                        </div>

                        <div class="note-item">
                            <div class="note-icon">⏰</div>
                            <div>
                                <div class="note-title">Cẩn thận hạn nộp</div>
                                <div class="note-desc">
                                    Thay đổi hạn nộp có thể ảnh hưởng đến tiến độ nộp bài của học viên.
                                </div>
                            </div>
                        </div>

                        <div class="note-item">
                            <div class="note-icon">📌</div>
                            <div>
                                <div class="note-title">Không đổi ngày tạo</div>
                                <div class="note-desc">
                                    Ngày tạo được giữ nguyên để đảm bảo lịch sử bài tập.
                                </div>
                            </div>
                        </div>

                        <div class="note-item">
                            <div class="note-icon">📝</div>
                            <div>
                                <div class="note-title">Mô tả rõ ràng</div>
                                <div class="note-desc">
                                    Mô tả nên ghi rõ yêu cầu, cách nộp và tiêu chí đánh giá.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm support-card">
                <div class="card-body p-4">
                    <div class="support-icon">💡</div>
                    <h5 class="support-title">Gợi ý</h5>
                    <p class="support-desc mb-0">
                        Nếu bài tập đã có học viên nộp, bạn nên hạn chế đổi nội dung quá nhiều để tránh gây nhầm lẫn cho học viên.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .teacher-assignment-edit-page {
            animation: fadeInPage 0.25s ease-in-out;
        }

        @@keyframes fadeInPage {
            from {
                opacity: 0;
                transform: translateY(6px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .assignments-edit-hero {
            border-radius: 22px;
            background: linear-gradient(135deg, #f4f8ff 0%, #ffffff 60%, #f8fbff 100%);
            overflow: hidden;
        }

        .page-eyebrow {
            font-size: 0.78rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            color: #3b82f6;
            text-transform: uppercase;
            margin-bottom: 6px;
        }

        .page-title {
            font-size: 2rem;
            font-weight: 800;
            color: #172554;
        }

        .hero-action-btn {
            border-radius: 14px;
            font-weight: 800;
            padding: 12px 16px;
            white-space: nowrap;
        }

        .hero-badge {
            min-width: 210px;
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 18px;
            border-radius: 18px;
            background: #ffffff;
            border: 1px solid #e5e7eb;
            box-shadow: 0 10px 25px rgba(15, 23, 42, 0.06);
        }

        .hero-badge-icon {
            width: 48px;
            height: 48px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #eff6ff;
            font-size: 1.4rem;
        }

        .hero-badge-label {
            color: #64748b;
            font-size: 0.9rem;
        }

        .hero-badge-value {
            color: #172554;
            font-size: 1.4rem;
            font-weight: 800;
            line-height: 1;
        }

        .form-card,
        .note-card,
        .support-card {
            border-radius: 20px;
            overflow: hidden;
        }

        .section-title {
            font-weight: 800;
            color: #172554;
        }

        .section-subtitle {
            color: #64748b;
            font-size: 0.95rem;
        }

        .custom-label {
            font-weight: 800;
            color: #334155;
            margin-bottom: 8px;
        }

        .required {
            color: #dc2626;
        }

        .custom-control {
            border-radius: 14px;
            border: 1px solid #dbe3ef;
            padding: 12px 14px;
            color: #0f172a;
            font-weight: 600;
            transition: all 0.18s ease-in-out;
        }

            .custom-control:focus {
                border-color: #3b82f6;
                box-shadow: 0 0 0 0.2rem rgba(59, 130, 246, 0.12);
            }

        .readonly-control {
            background: #f8fafc;
            color: #64748b;
        }

        textarea.custom-control {
            font-weight: 500;
            line-height: 1.5;
        }

        .form-hint {
            color: #64748b;
            font-size: 0.88rem;
            margin-top: 7px;
        }

        .form-actions {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            padding-top: 8px;
        }

            .form-actions .btn {
                border-radius: 12px;
                font-weight: 800;
                padding: 10px 18px;
            }

        .submit-btn {
            box-shadow: 0 10px 24px rgba(37, 99, 235, 0.18);
        }

        .custom-alert {
            border-radius: 18px;
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 16px 18px;
        }

        .alert-icon {
            font-size: 1.35rem;
            line-height: 1;
        }

        .note-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .note-item {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding-bottom: 16px;
            border-bottom: 1px dashed #e2e8f0;
        }

            .note-item:last-child {
                padding-bottom: 0;
                border-bottom: none;
            }

        .note-icon {
            width: 40px;
            height: 40px;
            border-radius: 14px;
            background: #eff6ff;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .note-title {
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 3px;
        }

        .note-desc {
            color: #64748b;
            font-size: 0.9rem;
            line-height: 1.45;
        }

        .support-card {
            background: linear-gradient(135deg, #eef4ff 0%, #ffffff 100%);
        }

        .support-icon {
            width: 48px;
            height: 48px;
            border-radius: 16px;
            background: #dbeafe;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            margin-bottom: 14px;
        }

        .support-title {
            font-weight: 800;
            color: #172554;
            margin-bottom: 8px;
        }

        .support-desc {
            color: #64748b;
            line-height: 1.55;
        }

        @@media (max-width: 767.98px) {
            .page-title {
                font-size: 1.6rem;
            }

            .hero-action-btn,
            .hero-badge {
                width: 100%;
            }

            .form-actions {
                flex-direction: column-reverse;
            }

                .form-actions .btn {
                    width: 100%;
                }
        }
    </style>
}