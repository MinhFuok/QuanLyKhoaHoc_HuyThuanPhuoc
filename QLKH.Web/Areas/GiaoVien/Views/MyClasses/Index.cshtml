@model IEnumerable<QLKH.Domain.Entities.ClassRoom>

@{
    ViewData["Title"] = "Lớp học của tôi";
    Layout = "~/Views/Shared/_DashBoardLayout.cshtml";

    var today = DateTime.Today;
    var classes = Model?.ToList() ?? new List<QLKH.Domain.Entities.ClassRoom>();

    var totalClasses = classes.Count;
    var activeClasses = classes.Count(x => x.StartDate.Date <= today && x.EndDate.Date >= today);
    var upcomingClasses = classes.Count(x => x.StartDate.Date > today);
    var endedClasses = classes.Count(x => x.EndDate.Date < today);

    var activeClassList = classes
        .Where(x => x.StartDate.Date <= today && x.EndDate.Date >= today)
        .OrderBy(x => x.EndDate)
        .ToList();

    var upcomingClassList = classes
        .Where(x => x.StartDate.Date > today)
        .OrderBy(x => x.StartDate)
        .ToList();

    var endedClassList = classes
        .Where(x => x.EndDate.Date < today)
        .OrderByDescending(x => x.EndDate)
        .ToList();

    var currentTab = Context.Request.Query["tab"].ToString();
    if (string.IsNullOrWhiteSpace(currentTab))
    {
        currentTab = "active";
    }

    var displayClasses = currentTab switch
    {
        "upcoming" => upcomingClassList,
        "ended" => endedClassList,
        _ => activeClassList
    };
}

<div class="teacher-classes-page">

    <!-- Header -->
    <div class="classes-hero card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <h2 class="page-title mb-2">LỚP HỌC CỦA TÔI</h2>
                    <div class="page-eyebrow">GIẢNG DẠY</div>
                </div>

                <div class="hero-badge">
                    <div class="hero-badge-icon">🎓</div>
                    <div>
                        <div class="hero-badge-label">Tổng số lớp</div>
                        <div class="hero-badge-value">@totalClasses</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Content -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 p-4 pb-2">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <h5 class="section-title mb-1">Danh sách lớp được phân công</h5>
                </div>

                <div class="class-filter-note">
                    <span class="status-dot active"></span> Đang diễn ra
                    <span class="status-dot upcoming ms-3"></span> Sắp diễn ra
                    <span class="status-dot ended ms-3"></span> Đã kết thúc
                </div>
            </div>
        </div>

        <div class="card-body p-4">
            <div class="class-tabs mb-4">
                <a asp-area="GiaoVien"
                   asp-controller="MyClasses"
                   asp-action="Index"
                   asp-route-tab="active"
                   class="class-tab @(currentTab == "active" ? "active" : "")">
                    <span>Đang diễn ra</span>
                    <strong>@activeClasses</strong>
                </a>

                <a asp-area="GiaoVien"
                   asp-controller="MyClasses"
                   asp-action="Index"
                   asp-route-tab="upcoming"
                   class="class-tab @(currentTab == "upcoming" ? "active" : "")">
                    <span>Sắp diễn ra</span>
                    <strong>@upcomingClasses</strong>
                </a>

                <a asp-area="GiaoVien"
                   asp-controller="MyClasses"
                   asp-action="Index"
                   asp-route-tab="ended"
                   class="class-tab @(currentTab == "ended" ? "active" : "")">
                    <span>Đã kết thúc</span>
                    <strong>@endedClasses</strong>
                </a>
            </div>

            @if (!classes.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">📭</div>
                    <h5>Chưa có lớp được phân công</h5>
                    <p>
                        Hiện tại bạn chưa được phân công giảng dạy lớp nào.
                        Khi học vụ phân công lớp, danh sách lớp sẽ hiển thị tại đây.
                    </p>
                </div>
            }
            else if (!displayClasses.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">📭</div>

                    @if (currentTab == "upcoming")
                    {
                        <h5>Chưa có lớp sắp diễn ra</h5>
                        <p>
                            Các lớp có ngày bắt đầu trong tương lai sẽ được hiển thị tại đây.
                        </p>
                    }
                    else if (currentTab == "ended")
                    {
                        <h5>Chưa có lớp đã kết thúc</h5>
                        <p>
                            Các lớp đã hoàn thành thời gian giảng dạy sẽ được hiển thị tại đây.
                        </p>
                    }
                    else
                    {
                        <h5>Chưa có lớp đang diễn ra</h5>
                        <p>
                            Các lớp đang trong thời gian giảng dạy sẽ được hiển thị tại đây.
                        </p>
                    }
                </div>
            }
            else
            {
                <div class="table-responsive class-table-wrap">
                    <table class="table class-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="text-center">Mã lớp</th>
                                <th class="text-center">Tên lớp</th>
                                <th class="text-center">Khóa học</th>
                                <th class="text-center">Thời gian</th>
                                <th class="text-center">Trạng thái</th>
                                <th class="text-center">Sĩ số</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in displayClasses)
                            {
                                var statusText = "";
                                var statusClass = "";
                                var isEnded = item.EndDate.Date < today;

                                if (item.StartDate.Date > today)
                                {
                                    statusText = "Sắp diễn ra";
                                    statusClass = "badge-upcoming";
                                }
                                else if (item.EndDate.Date < today)
                                {
                                    statusText = "Đã kết thúc";
                                    statusClass = "badge-ended";
                                }
                                else
                                {
                                    statusText = "Đang diễn ra";
                                    statusClass = "badge-active";
                                }

                                <tr>
                                    <td>
                                        <span class="class-code">@item.ClassCode</span>
                                    </td>

                                    <td>
                                        <div class="class-name">@item.ClassName</div>
                                        <div class="class-small">
                                            GV: @(item.Teacher?.FullName ?? "Chưa cập nhật")
                                        </div>
                                    </td>

                                    <td>
                                        <div class="course-name">
                                            @(item.Course?.CourseName ?? "Chưa có khóa học")
                                        </div>
                                    </td>

                                    <td>
                                        <div class="date-range">
                                            <span>@item.StartDate.ToString("dd/MM/yyyy")</span>
                                            <span class="date-arrow">→</span>
                                            <span>@item.EndDate.ToString("dd/MM/yyyy")</span>
                                        </div>
                                    </td>

                                    <td>
                                        <span class="class-status @statusClass">@statusText</span>
                                    </td>

                                    <td>
                                        <span class="capacity-pill">@item.MaxStudents học viên</span>
                                    </td>

                                    <td class="text-center">
                                        <div class="action-group action-icons">
                                            <a asp-area="GiaoVien"
                                               asp-controller="MyClasses"
                                               asp-action="Students"
                                               asp-route-id="@item.Id"
                                               class="icon-action-btn icon-action-btn--students"
                                               data-tooltip="Danh sách học viên"
                                               aria-label="Danh sách học viên">
                                                <svg viewBox="0 0 24 24" class="action-svg" aria-hidden="true">
                                                    <path d="M8 11C9.65685 11 11 9.65685 11 8C11 6.34315 9.65685 5 8 5C6.34315 5 5 6.34315 5 8C5 9.65685 6.34315 11 8 11Z" />
                                                    <path d="M16 11C17.6569 11 19 9.65685 19 8C19 6.34315 17.6569 5 16 5C14.3431 5 13 6.34315 13 8C13 9.65685 14.3431 11 16 11Z" />
                                                    <path d="M3.5 19C3.5 16.7909 5.51472 15 8 15C10.4853 15 12.5 16.7909 12.5 19" />
                                                    <path d="M11.5 19C11.5 16.7909 13.5147 15 16 15C18.4853 15 20.5 16.7909 20.5 19" />
                                                </svg>
                                            </a>

                                            <a asp-area="GiaoVien"
                                               asp-controller="MyAssignments"
                                               asp-action="Index"
                                               asp-route-classRoomId="@item.Id"
                                               class="icon-action-btn icon-action-btn--assignments"
                                               data-tooltip="Bài tập đã giao"
                                               aria-label="Bài tập đã giao">
                                                <svg viewBox="0 0 24 24" class="action-svg" aria-hidden="true">
                                                    <path d="M8 6H16M8 10H16M8 14H13" />
                                                    <path d="M7 3H17C18.1046 3 19 3.89543 19 5V19C19 20.1046 18.1046 21 17 21H7C5.89543 21 5 20.1046 5 19V5C5 3.89543 5.89543 3 7 3Z" />
                                                </svg>
                                            </a>

                                            <a asp-area="GiaoVien"
                                               asp-controller="ClassGrades"
                                               asp-action="Index"
                                               asp-route-classRoomId="@item.Id"
                                               class="icon-action-btn icon-action-btn--grades"
                                               data-tooltip="Bảng điểm"
                                               aria-label="Bảng điểm">
                                                <svg viewBox="0 0 24 24" class="action-svg" aria-hidden="true">
                                                    <path d="M7 20V10" />
                                                    <path d="M12 20V4" />
                                                    <path d="M17 20V14" />
                                                    <path d="M4 20H20" />
                                                </svg>
                                            </a>

                                            <a asp-area="GiaoVien"
                                               asp-controller="ClassMaterials"
                                               asp-action="Index"
                                               asp-route-classRoomId="@item.Id"
                                               class="icon-action-btn icon-action-btn--materials"
                                               data-tooltip="Tài liệu"
                                               aria-label="Tài liệu">
                                                <svg viewBox="0 0 24 24" class="action-svg" aria-hidden="true">
                                                    <path d="M3 7C3 5.89543 3.89543 5 5 5H9L11 7H19C20.1046 7 21 7.89543 21 9V18C21 19.1046 20.1046 20 19 20H5C3.89543 20 3 19.1046 3 18V7Z" />
                                                </svg>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="class-summary mt-3">
                    <span>Tổng lớp: <strong>@totalClasses</strong></span>
                    <span>Đang diễn ra: <strong>@activeClasses</strong></span>
                    <span>Sắp diễn ra: <strong>@upcomingClasses</strong></span>
                    <span>Đã kết thúc: <strong>@endedClasses</strong></span>
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <style>
        .teacher-classes-page {
            animation: fadeInPage 0.25s ease-in-out;
        }

        @@keyframes fadeInPage {
            from {
                opacity: 0;
                transform: translateY(6px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .classes-hero {
            border-radius: 22px;
            background: linear-gradient(135deg, #f4f8ff 0%, #ffffff 60%, #f8fbff 100%);
            overflow: hidden;
        }

        .page-eyebrow {
            font-size: 0.78rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            color: #3b82f6;
            text-transform: uppercase;
            margin-bottom: 6px;
        }

        .page-title {
            font-size: 2rem;
            font-weight: 800;
            color: #172554;
        }

        .hero-badge {
            min-width: 210px;
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 18px;
            border-radius: 18px;
            background: #ffffff;
            border: 1px solid #e5e7eb;
            box-shadow: 0 10px 25px rgba(15, 23, 42, 0.06);
        }

        .hero-badge-icon {
            width: 48px;
            height: 48px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #eff6ff;
            font-size: 1.4rem;
        }

        .hero-badge-label {
            color: #64748b;
            font-size: 0.9rem;
        }

        .hero-badge-value {
            color: #172554;
            font-size: 1.7rem;
            font-weight: 800;
            line-height: 1;
        }

        .class-stat-card {
            border-radius: 20px;
            overflow: hidden;
        }

            .class-stat-card .card-body {
                display: flex;
                align-items: center;
                gap: 16px;
                padding: 20px;
            }

        .stat-icon {
            width: 52px;
            height: 52px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.45rem;
            flex-shrink: 0;
        }

        .stat-total {
            background: linear-gradient(135deg, #eef4ff 0%, #ffffff 100%);
            border-left: 5px solid #2563eb !important;
        }

            .stat-total .stat-icon {
                background: #dbeafe;
            }

        .stat-active {
            background: linear-gradient(135deg, #ecfdf5 0%, #ffffff 100%);
            border-left: 5px solid #16a34a !important;
        }

            .stat-active .stat-icon {
                background: #dcfce7;
            }

        .stat-upcoming {
            background: linear-gradient(135deg, #fff7ed 0%, #ffffff 100%);
            border-left: 5px solid #f59e0b !important;
        }

            .stat-upcoming .stat-icon {
                background: #ffedd5;
            }

        .stat-ended {
            background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);
            border-left: 5px solid #64748b !important;
        }

            .stat-ended .stat-icon {
                background: #e2e8f0;
            }

        .stat-label {
            color: #64748b;
            font-weight: 600;
            font-size: 0.93rem;
            margin-bottom: 4px;
        }

        .stat-value {
            color: #0f172a;
            font-size: 2rem;
            font-weight: 800;
            line-height: 1;
        }

        .section-title {
            font-weight: 800;
            color: #172554;
        }

        .class-filter-note {
            color: #64748b;
            font-size: 0.9rem;
            white-space: nowrap;
        }

        .status-dot {
            display: inline-block;
            width: 9px;
            height: 9px;
            border-radius: 50%;
            margin-right: 5px;
        }

            .status-dot.active {
                background: #16a34a;
            }

            .status-dot.upcoming {
                background: #f59e0b;
            }

            .status-dot.ended {
                background: #64748b;
            }

        .class-tabs {
            display: inline-flex;
            gap: 8px;
            padding: 6px;
            border-radius: 16px;
            background: #f1f5f9;
            border: 1px solid #e5e7eb;
            flex-wrap: wrap;
        }

        .class-tab {
            min-width: 165px;
            display: inline-flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 10px 14px;
            border-radius: 12px;
            color: #475569;
            text-decoration: none;
            font-weight: 800;
            transition: all 0.18s ease-in-out;
        }

            .class-tab:hover {
                color: #1d4ed8;
                background: #ffffff;
            }

            .class-tab.active {
                color: #ffffff;
                background: #2563eb;
                box-shadow: 0 8px 18px rgba(37, 99, 235, 0.22);
            }

            .class-tab strong {
                min-width: 28px;
                height: 24px;
                padding: 0 8px;
                border-radius: 999px;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                background: rgba(255, 255, 255, 0.85);
                color: #1d4ed8;
                font-size: 0.82rem;
            }

            .class-tab.active strong {
                background: rgba(255, 255, 255, 0.95);
                color: #1d4ed8;
            }

        .class-table-wrap {
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            overflow: hidden;
        }

        .class-table {
            background: #ffffff;
        }

            .class-table thead th {
                background: #f8fafc;
                color: #475569;
                font-size: 0.85rem;
                text-transform: uppercase;
                letter-spacing: 0.04em;
                border-bottom: 1px solid #e5e7eb;
                padding: 14px 16px;
                white-space: nowrap;
            }

            .class-table tbody td {
                padding: 16px;
                border-bottom: 1px solid #eef2f7;
                vertical-align: middle;
            }

            .class-table tbody tr:last-child td {
                border-bottom: none;
            }

            .class-table tbody tr {
                transition: all 0.18s ease-in-out;
            }

                .class-table tbody tr:hover {
                    background: #f8fbff;
                }

        .class-code {
            display: inline-flex;
            align-items: center;
            padding: 7px 10px;
            border-radius: 999px;
            background: #eff6ff;
            color: #1d4ed8;
            font-weight: 800;
            font-size: 0.88rem;
            white-space: nowrap;
        }

        .class-name {
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 3px;
        }

        .class-small {
            color: #64748b;
            font-size: 0.88rem;
        }

        .course-name {
            color: #334155;
            font-weight: 600;
            min-width: 150px;
        }

        .date-range {
            display: flex;
            align-items: center;
            gap: 6px;
            color: #334155;
            font-weight: 600;
            white-space: nowrap;
        }

        .date-arrow {
            color: #94a3b8;
        }

        .class-status {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 7px 11px;
            border-radius: 999px;
            font-weight: 800;
            font-size: 0.82rem;
            white-space: nowrap;
        }

        .badge-active {
            color: #166534;
            background: #dcfce7;
        }

        .badge-upcoming {
            color: #92400e;
            background: #ffedd5;
        }

        .badge-ended {
            color: #475569;
            background: #e2e8f0;
        }

        .capacity-pill {
            display: inline-flex;
            align-items: center;
            padding: 7px 10px;
            border-radius: 999px;
            background: #f1f5f9;
            color: #334155;
            font-weight: 700;
            white-space: nowrap;
        }

        .action-group {
            display: flex;
            justify-content: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .action-icons {
            min-width: 170px;
        }

        .icon-action-btn {
            position: relative;
            width: 36px;
            height: 36px;
            border: 1px solid #d7dee8;
            border-radius: 11px;
            background: #ffffff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            transition: all 0.18s ease;
            box-shadow: 0 4px 12px rgba(15, 23, 42, 0.06);
            cursor: pointer;
        }

            .icon-action-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 20px rgba(15, 23, 42, 0.12);
            }

        .action-svg {
            width: 17px;
            height: 17px;
            fill: none;
            stroke: currentColor;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .icon-action-btn--students {
            color: #2563eb;
            border-color: rgba(37, 99, 235, 0.22);
            background: rgba(37, 99, 235, 0.06);
        }

        .icon-action-btn--assignments {
            color: #059669;
            border-color: rgba(5, 150, 105, 0.22);
            background: rgba(5, 150, 105, 0.06);
        }

        .icon-action-btn--grades {
            color: #d97706;
            border-color: rgba(217, 119, 6, 0.24);
            background: rgba(217, 119, 6, 0.08);
        }

        .icon-action-btn--materials {
            color: #7c3aed;
            border-color: rgba(124, 58, 237, 0.22);
            background: rgba(124, 58, 237, 0.06);
        }

        .icon-action-btn--disabled {
            color: #94a3b8;
            border-color: #e2e8f0;
            background: #f8fafc;
            cursor: not-allowed;
            box-shadow: none;
        }

            .icon-action-btn--disabled:hover {
                transform: none;
                box-shadow: none;
            }

        .icon-action-btn::after {
            content: attr(data-tooltip);
            position: absolute;
            left: 50%;
            bottom: calc(100% + 9px);
            transform: translateX(-50%) translateY(4px);
            padding: 7px 9px;
            border-radius: 8px;
            background: rgba(15, 23, 42, 0.96);
            color: #ffffff;
            font-size: 0.75rem;
            font-weight: 700;
            white-space: nowrap;
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
            transition: all 0.16s ease;
            z-index: 20;
        }

        .icon-action-btn::before {
            content: "";
            position: absolute;
            left: 50%;
            bottom: calc(100% + 4px);
            transform: translateX(-50%);
            border-width: 5px;
            border-style: solid;
            border-color: rgba(15, 23, 42, 0.96) transparent transparent transparent;
            opacity: 0;
            visibility: hidden;
            transition: all 0.16s ease;
            z-index: 19;
        }

        .icon-action-btn:hover::after,
        .icon-action-btn:hover::before {
            opacity: 1;
            visibility: visible;
            transform: translateX(-50%) translateY(0);
        }

        .class-summary {
            display: flex;
            justify-content: flex-end;
            gap: 14px;
            flex-wrap: wrap;
            color: #64748b;
            font-size: 0.92rem;
        }

            .class-summary strong {
                color: #172554;
            }

        .empty-state {
            text-align: center;
            padding: 50px 20px;
            background: #f8fafc;
            border: 1px dashed #cbd5e1;
            border-radius: 18px;
        }

        .empty-icon {
            font-size: 3rem;
            margin-bottom: 12px;
        }

        .empty-state h5 {
            color: #172554;
            font-weight: 800;
            margin-bottom: 8px;
        }

        .empty-state p {
            color: #64748b;
            max-width: 520px;
            margin: 0 auto;
        }

        @@media (max-width: 1199.98px) {
            .class-filter-note {
                white-space: normal;
            }

            .class-table {
                min-width: 1080px;
            }

            .class-table-wrap {
                overflow-x: auto;
            }
        }

        @@media (max-width: 767.98px) {
            .page-title {
                font-size: 1.6rem;
            }

            .hero-badge {
