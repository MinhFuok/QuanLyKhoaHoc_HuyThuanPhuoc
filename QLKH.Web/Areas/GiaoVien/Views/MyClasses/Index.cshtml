@model IEnumerable<QLKH.Domain.Entities.ClassRoom>

@{
    ViewData["Title"] = "Lớp tôi dạy";
}

<h2>Lớp tôi dạy</h2>

@if (!Model.Any())
{
    <div class="alert alert-warning">
        Hiện tại bạn chưa được phân công lớp nào.
    </div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Mã lớp</th>
                <th>Tên lớp</th>
                <th>Khóa học</th>
                <th>Giáo viên</th>
                <th>Ngày bắt đầu</th>
                <th>Ngày kết thúc</th>
                <th>Sĩ số tối đa</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ClassCode</td>
                    <td>@item.ClassName</td>
                    <td>@item.Course?.CourseName</td>
                    <td>@item.Teacher?.FullName</td>
                    <td>@item.StartDate.ToString("dd/MM/yyyy")</td>
                    <td>@item.EndDate.ToString("dd/MM/yyyy")</td>
                    <td>@item.MaxStudents</td>
                </tr>
            }
        </tbody>
    </table>
}