@model QLKH.Web.Areas.HocVu.Models.StudentCertificateViewModel

@{
    ViewData["Title"] = "Cập nhật chứng chỉ học viên";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/HocVuProfession.css" asp-append-version="true" />
}

<div class="course-page admin-profession-page student-certificate-page">
    <div class="cp-header">
        <div class="cp-header-left">
            <h1 class="cp-title">CẬP NHẤT CHỨNG CHỈ HỌC VIÊN</h1>
        </div>

        <a asp-area="HocVu"
           asp-controller="StudentCertificate"
           asp-action="Index"
           class="cp-btn cp-btn--ghost">
            ←Quay lại
        </a>
    </div>

    <form asp-area="HocVu"
          asp-controller="StudentCertificate"
          asp-action="Edit"
          method="post"
          enctype="multipart/form-data"
          id="studentCertificateForm"
          data-admin-form
          data-loading-text="Đang cập nhật..."
          class="cp-form-card">

        <input asp-for="Id" type="hidden" />

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
            <div asp-validation-summary="All" class="cp-validation-summary"></div>
        }

        <div class="cp-form-group-label">Thông tin chính</div>
        <div class="cp-form-row">
            <div class="cp-field">
                <label asp-for="StudentId" class="cp-label"></label>
                <select asp-for="StudentId" asp-items="Model.StudentOptions" class="cp-input cp-select">
                    <option value="">-- Chọn học viên --</option>
                </select>
                <span asp-validation-for="StudentId" class="cp-field-error"></span>
            </div>

            <div class="cp-field">
                <label asp-for="CertificateName" class="cp-label"></label>
                <input asp-for="CertificateName" class="cp-input" placeholder="VD: Chứng chỉ Tin học văn phòng" />
                <span asp-validation-for="CertificateName" class="cp-field-error"></span>
            </div>
            <div class="cp-field">
                <label asp-for="CertificateCode" class="cp-label"></label>
                <input asp-for="CertificateCode" class="cp-input" placeholder="Nhập mã hoặc số chứng chỉ" />
                <span asp-validation-for="CertificateCode" class="cp-field-error"></span>
            </div>
        </div>

        <div class="cp-form-row">

            <div class="cp-field">
                <label asp-for="IssuedDate" class="cp-label"></label>
                <input asp-for="IssuedDate" type="date" class="cp-input" />
                <span asp-validation-for="IssuedDate" class="cp-field-error"></span>
            </div>
            <div class="cp-field">
                <label asp-for="ExpiryDate" class="cp-label">Ngày hết hạn</label>
                <input asp-for="ExpiryDate" type="date" class="cp-input" />
                <span asp-validation-for="ExpiryDate" class="cp-field-error"></span>
                <small class="text-muted">Để trống nếu không thời hạn.</small>
            </div>
            <div class="cp-field">
                <label asp-for="IssuedBy" class="cp-label"></label>
                <input asp-for="IssuedBy" class="cp-input" placeholder="VD: Trung tâm khảo thí ABC" />
                <span asp-validation-for="IssuedBy" class="cp-field-error"></span>
            </div>
        </div>
        <div class="cp-field cp-field--full">
            <label asp-for="EvidenceFile" class="cp-label"></label>
            <div class="cp-file-picker">
                <input asp-for="EvidenceFile"
                       type="file"
                       accept=".jpg,.jpeg,.png,.pdf"
                       class="cp-file-input"
                       data-cp-file-input
                       data-cp-file-target="studentCertificateFileName" />
                <label asp-for="EvidenceFile" class="cp-btn cp-btn--ghost">Chọn file mới</label>
                <span id="studentCertificateFileName" class="cp-file-name">Giữ file hiện tại nếu không chọn file mới</span>
            </div>
            <span class="cp-form-hint">Chấp nhận file `.jpg`, `.jpeg`, `.png`, `.pdf`.</span>
            <span asp-validation-for="EvidenceFile" class="cp-field-error"></span>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ExistingEvidenceFilePath))
        {
            <div class="cp-current-file">
                <span class="cp-current-file-label">File hiện tại</span>
                <a href="@Model.ExistingEvidenceFilePath" target="_blank" rel="noopener noreferrer" class="cp-file-link">
                    Xem file hiện tại
                </a>
            </div>
        }

        <div class="cp-field cp-field--full">
            <label asp-for="Note" class="cp-label"></label>
            <textarea asp-for="Note" class="cp-input cp-textarea" rows="4" placeholder="Ghi chú thêm về chứng chỉ, kết quả hoặc tình trạng xác minh"></textarea>
            <span asp-validation-for="Note" class="cp-field-error"></span>
        </div>

        <div class="cp-form-group-label">Xác nhận</div>
        <div class="cp-switch-card">
            <label class="cp-switch">
                <input asp-for="IsApproved" class="cp-switch-input" />
                <span class="cp-switch-slider"></span>
                <span class="cp-switch-content">
                    <span class="cp-switch-title">Đã xác nhận</span>
                    <span class="cp-switch-subtitle">Tắt nếu chứng chỉ vẫn đang chờ kiểm tra.</span>
                </span>
            </label>
        </div>

        <div class="cp-form-actions">
            <button type="submit" class="cp-btn cp-btn--warning">Cập nhật thay đổi</button>
            <a asp-area="HocVu"
               asp-controller="StudentCertificate"
               asp-action="Index"
               class="cp-btn cp-btn--ghost">
                Hủy
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/HocVuProfession.js" asp-append-version="true"></script>
}

