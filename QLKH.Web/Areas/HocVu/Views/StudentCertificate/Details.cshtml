@model QLKH.Domain.Entities.StudentCertificate

@{
    ViewData["Title"] = "Chi tiết chứng chỉ học viên";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/AdminProfession.css" asp-append-version="true" />
}

<div class="course-page admin-profession-page student-certificate-page">
    <div class="cp-header">
        <div class="cp-header-left">
            <h1 class="cp-title">THÔNG TIN CHI TIẾT</h1>
        </div>

        <a asp-area="HocVu"
           asp-controller="StudentCertificate"
           asp-action="Index"
           class="cp-btn cp-btn--ghost">
            ←Quay lại
        </a>
    </div>

    <div class="cp-delete-card">
        <div class="cp-detail-body">
            <div class="cp-detail-row">
                <div class="cp-detail-label">Học viên</div>
                <div class="cp-detail-value">
                    <strong>@(Model.Student?.FullName ?? "Chưa có học viên")</strong>
                </div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Tên chứng chỉ</div>
                <div class="cp-detail-value">@Model.CertificateName</div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Mã/Số chứng chỉ</div>
                <div class="cp-detail-value">
                    @(!string.IsNullOrWhiteSpace(Model.CertificateCode) ? Model.CertificateCode : "Chưa có")
                </div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Ngày cấp</div>
                <div class="cp-detail-value">
                    @(Model.IssuedDate?.ToString("dd/MM/yyyy") ?? "Chưa có")
                </div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Ngày hết hạn</div>
                <div class="cp-detail-value">
                    @if (Model.ExpiryDate.HasValue)
                    {
                        if (Model.ExpiryDate.Value.Date < DateTime.Today)
                        {
                            <span>@Model.ExpiryDate.Value.ToString("dd/MM/yyyy")</span>
                            <span class="cp-muted"> - Đã hết hạn</span>
                        }
                        else
                        {
                            <span>@Model.ExpiryDate.Value.ToString("dd/MM/yyyy")</span>
                            <span class="cp-muted"> - Còn hiệu lực</span>
                        }
                    }
                    else
                    {
                        <span>Không thời hạn</span>
                    }
                </div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Đơn vị cấp</div>
                <div class="cp-detail-value">
                    @(!string.IsNullOrWhiteSpace(Model.IssuedBy) ? Model.IssuedBy : "Chưa có")
                </div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Trạng thái</div>
                <div class="cp-detail-value">
                    <div class="cp-status-surface cp-status-surface--@(Model.IsApproved ? "confirmed" : "pending")">
                        <span class="cp-badge cp-badge--@(Model.IsApproved ? "confirmed" : "pending")">
                            @(Model.IsApproved ? "Đã xác nhận" : "Chờ xác nhận")
                        </span>
                    </div>
                </div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Minh chứng</div>
                <div class="cp-detail-value">
                    @if (!string.IsNullOrWhiteSpace(Model.EvidenceFilePath))
                    {
                        <a href="@Model.EvidenceFilePath"
                           target="_blank"
                           rel="noopener noreferrer"
                           class="cp-file-link">
                            Xem file minh chứng
                        </a>
                    }
                    else
                    {
                        <span class="cp-muted">Không có file minh chứng</span>
                    }
                </div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Ghi chú</div>
                <div class="cp-detail-value">
                    @(!string.IsNullOrWhiteSpace(Model.Note) ? Model.Note : "Không có ghi chú")
                </div>
            </div>
        </div>

        <div class="cp-delete-actions">
            <a asp-area="HocVu"
               asp-controller="StudentCertificate"
               asp-action="Edit"
               asp-route-id="@Model.Id"
               class="cp-btn cp-btn--warning">
                Chỉnh sửa
            </a>

            <a asp-area="HocVu"
               asp-controller="StudentCertificate"
               asp-action="Index"
               class="cp-btn cp-btn--ghost">
                Hủy
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/AdminProfession.js" asp-append-version="true"></script>
}