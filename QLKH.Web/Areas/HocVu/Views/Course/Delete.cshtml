@model QLKH.Domain.Entities.Course

@{
    ViewData["Title"] = "Xóa khóa học";
}

@section Styles {
    <link rel="stylesheet" href="~/css/AdminProfession.css" asp-append-version="true" />
}

<div class="course-page admin-profession-page course-delete-page">
    <div class="cp-header">
        <div class="cp-header-left">
            <h1 class="cp-title">Xóa khóa học</h1>
            <p class="cp-subtitle">Kiểm tra lại thông tin trước khi xóa khóa học khỏi hệ thống.</p>
        </div>

        <a asp-area="HocVu"
           asp-controller="Course"
           asp-action="Index"
           class="cp-btn cp-btn--ghost">
            Quay lại
        </a>
    </div>

    <div class="cp-form-card">
        <div class="cp-delete-warning">
            <h3 class="cp-section-title text-danger">Xác nhận xóa</h3>
            <p class="cp-subtitle" style="margin-bottom:0;">
                Bạn có chắc chắn muốn xóa khóa học này không? Hành động này có thể ảnh hưởng đến dữ liệu liên quan.
            </p>
        </div>

        <div class="cp-form-group-label">Thông tin khóa học</div>

        <div class="cp-detail-grid">
            <div class="cp-detail-item">
                <span class="cp-detail-label">Mã khóa học</span>
                <span class="cp-detail-value">@Model.CourseCode</span>
            </div>

            <div class="cp-detail-item">
                <span class="cp-detail-label">Tên khóa học</span>
                <span class="cp-detail-value">@Model.CourseName</span>
            </div>

            <div class="cp-detail-item">
                <span class="cp-detail-label">Thời lượng</span>
                <span class="cp-detail-value">@Model.DurationInMonths tháng</span>
            </div>

            <div class="cp-detail-item">
                <span class="cp-detail-label">Học phí</span>
                <span class="cp-detail-value">@Model.Fee.ToString("N0") ₫</span>
            </div>

            <div class="cp-detail-item" style="grid-column: 1 / -1;">
                <span class="cp-detail-label">Mô tả</span>
                <span class="cp-detail-value">@(string.IsNullOrWhiteSpace(Model.Description) ? "Không có mô tả" : Model.Description)</span>
            </div>

            <div class="cp-detail-item">
                <span class="cp-detail-label">Trạng thái</span>
                <span class="cp-detail-value">
                    <span class="cp-badge cp-badge--@Model.Status.ToString().ToLower()">
                        @Model.Status
                    </span>
                </span>
            </div>
        </div>

        <form asp-area="HocVu"
              asp-controller="Course"
              asp-action="Delete"
              method="post"
              class="cp-form-actions">
            <input type="hidden" asp-for="Id" />

            <button type="submit" class="cp-btn cp-btn--danger">
                Xóa khóa học
            </button>

            <a asp-area="HocVu"
               asp-controller="Course"
               asp-action="Index"
               class="cp-btn cp-btn--ghost">
                Hủy
            </a>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/AdminProfession.js" asp-append-version="true"></script>
}