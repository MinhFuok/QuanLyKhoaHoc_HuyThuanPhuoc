@model QLKH.Application.ViewModels.CourseDeleteImpactViewModel

@{
    ViewData["Title"] = "Xóa khóa học";
}

@section Styles {
    <link rel="stylesheet" href="~/css/AdminProfession.css" asp-append-version="true" />
    <style>
        .delete-impact-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(220px, 1fr));
            gap: 14px;
        }

        .delete-impact-item {
            padding: 14px 16px;
            border-radius: 14px;
            background: rgba(255,255,255,.03);
            border: 1px solid rgba(255,255,255,.08);
        }

        .delete-impact-title {
            font-size: 13px;
            color: #aeb3d1;
            margin-bottom: 6px;
        }

        .delete-impact-value {
            color: #fff;
            font-size: 24px;
            font-weight: 700;
        }

        .delete-warning-box {
            margin-top: 18px;
            padding: 16px 18px;
            border-radius: 14px;
            background: rgba(255, 99, 99, .08);
            border: 1px solid rgba(255, 99, 99, .18);
        }
    </style>
}

<div class="course-page admin-profession-page classroom-page">
    <div class="cp-header">
        <div class="cp-header-left">
            <h1 class="cp-title">XÓA KHÓA HỌC</h1>
        </div>

        <a asp-area="HocVu" asp-controller="Course" asp-action="Index" class="cp-btn cp-btn--ghost">←Quay lại</a>
    </div>

    <form asp-area="HocVu" asp-controller="Course" asp-action="Delete" method="post" class="cp-form-card">
        <input type="hidden" name="courseId" value="@Model.CourseId" />

        <div class="cp-form-group-label">Các dữ liệu sẽ bị ảnh hưởng</div>

        <div class="delete-impact-grid">
            <div class="delete-impact-item">
                <div class="delete-impact-title">Lớp học</div>
                <div class="delete-impact-value">@Model.ClassRoomCount</div>
            </div>

            <div class="delete-impact-item">
                <div class="delete-impact-title">Ghi danh</div>
                <div class="delete-impact-value">@Model.EnrollmentCount</div>
            </div>

            <div class="delete-impact-item">
                <div class="delete-impact-title">Lịch học</div>
                <div class="delete-impact-value">@Model.ScheduleCount</div>
            </div>

            <div class="delete-impact-item">
                <div class="delete-impact-title">Tài liệu</div>
                <div class="delete-impact-value">@Model.MaterialCount</div>
            </div>

            <div class="delete-impact-item">
                <div class="delete-impact-title">Bài tập</div>
                <div class="delete-impact-value">@Model.AssignmentCount</div>
            </div>

            <div class="delete-impact-item">
                <div class="delete-impact-title">Bài nộp</div>
                <div class="delete-impact-value">@Model.SubmissionCount</div>
            </div>

            <div class="delete-impact-item">
                <div class="delete-impact-title">Đánh giá giảng viên</div>
                <div class="delete-impact-value">@Model.ReviewCount</div>
            </div>
        </div>

        <div class="delete-warning-box">
            <strong>Cảnh báo:</strong>
            Khi xác nhận xóa, hệ thống sẽ xóa khóa học này và toàn bộ dữ liệu con đang liên quan.
            Hãy cân nhắc kỹ trước khi tiếp tục.
        </div>

        <div class="cp-form-row" style="margin-top:18px; width:100%;">
            <div class="cp-field" style="width:100% !important; max-width:100% !important; flex:0 0 100% !important;">
                <label style="display:flex; gap:8px; align-items:center; width:100%;">
                    <input type="checkbox" name="confirmCascadeDelete" value="true" />
                    <span>Tôi hiểu rằng thao tác này sẽ xóa cả dữ liệu liên quan.</span>
                </label>
            </div>
        </div>

        <div class="cp-form-actions">
            <button type="submit"
                    class="cp-btn cp-btn--danger"
                    onclick="return confirm('Bạn có chắc chắn muốn xóa khóa học này và toàn bộ dữ liệu liên quan không?');">
                Xác nhận xóa
            </button>

            <a asp-area="HocVu" asp-controller="Course" asp-action="Index" class="cp-btn cp-btn--ghost">
                Hủy
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/AdminProfession.js" asp-append-version="true"></script>
}