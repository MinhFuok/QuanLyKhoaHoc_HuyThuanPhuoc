@model QLKH.Domain.Entities.Course

@{
    ViewData["Title"] = "Chi tiết khóa học";
    Layout = "~/Views/Shared/_DashBoardLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/HocVuProfession.css" asp-append-version="true" />
}

<div class="course-page course-details">

    <div class="cp-header">
        <div class="cp-header-left">
            <h1 class="cp-title">THÔNG TIN CHI TIẾT</h1>
        </div>
        <a asp-area="HocVu" asp-controller="Course" asp-action="Index" class="cp-btn cp-btn--ghost">← Quay lại</a>
    </div>

    <div class="cp-detail-card">

        <div class="cp-detail-hero">
            <div class="cp-detail-hero-left">
                <span class="cp-code cp-code--lg">@Model.CourseCode</span>
                <h2 class="cp-detail-name">@Model.CourseName</h2>
            </div>
            <span class="cp-badge cp-badge--lg cp-badge--@Model.Status.ToString().ToLower()">
                @Model.Status
            </span>
        </div>

        <div class="cp-detail-body">
            <div class="cp-detail-row">
                <span class="cp-detail-label">Mô tả</span>
                <span class="cp-detail-value">@(string.IsNullOrWhiteSpace(Model.Description) ? "—" : Model.Description)</span>
            </div>
            <div class="cp-detail-row">
                <span class="cp-detail-label">Thời lượng</span>
                <span class="cp-detail-value"><strong>@Model.DurationInMonths</strong> tháng</span>
            </div>
            <div class="cp-detail-row">
                <span class="cp-detail-label">Học phí</span>
                <span class="cp-detail-value cp-fee-lg">@Model.Fee.ToString("N0") ₫</span>
            </div>
        </div>

        <div class="cp-detail-footer">
            <a asp-area="HocVu" asp-controller="Course" asp-action="Edit" asp-route-id="@Model.Id" class="cp-btn cp-btn--warning">Chỉnh sửa</a>
            <a asp-area="HocVu" asp-controller="Course" asp-action="Index" class="cp-btn cp-btn--ghost">Hủy</a>
        </div>

    </div>

</div>

@section Scripts {
    <script src="~/js/HocVuProfession.js" asp-append-version="true"></script>
}

