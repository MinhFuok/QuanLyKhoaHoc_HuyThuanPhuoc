@model IEnumerable<QLKH.Domain.Entities.Enrollment>
@using QLKH.Domain.Enums

@{
    ViewData["Title"] = "Danh sách ghi danh";

    var enrollments = Model ?? Enumerable.Empty<QLKH.Domain.Entities.Enrollment>();

    var pendingList = enrollments.Where(x => x.Status == EnrollmentStatus.Pending).ToList();
    var confirmedList = enrollments.Where(x => x.Status == EnrollmentStatus.Confirmed).ToList();
    var cancelledList = enrollments.Where(x => x.Status == EnrollmentStatus.Cancelled).ToList();
}

@section Styles {
    <link rel="stylesheet" href="~/css/AdminProfession.css" asp-append-version="true" />
}

<div class="course-page admin-profession-page enrollment-page">
    <div class="cp-header">
        <div class="cp-header-left">
            <h1 class="cp-title">Danh sách ghi danh</h1>
            <p class="cp-subtitle">Quản lý ghi danh theo 3 trạng thái: chờ xác nhận, đã xác nhận và đã hủy.</p>
        </div>

        <a asp-area="HocVu" asp-controller="Enrollment" asp-action="Create" class="cp-btn cp-btn--primary">+ Thêm mới</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success mb-3">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger mb-3">@TempData["ErrorMessage"]</div>
    }

    <ul class="nav nav-tabs mb-4" id="enrollmentTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="pending-tab" data-bs-toggle="tab" data-bs-target="#pending-pane" type="button" role="tab">
                Pending (@pendingList.Count)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="confirmed-tab" data-bs-toggle="tab" data-bs-target="#confirmed-pane" type="button" role="tab">
                Confirmed (@confirmedList.Count)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="cancelled-tab" data-bs-toggle="tab" data-bs-target="#cancelled-pane" type="button" role="tab">
                Cancelled (@cancelledList.Count)
            </button>
        </li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade show active" id="pending-pane" role="tabpanel">
            @await Html.PartialAsync("_EnrollmentTablePartial", pendingList)
        </div>

        <div class="tab-pane fade" id="confirmed-pane" role="tabpanel">
            @await Html.PartialAsync("_EnrollmentTablePartial", confirmedList)
        </div>

        <div class="tab-pane fade" id="cancelled-pane" role="tabpanel">
            @await Html.PartialAsync("_EnrollmentTablePartial", cancelledList)
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/AdminProfession.js" asp-append-version="true"></script>
}