@model IEnumerable<QLKH.Domain.Entities.Enrollment>
@using QLKH.Domain.Enums
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Danh sách ghi danh";

    var selectedClassRoomId = ViewBag.SelectedClassRoomId as int?;
    var classRoomFilter = ViewBag.ClassRoomFilter as SelectList;
    var activeTab = ViewBag.ActiveTab as string;

    var pendingList = Model?.Where(x => x.Status == EnrollmentStatus.Pending).ToList()
                      ?? new List<QLKH.Domain.Entities.Enrollment>();

    var confirmedList = Model?.Where(x => x.Status == EnrollmentStatus.Confirmed).ToList()
                        ?? new List<QLKH.Domain.Entities.Enrollment>();

    var cancelledList = Model?.Where(x => x.Status == EnrollmentStatus.Cancelled).ToList()
                        ?? new List<QLKH.Domain.Entities.Enrollment>();

    var pendingActive = string.IsNullOrWhiteSpace(activeTab) || activeTab == "pending";
    var confirmedActive = activeTab == "confirmed";
    var cancelledActive = activeTab == "cancelled";
}

@section Styles {
    <link rel="stylesheet" href="~/css/AdminProfession.css" asp-append-version="true" />

    <style>
        .enrollment-filter-card {
            padding: 18px 20px;
            border-radius: 18px;
            background: rgba(20, 8, 42, 0.78);
            border: 1px solid rgba(168, 85, 247, 0.28);
            box-shadow: 0 18px 40px rgba(15, 23, 42, 0.14);
        }

        .enrollment-filter-form {
            margin: 0;
        }

        .filter-main {
            display: flex;
            align-items: flex-end;
            gap: 14px;
            flex-wrap: wrap;
        }

        .filter-field {
            flex: 1;
            min-width: 260px;
        }

        .filter-label {
            display: block;
            color: #c4b5fd;
            font-weight: 800;
            margin-bottom: 8px;
        }

        .filter-select {
            width: 100%;
            min-height: 48px;
            border-radius: 12px;
            padding: 10px 14px;
            background: rgba(30, 12, 58, 0.95);
            border: 1px solid rgba(168, 85, 247, 0.45);
            color: #ffffff;
            font-weight: 700;
            outline: none;
        }

            .filter-select:focus {
                border-color: #a855f7;
                box-shadow: 0 0 0 0.2rem rgba(168, 85, 247, 0.16);
            }

        .filter-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

            .filter-actions .cp-btn {
                min-height: 48px;
                justify-content: center;
                white-space: nowrap;
            }

        .active-filter-note {
            margin-top: 12px;
            color: rgba(196, 181, 253, 0.82);
            font-size: 0.92rem;
            font-weight: 700;
        }

        .cp-header-actions {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        @@media (max-width: 767.98px) {
            .filter-main {
                flex-direction: column;
                align-items: stretch;
            }

            .filter-field {
                min-width: 0;
            }

            .filter-actions {
                flex-direction: column;
            }

                .filter-actions .cp-btn,
                .cp-header-actions .cp-btn {
                    width: 100%;
                }

            .cp-header-actions {
                width: 100%;
            }
        }
    </style>
}

<div class="course-page admin-profession-page enrollment-page">
    <div class="cp-header">
        <div class="cp-header-left">
            <h1 class="cp-title">DANH SÁCH HỌC VIÊN GHI DANH</h1>
            <p class="cp-subtitle">
                Quản lý ghi danh học viên theo từng lớp...
            </p>
        </div>

        <div class="cp-header-actions">
            <a asp-area="HocVu"
               asp-controller="Enrollment"
               asp-action="Create"
               class="cp-btn cp-btn--primary">
                + Ghi danh
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success mb-3">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger mb-3">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="enrollment-filter-card mb-4">
        <form method="get"
              asp-area="HocVu"
              asp-controller="Enrollment"
              asp-action="Index"
              class="enrollment-filter-form">

            <div class="filter-main">
                <div class="filter-field">
                    <select name="classRoomId" class="filter-select">
                        <option value="">-- Tất cả lớp --</option>

                        @if (classRoomFilter != null)
                        {
                            foreach (var item in classRoomFilter)
                            {
                                <option value="@item.Value" selected="@item.Selected">
                                    @item.Text
                                </option>
                            }
                        }
                    </select>
                </div>

                <div class="filter-actions">
                    <button type="submit" class="cp-btn cp-btn--primary">
                        Lọc
                    </button>

                    @if (selectedClassRoomId.HasValue)
                    {
                        <a asp-area="HocVu"
                           asp-controller="Enrollment"
                           asp-action="Index"
                           class="cp-btn cp-btn--ghost">
                            Xóa lọc
                        </a>
                    }
                </div>
            </div>
        </form>
    </div>

    <div class="enrollment-tabs-wrap" data-enrollment-tabs>
        <div class="enrollment-tabs" role="tablist" aria-label="Trạng thái ghi danh">
            <button type="button"
                    class="enrollment-tab-btn @(pendingActive ? "active" : "")"
                    data-tab="pendingTab"
                    role="tab"
                    aria-selected="@(pendingActive ? "true" : "false")"
                    aria-controls="pendingTab">
                Chờ duyệt
                <span class="enrollment-count">@pendingList.Count</span>
            </button>

            <button type="button"
                    class="enrollment-tab-btn @(confirmedActive ? "active" : "")"
                    data-tab="confirmedTab"
                    role="tab"
                    aria-selected="@(confirmedActive ? "true" : "false")"
                    aria-controls="confirmedTab">
                Đã xác nhận
                <span class="enrollment-count">@confirmedList.Count</span>
            </button>

            <button type="button"
                    class="enrollment-tab-btn @(cancelledActive ? "active" : "")"
                    data-tab="cancelledTab"
                    role="tab"
                    aria-selected="@(cancelledActive ? "true" : "false")"
                    aria-controls="cancelledTab">
                Đã hủy
                <span class="enrollment-count">@cancelledList.Count</span>
            </button>
        </div>

        <div id="pendingTab"
             class="enrollment-tab-pane @(pendingActive ? "active" : "")"
             role="tabpanel"
             @(pendingActive ? "" : "hidden")>
            @await Html.PartialAsync("_EnrollmentTablePartial", pendingList)
        </div>

        <div id="confirmedTab"
             class="enrollment-tab-pane @(confirmedActive ? "active" : "")"
             role="tabpanel"
             @(confirmedActive ? "" : "hidden")>
            @await Html.PartialAsync("_EnrollmentTablePartial", confirmedList)
        </div>

        <div id="cancelledTab"
             class="enrollment-tab-pane @(cancelledActive ? "active" : "")"
             role="tabpanel"
             @(cancelledActive ? "" : "hidden")>
            @await Html.PartialAsync("_EnrollmentTablePartial", cancelledList)
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/AdminProfession.js" asp-append-version="true"></script>
}