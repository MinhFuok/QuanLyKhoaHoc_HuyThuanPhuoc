@model QLKH.Domain.Entities.Enrollment

@{
    ViewData["Title"] = "Chi tiết ghi danh";
}

@section Styles {
    <link rel="stylesheet" href="~/css/AdminProfession.css" asp-append-version="true" />
}

<div class="course-page admin-profession-page enrollment-page">
    <div class="cp-header">
        <div class="cp-header-left">
            <h1 class="cp-title">Chi tiết ghi danh</h1>
            <p class="cp-subtitle">Thông tin học viên, lớp học và trạng thái ghi danh.</p>
        </div>
    </div>

    <div class="cp-detail-card">
        <div class="cp-detail-hero">
            <div class="cp-detail-hero-left">
                <span class="cp-code cp-code--lg">@Model.EnrolledAt.ToString("dd/MM/yyyy HH:mm")</span>
                <h2 class="cp-detail-name">@Model.Student?.FullName</h2>
            </div>
            <span class="cp-badge cp-badge--lg cp-badge--@Model.Status.ToString().ToLower()">@Model.Status</span>
        </div>

        <div class="cp-detail-body">
            <div class="cp-detail-row">
                <div class="cp-detail-label">Lớp học</div>
                <div class="cp-detail-value">@Model.ClassRoom?.ClassName</div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Khóa học</div>
                <div class="cp-detail-value">@Model.ClassRoom?.Course?.CourseName</div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Giảng viên</div>
                <div class="cp-detail-value">@Model.ClassRoom?.Teacher?.FullName</div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Ngày ghi danh</div>
                <div class="cp-detail-value">@Model.EnrolledAt.ToString("dd/MM/yyyy HH:mm")</div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Trạng thái</div>
                <div class="cp-detail-value"><span class="cp-badge cp-badge--@Model.Status.ToString().ToLower()">@Model.Status</span></div>
            </div>
        </div>

        <div class="cp-detail-footer">
            <a asp-area="HocVu" asp-controller="Enrollment" asp-action="Edit" asp-route-id="@Model.Id" class="cp-btn cp-btn--warning">Sửa</a>
            <a asp-area="HocVu" asp-controller="Enrollment" asp-action="Index" class="cp-btn cp-btn--ghost">Quay lại</a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/AdminProfession.js" asp-append-version="true"></script>
}
