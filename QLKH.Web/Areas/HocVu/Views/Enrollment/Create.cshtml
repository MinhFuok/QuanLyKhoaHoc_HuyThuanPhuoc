@using QLKH.Domain.Entities

@{
    ViewData["Title"] = "Thêm ghi danh";

    var students = ViewBag.Students as IEnumerable<Student> ?? Enumerable.Empty<Student>();
    var classRooms = ViewBag.ClassRooms as IEnumerable<ClassRoom> ?? Enumerable.Empty<ClassRoom>();
    var selectedClassRoomId = ViewBag.SelectedClassRoomId as int?;
}

@section Styles {
    <link rel="stylesheet" href="~/css/AdminProfession.css" asp-append-version="true" />
}

<div class="course-page admin-profession-page enrollment-page">
    <div class="cp-header">
        <div class="cp-header-left">
            <h1 class="cp-title">Thêm ghi danh</h1>
            <p class="cp-subtitle">
                Chọn lớp học, sau đó tích chọn một hoặc nhiều học viên để ghi danh vào lớp.
                Trạng thái ban đầu luôn là chờ xác nhận.
            </p>
        </div>

        <a asp-area="HocVu"
           asp-controller="Enrollment"
           asp-action="Index"
           class="cp-btn cp-btn--ghost">
            Quay lại
        </a>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="cp-validation-summary mb-3">
            <div asp-validation-summary="ModelOnly"></div>
        </div>
    }

    <div class="cp-form-card">
        <form method="get"
              asp-area="HocVu"
              asp-controller="Enrollment"
              asp-action="Create"
              class="mb-4">

            <div class="cp-form-group-label">Lọc theo lớp</div>

            <div class="cp-form-row">
                <div class="cp-field">
                    <label class="cp-label">Lớp học</label>

                    <select name="classRoomId" class="cp-input cp-select">
                        <option value="">-- Chọn lớp học --</option>

                        @foreach (var item in classRooms)
                        {
                            if (selectedClassRoomId.HasValue && selectedClassRoomId.Value == item.Id)
                            {
                                <option value="@item.Id" selected>
                                    @item.ClassName (@item.ClassCode)
                                </option>
                            }
                            else
                            {
                                <option value="@item.Id">
                                    @item.ClassName (@item.ClassCode)
                                </option>
                            }
                        }
                    </select>
                </div>

                <div class="cp-field enrollment-filter-action">
                    <label class="cp-label">&nbsp;</label>
                    <button type="submit" class="cp-btn cp-btn--primary">
                        Lọc học viên
                    </button>
                </div>
            </div>
        </form>

        <form asp-area="HocVu"
              asp-controller="Enrollment"
              asp-action="Create"
              method="post"
              id="enrollmentForm">

            @Html.AntiForgeryToken()

            <input type="hidden" name="classRoomId" value="@selectedClassRoomId" />

            <div class="cp-form-group-label">Danh sách học viên</div>

            @if (!selectedClassRoomId.HasValue)
            {
                <div class="enrollment-empty-state">
                    <div class="enrollment-empty-icon">📌</div>
                    <h5>Vui lòng chọn lớp học</h5>
                    <p>
                        Sau khi chọn lớp học, hệ thống sẽ hiển thị danh sách học viên để ghi danh.
                    </p>
                </div>
            }
            else if (!students.Any())
            {
                <div class="enrollment-empty-state">
                    <div class="enrollment-empty-icon">📭</div>
                    <h5>Không có học viên</h5>
                    <p>
                        Hiện tại chưa có học viên nào để ghi danh.
                    </p>
                </div>
            }
            else
            {
                <div class="enrollment-table-toolbar">
                    <div>
                        <strong>@students.Count()</strong> học viên khả dụng
                    </div>

                    <div class="enrollment-toolbar-note">
                        Có thể chọn nhiều học viên cùng lúc
                    </div>
                </div>

                <div class="table-responsive enrollment-table-wrap">
                    <table class="table enrollment-table align-middle mb-0">
                        <colgroup>
                            <col style="width: 7%;" />
                            <col style="width: 16%;" />
                            <col style="width: 25%;" />
                            <col style="width: 32%;" />
                            <col style="width: 20%;" />
                        </colgroup>

                        <thead>
                            <tr>
                                <th class="text-center">
                                    <input type="checkbox" id="checkAllStudents" />
                                </th>
                                <th>Mã học viên</th>
                                <th>Họ tên</th>
                                <th>Email</th>
                                <th>Số điện thoại</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var student in students)
                            {
                                <tr>
                                    <td class="text-center">
                                        <input type="checkbox"
                                               name="studentIds"
                                               value="@student.Id"
                                               class="student-checkbox" />
                                    </td>

                                    <td>
                                        <span class="student-code">
                                            @student.StudentCode
                                        </span>
                                    </td>

                                    <td>
                                        <div class="student-name">
                                            @student.FullName
                                        </div>
                                    </td>

                                    <td>
                                        <div class="student-email">
                                            @(string.IsNullOrWhiteSpace(student.Email)
                                                                                ? "Chưa cập nhật"
                                                                                : student.Email)
                                                                                            </div>
                                                                                        </td>

                                    <td>
                                        <div class="student-phone">
                                            @(string.IsNullOrWhiteSpace(student.PhoneNumber)
                                                                                ? "Chưa cập nhật"
                                                                                : student.PhoneNumber)
                                </div>
                            </td>
                        </tr>
                                                }
                        </tbody>
                    </table>
                </div>

                <div class="cp-form-group-label mt-4">Trạng thái</div>

                <div class="cp-form-row">
                    <div class="cp-field">
                        <label class="cp-label">Trạng thái ghi danh</label>
                        <input class="cp-input" value="Pending" readonly />
                    </div>
                </div>

                <div class="cp-form-actions">
                    <button type="submit" class="cp-btn cp-btn--primary">
                        Lưu ghi danh
                    </button>

                    <a asp-area="HocVu"
                       asp-controller="Enrollment"
                       asp-action="Index"
                       class="cp-btn cp-btn--ghost">
                        Quay lại
                    </a>
                </div>
            }
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/js/AdminProfession.js" asp-append-version="true"></script>

    <script>
        (function () {
            const checkAll = document.getElementById('checkAllStudents');
            const studentCheckboxes = Array.from(document.querySelectorAll('.student-checkbox'));

            if (!checkAll || !studentCheckboxes.length) return;

            checkAll.addEventListener('change', function () {
                studentCheckboxes.forEach(function (checkbox) {
                    checkbox.checked = checkAll.checked;
                });
            });

            studentCheckboxes.forEach(function (checkbox) {
                checkbox.addEventListener('change', function () {
                    const checkedCount = studentCheckboxes.filter(x => x.checked).length;

                    checkAll.checked = checkedCount === studentCheckboxes.length;
                    checkAll.indeterminate = checkedCount > 0 && checkedCount < studentCheckboxes.length;
                });
            });
        })();
    </script>
}

<style>
    .enrollment-filter-action {
        max-width: 220px;
    }

        .enrollment-filter-action .cp-btn {
            width: 100%;
            justify-content: center;
        }

    .enrollment-table-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        margin-bottom: 14px;
        color: rgba(255, 255, 255, 0.78);
        font-weight: 700;
    }

    .enrollment-toolbar-note {
        color: rgba(196, 181, 253, 0.82);
        font-size: 0.92rem;
    }

    .enrollment-table-wrap {
        border: 1px solid rgba(168, 85, 247, 0.24);
        border-radius: 18px;
        overflow: hidden;
        background: rgba(15, 23, 42, 0.22);
    }

    .enrollment-table {
        color: #ffffff;
        background: transparent;
        width: 100%;
        table-layout: fixed;
    }

        .enrollment-table thead th {
            background: rgba(255, 255, 255, 0.06);
            color: #c4b5fd;
            font-size: 0.82rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            border-bottom: 1px solid rgba(168, 85, 247, 0.32);
            padding: 14px 16px;
            white-space: nowrap;
        }

        .enrollment-table tbody td {
            padding: 15px 16px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
            vertical-align: middle;
        }

        .enrollment-table tbody tr:last-child td {
            border-bottom: none;
        }

        .enrollment-table tbody tr:hover {
            background: rgba(255, 255, 255, 0.04);
        }

    .student-code {
        display: inline-flex;
        align-items: center;
        padding: 7px 10px;
        border-radius: 999px;
        background: rgba(59, 130, 246, 0.16);
        color: #93c5fd;
        font-weight: 900;
        font-size: 0.88rem;
        white-space: nowrap;
    }

    .student-name {
        color: #ffffff;
        font-weight: 900;
        word-break: break-word;
    }

    .student-email,
    .student-phone {
        color: #cbd5e1;
        font-weight: 600;
        word-break: break-word;
    }

    .enrollment-table input[type="checkbox"] {
        width: 18px;
        height: 18px;
        cursor: pointer;
        accent-color: #a855f7;
    }

    .enrollment-empty-state {
        text-align: center;
        padding: 48px 20px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px dashed rgba(168, 85, 247, 0.32);
    }

    .enrollment-empty-icon {
        font-size: 3rem;
        margin-bottom: 10px;
    }

    .enrollment-empty-state h5 {
        color: #ffffff;
        font-weight: 900;
        margin-bottom: 8px;
    }

    .enrollment-empty-state p {
        color: #c4b5fd;
        margin: 0;
    }

    @@media (max-width: 991.98px) {
        .enrollment-filter-action {
            max-width: none;
        }

        .enrollment-table {
            min-width: 900px;
        }

        .enrollment-table-wrap {
            overflow-x: auto;
        }
    }

    @@media (max-width: 767.98px) {
        .enrollment-table-toolbar {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>