@model QLKH.Application.ViewModels.ClassSchedulePickSessionViewModel

@{
    ViewData["Title"] = "Chọn kiểu sửa lịch học";
}

@section Styles {
    <link rel="stylesheet" href="~/css/AdminProfession.css" asp-append-version="true" />
}

<div class="course-page admin-profession-page classroom-page">
    <div class="cp-header">
        <div class="cp-header-left">
            <h1 class="cp-title">Chọn kiểu sửa lịch học</h1>
            <p class="cp-subtitle">Bạn có thể sửa một buổi cụ thể hoặc sửa toàn bộ chuỗi lịch học.</p>
        </div>

        <a asp-area="HocVu" asp-controller="ClassSchedule" asp-action="Index" class="cp-btn cp-btn--ghost">Quay lại</a>
    </div>

    <form asp-area="HocVu" asp-controller="ClassSchedule" asp-action="EditSelect" method="post" class="cp-form-card">
        <input type="hidden" asp-for="AnchorId" />
        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="cp-form-group-label">Thông tin nhóm lịch học</div>

        <div class="cp-form-row">
            <div class="cp-field">
                <label class="cp-label">Lớp học</label>
                <input class="cp-input" value="@Model.ClassName (@Model.ClassCode)" readonly />
            </div>

            <div class="cp-field">
                <label class="cp-label">Khóa học</label>
                <input class="cp-input" value="@Model.CourseName" readonly />
            </div>
        </div>

        <div class="cp-form-row">
            <div class="cp-field">
                <label class="cp-label">Buổi học</label>
                <input class="cp-input" value="@Model.SessionText (@Model.TimeRangeText)" readonly />
            </div>

            <div class="cp-field">
                <label class="cp-label">Tổng số buổi</label>
                <input class="cp-input" value="@Model.TotalSessions" readonly />
            </div>
        </div>

        <div class="cp-form-row">
            <div class="cp-field">
                <label class="cp-label">TeamCode</label>
                <input class="cp-input" value="@Model.TeamCode" readonly />
            </div>

            <div class="cp-field">
                <label class="cp-label">Ghi chú</label>
                <input class="cp-input" value="@Model.Note" readonly />
            </div>
        </div>

        <div class="cp-form-group-label">Chọn kiểu sửa</div>

        <div class="cp-form-row">
            <div class="cp-field" style="flex: 0 0 100%; max-width: 100%;">
                <label style="display:flex; gap:8px; align-items:center; margin-bottom:10px;">
                    <input asp-for="EditAllSessions" id="editAllSessionsCheckbox" />
                    <span>Sửa toàn bộ chuỗi lịch này</span>
                </label>
            </div>
        </div>

        <div class="cp-form-group-label" id="singleEditTitle">Chọn buổi cần sửa</div>
        <div class="cp-form-row" id="singleEditSection">
            <div class="cp-field" style="flex: 0 0 100%; max-width: 100%;">
                <label asp-for="SelectedScheduleId" class="cp-label"></label>
                <select asp-for="SelectedScheduleId" class="cp-input cp-select">
                    <option value="">-- Chọn buổi --</option>
                    @foreach (var item in Model.SessionOptions)
                    {
                        <option value="@item.Id">@item.Text</option>
                    }
                </select>
                <span asp-validation-for="SelectedScheduleId" class="cp-field-error"></span>
            </div>
        </div>

        <div class="cp-form-actions">
            <button type="submit" class="cp-btn cp-btn--primary">Tiếp tục</button>
            <a asp-area="HocVu" asp-controller="ClassSchedule" asp-action="Index" class="cp-btn cp-btn--ghost">Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/AdminProfession.js" asp-append-version="true"></script>
    <script>
        const editAllCheckbox = document.getElementById('editAllSessionsCheckbox');
        const singleEditSection = document.getElementById('singleEditSection');
        const singleEditTitle = document.getElementById('singleEditTitle');

        function toggleEditMode() {
            const editingAll = editAllCheckbox.checked;
            singleEditSection.style.display = editingAll ? 'none' : 'flex';
            singleEditTitle.style.display = editingAll ? 'none' : 'block';
        }

        editAllCheckbox.addEventListener('change', toggleEditMode);
        toggleEditMode();
    </script>
}