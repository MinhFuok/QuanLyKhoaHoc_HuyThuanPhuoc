@model QLKH.Domain.Entities.ClassSchedule

@{
    ViewData["Title"] = "Chi tiết lịch học";

    var sessionText = (Model.StartTime == new TimeSpan(7, 0, 0) && Model.EndTime == new TimeSpan(11, 30, 0))
        ? "Sáng"
        : (Model.StartTime == new TimeSpan(13, 0, 0) && Model.EndTime == new TimeSpan(17, 0, 0))
            ? "Chiều"
            : $"{Model.StartTime:hh\\:mm} - {Model.EndTime:hh\\:mm}";

    var weekDay = Model.StudyDate.DayOfWeek switch
    {
        DayOfWeek.Monday => "Thứ hai",
        DayOfWeek.Tuesday => "Thứ ba",
        DayOfWeek.Wednesday => "Thứ tư",
        DayOfWeek.Thursday => "Thứ năm",
        DayOfWeek.Friday => "Thứ sáu",
        DayOfWeek.Saturday => "Thứ bảy",
        _ => "Chủ nhật"
    };
}
<p class="cp-subtitle">Bạn đang chỉnh sửa một buổi học cụ thể đã được chọn từ nhóm lịch học.</p>
@section Styles {
    <link rel="stylesheet" href="~/css/AdminProfession.css" asp-append-version="true" />
    <style>
        .schedule-detail-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(260px, 1fr));
            gap: 16px;
        }

        .schedule-detail-box {
            padding: 14px 16px;
            border-radius: 14px;
            background: rgba(255,255,255,.03);
            border: 1px solid rgba(255,255,255,.08);
        }

        .schedule-detail-label {
            font-size: 13px;
            color: #aeb3d1;
            margin-bottom: 6px;
        }

        .schedule-detail-value {
            color: #fff;
            font-weight: 600;
        }

        .schedule-session-badge {
            display: inline-flex;
            align-items: center;
            padding: 6px 14px;
            border-radius: 999px;
            background: rgba(122, 92, 255, .16);
            border: 1px solid rgba(122, 92, 255, .28);
            color: #f1edff;
            font-weight: 700;
        }
    </style>
}

<div class="course-page admin-profession-page classroom-page">
    <div class="cp-header">
        <div class="cp-header-left">
            <h1 class="cp-title">Chi tiết lịch học</h1>
            <p class="cp-subtitle">
                Thông tin chi tiết của một buổi học thuộc lớp
                <strong>@(Model.ClassRoom?.ClassName ?? "Chưa xác định")</strong>.
            </p>
        </div>

        <div class="cp-header-actions">
            <a asp-area="HocVu"
               asp-controller="ClassSchedule"
               asp-action="Edit"
               asp-route-id="@Model.Id"
               class="cp-btn cp-btn--warning">
                Sửa
            </a>

            <a asp-area="HocVu"
               asp-controller="ClassSchedule"
               asp-action="Index"
               class="cp-btn cp-btn--ghost">
                Quay lại
            </a>
        </div>
    </div>

    <div class="cp-detail-card">
        <div class="cp-detail-hero">
            <div class="cp-detail-hero-left">
                <span class="cp-code cp-code--lg">@(Model.ClassRoom?.ClassCode ?? "N/A")</span>
                <h2 class="cp-detail-name">@(Model.ClassRoom?.ClassName ?? "Chưa có lớp học")</h2>
                <div class="text-muted" style="margin-top: 6px;">
                    <span class="schedule-session-badge">@sessionText</span>
                </div>
            </div>

            <span class="cp-badge cp-badge--lg">@Model.StudyDate.ToString("dd/MM/yyyy")</span>
        </div>

        <div class="schedule-detail-grid">
            <div class="schedule-detail-box">
                <div class="schedule-detail-label">Khóa học</div>
                <div class="schedule-detail-value">@(Model.ClassRoom?.Course?.CourseName ?? "Không có")</div>
            </div>

            <div class="schedule-detail-box">
                <div class="schedule-detail-label">Giảng viên</div>
                <div class="schedule-detail-value">@(Model.ClassRoom?.Teacher?.FullName ?? "Chưa phân công")</div>
            </div>

            <div class="schedule-detail-box">
                <div class="schedule-detail-label">Ngày học</div>
                <div class="schedule-detail-value">@Model.StudyDate.ToString("dd/MM/yyyy")</div>
            </div>

            <div class="schedule-detail-box">
                <div class="schedule-detail-label">Thứ trong tuần</div>
                <div class="schedule-detail-value">@weekDay</div>
            </div>

            <div class="schedule-detail-box">
                <div class="schedule-detail-label">Buổi học</div>
                <div class="schedule-detail-value">@sessionText</div>
            </div>

            <div class="schedule-detail-box">
                <div class="schedule-detail-label">Khung giờ</div>
                <div class="schedule-detail-value">@Model.StartTime.ToString(@"hh\:mm") - @Model.EndTime.ToString(@"hh\:mm")</div>
            </div>

            <div class="schedule-detail-box">
                <div class="schedule-detail-label">TeamCode</div>
                <div class="schedule-detail-value">@(string.IsNullOrWhiteSpace(Model.RoomName) ? "Chưa cập nhật" : Model.RoomName)</div>
            </div>

            <div class="schedule-detail-box">
                <div class="schedule-detail-label">Ghi chú</div>
                <div class="schedule-detail-value">@(string.IsNullOrWhiteSpace(Model.Note) ? "Không có" : Model.Note)</div>
            </div>
        </div>

        <div class="cp-detail-footer" style="margin-top: 20px;">
            <a asp-area="HocVu"
               asp-controller="ClassSchedule"
               asp-action="Edit"
               asp-route-id="@Model.Id"
               class="cp-btn cp-btn--warning">
                Sửa lịch học
            </a>

            <a asp-area="HocVu"
               asp-controller="ClassSchedule"
               asp-action="Index"
               class="cp-btn cp-btn--ghost">
                Quay lại danh sách
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/AdminProfession.js" asp-append-version="true"></script>
}