@model IEnumerable<QLKH.Domain.Entities.ClassSchedule>

@{
    ViewData["Title"] = "Danh sách lịch học";

    string GetSessionText(TimeSpan start, TimeSpan end)
    {
        if (start == new TimeSpan(7, 0, 0) && end == new TimeSpan(11, 30, 0))
        {
            return "Sáng";
        }

        if (start == new TimeSpan(13, 0, 0) && end == new TimeSpan(17, 0, 0))
        {
            return "Chiều";
        }

        return $"{start:hh\\:mm} - {end:hh\\:mm}";
    }

    string GetWeekDayText(DayOfWeek day)
    {
        return day switch
        {
            DayOfWeek.Monday => "Thứ hai",
            DayOfWeek.Tuesday => "Thứ ba",
            DayOfWeek.Wednesday => "Thứ tư",
            DayOfWeek.Thursday => "Thứ năm",
            DayOfWeek.Friday => "Thứ sáu",
            DayOfWeek.Saturday => "Thứ bảy",
            _ => "Chủ nhật"
        };
    }

    var groupedSchedules = (Model ?? Enumerable.Empty<QLKH.Domain.Entities.ClassSchedule>())
        .GroupBy(x => new
        {
            x.ClassRoomId,
            x.StartTime,
            x.EndTime,
            TeamCode = x.RoomName,
            x.Note
        })
        .Select(g => new
        {
            Key = g.Key,
            First = g.OrderBy(x => x.StudyDate).First(),
            Dates = g.OrderBy(x => x.StudyDate).Select(x => x.StudyDate.Date).ToList(),
            Count = g.Count(),
            MinDate = g.Min(x => x.StudyDate),
            MaxDate = g.Max(x => x.StudyDate),
            WeekDays = g.Select(x => x.StudyDate.DayOfWeek).Distinct().OrderBy(x => (int)x).ToList(),
            FirstScheduleId = g.OrderBy(x => x.StudyDate).First().Id
        })
        .OrderBy(x => x.First.ClassRoom?.ClassName)
        .ThenBy(x => x.MinDate)
        .ThenBy(x => x.Key.StartTime)
        .ToList();
}

@section Styles {
    <link rel="stylesheet" href="~/css/HocVuProfession.css" asp-append-version="true" />
    <style>
        .schedule-summary-box {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .schedule-badges {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-top: 4px;
        }

        .schedule-badge {
            display: inline-flex;
            align-items: center;
            padding: 4px 10px;
            border-radius: 999px;
            background: rgba(255,255,255,.06);
            border: 1px solid rgba(255,255,255,.08);
            font-size: 13px;
            color: #d8d9ff;
        }

        .schedule-dates-wrap {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            max-width: 520px;
        }

        .schedule-date-chip {
            display: inline-flex;
            align-items: center;
            padding: 4px 10px;
            border-radius: 10px;
            background: rgba(122, 92, 255, .14);
            border: 1px solid rgba(122, 92, 255, .22);
            color: #efeaff;
            font-size: 13px;
        }

        .schedule-meta {
            color: #aeb3d1;
            font-size: 13px;
        }

        .schedule-highlight {
            font-weight: 700;
            color: #fff;
        }
    </style>
}

<div class="course-page admin-profession-page classroom-page">
    <div class="cp-header">
        <div class="cp-header-left">
            <h1 class="cp-title">DANH SÁCH LỊCH HỌC</h1>
            <p class="cp-subtitle">Danh sách lịch học dành cho học viên và giảng viên...</p>
        </div>

        <a asp-area="HocVu"
           asp-controller="ClassSchedule"
           asp-action="Create"
           class="cp-btn cp-btn--primary">
            + Thêm lịch học
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <form method="get"
      asp-area="HocVu"
      asp-controller="ClassSchedule"
      asp-action="Index"
      class="cp-form-card"
      style="margin-bottom: 20px;">
    <div class="cp-form-row">
        <div class="cp-field">
            <label class="cp-label">Lọc theo lớp học</label>
            <select name="classRoomId" asp-items="ViewBag.ClassRoomId" class="cp-input cp-select">
                <option value="">-- Tất cả lớp học --</option>
            </select>
        </div>

        <div class="cp-field">
            <label class="cp-label">Lọc theo buổi</label>
            <select name="session" class="cp-input cp-select">
                <option value="">-- Tất cả buổi --</option>
                <option value="Morning" selected="@(ViewBag.SelectedSession == "Morning")">Sáng</option>
                <option value="Afternoon" selected="@(ViewBag.SelectedSession == "Afternoon")">Chiều</option>
            </select>
        </div>
    </div>

    <div class="cp-form-actions">
        <button type="submit" class="cp-btn cp-btn--primary">Lọc dữ liệu</button>
        <a asp-area="HocVu" asp-controller="ClassSchedule" asp-action="Index" class="cp-btn cp-btn--ghost">Bỏ lọc</a>
    </div>
</form>

    <div class="cp-table-wrap">
        <table class="cp-table">
            <thead>
                <tr>
                    <th class="text-center">Lớp học</th>
                    <th class="text-center">Tổng hợp</th>
                    <th class="text-center">Các ngày học</th>
                    <th class="cp-col-action text-center">Chức năng</th>
                </tr>
            </thead>
            <tbody>
                @if (groupedSchedules.Any())
                {
                    foreach (var group in groupedSchedules)
                    {
                        var sessionText = GetSessionText(group.Key.StartTime, group.Key.EndTime);
                        var weekDayTexts = group.WeekDays.Select(GetWeekDayText).ToList();

                        <tr class="cp-row">
                            <td>
                                <div class="cp-name">@(group.First.ClassRoom?.ClassName ?? "Chưa có lớp")</div>
                                <div class="text-muted">@(group.First.ClassRoom?.ClassCode ?? "")</div>
                                <div class="text-muted">@(group.First.ClassRoom?.Course?.CourseName ?? "")</div>
                            </td>

                            <td>
                                <div class="schedule-summary-box">
                                    <div class="schedule-meta">
                                        Buổi học:
                                        <span class="schedule-highlight">@sessionText</span>
                                        (@group.Key.StartTime.ToString(@"hh\:mm") - @group.Key.EndTime.ToString(@"hh\:mm"))
                                    </div>

                                    <div class="schedule-meta">
                                        TeamCode:
                                        <span class="schedule-highlight">
                                            @(string.IsNullOrWhiteSpace(group.Key.TeamCode) ? "Chưa cập nhật" : group.Key.TeamCode)
                                        </span>
                                    </div>

                                    <div class="schedule-meta">
                                        Từ
                                        <span class="schedule-highlight">@group.MinDate.ToString("dd/MM/yyyy")</span>
                                        đến
                                        <span class="schedule-highlight">@group.MaxDate.ToString("dd/MM/yyyy")</span>
                                    </div>

                                    <div class="schedule-meta">
                                        Tổng số buổi:
                                        <span class="schedule-highlight">@group.Count</span>
                                    </div>

                                    <div class="schedule-badges">
                                        @foreach (var day in weekDayTexts)
                                        {
                                            <span class="schedule-badge">@day</span>
                                        }
                                    </div>

                                    <div class="schedule-meta">
                                        Ghi chú:
                                        <span class="schedule-highlight">
                                            @(string.IsNullOrWhiteSpace(group.Key.Note) ? "-" : group.Key.Note)
                                        </span>
                                    </div>
                                </div>
                            </td>

                            <td>
                                <div class="schedule-dates-wrap">
                                    @foreach (var date in group.Dates)
                                    {
                                        <span class="schedule-date-chip">@date.ToString("dd/MM")</span>
                                    }
                                </div>
                            </td>

                            <td>
                                <div class="cp-actions">
                                    <a asp-area="HocVu"
                                       asp-controller="ClassSchedule"
                                       asp-action="Details"
                                       asp-route-id="@group.FirstScheduleId"
                                       class="cp-btn cp-btn--info cp-btn--sm">
                                        Chi tiết
                                    </a>

                                    <a asp-area="HocVu"
                                       asp-controller="ClassSchedule"
                                       asp-action="EditSelect"
                                       asp-route-id="@group.FirstScheduleId"
                                       class="cp-btn cp-btn--warning cp-btn--sm">
                                        Sửa
                                    </a>

                                    <a asp-area="HocVu"
                                       asp-controller="ClassSchedule"
                                       asp-action="Delete"
                                       asp-route-id="@group.FirstScheduleId"
                                       class="cp-btn cp-btn--danger cp-btn--sm">
                                        Xóa
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="cp-empty">Chưa có lịch học nào trong hệ thống.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/HocVuProfession.js" asp-append-version="true"></script>
}
