@model IEnumerable<QLKH.Domain.Entities.Teacher>

@{
    ViewData["Title"] = "Danh sách giảng viên";
    var keyword = ViewBag.Keyword as string ?? "";
    var ratingSort = ViewBag.RatingSort as string ?? "";
    var averageRatings = ViewBag.TeacherAverageRatings as Dictionary<int, double>
        ?? new Dictionary<int, double>();

    var reviewCounts = ViewBag.TeacherReviewCounts as Dictionary<int, int>
        ?? new Dictionary<int, int>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/AdminProfession.css" asp-append-version="true" />

    <style>
        .teacher-rating {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 7px 10px;
            border-radius: 999px;
            background: rgba(245, 158, 11, 0.16);
            border: 1px solid rgba(245, 158, 11, 0.26);
            color: #fed7aa;
            font-weight: 900;
            white-space: nowrap;
        }

        .teacher-rating-empty {
            display: inline-flex;
            align-items: center;
            padding: 7px 10px;
            border-radius: 999px;
            background: rgba(100, 116, 139, 0.16);
            border: 1px solid rgba(148, 163, 184, 0.22);
            color: #cbd5e1;
            font-weight: 800;
            white-space: nowrap;
        }

        .teacher-rating-count {
            color: rgba(203, 213, 225, 0.82);
            font-size: 0.82rem;
            font-weight: 700;
            margin-top: 5px;
        }

        .teacher-table {
            width: 100%;
            table-layout: fixed;
        }

        .teacher-email,
        .teacher-phone,
        .teacher-specialization,
        .teacher-name-limit {
            word-break: break-word;
        }

        .teacher-actions {
            display: flex;
            flex-wrap: wrap;
            justify-content: flex-end;
            gap: 8px;
        }

            .teacher-actions .cp-btn {
                min-width: 72px;
                justify-content: center;
            }

        @@media (max-width: 1199.98px) {
            .teacher-table {
                min-width: 1080px;
            }

            .cp-table-wrap {
                overflow-x: auto;
            }
        }

        .teacher-filter-card {
            background: var(--cp-surface, rgba(13, 8, 30, .75));
            border: 1px solid var(--cp-border, rgba(140, 80, 255, .18));
            border-radius: var(--cp-radius, 10px);
            padding: 16px;
            margin: 18px 0;
            box-shadow: var(--cp-shadow, 0 2px 12px rgba(0,0,0,.5));
        }

        .teacher-filter-form {
            display: grid;
            grid-template-columns: minmax(0, 1fr) minmax(230px, 300px) auto;
            gap: 12px;
            align-items: end;
        }

        .teacher-filter-field label {
            display: block;
            margin-bottom: 6px;
            color: var(--cp-text-sub, rgba(210,185,255,.8));
            font-size: 0.9rem;
            font-weight: 800;
        }

        .teacher-filter-input,
        .teacher-filter-select {
            width: 100%;
            min-height: 42px;
            border: 1px solid var(--cp-border, rgba(140,80,255,.18));
            border-radius: var(--cp-radius-sm, 7px);
            padding: 9px 12px;
            color: var(--cp-text, #f0e8ff);
            background: var(--cp-surface-2, rgba(25,12,55,.65));
            font-weight: 700;
            outline: none;
        }

            .teacher-filter-input::placeholder {
                color: var(--cp-text-muted, rgba(180,150,255,.55));
            }

            .teacher-filter-input:focus,
            .teacher-filter-select:focus {
                border-color: var(--cp-accent, #a855f7);
                box-shadow: 0 0 0 0.18rem var(--cp-accent-light, rgba(168,85,247,.10));
            }

        .teacher-filter-actions {
            display: flex;
            gap: 8px;
        }

            .teacher-filter-actions .cp-btn {
                min-height: 42px;
                white-space: nowrap;
            }

        .teacher-filter-note {
            margin-top: 10px;
            color: var(--cp-text-muted, rgba(180,150,255,.55));
            font-size: 0.9rem;
            font-weight: 700;
        }

        @@media (max-width: 991.98px) {
            .teacher-filter-form {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 575.98px) {
            .teacher-filter-actions {
                flex-direction: column;
            }

                .teacher-filter-actions .cp-btn {
                    width: 100%;
                }
        }
    </style>
}

<div class="course-page admin-profession-page teacher-page">
    <div class="cp-header">
        <div class="cp-header-left">
            <h1 class="cp-title">DANH SÁCH GIẢNG VIÊN</h1>
            <p class="cp-subtitle">
                Quản lý hồ sơ giảng viên, chuyên môn, thông tin liên hệ và đánh giá...
            </p>
        </div>

        <a asp-area="HocVu"
           asp-controller="Teacher"
           asp-action="Create"
           class="cp-btn cp-btn--primary">
            + Thêm giảng viên
        </a>
    </div>
    <div class="teacher-filter-card">
        <form asp-area="HocVu"
              asp-controller="Teacher"
              asp-action="Index"
              method="get"
              class="teacher-filter-form">

            <div class="teacher-filter-field">
                <label>Tìm kiếm</label>
                <input type="text"
                       name="keyword"
                       value="@keyword"
                       class="teacher-filter-input"/>
            </div>

            <div class="teacher-filter-field">
                <label>Đánh giá</label>
                <select name="ratingSort" class="teacher-filter-select">
                    <option value="" selected="@(ratingSort == "")">Mặc định</option>
                    <option value="rating_desc" selected="@(ratingSort == "rating_desc")">Sao ↓</option>
                    <option value="rating_asc" selected="@(ratingSort == "rating_asc")">Sao ↑</option>
                </select>
            </div>

            <div class="teacher-filter-actions">
                <button type="submit" class="cp-btn cp-btn--primary">
                    Lọc
                </button>

                <a asp-area="HocVu"
                   asp-controller="Teacher"
                   asp-action="Index"
                   class="cp-btn cp-btn--ghost">
                    Bỏ lọc
                </a>
            </div>
        </form>

        @if (!string.IsNullOrWhiteSpace(keyword) || !string.IsNullOrWhiteSpace(ratingSort))
        {
            <div class="teacher-filter-note">
                Đang áp dụng bộ lọc
                @if (!string.IsNullOrWhiteSpace(keyword))
                {
                    <span>theo từ khóa: <strong>@keyword</strong></span>
                }
            </div>
        }
    </div>

    <div class="cp-table-wrap">
        <table class="cp-table teacher-table">
            <colgroup>
                <col style="width: 8%;" />
                <col style="width: 17%;" />
                <col style="width: 25%;" />
                <col style="width: 15%;" />
                <col style="width: 10%;" />
                <col style="width: 25%;" />
            </colgroup>

            <thead>
                <tr>
                    <th class="text-center">Mã GV</th>
                    <th class="text-center">Họ tên</th>
                    <th class="text-center">Email</th>
                    <th class="text-center">Chuyên môn</th>
                    <th class="text-center">Đánh giá</th>
                    <th class="cp-col-action text-center">Chức năng</th>
                </tr>
            </thead>

            <tbody>
                @if (Model?.Any() == true)
                {
                    foreach (var item in Model)
                    {
                        var hasRating = averageRatings.ContainsKey(item.Id);
                        var averageRating = hasRating ? averageRatings[item.Id] : 0;
                        var reviewCount = reviewCounts.ContainsKey(item.Id) ? reviewCounts[item.Id] : 0;

                        <tr class="cp-row">
                            <td>
                                <span class="cp-code">@item.TeacherCode</span>
                            </td>

                            <td>
                                <div class="cp-name teacher-name-limit">@item.FullName</div>
                            </td>

                            <td>
                                <div class="teacher-email">
                                    @(string.IsNullOrWhiteSpace(item.Email) ? "Chưa cập nhật" : item.Email)
                                </div>
                            </td>

                            <td>
                                <span class="cp-badge teacher-specialization">
                                    @(string.IsNullOrWhiteSpace(item.Specialization) ? "Chưa cập nhật" : item.Specialization)
                                </span>
                            </td>

                            <td>
                                @if (hasRating)
                                {
                                    <div>
                                        <span class="teacher-rating">
                                            ⭐ @averageRating.ToString("0.##")/5
                                        </span>
                                        <div class="teacher-rating-count">
                                            @reviewCount đánh giá
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <span class="teacher-rating-empty">
                                        Chưa có
                                    </span>
                                }
                            </td>

                            <td>
                                <div class="cp-actions teacher-actions">
                                    <a asp-area="HocVu"
                                       asp-controller="Teacher"
                                       asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="cp-btn cp-btn--info cp-btn--sm">
                                        Chi tiết
                                    </a>

                                    <a asp-area="HocVu"
                                       asp-controller="Teacher"
                                       asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="cp-btn cp-btn--warning cp-btn--sm">
                                        Sửa
                                    </a>

                                    <a asp-area="HocVu"
                                       asp-controller="Teacher"
                                       asp-action="Delete"
                                       asp-route-id="@item.Id"
                                       class="cp-btn cp-btn--danger cp-btn--sm">
                                        Xóa
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="cp-empty">
                            Chưa có giảng viên nào trong hệ thống.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/AdminProfession.js" asp-append-version="true"></script>
}