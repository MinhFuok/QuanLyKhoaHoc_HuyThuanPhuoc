@model QLKH.Application.ViewModels.TeacherFormViewModel

@{
    ViewData["Title"] = "Chi tiết giảng viên";
}

@section Styles {
    <link rel="stylesheet" href="~/css/AdminProfession.css" asp-append-version="true" />
}

<div class="course-page admin-profession-page teacher-page">
    <div class="cp-header">
        <div class="cp-header-left">
            <h1 class="cp-title">THÔNG TIN CHI TIẾT</h1>
        </div>
        <a asp-area="HocVu" asp-controller="Teacher" asp-action="Index" class="cp-btn cp-btn--ghost">←Quay lại</a>
    </div>

    <div class="cp-detail-card">
        <div class="cp-detail-hero">
            <div class="cp-detail-hero-left">
                <span class="cp-code cp-code--lg">@Model.TeacherCode</span>
                <h2 class="cp-detail-name">@Model.FullName</h2>
            </div>
            <span class="cp-badge cp-badge--lg">Giáo viên</span>
        </div>

        <div class="cp-detail-body">
            <div class="cp-detail-row">
                <div class="cp-detail-label">Email hồ sơ</div>
                <div class="cp-detail-value">@Model.Email</div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Số điện thoại</div>
                <div class="cp-detail-value">@Model.PhoneNumber</div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Chuyên môn</div>
                <div class="cp-detail-value">@Model.Specialization</div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Tài khoản liên kết</div>
                <div class="cp-detail-value">
                    @(string.IsNullOrWhiteSpace(Model.LinkedAccountEmail) ? "Chưa liên kết" : Model.LinkedAccountEmail)
                </div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Họ tên tài khoản</div>
                <div class="cp-detail-value">
                    @(string.IsNullOrWhiteSpace(Model.LinkedAccountFullName) ? "Không có" : Model.LinkedAccountFullName)
                </div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Trạng thái tài khoản</div>
                <div class="cp-detail-value">
                    @if (string.IsNullOrWhiteSpace(Model.LinkedAccountEmail))
                    {
                        <span>Không có tài khoản liên kết</span>
                    }
                    else if (Model.LinkedAccountLocked)
                    {
                        <span class="text-danger">Đã vô hiệu hóa</span>
                    }
                    else
                    {
                        <span class="text-success">Đang hoạt động</span>
                    }
                </div>
            </div>
        </div>

        <div class="cp-detail-footer">
            <a asp-area="HocVu" asp-controller="Teacher" asp-action="Edit" asp-route-id="@Model.Id" class="cp-btn cp-btn--warning">Chỉnh sửa</a>
            <a asp-area="HocVu" asp-controller="Teacher" asp-action="Index" class="cp-btn cp-btn--ghost">Hủy</a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/AdminProfession.js" asp-append-version="true"></script>
}