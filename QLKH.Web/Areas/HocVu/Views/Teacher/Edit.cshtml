@model QLKH.Application.ViewModels.TeacherFormViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Cập nhật giảng viên";
    var teacherAccountMetaJson = JsonSerializer.Serialize(ViewBag.TeacherAccountMeta ?? new List<object>());
}

@section Styles {
    <link rel="stylesheet" href="~/css/HocVuProfession.css" asp-append-version="true" />
}

<div class="course-page admin-profession-page teacher-page">
    <div class="cp-header">
        <div class="cp-header-left">
            <h1 class="cp-title">CẬP NHẬT GIẢNG VIÊN</h1>
        </div>

        <a asp-area="HocVu" asp-controller="Teacher" asp-action="Index" class="cp-btn cp-btn--ghost">←Quay lại</a>
    </div>

    <form asp-area="HocVu" asp-controller="Teacher" asp-action="Edit" method="post" class="cp-form-card">
        <input type="hidden" asp-for="Id" />

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
            <div asp-validation-summary="All" class="cp-validation-summary"></div>
        }

        <div class="cp-form-group-label">Tài khoản liên kết</div>
        <div class="cp-form-row">
            <div class="cp-field" style="flex:0 0 100%; max-width:100%;">
                <label asp-for="ApplicationUserId" class="cp-label"></label>
                <select asp-for="ApplicationUserId" asp-items="ViewBag.ApplicationUserId" class="cp-input cp-select" id="applicationUserSelect">
                    <option value="">-- Chọn tài khoản giáo viên --</option>
                </select>
                <span asp-validation-for="ApplicationUserId" class="cp-field-error"></span>
            </div>
        </div>

        <div class="cp-form-group-label">Thông tin lấy từ tài khoản</div>
        <div class="cp-form-row">
            <div class="cp-field">
                <label asp-for="FullName" class="cp-label"></label>
                <input asp-for="FullName" class="cp-input" id="fullNameInput" readonly />
                <span asp-validation-for="FullName" class="cp-field-error"></span>
            </div>

            <div class="cp-field">
                <label asp-for="Email" class="cp-label"></label>
                <input asp-for="Email" class="cp-input" id="emailInput" readonly />
                <span asp-validation-for="Email" class="cp-field-error"></span>
            </div>
        </div>

        <div class="cp-form-group-label">Thông tin giáo viên</div>
        <div class="cp-form-row">
            <div class="cp-field">
                <label asp-for="TeacherCode" class="cp-label"></label>
                <input asp-for="TeacherCode" class="cp-input" readonly />
                <span asp-validation-for="TeacherCode" class="cp-field-error"></span>
            </div>

            <div class="cp-field">
                <label asp-for="PhoneNumber" class="cp-label"></label>
                <input asp-for="PhoneNumber"
                       class="cp-input"
                       maxlength="10"
                       inputmode="numeric"
                       pattern="\d{10}"
                       oninput="this.value = this.value.replace(/\D/g, '').slice(0,10);" />
                <span asp-validation-for="PhoneNumber" class="cp-field-error"></span>
            </div>
        </div>

        <div class="cp-form-group-label">Chuyên môn</div>
        <div class="cp-form-row">
            <div class="cp-field" style="flex:0 0 100%; max-width:100%;">
                <label asp-for="Specialization" class="cp-label"></label>
                <input asp-for="Specialization" class="cp-input" />
                <span asp-validation-for="Specialization" class="cp-field-error"></span>
            </div>
        </div>

        <div class="cp-form-actions">
            <button type="submit" class="cp-btn cp-btn--warning">Cập nhật thay đổi</button>
            <a asp-area="HocVu" asp-controller="Teacher" asp-action="Index" class="cp-btn cp-btn--ghost">Hủy</a>
        </div>
    </form>
</div>

<script id="teacher-account-meta" type="application/json">
    @Html.Raw(teacherAccountMetaJson)
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/HocVuProfession.js" asp-append-version="true"></script>
    <script>
        const metaElement = document.getElementById('teacher-account-meta');
        const accountMeta = metaElement ? JSON.parse(metaElement.textContent) : [];

        const applicationUserSelect = document.getElementById('applicationUserSelect');
        const fullNameInput = document.getElementById('fullNameInput');
        const emailInput = document.getElementById('emailInput');

        function updateLinkedAccountInfo() {
            const selectedId = applicationUserSelect.value;
            const selected = accountMeta.find(x => x.id === selectedId);

            if (!selected) {
                fullNameInput.value = '';
                emailInput.value = '';
                return;
            }

            fullNameInput.value = selected.fullName || '';
            emailInput.value = selected.email || '';
        }

        if (applicationUserSelect) {
            applicationUserSelect.addEventListener('change', updateLinkedAccountInfo);
            updateLinkedAccountInfo();
        }
    </script>
}
