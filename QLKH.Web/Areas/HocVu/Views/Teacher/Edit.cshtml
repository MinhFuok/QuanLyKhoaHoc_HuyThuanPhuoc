@model QLKH.Domain.Entities.Teacher

@{
    ViewData["Title"] = "Sửa giảng viên";
}

@section Styles {
    <link rel="stylesheet" href="~/css/AdminProfession.css" asp-append-version="true" />
}

<div class="course-page admin-profession-page teacher-page">
    <div class="cp-header">
        <div class="cp-header-left">
            <h1 class="cp-title">Sửa giảng viên</h1>
            <p class="cp-subtitle">Cập nhật hồ sơ giảng viên <strong>@Model.TeacherCode</strong>.</p>
        </div>

        <a asp-area="HocVu" asp-controller="Teacher" asp-action="Index" class="cp-btn cp-btn--ghost">Quay lại</a>
    </div>

    <form asp-area="HocVu" asp-controller="Teacher" asp-action="Edit" method="post" id="teacherForm" data-admin-form data-loading-text="Đang lưu..." class="cp-form-card">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="cp-validation-summary"></div>

        <div class="cp-form-group-label">Thông tin giảng viên</div>
        <div class="cp-form-row">
            <div class="cp-field">
                <label asp-for="TeacherCode" class="cp-label">Mã giảng viên</label>
                <input asp-for="TeacherCode" class="cp-input" />
                <span asp-validation-for="TeacherCode" class="cp-field-error"></span>
            </div>

            <div class="cp-field">
                <label asp-for="FullName" class="cp-label">Họ tên</label>
                <input asp-for="FullName" class="cp-input" />
                <span asp-validation-for="FullName" class="cp-field-error"></span>
            </div>
        </div>

        <div class="cp-form-group-label">Thông tin liên hệ</div>
        <div class="cp-form-row">
            <div class="cp-field">
                <label asp-for="Email" class="cp-label">Email</label>
                <input asp-for="Email" class="cp-input" />
                <span asp-validation-for="Email" class="cp-field-error"></span>
            </div>

            <div class="cp-field">
                <label asp-for="PhoneNumber" class="cp-label">Số điện thoại</label>
                <input asp-for="PhoneNumber" class="cp-input" />
                <span asp-validation-for="PhoneNumber" class="cp-field-error"></span>
            </div>
        </div>

        <div class="cp-form-group-label">Chuyên môn</div>
        <div class="cp-field">
            <label asp-for="Specialization" class="cp-label">Chuyên môn</label>
            <input asp-for="Specialization" class="cp-input" />
            <span asp-validation-for="Specialization" class="cp-field-error"></span>
        </div>

        <div class="cp-form-actions">
            <button type="submit" class="cp-btn cp-btn--warning">Cập nhật</button>
            <a asp-area="HocVu" asp-controller="Teacher" asp-action="Index" class="cp-btn cp-btn--ghost">Quay lại</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/AdminProfession.js" asp-append-version="true"></script>
}
