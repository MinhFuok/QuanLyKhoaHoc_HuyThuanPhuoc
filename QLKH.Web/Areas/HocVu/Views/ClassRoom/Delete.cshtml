@model QLKH.Domain.Entities.ClassRoom

@{
    ViewData["Title"] = "Xóa lớp học";
}

@section Styles {
    <link rel="stylesheet" href="~/css/HocVuProfession.css" asp-append-version="true" />
}

<div class="course-page admin-profession-page classroom-page">
    <div class="cp-header">
        <div class="cp-header-left">
            <h1 class="cp-title">XÓA LỚP HỌC</h1>
        </div>
        <a asp-area="HocVu" asp-controller="ClassRoom" asp-action="Index" class="cp-btn cp-btn--ghost">←Quay lại</a>
    </div>

    <div class="cp-delete-card">
        <div class="cp-delete-warning">
            <div class="cp-delete-warning-icon">!</div>
            <div>
                <strong>Bạn có chắc muốn xóa lớp học này không?</strong>
                <p>Hành động này có thể ảnh hưởng đến dữ liệu học viên, lịch học và các nghiệp vụ liên quan.</p>
            </div>
        </div>

        <div class="cp-detail-body">
            <div class="cp-detail-row">
                <div class="cp-detail-label">Mã lớp</div>
                <div class="cp-detail-value"><span class="cp-code">@Model.ClassCode</span></div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Tên lớp</div>
                <div class="cp-detail-value"><strong>@Model.ClassName</strong></div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Khóa học</div>
                <div class="cp-detail-value">@Model.Course?.CourseName</div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Giảng viên</div>
                <div class="cp-detail-value">@Model.Teacher?.FullName</div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Thời gian</div>
                <div class="cp-detail-value">@Model.StartDate.ToString("dd/MM/yyyy") - @Model.EndDate.ToString("dd/MM/yyyy")</div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Sĩ số tối đa</div>
                <div class="cp-detail-value">@Model.MaxStudents học viên</div>
            </div>
        </div>

        <form asp-area="HocVu" asp-controller="ClassRoom" asp-action="Delete" method="post" id="deleteForm" data-delete-label="lớp học">
            <input type="hidden" asp-for="Id" />
            <div class="cp-delete-actions">
                <button type="submit" class="cp-btn cp-btn--danger">Xác nhận xóa</button>
                <a asp-area="HocVu" asp-controller="ClassRoom" asp-action="Index" class="cp-btn cp-btn--ghost">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/HocVuProfession.js" asp-append-version="true"></script>
}

