@model QLKH.Domain.Entities.ClassRoom

@{
    ViewData["Title"] = "Chi tiết lớp học";
}

@section Styles {
    <link rel="stylesheet" href="~/css/AdminProfession.css" asp-append-version="true" />
}

<div class="course-page admin-profession-page classroom-page">
    <div class="cp-header">
        <div class="cp-header-left">
            <h1 class="cp-title">Chi tiết lớp học</h1>
            <p class="cp-subtitle">Thông tin tổng quan của lớp <strong>@Model.ClassCode</strong>.</p>
        </div>
    </div>

    <div class="cp-detail-card">
        <div class="cp-detail-hero">
            <div class="cp-detail-hero-left">
                <span class="cp-code cp-code--lg">@Model.ClassCode</span>
                <h2 class="cp-detail-name">@Model.ClassName</h2>
            </div>
            <span class="cp-badge cp-badge--lg">@Model.MaxStudents học viên</span>
        </div>

        <div class="cp-detail-body">
            <div class="cp-detail-row">
                <div class="cp-detail-label">Khóa học</div>
                <div class="cp-detail-value">@Model.Course?.CourseName</div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Giảng viên</div>
                <div class="cp-detail-value">@Model.Teacher?.FullName</div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Ngày bắt đầu</div>
                <div class="cp-detail-value">@Model.StartDate.ToString("dd/MM/yyyy")</div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Ngày kết thúc</div>
                <div class="cp-detail-value">@Model.EndDate.ToString("dd/MM/yyyy")</div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Sĩ số tối đa</div>
                <div class="cp-detail-value"><strong>@Model.MaxStudents</strong> học viên</div>
            </div>
        </div>

        <div class="cp-detail-footer">
            <a asp-area="HocVu" asp-controller="ClassRoom" asp-action="Edit" asp-route-id="@Model.Id" class="cp-btn cp-btn--warning">Sửa</a>
            <a asp-area="HocVu" asp-controller="ClassRoom" asp-action="Index" class="cp-btn cp-btn--ghost">Quay lại</a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/AdminProfession.js" asp-append-version="true"></script>
}
