@model QLKH.Application.ViewModels.StudentFormViewModel

@{
    ViewData["Title"] = "Xóa học viên";
}

@section Styles {
    <link rel="stylesheet" href="~/css/HocVuProfession.css" asp-append-version="true" />
}

<div class="course-page admin-profession-page student-page">
    <div class="cp-header">
        <div class="cp-header-left">
            <h1 class="cp-title">Xóa học viên</h1>
        </div>
        <a asp-area="HocVu" asp-controller="Student" asp-action="Index" class="cp-btn cp-btn--ghost">←Quay lại</a>
    </div>

    <div class="cp-delete-card">
        <div class="cp-delete-warning">
            <div class="cp-delete-warning-icon">!</div>
            <div>
                <strong>Bạn có chắc muốn xóa học viên này không?</strong>
                <p>Hồ sơ học viên sẽ bị xóa và tài khoản liên kết sẽ bị vô hiệu hóa.</p>
            </div>
        </div>

        <div class="cp-detail-body">
            <div class="cp-detail-row">
                <div class="cp-detail-label">Mã học viên</div>
                <div class="cp-detail-value"><span class="cp-code">@Model.StudentCode</span></div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Họ tên</div>
                <div class="cp-detail-value"><strong>@Model.FullName</strong></div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Email hồ sơ học viên</div>
                <div class="cp-detail-value">@Model.Email</div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Tài khoản liên kết</div>
                <div class="cp-detail-value">
                    @(string.IsNullOrWhiteSpace(Model.LinkedAccountEmail) ? "Chưa liên kết" : Model.LinkedAccountEmail)
                </div>
            </div>

            <div class="cp-detail-row">
                <div class="cp-detail-label">Trạng thái tài khoản</div>
                <div class="cp-detail-value">
                    @if (string.IsNullOrWhiteSpace(Model.LinkedAccountEmail))
                    {
                        <span>Không có tài khoản liên kết</span>
                    }
                    else if (Model.LinkedAccountLocked)
                    {
                        <span class="text-danger">Đã vô hiệu hóa</span>
                    }
                    else
                    {
                        <span class="text-success">Đang hoạt động</span>
                    }
                </div>
            </div>
        </div>

        <form asp-area="HocVu" asp-controller="Student" asp-action="Delete" method="post" id="deleteForm">
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="cp-delete-actions">
                <button type="submit"
                        class="cp-btn cp-btn--danger"
                        onclick="return confirm('Bạn có chắc chắn muốn xóa học viên này và vô hiệu hóa tài khoản liên kết không?');">
                    Xác nhận xóa
                </button>
                <a asp-area="HocVu" asp-controller="Student" asp-action="Index" class="cp-btn cp-btn--ghost">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/HocVuProfession.js" asp-append-version="true"></script>
}
