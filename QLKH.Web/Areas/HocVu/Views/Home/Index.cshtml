@model QLKH.Web.Areas.HocVu.Models.HocVuDashboardViewModel

@{
    ViewData["Title"] = "Dashboard Học vụ";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="admin-dashboard-page">
    <div class="dashboard-header card shadow-sm border-0 mb-4">
        <div class="card-body p-4">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <h2 class="dashboard-title mb-2">DASHBOARD HỌC VỤ</h2>
                    <p class="text-muted mb-0">
                        Tổng quan nhanh tình hình vận hành lớp học, ghi danh và học viên trong hệ thống.
                    </p>
                </div>

                <div class="admin-identity-box">
                    <div class="admin-avatar">
                        @(string.IsNullOrWhiteSpace(Model.HocVuFullName) ? "H" : Model.HocVuFullName.Trim()[0].ToString().ToUpper())
                    </div>
                    <div>
                        <div class="fw-bold">@Model.HocVuFullName</div>
                        <div class="text-muted small">@Model.HocVuEmail</div>
                        <span class="badge bg-primary mt-1">@Model.HocVuRole</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card dashboard-stat-card stat-primary shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="stat-label">Khóa học / Lớp học</div>
                    <div class="stat-value">@Model.TotalClassRooms</div>
                    <div class="stat-meta">
                        Khóa học: <strong>@Model.TotalCourses</strong>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card dashboard-stat-card stat-success shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="stat-label">Học viên</div>
                    <div class="stat-value">@Model.TotalStudents</div>
                    <div class="stat-meta">
                        Tổng hồ sơ học viên hiện có trong hệ thống
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card dashboard-stat-card stat-warning shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="stat-label">Giảng viên</div>
                    <div class="stat-value">@Model.TotalTeachers</div>
                    <div class="stat-meta">
                        Tổng giảng viên đang quản lý
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card dashboard-stat-card stat-info shadow-sm h-100 border-0">
                <div class="card-body">
                    <div class="stat-label">Chứng chỉ</div>
                    <div class="stat-value">@Model.TotalCertificates</div>
                    <div class="stat-meta">
                        Tổng chứng chỉ học viên đã tạo
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-12 col-xl-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0 pb-0">
                    <h5 class="mb-0">Thông tin học vụ</h5>
                </div>
                <div class="card-body">
                    <div class="info-list">
                        <div class="info-item">
                            <span class="info-label">Họ tên</span>
                            <span class="info-value">@Model.HocVuFullName</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Email</span>
                            <span class="info-value">@Model.HocVuEmail</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Vai trò</span>
                            <span class="info-value">
                                <span class="badge bg-primary">@Model.HocVuRole</span>
                            </span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Ghi danh chờ duyệt</span>
                            <span class="info-value">
                                <span class="badge bg-warning text-dark">@Model.PendingEnrollments</span>
                            </span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Ghi danh đã duyệt</span>
                            <span class="info-value">
                                <span class="badge bg-success">@Model.ConfirmedEnrollments</span>
                            </span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Ghi danh đã hủy</span>
                            <span class="info-value">
                                <span class="badge bg-secondary">@Model.CancelledEnrollments</span>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0 pb-0">
                    <h5 class="mb-0">Tác vụ nhanh</h5>
                </div>
                <div class="card-body">
                    <div class="quick-actions-grid">
                        <a asp-area="HocVu" asp-controller="Course" asp-action="Index" class="quick-action-item">
                            <div class="quick-action-title">Khóa học</div>
                            <div class="quick-action-desc">Quản lý danh sách khóa học đào tạo</div>
                        </a>

                        <a asp-area="HocVu" asp-controller="ClassRoom" asp-action="Index" class="quick-action-item">
                            <div class="quick-action-title">Lớp học</div>
                            <div class="quick-action-desc">Quản lý lớp học, giảng viên và sĩ số</div>
                        </a>

                        <a asp-area="HocVu" asp-controller="Enrollment" asp-action="Index" class="quick-action-item">
                            <div class="quick-action-title">Ghi danh</div>
                            <div class="quick-action-desc">Duyệt và theo dõi đăng ký học viên</div>
                        </a>

                        <a asp-area="HocVu" asp-controller="ClassSchedule" asp-action="Index" class="quick-action-item">
                            <div class="quick-action-title">Lịch học</div>
                            <div class="quick-action-desc">Quản lý buổi học và tránh trùng lịch</div>
                        </a>

                        <a asp-area="HocVu" asp-controller="Student" asp-action="Index" class="quick-action-item">
                            <div class="quick-action-title">Học viên</div>
                            <div class="quick-action-desc">Quản lý hồ sơ và tài khoản học viên</div>
                        </a>

                        <a asp-area="HocVu" asp-controller="Teacher" asp-action="Index" class="quick-action-item">
                            <div class="quick-action-title">Giảng viên</div>
                            <div class="quick-action-desc">Quản lý hồ sơ giảng viên giảng dạy</div>
                        </a>

                        <a asp-area="HocVu" asp-controller="StudentCertificate" asp-action="Index" class="quick-action-item">
                            <div class="quick-action-title">Chứng chỉ học viên</div>
                            <div class="quick-action-desc">Theo dõi và xử lý chứng chỉ học viên</div>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-12 col-xl-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0">
                    <h5 class="mb-0">Tổng quan dữ liệu đào tạo</h5>
                </div>
                <div class="card-body">
                    <canvas id="hocVuOverviewChart" height="130"></canvas>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0">
                    <h5 class="mb-0">Trạng thái ghi danh</h5>
                </div>
                <div class="card-body">
                    <canvas id="hocVuEnrollmentChart" height="130"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-0">
            <h5 class="mb-0">Ghi chú vận hành</h5>
        </div>
        <div class="card-body">
            @if (Model.RecentNotes != null && Model.RecentNotes.Any())
            {
                <ul class="mb-0">
                    @foreach (var note in Model.RecentNotes)
                    {
                        <li class="mb-2">@note</li>
                    }
                </ul>
            }
            else
            {
                <div class="text-muted">Chưa có ghi chú vận hành.</div>
            }
        </div>
    </div>
</div>

@section Styles {
    <style>
        .admin-dashboard-page .dashboard-title {
            font-size: 2rem;
            font-weight: 700;
            color: #1d2b53;
        }

        .admin-identity-box {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 12px 16px;
            background: #f8f9ff;
            border-radius: 16px;
            border: 1px solid #e9ecf5;
        }

        .admin-avatar {
            width: 52px;
            height: 52px;
            border-radius: 50%;
            background: linear-gradient(135deg, #4f8cff, #6a5cff);
            color: #fff;
            font-weight: 700;
            font-size: 1.25rem;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .dashboard-stat-card {
            border-radius: 18px;
            overflow: hidden;
        }

            .dashboard-stat-card .card-body {
                padding: 1.25rem;
            }

        .stat-label {
            color: #6c757d;
            font-size: 0.95rem;
            margin-bottom: 8px;
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 700;
            line-height: 1.1;
            margin-bottom: 10px;
            color: #1f2d3d;
        }

        .stat-meta {
            color: #6c757d;
            font-size: 0.92rem;
        }

        .stat-primary {
            background: linear-gradient(135deg, #eef4ff 0%, #ffffff 100%);
            border-left: 5px solid #0d6efd;
        }

        .stat-success {
            background: linear-gradient(135deg, #eefbf3 0%, #ffffff 100%);
            border-left: 5px solid #198754;
        }

        .stat-warning {
            background: linear-gradient(135deg, #fff8eb 0%, #ffffff 100%);
            border-left: 5px solid #ffc107;
        }

        .stat-info {
            background: linear-gradient(135deg, #eef8ff 0%, #ffffff 100%);
            border-left: 5px solid #0dcaf0;
        }

        .info-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .info-item {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            padding: 10px 0;
            border-bottom: 1px dashed #e5e7eb;
        }

            .info-item:last-child {
                border-bottom: none;
            }

        .info-label {
            min-width: 130px;
            color: #6c757d;
            font-weight: 500;
        }

        .info-value {
            text-align: right;
            color: #212529;
            font-weight: 600;
        }

        .quick-actions-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
        }

        .quick-action-item {
            display: block;
            text-decoration: none;
            padding: 14px 16px;
            border-radius: 14px;
            background: #f8f9fc;
            border: 1px solid #e9ecf5;
            transition: all 0.2s ease-in-out;
        }

            .quick-action-item:hover {
                background: #eef4ff;
                border-color: #cfe0ff;
                transform: translateY(-1px);
            }

        .quick-action-title {
            font-weight: 700;
            color: #1d2b53;
            margin-bottom: 4px;
        }

        .quick-action-desc {
            color: #6c757d;
            font-size: 0.92rem;
        }

        @@media (max-width: 991.98px) {
            .quick-actions-grid {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 767.98px) {
            .info-item {
                flex-direction: column;
                align-items: flex-start;
            }

            .info-value {
                text-align: left;
            }
        }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const hocVuOverviewChart = document.getElementById('hocVuOverviewChart');
        if (hocVuOverviewChart) {
            new Chart(hocVuOverviewChart, {
                type: 'bar',
                data: {
                    labels: ['Khóa học', 'Lớp học', 'Học viên', 'Giảng viên', 'Chứng chỉ'],
                    datasets: [{
                        label: 'Số lượng',
                        data: [
                            @Model.TotalCourses,
                            @Model.TotalClassRooms,
                            @Model.TotalStudents,
                            @Model.TotalTeachers,
                            @Model.TotalCertificates
                        ],
                        borderWidth: 1,
                        borderRadius: 8
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: { precision: 0 }
                        }
                    }
                }
            });
        }

        const hocVuEnrollmentChart = document.getElementById('hocVuEnrollmentChart');
        if (hocVuEnrollmentChart) {
            new Chart(hocVuEnrollmentChart, {
                type: 'doughnut',
                data: {
                    labels: ['Chờ duyệt', 'Đã duyệt', 'Đã hủy'],
                    datasets: [{
                        data: [
                            @Model.PendingEnrollments,
                            @Model.ConfirmedEnrollments,
                            @Model.CancelledEnrollments
                        ],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    }
                }
            });
        }
    </script>
}