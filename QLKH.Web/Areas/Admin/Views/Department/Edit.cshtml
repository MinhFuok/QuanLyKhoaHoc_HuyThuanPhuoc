@model QLKH.Web.Areas.Admin.Models.DepartmentEditViewModel

@{
    ViewData["Title"] = "Sửa chương trình/khóa";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="admin-account-page admin-program-page">
    <div class="admin-page-header">
        <div>
            <h2 class="admin-page-title">SỬA CHƯƠNG TRÌNH/KHÓA</h2>
        </div>

        <a asp-area="Admin"
           asp-controller="Department"
           asp-action="Index"
           class="btn btn-outline-secondary admin-btn-main">
            Quay lại
        </a>
    </div>

    <div class="admin-form-card">
        <div class="admin-form-title">
            <span>Thông tin chương trình/khóa</span>
        </div>

        <form asp-area="Admin" asp-controller="Department" asp-action="Edit" method="post">
            @Html.AntiForgeryToken()

            <input asp-for="Id" type="hidden" />

            <div asp-validation-summary="All" class="text-danger admin-validation"></div>

            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label asp-for="DepartmentCode" class="form-label admin-label"></label>
                    <input asp-for="DepartmentCode" class="form-control admin-input" />
                    <span asp-validation-for="DepartmentCode" class="text-danger admin-field-error"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="ParentDepartmentId" class="form-label admin-label"></label>
                    <select asp-for="ParentDepartmentId"
                            asp-items="ViewBag.ParentDepartments"
                            class="form-select admin-input">
                        <option value="">-- Không chọn (Tạo chương trình) --</option>
                    </select>
                    <span asp-validation-for="ParentDepartmentId" class="text-danger admin-field-error"></span>
                </div>

                <div class="col-12">
                    <label asp-for="DepartmentName" class="form-label admin-label"></label>
                    <input asp-for="DepartmentName"
                           class="form-control admin-input"
                           placeholder="Nhập tên chương trình hoặc khóa..." />
                    <span asp-validation-for="DepartmentName" class="text-danger admin-field-error"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Description" class="form-label admin-label"></label>
                    <textarea asp-for="Description"
                              class="form-control admin-input admin-textarea"
                              rows="4"
                              placeholder="Nhập mô tả ngắn cho chương trình hoặc khóa..."></textarea>
                    <span asp-validation-for="Description" class="text-danger admin-field-error"></span>
                </div>

                <div class="col-12">
                    <div class="admin-check-row">
                        <input asp-for="IsActive" class="form-check-input admin-check-input" />
                        <label asp-for="IsActive" class="form-check-label admin-check-label"></label>
                    </div>
                </div>
            </div>

            <div class="admin-form-actions">
                <button type="submit" class="btn btn-primary">
                    Xác nhận thay đổi
                </button>

                <a asp-area="Admin"
                   asp-controller="Department"
                   asp-action="Index"
                   class="btn btn-outline-secondary">
                    Hủy
                </a>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
