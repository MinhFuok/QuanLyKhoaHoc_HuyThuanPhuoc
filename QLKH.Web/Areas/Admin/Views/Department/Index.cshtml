            color: #4b5563;
            font-weight: 700;
        }

        .admin-name {
            color: #111827;
            font-weight: 800;
            line-height: 1.45;
            word-break: break-word;
        }

        .program-child-name {
            display: flex;
            align-items: flex-start;
            gap: 8px;
            color: #374151;
            font-weight: 600;
            line-height: 1.45;
            word-break: break-word;
            padding-left: 22px;
        }

        .child-mark {
            color: #9ca3af;
            font-weight: 800;
            flex-shrink: 0;
        }

        .admin-text-limit {
            color: #4b5563;
            line-height: 1.45;
            word-break: break-word;
        }

        .admin-badge {
            display: inline-flex;
            justify-content: center;
            align-items: center;
            max-width: 100%;
            padding: 6px 10px;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 700;
            line-height: 1.25;
            white-space: normal;
            text-align: center;
        }

        .admin-badge-role {
            background: #eef2ff;
            color: #3730a3;
        }

        .admin-badge-linked {
            background: #ecfeff;
            color: #155e75;
        }

        .admin-badge-muted {
            background: #f3f4f6;
            color: #4b5563;
        }

        .admin-badge-success {
            background: #ecfdf5;
            color: #166534;
        }

        .admin-actions {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 8px;
        }

            .admin-actions .btn {
                min-width: 64px;
                border-radius: 7px;
                font-size: 0.8rem;
                font-weight: 700;
                white-space: nowrap;
                padding: 6px 10px;
            }

        @@media (max-width: 1199.98px) {
            .department-table {
                min-width: 1080px;
            }
        }

        @@media (max-width: 767.98px) {
            .admin-page-header {
                flex-direction: column;
            }

            .admin-btn-main {
                width: 100%;
            }

            .admin-filter-actions {
                flex-direction: column;
            }
        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const arrows = document.querySelectorAll(".toggle-arrow");

            arrows.forEach(arrow => {
                arrow.addEventListener("click", function () {
                    const targetClass = this.getAttribute("data-target");
                    const rows = document.querySelectorAll("." + targetClass);

                    let isVisible = false;

                    rows.forEach(row => {
                        if (row.style.display !== "none") {
                            isVisible = true;
                        }
                    });

                    rows.forEach(row => {
                        row.style.display = isVisible ? "none" : "table-row";
                    });

                    this.textContent = isVisible ? "▶" : "▼";
                });
            });
        });
    </script>
}