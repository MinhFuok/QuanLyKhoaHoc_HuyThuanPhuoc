@model IEnumerable<QLKH.Domain.Entities.Department>

@{
    ViewData["Title"] = "Chương trình đào tạo";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";

    var keyword = (ViewBag.Keyword as string ?? "").Trim();

    var allDepartments = Model?.ToList() ?? new List<QLKH.Domain.Entities.Department>();

    var allParents = allDepartments
        .Where(d => d.ParentDepartmentId == null)
        .OrderBy(d => d.DepartmentCode)
        .ToList();

    var allChildren = allDepartments
        .Where(d => d.ParentDepartmentId != null)
        .OrderBy(d => d.ParentDepartmentId)
        .ThenBy(d => d.DepartmentCode)
        .ToList();

    var hasKeyword = !string.IsNullOrWhiteSpace(keyword);

    var parentDepartments = allParents;
    var childDepartments = allChildren;

    if (hasKeyword)
    {
        var lowerKeyword = keyword.ToLower();

        var matchedParentIds = allParents
            .Where(p => (p.DepartmentName ?? "").ToLower().Contains(lowerKeyword))
            .Select(p => p.Id)
            .ToHashSet();

        var matchedChildren = allChildren
            .Where(c => (c.DepartmentName ?? "").ToLower().Contains(lowerKeyword))
            .ToList();

        var parentIdsFromMatchedChildren = matchedChildren
            .Where(c => c.ParentDepartmentId.HasValue)
            .Select(c => c.ParentDepartmentId!.Value)
            .ToHashSet();

        var finalParentIds = matchedParentIds
            .Union(parentIdsFromMatchedChildren)
            .ToHashSet();

        parentDepartments = allParents
            .Where(p => finalParentIds.Contains(p.Id))
            .OrderBy(p => p.DepartmentCode)
            .ToList();

        childDepartments = allChildren
            .Where(c =>
                c.ParentDepartmentId.HasValue &&
                (
                    matchedParentIds.Contains(c.ParentDepartmentId.Value) ||
                    (c.DepartmentName ?? "").ToLower().Contains(lowerKeyword)
                ))
            .OrderBy(c => c.ParentDepartmentId)
            .ThenBy(c => c.DepartmentCode)
            .ToList();
    }
}

<div class="admin-account-page admin-program-page">
    <div class="admin-page-header">
        <div>
            <h2 class="admin-page-title">CHƯƠNG TRÌNH ĐÀO TẠO</h2>
            <p class="admin-page-subtitle">
                Quản lý danh sách chương trình và khóa đào tạo của nền tảng...
            </p>
        </div>

        <a asp-area="Admin"
           asp-controller="Department"
           asp-action="Create"
           class="btn btn-primary admin-btn-main">
            + Thêm chương trình
        </a>
    </div>

    <div class="admin-filter-card">
        <form asp-area="Admin"
              asp-controller="Department"
              asp-action="Index"
              method="get">

            <div class="row g-3 align-items-end">
                <div class="col-12 col-lg-8">
                    <label class="form-label admin-label">Tìm theo tên chương trình hoặc khóa</label>
                    <input type="text"
                           name="keyword"
                           value="@keyword"
                           class="form-control admin-input"
                           placeholder="Nhập tên chương trình hoặc khóa..." />
                </div>

                <div class="col-12 col-lg-4">
                    <div class="admin-filter-actions">
                        <button type="submit" class="btn btn-primary">
                            Lọc
                        </button>

                        <a asp-area="Admin"
                           asp-controller="Department"
                           asp-action="Index"
                           class="btn btn-outline-secondary">
                            Bỏ lọc
                        </a>
                    </div>
                </div>
            </div>
        </form>

        @if (hasKeyword)
        {
            <div class="admin-filter-note">
                Đang lọc theo từ khóa: <strong>@keyword</strong>
            </div>
        }
    </div>

    <div class="admin-table-card">
        <div class="admin-table-title">
            <span>Danh sách chương trình/khóa</span>
        </div>

        <div class="table-responsive">
            <table class="table admin-table department-table align-middle mb-0">
                <colgroup>
                    <col style="width: 8%;" />
                    <col style="width: 22%;" />
                    <col style="width: 28%;" />
                    <col style="width: 12%;" />
                    <col style="width: 12%;" />
                    <col style="width: 17%;" />
                </colgroup>

                <thead>
                    <tr>
                        <th class="text-center">Mã</th>
                        <th class="text-center">Tên chương trình</th>
                        <th class="text-center">Mã t?</th>
                        <th class="text-center">Loại</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>

                <tbody>
                    @if (parentDepartments.Any())
                    {
                        foreach (var parent in parentDepartments)
                        {
                            var children = childDepartments
                            .Where(c => c.ParentDepartmentId == parent.Id)
                            .ToList();

                            var groupId = $"group-{parent.Id}";

                            <tr class="program-parent-row">
                                <td class="text-center">
                                    <span class="admin-code">@parent.DepartmentCode</span>
                                </td>

                                <td>
                                    <div class="program-name-wrap">
                                        <span class="toggle-arrow"
                                              data-target="@groupId"
                                              title="Ẩn/hiện khóa thuộc chương trình">
                                            ?
                                        </span>

                                        <span class="admin-name">@parent.DepartmentName</span>
                                    </div>
                                </td>

                                <td>
                                    <div class="admin-text-limit">
                                        @(string.IsNullOrWhiteSpace(parent.Description) ? "Chưa có mô tả" : parent.Description)
                                    </div>
                                </td>

                                <td class="text-center">
                                    <span class="admin-badge admin-badge-role">Chương trình</span>
                                </td>

                                <td class="text-center">
                                    @if (parent.IsActive)
                                    {
                                        <span class="admin-badge admin-badge-success">Đang sử dụng</span>
                                    }
                                    else
                                    {
                                        <span class="admin-badge admin-badge-muted">Ngưng sử dụng</span>
                                    }
                                </td>

                                <td class="text-center">
                                    <div class="admin-actions department-actions">
                                        <a asp-area="Admin"
                                           asp-controller="Department"
                                           asp-action="Edit"
                                           asp-route-id="@parent.Id"
                                           class="admin-icon-action admin-action-edit"
                                           data-label="Sửa"
                                           title="Sửa"
                                           aria-label="Sửa">
                                            <svg class="edit-svgIcon" viewBox="0 0 512 512" aria-hidden="true">
                                                <path d="M410.3 231l11.3-11.3-33.9-33.9-62.1-62.1L291.7 89.8l-11.3 11.3-22.6 22.6L58.6 322.9c-10.4 10.4-18 23.3-22.2 37.4L1 480.7c-2.5 8.4-.2 17.5 6.1 23.7s15.3 8.5 23.7 6.1l120.3-35.4c14.1-4.2 27-11.8 37.4-22.2L387.7 253.7 410.3 231zM160 399.4l-9.1 22.7c-4 3.1-8.5 5.4-13.3 6.9L59.4 452l23-78.1c1.4-4.9 3.8-9.4 6.9-13.3l22.7-9.1v32c0 8.8 7.2 16 16 16h32zM362.7 18.7L348.3 33.2 325.7 55.8 314.3 67.1l33.9 33.9 62.1 62.1 33.9 33.9 11.3-11.3 22.6-22.6 14.5-14.5c25-25 25-65.5 0-90.5L453.3 18.7c-25-25-65.5-25-90.5 0zm-47.4 168l-144 144c-6.2 6.2-16.4 6.2-22.6 0s-6.2-16.4 0-22.6l144-144c6.2-6.2 16.4-6.2 22.6 0s6.2 16.4 0 22.6z"></path>
                                            </svg>
                                        </a>

                                        <a asp-area="Admin"
                                           asp-controller="Department"
                                           asp-action="Delete"
                                           asp-route-id="@parent.Id"
                                           class="admin-icon-action admin-action-delete"
                                           data-label="Xóa"
                                           title="Xóa"
                                           aria-label="Xóa">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 39 7" class="bin-top" aria-hidden="true">
                                                <line stroke-width="4" stroke="white" y2="5" x2="39" y1="5"></line>
                                                <line stroke-width="3" stroke="white" y2="1.5" x2="26.0357" y1="1.5" x1="12"></line>
                                            </svg>
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 33 39" class="bin-bottom" aria-hidden="true">
                                                <mask fill="white" id="department-delete-mask-parent-@parent.Id">
                                                    <path d="M0 0H33V35C33 37.2091 31.2091 39 29 39H4C1.79086 39 0 37.2091 0 35V0Z"></path>
                                                </mask>
                                                <path mask="url(#department-delete-mask-parent-@parent.Id)" fill="white" d="M0 0H33H0ZM37 35C37 39.4183 33.4183 43 29 43H4C-0.418278 43 -4 39.4183 -4 35H4H29H37ZM4 43C-0.418278 43 -4 39.4183 -4 35V0H4V35V43ZM37 0V35C37 39.4183 33.4183 43 29 43V35V0H37Z"></path>
                                                <path stroke-width="4" stroke="white" d="M12 6L12 29"></path>
                                                <path stroke-width="4" stroke="white" d="M21 6V29"></path>
                                            </svg>
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 89 80" class="garbage" aria-hidden="true">
                                                <path fill="white" d="M20.5 10.5L37.5 15.5L42.5 11.5L51.5 12.5L68.75 0L72 11.5L79.5 12.5H88.5L87 22L68.75 31.5L75.5066 25L86 26L87 35.5L77.5 48L70.5 49.5L80 50L77.5 71.5L63.5 58.5L53.5 68.5L65.5 70.5L45.5 73L35.5 79.5L28 67L16 63L12 51.5L0 48L16 25L22.5 17L20.5 10.5Z"></path>
                                            </svg>
                                        </a>
                                    </div>
                                </td>
                            </tr>

                            if (children.Any())
                            {
                                foreach (var child in children)
                                {
                                    <tr class="@groupId child-row">
                                        <td class="text-center">
                                            <span class="admin-code child-code">@child.DepartmentCode</span>
                                        </td>

                                        <td>
                                            <div class="program-child-name">
                                                <span class="child-mark">?</span>
                                                <span>@child.DepartmentName</span>
                                            </div>
                                        </td>

                                        <td>
                                            <div class="admin-text-limit">
                                                @(string.IsNullOrWhiteSpace(child.Description) ? "Chưa có mô tả" : child.Description)
                                            </div>
                                        </td>

                                        <td class="text-center">
                                            <span class="admin-badge admin-badge-linked">Khóa</span>
                                        </td>

                                        <td class="text-center">
                                            @if (child.IsActive)
                                            {
                                                <span class="admin-badge admin-badge-success">Đang sử dụng</span>
                                            }
                                            else
                                            {
                                                <span class="admin-badge admin-badge-muted">Ngưng sử dụng</span>
                                            }
                                        </td>

                                        <td class="text-center">
                                            <div class="admin-actions department-actions">
                                                <a asp-area="Admin"
                                                   asp-controller="Department"
                                                   asp-action="Edit"
                                                   asp-route-id="@child.Id"
                                                   class="admin-icon-action admin-action-edit"
                                                   data-label="Sửa"
                                                   title="Sửa"
                                                   aria-label="Sửa">
                                                    <svg class="edit-svgIcon" viewBox="0 0 512 512" aria-hidden="true">
                                                        <path d="M410.3 231l11.3-11.3-33.9-33.9-62.1-62.1L291.7 89.8l-11.3 11.3-22.6 22.6L58.6 322.9c-10.4 10.4-18 23.3-22.2 37.4L1 480.7c-2.5 8.4-.2 17.5 6.1 23.7s15.3 8.5 23.7 6.1l120.3-35.4c14.1-4.2 27-11.8 37.4-22.2L387.7 253.7 410.3 231zM160 399.4l-9.1 22.7c-4 3.1-8.5 5.4-13.3 6.9L59.4 452l23-78.1c1.4-4.9 3.8-9.4 6.9-13.3l22.7-9.1v32c0 8.8 7.2 16 16 16h32zM362.7 18.7L348.3 33.2 325.7 55.8 314.3 67.1l33.9 33.9 62.1 62.1 33.9 33.9 11.3-11.3 22.6-22.6 14.5-14.5c25-25 25-65.5 0-90.5L453.3 18.7c-25-25-65.5-25-90.5 0zm-47.4 168l-144 144c-6.2 6.2-16.4 6.2-22.6 0s-6.2-16.4 0-22.6l144-144c6.2-6.2 16.4-6.2 22.6 0s6.2 16.4 0 22.6z"></path>
                                                    </svg>
                                                </a>

                                                <a asp-area="Admin"
                                                   asp-controller="Department"
                                                   asp-action="Delete"
                                                   asp-route-id="@child.Id"
                                                   class="admin-icon-action admin-action-delete"
                                                   data-label="Xóa"
                                                   title="Xóa"
                                                   aria-label="Xóa">
                                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 39 7" class="bin-top" aria-hidden="true">
                                                        <line stroke-width="4" stroke="white" y2="5" x2="39" y1="5"></line>
                                                        <line stroke-width="3" stroke="white" y2="1.5" x2="26.0357" y1="1.5" x1="12"></line>
                                                    </svg>
                                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 33 39" class="bin-bottom" aria-hidden="true">
                                                        <mask fill="white" id="department-delete-mask-child-@child.Id">
                                                            <path d="M0 0H33V35C33 37.2091 31.2091 39 29 39H4C1.79086 39 0 37.2091 0 35V0Z"></path>
                                                        </mask>
                                                        <path mask="url(#department-delete-mask-child-@child.Id)" fill="white" d="M0 0H33H0ZM37 35C37 39.4183 33.4183 43 29 43H4C-0.418278 43 -4 39.4183 -4 35H4H29H37ZM4 43C-0.418278 43 -4 39.4183 -4 35V0H4V35V43ZM37 0V35C37 39.4183 33.4183 43 29 43V35V0H37Z"></path>
                                                        <path stroke-width="4" stroke="white" d="M12 6L12 29"></path>
                                                        <path stroke-width="4" stroke="white" d="M21 6V29"></path>
                                                    </svg>
                                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 89 80" class="garbage" aria-hidden="true">
                                                        <path fill="white" d="M20.5 10.5L37.5 15.5L42.5 11.5L51.5 12.5L68.75 0L72 11.5L79.5 12.5H88.5L87 22L68.75 31.5L75.5066 25L86 26L87 35.5L77.5 48L70.5 49.5L80 50L77.5 71.5L63.5 58.5L53.5 68.5L65.5 70.5L45.5 73L35.5 79.5L28 67L16 63L12 51.5L0 48L16 25L22.5 17L20.5 10.5Z"></path>
                                                    </svg>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr class="@groupId child-row">
                                    <td colspan="7" class="text-center text-muted py-3">
                                        @(hasKeyword ? "Không có khóa phù hợp với từ khóa." : "Chương trình này chưa có khóa.")
                                    </td>
                                </tr>
                            }
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                @(hasKeyword ? "Không tìm thấy chương trình hoặc khóa phù hợp." : "Chưa có dữ liệu.")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const arrows = document.querySelectorAll(".toggle-arrow");

            arrows.forEach(arrow => {
                arrow.addEventListener("click", function () {
                    const targetClass = this.getAttribute("data-target");
                    const rows = document.querySelectorAll("." + targetClass);

                    let isVisible = false;

                    rows.forEach(row => {
                        if (row.style.display !== "none") {
                            isVisible = true;
                        }
                    });

                    rows.forEach(row => {
                        row.style.display = isVisible ? "none" : "table-row";
                    });

                    this.textContent = isVisible ? "?" : "?";
                });
            });
        });
    </script>
}
