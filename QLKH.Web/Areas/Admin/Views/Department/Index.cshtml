@model IEnumerable<QLKH.Domain.Entities.Department>

@{
    ViewData["Title"] = "Chương trình đào tạo";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";

    var parentDepartments = Model?
        .Where(d => d.ParentDepartmentId == null)
        .OrderBy(d => d.DepartmentCode)
        .ToList() ?? new List<QLKH.Domain.Entities.Department>();

    var childDepartments = Model?
        .Where(d => d.ParentDepartmentId != null)
        .OrderBy(d => d.ParentDepartmentId)
        .ThenBy(d => d.DepartmentCode)
        .ToList() ?? new List<QLKH.Domain.Entities.Department>();
}

<h2 class="mb-4">CHƯƠNG TRÌNH ĐÀO TẠO</h2>

<div class="mb-3">
    <a asp-area="Admin" asp-controller="Department" asp-action="Create" class="btn btn-primary">
        + Thêm chương trình
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-bordered table-striped align-middle">
            <thead>
                <tr>
                    <th style="width: 90px;">Mã</th>
                    <th>Tên chương trình</th>
                    <th>Mô tả</th>
                    <th style="width: 120px;">Loại</th>
                    <th style="width: 180px;">Thuộc nhóm</th>
                    <th style="width: 140px;">Trạng thái</th>
                    <th style="width: 160px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (parentDepartments.Any())
                {
                    foreach (var parent in parentDepartments)
                    {
                        var children = childDepartments
                        .Where(c => c.ParentDepartmentId == parent.Id)
                        .ToList();

                        var groupId = $"group-{parent.Id}";

                        <tr class="table-light fw-bold">
                            <td>@parent.DepartmentCode</td>
                            <td>
                                <span class="toggle-arrow me-2"
                                      data-target="@groupId"
                                      style="cursor:pointer; user-select:none; display:inline-block; width:16px; color:#6c757d; font-size:14px;">
                                    ▼
                                </span>
                                @parent.DepartmentName
                            </td>
                            <td>@parent.Description</td>
                            <td>
                                <span class="badge bg-primary">Chương trình</span>
                            </td>
                            <td>-</td>
                            <td>
                                @if (parent.IsActive)
                                {
                                    <span class="badge bg-success">Đang sử dụng</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Ngưng sử dụng</span>
                                }
                            </td>
                            <td>
                                <a asp-area="Admin"
                                   asp-controller="Department"
                                   asp-action="Edit"
                                   asp-route-id="@parent.Id"
                                   class="btn btn-warning btn-sm">
                                    Sửa
                                </a>
                                <a asp-area="Admin"
                                   asp-controller="Department"
                                   asp-action="Delete"
                                   asp-route-id="@parent.Id"
                                   class="btn btn-danger btn-sm">
                                    Xóa
                                </a>
                            </td>
                        </tr>

                        if (children.Any())
                        {
                            foreach (var child in children)
                            {
                                <tr class="@groupId child-row">
                                    <td>@child.DepartmentCode</td>
                                    <td class="ps-5">↳ @child.DepartmentName</td>
                                    <td>@child.Description</td>
                                    <td>
                                        <span class="badge bg-info text-dark">Khóa</span>
                                    </td>
                                    <td>@parent.DepartmentName</td>
                                    <td>
                                        @if (child.IsActive)
                                        {
                                            <span class="badge bg-success">Đang sử dụng</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Ngưng sử dụng</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-area="Admin"
                                           asp-controller="Department"
                                           asp-action="Edit"
                                           asp-route-id="@child.Id"
                                           class="btn btn-warning btn-sm">
                                            Sửa
                                        </a>
                                        <a asp-area="Admin"
                                           asp-controller="Department"
                                           asp-action="Delete"
                                           asp-route-id="@child.Id"
                                           class="btn btn-danger btn-sm">
                                            Xóa
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr class="@groupId child-row">
                                <td colspan="7" class="text-center text-muted">
                                    Chương trình này chưa có khóa.
                                </td>
                            </tr>
                        }
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center">Chưa có dữ liệu.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const arrows = document.querySelectorAll(".toggle-arrow");

            arrows.forEach(arrow => {
                arrow.addEventListener("click", function () {
                    const targetClass = this.getAttribute("data-target");
                    const rows = document.querySelectorAll("." + targetClass);

                    let isVisible = false;

                    rows.forEach(row => {
                        if (row.style.display !== "none") {
                            isVisible = true;
                        }
                    });

                    rows.forEach(row => {
                        row.style.display = isVisible ? "none" : "table-row";
                    });

                    this.textContent = isVisible ? "▶" : "▼";
                });
            });
        });
    </script>
}