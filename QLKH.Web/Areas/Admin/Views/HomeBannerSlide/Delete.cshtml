@model QLKH.Web.Areas.Admin.Models.HomeBannerSlideViewModel

@{
    ViewData["Title"] = "Xóa banner";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="admin-account-page admin-banner-page">
    <div class="admin-page-header admin-page-header--danger">
        <div>
            <h2 class="admin-page-title">XÓA BANNER</h2>
        </div>

        <a asp-area="Admin"
           asp-controller="SystemSettings"
           asp-action="Index"
           class="btn btn-outline-secondary admin-btn-main">
            Quay lại
        </a>
    </div>

    <div class="admin-delete-card">
        <div class="admin-delete-title">
            <span>Thông tin banner</span>
        </div>

        <div class="admin-delete-body">
            <div class="admin-warning-box">
                <strong>Cảnh báo:</strong>
                Bạn có chắc chắn muốn xóa banner này không?
            </div>

            <div class="admin-detail-list">
                <div class="admin-detail-row">
                    <div class="admin-detail-label">Tiêu đề</div>
                    <div class="admin-detail-value">@Model.Title</div>
                </div>

                <div class="admin-detail-row">
                    <div class="admin-detail-label">?nh</div>
                    <div class="admin-detail-value">
                        @if (!string.IsNullOrWhiteSpace(Model.ExistingImageUrl))
                        {
                            <img src="@Model.ExistingImageUrl"
                                 alt="@Model.AltText"
                                 class="admin-delete-image" />
                        }
                        else
                        {
                            <span class="text-muted">Chưa có ảnh</span>
                        }
                    </div>
                </div>

                <div class="admin-detail-row">
                    <div class="admin-detail-label">Mô tả ảnh</div>
                    <div class="admin-detail-value">
                        @(string.IsNullOrWhiteSpace(Model.AltText) ? "Chưa có mô tả" : Model.AltText)
                    </div>
                </div>

                <div class="admin-detail-row">
                    <div class="admin-detail-label">Th? t? hiển thị</div>
                    <div class="admin-detail-value">@Model.DisplayOrder</div>
                </div>

                <div class="admin-detail-row">
                    <div class="admin-detail-label">Trạng thái</div>
                    <div class="admin-detail-value">
                        @if (Model.IsActive)
                        {
                            <span class="admin-badge admin-badge-success">Đang hiển thị</span>
                        }
                        else
                        {
                            <span class="admin-badge admin-badge-muted">Đã ẩn</span>
                        }
                    </div>
                </div>
            </div>

            <form asp-area="Admin" asp-controller="HomeBannerSlide" asp-action="Delete" method="post">
                @Html.AntiForgeryToken()

                <input asp-for="Id" type="hidden" />

                <div class="admin-form-actions">
                    <button type="submit"
                            class="btn btn-danger"
                            onclick="return confirm('Bạn có chắc chắn muốn xóa banner này không?');">
                        Xác nhận xóa
                    </button>

                    <a asp-area="Admin"
                       asp-controller="SystemSettings"
                       asp-action="Index"
                       class="btn btn-outline-secondary">
                        Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

