@model IEnumerable<QLKH.Web.Areas.Admin.Models.HomeBannerSlideViewModel>

@{
    ViewData["Title"] = "Quản lý slide banner";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<h2 class="mb-4">Quản lý slide banner trang chủ</h2>

<div class="mb-3">
    <a asp-area="Admin" asp-controller="HomeBannerSlide" asp-action="Create" class="btn btn-primary">
        + Thêm slide mới
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-bordered table-striped align-middle">
            <thead>
                <tr>
                    <th>Thứ tự</th>
                    <th>Tiêu đề</th>
                    <th>Ảnh</th>
                    <th>Mô tả ảnh</th>
                    <th>Trạng thái</th>
                    <th style="width: 220px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.DisplayOrder</td>
                        <td>@item.Title</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(item.ExistingImageUrl))
                            {
                                <img src="@item.ExistingImageUrl" alt="@item.AltText" style="height:70px; border-radius:6px;" />
                            }
                        </td>
                        <td>@item.AltText</td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success">Đang hiển thị</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Đã ẩn</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex flex-wrap gap-1">
                                <form asp-area="Admin" asp-controller="HomeBannerSlide" asp-action="MoveUp" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-outline-secondary btn-sm">↑</button>
                                </form>

                                <form asp-area="Admin" asp-controller="HomeBannerSlide" asp-action="MoveDown" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-outline-secondary btn-sm">↓</button>
                                </form>

                                <a asp-area="Admin" asp-controller="HomeBannerSlide" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                    Sửa
                                </a>
                                <a asp-area="Admin" asp-controller="HomeBannerSlide" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                    Xóa
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>