@model QLKH.Web.Areas.Admin.Models.HomeBannerSlideViewModel

@{
    ViewData["Title"] = "Sửa banner";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<h2 class="mb-4">SỬA BANNER</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-area="Admin" asp-controller="HomeBannerSlide" asp-action="Edit" method="post" enctype="multipart/form-data">
            <input asp-for="Id" type="hidden" />
            <input asp-for="ExistingImageUrl" type="hidden" />
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Ảnh hiện tại</label><br />
                @if (!string.IsNullOrWhiteSpace(Model.ExistingImageUrl))
                {
                    <img src="@Model.ExistingImageUrl" alt="@Model.AltText" style="max-height:120px; border-radius:8px;" />
                }
                else
                {
                    <span class="text-muted">Chưa có ảnh</span>
                }
            </div>

            <div class="mb-3">
                <label asp-for="ImageFile" class="form-label"></label>
                <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                <span class="form-text">Để trống nếu không muốn thay ảnh.</span>
            </div>

            <div class="mb-3">
                <label asp-for="AltText" class="form-label"></label>
                <input asp-for="AltText" class="form-control" />
                <span class="form-text">Mô tả ngắn cho ảnh banner.</span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Xác nhận thay đổi</button>
                <a asp-area="Admin" asp-controller="SystemSettings" asp-action="Index" class="btn btn-secondary">
                    Hủy
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}