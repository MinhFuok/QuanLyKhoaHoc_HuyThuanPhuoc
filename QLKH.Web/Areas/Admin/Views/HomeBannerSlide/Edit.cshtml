@model QLKH.Web.Areas.Admin.Models.HomeBannerSlideViewModel

@{
    ViewData["Title"] = "Sửa banner";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="admin-account-page admin-banner-page">
    <div class="admin-page-header">
        <div>
            <h2 class="admin-page-title">SỬA BANNER</h2>
        </div>

        <a asp-area="Admin"
           asp-controller="SystemSettings"
           asp-action="Index"
           class="btn btn-outline-secondary admin-btn-main">
            Quay lại
        </a>
    </div>

    <div class="admin-form-card">
        <div class="admin-form-title">
            <span>Thông tin banner</span>
        </div>

        <form asp-area="Admin"
              asp-controller="HomeBannerSlide"
              asp-action="Edit"
              method="post"
              enctype="multipart/form-data">

            @Html.AntiForgeryToken()

            <input asp-for="Id" type="hidden" />
            <input asp-for="ExistingImageUrl" type="hidden" />

            <div asp-validation-summary="All" class="text-danger admin-validation"></div>

            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Title" class="form-label admin-label"></label>
                    <input asp-for="Title"
                           class="form-control admin-input"
                           placeholder="Nhập tiêu đề banner..." />
                    <span asp-validation-for="Title" class="text-danger admin-field-error"></span>
                </div>

                <div class="col-12">
                    <label class="form-label admin-label">Ảnh hiện tại</label>

                    <div class="admin-current-image-box">
                        @if (!string.IsNullOrWhiteSpace(Model.ExistingImageUrl))
                        {
                            <img src="@Model.ExistingImageUrl"
                                 alt="@Model.AltText"
                                 class="admin-current-image" />
                        }
                        else
                        {
                            <span class="text-muted">Chưa có ảnh</span>
                        }
                    </div>
                </div>

                <div class="col-12">
                    <label asp-for="ImageFile" class="form-label admin-label"></label>
                    <input asp-for="ImageFile"
                           type="file"
                           class="form-control admin-input"
                           accept="image/*" />
                    <span asp-validation-for="ImageFile" class="text-danger admin-field-error"></span>
                    <div class="admin-help-text">Để trống nếu không muốn thay ảnh.</div>
                </div>

                <div class="col-12">
                    <label asp-for="AltText" class="form-label admin-label"></label>
                    <input asp-for="AltText"
                           class="form-control admin-input"
                           placeholder="Nhập mô tả ngắn cho ảnh banner..." />
                    <span asp-validation-for="AltText" class="text-danger admin-field-error"></span>
                    <div class="admin-help-text">Mô tả ngắn cho ảnh banner.</div>
                </div>

                <div class="col-12">
                    <div class="admin-check-row">
                        <input asp-for="IsActive" class="form-check-input admin-check-input" />
                        <label asp-for="IsActive" class="form-check-label admin-check-label"></label>
                    </div>
                </div>
            </div>

            <div class="admin-form-actions">
                <button type="submit" class="btn btn-primary">
                    Xác nhận thay đổi
                </button>

                <a asp-area="Admin"
                   asp-controller="SystemSettings"
                   asp-action="Index"
                   class="btn btn-outline-secondary">
                    Hủy
                </a>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <style>
        .admin-account-page {
            color: #1f2937;
        }

        .admin-page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 18px;
            padding-bottom: 14px;
            border-bottom: 1px solid #e5e7eb;
        }

        .admin-page-title {
            margin: 0;
            color: #111827;
            font-size: 1.55rem;
            font-weight: 800;
            letter-spacing: -0.02em;
        }

        .admin-btn-main {
            border-radius: 8px;
            font-weight: 700;
            white-space: nowrap;
            padding: 9px 14px;
        }

        .admin-form-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            overflow: hidden;
            margin-bottom: 16px;
        }

        .admin-form-title {
            padding: 13px 16px;
            border-bottom: 1px solid #e5e7eb;
            color: #111827;
            font-weight: 800;
            background: #f9fafb;
        }

        .admin-form-card form {
            padding: 16px;
        }

        .admin-label {
            color: #374151;
            font-weight: 700;
            font-size: 0.9rem;
            margin-bottom: 6px;
        }

        .admin-input {
            border-radius: 8px;
            border-color: #d1d5db;
            min-height: 40px;
            font-size: 0.94rem;
        }

            .admin-input:focus {
                border-color: #2563eb;
                box-shadow: 0 0 0 0.18rem rgba(37, 99, 235, 0.12);
            }

        .admin-validation {
            margin-bottom: 14px;
            font-size: 0.9rem;
        }

        .admin-field-error {
            font-size: 0.84rem;
            margin-top: 4px;
            display: block;
        }

        .admin-help-text {
            margin-top: 6px;
            color: #6b7280;
            font-size: 0.84rem;
        }

        .admin-current-image-box {
            min-height: 130px;
            padding: 12px;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            background: #f9fafb;
            display: flex;
            align-items: center;
        }

        .admin-current-image {
            max-height: 120px;
            max-width: 100%;
            object-fit: cover;
            border-radius: 8px;
            border: 1px solid #e5e7eb;
            background: #ffffff;
        }

        .admin-check-row {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 14px;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            background: #f9fafb;
        }

        .admin-check-input {
            margin: 0;
            width: 18px;
            height: 18px;
        }

        .admin-check-label {
            color: #374151;
            font-weight: 700;
            margin: 0;
        }

        .admin-form-actions {
            display: flex;
            gap: 8px;
            justify-content: flex-end;
            margin-top: 18px;
            padding-top: 16px;
            border-top: 1px solid #e5e7eb;
        }

            .admin-form-actions .btn {
                border-radius: 8px;
                font-weight: 700;
                min-width: 120px;
            }

        @@media (max-width: 767.98px) {
            .admin-page-header {
                flex-direction: column;
            }

            .admin-btn-main,
            .admin-form-actions .btn {
                width: 100%;
            }

            .admin-form-actions {
                flex-direction: column;
            }
        }
    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}