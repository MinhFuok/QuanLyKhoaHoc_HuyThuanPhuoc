@model QLKH.Web.Areas.Admin.Models.HomeBannerSlideViewModel

@{
    ViewData["Title"] = "Thêm slide banner";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<h2 class="mb-4">Thêm slide banner</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-area="Admin" asp-controller="HomeBannerSlide" asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="ImageFile" class="form-label"></label>
                <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                <span asp-validation-for="ImageFile" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="AltText" class="form-label"></label>
                <input asp-for="AltText" class="form-control" />
                <span class="form-text">Mô tả ngắn cho ảnh banner.</span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>

            <div class="alert alert-info">
                Thứ tự hiển thị sẽ được hệ thống tự động sắp ở cuối danh sách.
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Lưu</button>
                <a asp-area="Admin" asp-controller="SystemSettings" asp-action="Index" class="btn btn-secondary">
                    Quay lại
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}