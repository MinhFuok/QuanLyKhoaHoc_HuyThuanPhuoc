@model QLKH.Web.Areas.Admin.Models.SystemSettingViewModel

@{
    ViewData["Title"] = "Cấu hình hệ thống";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<h2 class="mb-4">Cấu hình hệ thống</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-area="Admin" asp-controller="SystemSettings" asp-action="Index" method="post" enctype="multipart/form-data">
            <input asp-for="Id" type="hidden" />
            <input asp-for="HomeBannerImageUrl" type="hidden" />

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <ul class="nav nav-tabs" id="systemSettingTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="website-tab" data-bs-toggle="tab" data-bs-target="#website-pane" type="button" role="tab">
                        Giao diện website
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="contact-tab" data-bs-toggle="tab" data-bs-target="#contact-pane" type="button" role="tab">
                        Liên hệ
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="status-tab" data-bs-toggle="tab" data-bs-target="#status-pane" type="button" role="tab">
                        Trạng thái website
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="email-tab" data-bs-toggle="tab" data-bs-target="#email-pane" type="button" role="tab">
                        Email hệ thống
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="payment-tab" data-bs-toggle="tab" data-bs-target="#payment-pane" type="button" role="tab">
                        Thanh toán
                    </button>
                </li>
            </ul>

            <div class="tab-content border border-top-0 p-4" id="systemSettingTabsContent">
                <div class="tab-pane fade show active" id="website-pane" role="tabpanel">
                    <div class="mb-3">
                        <label asp-for="SiteName" class="form-label"></label>
                        <input asp-for="SiteName" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="HomeBannerTitle" class="form-label"></label>
                        <input asp-for="HomeBannerTitle" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="HomeBannerSubtitle" class="form-label"></label>
                        <input asp-for="HomeBannerSubtitle" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="BannerImageFile" class="form-label"></label>
                        <input asp-for="BannerImageFile" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                        <span asp-validation-for="BannerImageFile" class="text-danger"></span>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.HomeBannerImageUrl))
                    {
                        <div class="mb-3">
                            <label class="form-label">Ảnh banner hiện tại</label><br />
                            <img src="@Model.HomeBannerImageUrl" alt="Banner hiện tại" style="max-width:300px; height:auto; border:1px solid #ddd; padding:4px;" />
                            <div class="mt-2 text-muted">@Model.HomeBannerImageUrl</div>
                        </div>
                    }

                    <div class="mb-3">
                        <label asp-for="FooterText" class="form-label"></label>
                        <input asp-for="FooterText" class="form-control" />
                    </div>
                </div>

                <div class="tab-pane fade" id="contact-pane" role="tabpanel">
                    <div class="mb-3">
                        <label asp-for="ContactEmail" class="form-label"></label>
                        <input asp-for="ContactEmail" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="ContactPhone" class="form-label"></label>
                        <input asp-for="ContactPhone" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="ContactAddress" class="form-label"></label>
                        <input asp-for="ContactAddress" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="FacebookUrl" class="form-label"></label>
                        <input asp-for="FacebookUrl" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="YoutubeUrl" class="form-label"></label>
                        <input asp-for="YoutubeUrl" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="TiktokUrl" class="form-label"></label>
                        <input asp-for="TiktokUrl" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="XUrl" class="form-label"></label>
                        <input asp-for="XUrl" class="form-control" />
                    </div>
                </div>

                <div class="tab-pane fade" id="status-pane" role="tabpanel">
                    <div class="form-check mb-3">
                        <input asp-for="IsWebsiteEnabled" class="form-check-input" />
                        <label asp-for="IsWebsiteEnabled" class="form-check-label"></label>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MaintenanceMessage" class="form-label"></label>
                        <textarea asp-for="MaintenanceMessage" class="form-control" rows="4"></textarea>
                    </div>
                </div>

                <div class="tab-pane fade" id="email-pane" role="tabpanel">
                    <div class="form-check mb-3">
                        <input asp-for="EnableEmail" class="form-check-input" />
                        <label asp-for="EnableEmail" class="form-check-label"></label>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SmtpServer" class="form-label"></label>
                        <input asp-for="SmtpServer" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="SmtpPort" class="form-label"></label>
                        <input asp-for="SmtpPort" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="SenderName" class="form-label"></label>
                        <input asp-for="SenderName" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="SenderEmail" class="form-label"></label>
                        <input asp-for="SenderEmail" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="SmtpUsername" class="form-label"></label>
                        <input asp-for="SmtpUsername" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="SmtpPassword" class="form-label"></label>
                        <input asp-for="SmtpPassword" class="form-control" />
                    </div>
                </div>

                <div class="tab-pane fade" id="payment-pane" role="tabpanel">
                    <div class="form-check mb-2">
                        <input asp-for="EnableVnPay" class="form-check-input" />
                        <label asp-for="EnableVnPay" class="form-check-label"></label>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="EnableMomo" class="form-check-input" />
                        <label asp-for="EnableMomo" class="form-check-label"></label>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Lưu cấu hình</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}