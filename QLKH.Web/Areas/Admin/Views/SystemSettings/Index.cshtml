@model QLKH.Web.Areas.Admin.Models.SystemSettingsPageViewModel

@{
    ViewData["Title"] = "Cấu hình hệ thống";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="admin-account-page admin-system-page">
    <div class="admin-page-header">
        <div>
            <h2 class="admin-page-title">CẤU HÌNH HỆ THỐNG</h2>
            <p class="admin-page-subtitle">
                Quản lý thông tin website, banner, liên hệ, bảo trì và email hệ thống...
            </p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success admin-alert">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="admin-table-card admin-system-card">
        <div class="admin-table-title">
            <span>Thiết lập hệ thống</span>
        </div>

        <div class="admin-system-body">
            <div class="admin-tabbar admin-system-tabs" id="systemSettingTabs" role="tablist">
                <button class="nav-link admin-tab active"
                        id="website-tab"
                        data-bs-toggle="tab"
                        data-bs-target="#website-pane"
                        type="button"
                        role="tab"
                        aria-controls="website-pane"
                        aria-selected="true">
                    Trang chủ
                </button>

                <button class="nav-link admin-tab"
                        id="banner-tab"
                        data-bs-toggle="tab"
                        data-bs-target="#banner-pane"
                        type="button"
                        role="tab"
                        aria-controls="banner-pane"
                        aria-selected="false">
                    Banner
                </button>

                <button class="nav-link admin-tab"
                        id="contact-tab"
                        data-bs-toggle="tab"
                        data-bs-target="#contact-pane"
                        type="button"
                        role="tab"
                        aria-controls="contact-pane"
                        aria-selected="false">
                    Liên hệ
                </button>

                <button class="nav-link admin-tab"
                        id="status-tab"
                        data-bs-toggle="tab"
                        data-bs-target="#status-pane"
                        type="button"
                        role="tab"
                        aria-controls="status-pane"
                        aria-selected="false">
                    Bảo trì
                </button>

                <button class="nav-link admin-tab"
                        id="email-tab"
                        data-bs-toggle="tab"
                        data-bs-target="#email-pane"
                        type="button"
                        role="tab"
                        aria-controls="email-pane"
                        aria-selected="false">
                    Email system
                </button>
            </div>

            <div class="tab-content admin-system-tab-content" id="systemSettingTabsContent">

                <!-- TAB: GIAO DIỆN WEBSITE -->
                <div class="tab-pane fade show active" id="website-pane" role="tabpanel" aria-labelledby="website-tab">
                    <form asp-area="Admin" asp-controller="SystemSettings" asp-action="Index" method="post">
                        @Html.AntiForgeryToken()
                        <input asp-for="SystemSetting.Id" type="hidden" />

                        <div asp-validation-summary="All" class="text-danger admin-validation"></div>

                        <div class="admin-section-title">Thông tin trang ch?</div>

                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="SystemSetting.SiteName" class="form-label admin-label"></label>
                                <input asp-for="SystemSetting.SiteName" class="form-control admin-input" />
                                <span asp-validation-for="SystemSetting.SiteName" class="text-danger admin-field-error"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="SystemSetting.HomeBannerTitle" class="form-label admin-label"></label>
                                <input asp-for="SystemSetting.HomeBannerTitle" class="form-control admin-input" />
                                <span asp-validation-for="SystemSetting.HomeBannerTitle" class="text-danger admin-field-error"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="SystemSetting.HomeBannerSubtitle" class="form-label admin-label"></label>
                                <textarea asp-for="SystemSetting.HomeBannerSubtitle"
                                          class="form-control admin-input admin-textarea"
                                          rows="3"></textarea>
                                <span asp-validation-for="SystemSetting.HomeBannerSubtitle" class="text-danger admin-field-error"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="SystemSetting.FooterText" class="form-label admin-label"></label>
                                <input asp-for="SystemSetting.FooterText" class="form-control admin-input" />
                                <span asp-validation-for="SystemSetting.FooterText" class="text-danger admin-field-error"></span>
                            </div>
                        </div>

                        <div class="admin-section-divider"></div>

                        <div class="admin-section-title">Thẻ giới thiệu trang chủ</div>

                        <div class="admin-feature-card">
                            <div class="admin-feature-title">Th? 1</div>
                            <div class="row g-3">
                                <div class="col-md-2">
                                    <label asp-for="SystemSetting.FeatureCard1Number" class="form-label admin-label">S?</label>
                                    <input asp-for="SystemSetting.FeatureCard1Number" class="form-control admin-input" />
                                    <span asp-validation-for="SystemSetting.FeatureCard1Number" class="text-danger admin-field-error"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="SystemSetting.FeatureCard1Title" class="form-label admin-label">Tiêu đề</label>
                                    <input asp-for="SystemSetting.FeatureCard1Title" class="form-control admin-input" />
                                    <span asp-validation-for="SystemSetting.FeatureCard1Title" class="text-danger admin-field-error"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="SystemSetting.FeatureCard1Description" class="form-label admin-label">Mô tả</label>
                                    <input asp-for="SystemSetting.FeatureCard1Description" class="form-control admin-input" />
                                    <span asp-validation-for="SystemSetting.FeatureCard1Description" class="text-danger admin-field-error"></span>
                                </div>
                            </div>
                        </div>

                        <div class="admin-feature-card">
                            <div class="admin-feature-title">Th? 2</div>
                            <div class="row g-3">
                                <div class="col-md-2">
                                    <label asp-for="SystemSetting.FeatureCard2Number" class="form-label admin-label">S?</label>
                                    <input asp-for="SystemSetting.FeatureCard2Number" class="form-control admin-input" />
                                    <span asp-validation-for="SystemSetting.FeatureCard2Number" class="text-danger admin-field-error"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="SystemSetting.FeatureCard2Title" class="form-label admin-label">Tiêu đề</label>
                                    <input asp-for="SystemSetting.FeatureCard2Title" class="form-control admin-input" />
                                    <span asp-validation-for="SystemSetting.FeatureCard2Title" class="text-danger admin-field-error"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="SystemSetting.FeatureCard2Description" class="form-label admin-label">Mô tả</label>
                                    <input asp-for="SystemSetting.FeatureCard2Description" class="form-control admin-input" />
                                    <span asp-validation-for="SystemSetting.FeatureCard2Description" class="text-danger admin-field-error"></span>
                                </div>
                            </div>
                        </div>

                        <div class="admin-feature-card">
                            <div class="admin-feature-title">Th? 3</div>
                            <div class="row g-3">
                                <div class="col-md-2">
                                    <label asp-for="SystemSetting.FeatureCard3Number" class="form-label admin-label">S?</label>
                                    <input asp-for="SystemSetting.FeatureCard3Number" class="form-control admin-input" />
                                    <span asp-validation-for="SystemSetting.FeatureCard3Number" class="text-danger admin-field-error"></span>
                                </div>
                                <div class="col-md-4">
