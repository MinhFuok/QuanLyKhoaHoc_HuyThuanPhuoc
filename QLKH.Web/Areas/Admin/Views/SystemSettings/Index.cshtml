                        <input asp-for="SystemSetting.FeatureCard1Description" type="hidden" />
                        <input asp-for="SystemSetting.FeatureCard2Number" type="hidden" />
                        <input asp-for="SystemSetting.FeatureCard2Title" type="hidden" />
                        <input asp-for="SystemSetting.FeatureCard2Description" type="hidden" />
                        <input asp-for="SystemSetting.FeatureCard3Number" type="hidden" />
                        <input asp-for="SystemSetting.FeatureCard3Title" type="hidden" />
                        <input asp-for="SystemSetting.FeatureCard3Description" type="hidden" />
                        <input asp-for="SystemSetting.FeatureCard4Number" type="hidden" />
                        <input asp-for="SystemSetting.FeatureCard4Title" type="hidden" />
