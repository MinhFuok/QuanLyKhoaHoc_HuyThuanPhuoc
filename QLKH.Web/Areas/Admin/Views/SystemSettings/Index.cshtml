@model QLKH.Web.Areas.Admin.Models.SystemSettingsPageViewModel

@{
    ViewData["Title"] = "Cấu hình hệ thống";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="admin-account-page admin-system-page">
    <div class="admin-page-header">
        <div>
            <h2 class="admin-page-title">CẤU HÌNH HỆ THỐNG</h2>
            <p class="admin-page-subtitle">
                Quản lý thông tin website, banner, liên hệ, bảo trì và email hệ thống...
            </p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success admin-alert">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="admin-table-card admin-system-card">
        <div class="admin-table-title">
            <span>Thiết lập hệ thống</span>
        </div>

        <div class="admin-system-body">
            <div class="admin-tabbar admin-system-tabs" id="systemSettingTabs" role="tablist">
                <button class="nav-link admin-tab active"
                        id="website-tab"
                        data-bs-toggle="tab"
                        data-bs-target="#website-pane"
                        type="button"
                        role="tab"
                        aria-controls="website-pane"
                        aria-selected="true">
                    Trang chủ
                </button>

                <button class="nav-link admin-tab"
                        id="banner-tab"
                        data-bs-toggle="tab"
                        data-bs-target="#banner-pane"
                        type="button"
                        role="tab"
                        aria-controls="banner-pane"
                        aria-selected="false">
                    Banner
                </button>

                <button class="nav-link admin-tab"
                        id="contact-tab"
                        data-bs-toggle="tab"
                        data-bs-target="#contact-pane"
                        type="button"
                        role="tab"
                        aria-controls="contact-pane"
                        aria-selected="false">
                    Liên hệ
                </button>

                <button class="nav-link admin-tab"
                        id="status-tab"
                        data-bs-toggle="tab"
                        data-bs-target="#status-pane"
                        type="button"
                        role="tab"
                        aria-controls="status-pane"
                        aria-selected="false">
                    Bảo trì
                </button>

                <button class="nav-link admin-tab"
                        id="email-tab"
                        data-bs-toggle="tab"
                        data-bs-target="#email-pane"
                        type="button"
                        role="tab"
                        aria-controls="email-pane"
                        aria-selected="false">
                    Email system
                </button>
            </div>

            <div class="tab-content admin-system-tab-content" id="systemSettingTabsContent">

                <!-- TAB: GIAO DIỆN WEBSITE -->
                <div class="tab-pane fade show active" id="website-pane" role="tabpanel" aria-labelledby="website-tab">
                    <form asp-area="Admin" asp-controller="SystemSettings" asp-action="Index" method="post">
                        @Html.AntiForgeryToken()
                        <input asp-for="SystemSetting.Id" type="hidden" />

                        <div asp-validation-summary="All" class="text-danger admin-validation"></div>

                        <div class="admin-section-title">Thông tin trang chủ</div>

                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="SystemSetting.SiteName" class="form-label admin-label"></label>
                                <input asp-for="SystemSetting.SiteName" class="form-control admin-input" />
                                <span asp-validation-for="SystemSetting.SiteName" class="text-danger admin-field-error"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="SystemSetting.HomeBannerTitle" class="form-label admin-label"></label>
                                <input asp-for="SystemSetting.HomeBannerTitle" class="form-control admin-input" />
                                <span asp-validation-for="SystemSetting.HomeBannerTitle" class="text-danger admin-field-error"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="SystemSetting.HomeBannerSubtitle" class="form-label admin-label"></label>
                                <textarea asp-for="SystemSetting.HomeBannerSubtitle"
                                          class="form-control admin-input admin-textarea"
                                          rows="3"></textarea>
                                <span asp-validation-for="SystemSetting.HomeBannerSubtitle" class="text-danger admin-field-error"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="SystemSetting.FooterText" class="form-label admin-label"></label>
                                <input asp-for="SystemSetting.FooterText" class="form-control admin-input" />
                                <span asp-validation-for="SystemSetting.FooterText" class="text-danger admin-field-error"></span>
                            </div>
                        </div>

                        <div class="admin-section-divider"></div>

                        <div class="admin-section-title">Thẻ giới thiệu trang chủ</div>

                        <div class="admin-feature-card">
                            <div class="admin-feature-title">Thẻ 1</div>
                            <div class="row g-3">
                                <div class="col-md-2">
                                    <label asp-for="SystemSetting.FeatureCard1Number" class="form-label admin-label">Số</label>
                                    <input asp-for="SystemSetting.FeatureCard1Number" class="form-control admin-input" />
                                    <span asp-validation-for="SystemSetting.FeatureCard1Number" class="text-danger admin-field-error"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="SystemSetting.FeatureCard1Title" class="form-label admin-label">Tiêu đề</label>
                                    <input asp-for="SystemSetting.FeatureCard1Title" class="form-control admin-input" />
                                    <span asp-validation-for="SystemSetting.FeatureCard1Title" class="text-danger admin-field-error"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="SystemSetting.FeatureCard1Description" class="form-label admin-label">Mô tả</label>
                                    <input asp-for="SystemSetting.FeatureCard1Description" class="form-control admin-input" />
                                    <span asp-validation-for="SystemSetting.FeatureCard1Description" class="text-danger admin-field-error"></span>
                                </div>
                            </div>
                        </div>

                        <div class="admin-feature-card">
                            <div class="admin-feature-title">Thẻ 2</div>
                            <div class="row g-3">
                                <div class="col-md-2">
                                    <label asp-for="SystemSetting.FeatureCard2Number" class="form-label admin-label">Số</label>
                                    <input asp-for="SystemSetting.FeatureCard2Number" class="form-control admin-input" />
                                    <span asp-validation-for="SystemSetting.FeatureCard2Number" class="text-danger admin-field-error"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="SystemSetting.FeatureCard2Title" class="form-label admin-label">Tiêu đề</label>
                                    <input asp-for="SystemSetting.FeatureCard2Title" class="form-control admin-input" />
                                    <span asp-validation-for="SystemSetting.FeatureCard2Title" class="text-danger admin-field-error"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="SystemSetting.FeatureCard2Description" class="form-label admin-label">Mô tả</label>
                                    <input asp-for="SystemSetting.FeatureCard2Description" class="form-control admin-input" />
                                    <span asp-validation-for="SystemSetting.FeatureCard2Description" class="text-danger admin-field-error"></span>
                                </div>
                            </div>
                        </div>

                        <div class="admin-feature-card">
                            <div class="admin-feature-title">Thẻ 3</div>
                            <div class="row g-3">
                                <div class="col-md-2">
                                    <label asp-for="SystemSetting.FeatureCard3Number" class="form-label admin-label">Số</label>
                                    <input asp-for="SystemSetting.FeatureCard3Number" class="form-control admin-input" />
                                    <span asp-validation-for="SystemSetting.FeatureCard3Number" class="text-danger admin-field-error"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="SystemSetting.FeatureCard3Title" class="form-label admin-label">Tiêu đề</label>
                                    <input asp-for="SystemSetting.FeatureCard3Title" class="form-control admin-input" />
                                    <span asp-validation-for="SystemSetting.FeatureCard3Title" class="text-danger admin-field-error"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="SystemSetting.FeatureCard3Description" class="form-label admin-label">Mô tả</label>
                                    <input asp-for="SystemSetting.FeatureCard3Description" class="form-control admin-input" />
                                    <span asp-validation-for="SystemSetting.FeatureCard3Description" class="text-danger admin-field-error"></span>
                                </div>
                            </div>
                        </div>

                        <div class="admin-feature-card">
                            <div class="admin-feature-title">Thẻ 4</div>
                            <div class="row g-3">
                                <div class="col-md-2">
                                    <label asp-for="SystemSetting.FeatureCard4Number" class="form-label admin-label">Số</label>
                                    <input asp-for="SystemSetting.FeatureCard4Number" class="form-control admin-input" />
                                    <span asp-validation-for="SystemSetting.FeatureCard4Number" class="text-danger admin-field-error"></span>
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="SystemSetting.FeatureCard4Title" class="form-label admin-label">Tiêu đề</label>
                                    <input asp-for="SystemSetting.FeatureCard4Title" class="form-control admin-input" />
                                    <span asp-validation-for="SystemSetting.FeatureCard4Title" class="text-danger admin-field-error"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="SystemSetting.FeatureCard4Description" class="form-label admin-label">Mô tả</label>
                                    <input asp-for="SystemSetting.FeatureCard4Description" class="form-control admin-input" />
                                    <span asp-validation-for="SystemSetting.FeatureCard4Description" class="text-danger admin-field-error"></span>
                                </div>
                            </div>
                        </div>

                        <!-- giữ dữ liệu các tab khác -->
                        <input asp-for="SystemSetting.ContactEmail" type="hidden" />
                        <input asp-for="SystemSetting.ContactPhone" type="hidden" />
                        <input asp-for="SystemSetting.ContactAddress" type="hidden" />
                        <input asp-for="SystemSetting.FacebookUrl" type="hidden" />
                        <input asp-for="SystemSetting.YoutubeUrl" type="hidden" />
                        <input asp-for="SystemSetting.TiktokUrl" type="hidden" />
                        <input asp-for="SystemSetting.XUrl" type="hidden" />
                        <input asp-for="SystemSetting.IsWebsiteEnabled" type="hidden" />
                        <input asp-for="SystemSetting.MaintenanceMessage" type="hidden" />
                        <input asp-for="SystemSetting.EnableEmail" type="hidden" />
                        <input asp-for="SystemSetting.SmtpServer" type="hidden" />
                        <input asp-for="SystemSetting.SmtpPort" type="hidden" />
                        <input asp-for="SystemSetting.SenderName" type="hidden" />
                        <input asp-for="SystemSetting.SenderEmail" type="hidden" />
                        <input asp-for="SystemSetting.SmtpUsername" type="hidden" />
                        <input asp-for="SystemSetting.SmtpPassword" type="hidden" />

                        <div class="admin-form-actions">
                            <button type="submit" class="btn btn-primary">
                                Xác nhận lưu hệ thống
                            </button>
                        </div>
                    </form>
                </div>

                <!-- TAB: BANNER -->
                <div class="tab-pane fade" id="banner-pane" role="tabpanel" aria-labelledby="banner-tab">
                    <div class="admin-tab-header">
                        <h5>Quản lý banner</h5>

                        <a asp-area="Admin"
                           asp-controller="HomeBannerSlide"
                           asp-action="Create"
                           class="btn btn-primary admin-btn-main">
                            + Thêm banner mới
                        </a>
                    </div>

                    <div class="table-responsive">
                        <table class="table admin-table admin-banner-table align-middle mb-0">
                            <colgroup>
                                <col style="width: 8%;" />
                                <col style="width: 20%;" />
                                <col style="width: 14%;" />
                                <col style="width: 20%;" />
                                <col style="width: 14%;" />
                                <col style="width: 24%;" />
                            </colgroup>

                            <thead>
                                <tr>
                                    <th class="text-center">Thứ tự</th>
                                    <th>Tiêu đề</th>
                                    <th class="text-center">Ảnh</th>
                                    <th>Mô tả ảnh</th>
                                    <th class="text-center">Trạng thái</th>
                                    <th class="text-center">Thao tác</th>
                                </tr>
                            </thead>

                            <tbody>
                                @if (Model.BannerSlides != null && Model.BannerSlides.Any())
                                {
                                    foreach (var item in Model.BannerSlides.OrderBy(x => x.DisplayOrder))
                                    {
                                        <tr>
                                            <td class="text-center">
                                                <span class="admin-code">@item.DisplayOrder</span>
                                            </td>

                                            <td>
                                                <div class="admin-name">@item.Title</div>
                                            </td>

                                            <td class="text-center">
                                                @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                                {
                                                    <img src="@item.ImageUrl"
                                                         alt="@item.AltText"
                                                         class="admin-banner-img" />
                                                }
                                            </td>

                                            <td>
                                                <div class="admin-text-limit">@item.AltText</div>
                                            </td>

                                            <td class="text-center">
                                                @if (item.IsActive)
                                                {
                                                    <span class="admin-badge admin-badge-success">Đang hiển thị</span>
                                                }
                                                else
                                                {
                                                    <span class="admin-badge admin-badge-muted">Đã ẩn</span>
                                                }
                                            </td>

                                            <td class="text-center">
                                                <div class="admin-actions admin-banner-actions">
                                                    <form asp-area="Admin"
                                                          asp-controller="HomeBannerSlide"
                                                          asp-action="MoveUp"
                                                          method="post">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@item.Id" />
                                                        <button type="submit" class="btn btn-outline-secondary btn-sm" title="Đưa lên">↑</button>
                                                    </form>

                                                    <form asp-area="Admin"
                                                          asp-controller="HomeBannerSlide"
                                                          asp-action="MoveDown"
                                                          method="post">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@item.Id" />
                                                        <button type="submit" class="btn btn-outline-secondary btn-sm" title="Đưa xuống">↓</button>
                                                    </form>

                                                    <a asp-area="Admin"
                                                       asp-controller="HomeBannerSlide"
                                                       asp-action="Edit"
                                                       asp-route-id="@item.Id"
                                                       class="btn btn-outline-primary btn-sm">
                                                        Sửa
                                                    </a>

                                                    <a asp-area="Admin"
                                                       asp-controller="HomeBannerSlide"
                                                       asp-action="Delete"
                                                       asp-route-id="@item.Id"
                                                       class="btn btn-outline-danger btn-sm">
                                                        Xóa
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">
                                            Chưa có slide banner nào.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- TAB: LIÊN HỆ -->
                <div class="tab-pane fade" id="contact-pane" role="tabpanel" aria-labelledby="contact-tab">
