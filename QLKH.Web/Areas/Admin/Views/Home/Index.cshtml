@model QLKH.Web.Areas.Admin.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "Dashboard Admin";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var overviewTotal = Model.TotalStudents + Model.TotalTeachers + Model.TotalCourses + Model.TotalClassRooms + Model.TotalDepartments;
    var activeRate = Model.TotalUsers > 0
        ? Math.Round((double)Model.ActiveUsers / Model.TotalUsers * 100, 1)
        : 0;
    var totalLinkedAccounts = Model.LinkedStudents + Model.LinkedTeachers;
    var totalLinkTargets = Model.TotalStudents + Model.TotalTeachers;
    var linkedRate = totalLinkTargets > 0
        ? Math.Round((double)totalLinkedAccounts / totalLinkTargets * 100, 1)
        : 0;
}

<div class="admin-dashboard-page">

    <div class="da-header mb-4">
        <div class="da-header-inner">
            <div class="da-header-left">
                <div class="da-header-eyebrow">
                    <i class="bi bi-grid-3x3-gap-fill"></i>
                    Hệ thống Quản lý Đào tạo
                </div>
                <h1 class="da-header-title">Dashboard Admin</h1>
                <p class="da-header-sub">
                    Tổng quan vận hành hệ thống — cập nhật theo thời gian thực.
                </p>
            </div>

            <div class="da-identity">
                <div class="da-avatar">
                    @(string.IsNullOrWhiteSpace(Model.AdminFullName)
                        ? "A"
                        : Model.AdminFullName.Trim()[0].ToString().ToUpper())
                </div>
                <div class="da-identity-info">
                    <div class="da-identity-name">@Model.AdminFullName</div>
                    <div class="da-identity-email">@Model.AdminEmail</div>
                    <div class="da-identity-badges">
                        <span class="da-badge da-badge-role">
                            <i class="bi bi-shield-fill-check"></i>
                            @Model.AdminRole
                        </span>
                        @if (Model.IsWebsiteEnabled)
                        {
                            <span class="da-badge da-badge-online">
                                <i class="bi bi-circle-fill"></i> Online
                            </span>
                        }
                        else
                        {
                            <span class="da-badge da-badge-maintenance">
                                <i class="bi bi-cone-striped"></i> Bảo trì
                            </span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.IsWebsiteEnabled && !string.IsNullOrWhiteSpace(Model.MaintenanceMessage))
    {
        <div class="da-maintenance-alert mb-4">
            <i class="bi bi-exclamation-triangle-fill da-alert-icon"></i>
            <div>
                <div class="da-alert-title">Website đang trong chế độ bảo trì</div>
                <div class="da-alert-body">@Model.MaintenanceMessage</div>
            </div>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="da-kpi da-kpi-blue">
                <div class="da-kpi-icon-wrap">
                    <i class="bi bi-people-fill"></i>
                </div>
                <div class="da-kpi-body">
                    <div class="stat-label">Tổng tài khoản</div>
                    <div class="stat-value">@Model.TotalUsers</div>
                    <div class="stat-meta">
                        <span><i class="bi bi-check-circle-fill text-success"></i> @Model.ActiveUsers hoạt động</span>
                        <span><i class="bi bi-lock-fill text-danger"></i> @Model.LockedUsers bị khóa</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="da-kpi da-kpi-cyan">
                <div class="da-kpi-icon-wrap">
                    <i class="bi bi-mortarboard-fill"></i>
                </div>
                <div class="da-kpi-body">
                    <div class="stat-label">Học viên</div>
                    <div class="stat-value">@Model.TotalStudents</div>
                    <div class="stat-meta">
                        <span><i class="bi bi-link-45deg"></i> @Model.LinkedStudents đã liên kết</span>
                        <span><i class="bi bi-slash-circle"></i> @Model.UnlinkedStudents chưa liên kết</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="da-kpi da-kpi-navy">
                <div class="da-kpi-icon-wrap">
                    <i class="bi bi-person-video3"></i>
                </div>
                <div class="da-kpi-body">
                    <div class="stat-label">Giáo viên</div>
                    <div class="stat-value">@Model.TotalTeachers</div>
                    <div class="stat-meta">
                        <span><i class="bi bi-link-45deg"></i> @Model.LinkedTeachers đã liên kết</span>
                        <span><i class="bi bi-slash-circle"></i> @Model.UnlinkedTeachers chưa liên kết</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="da-kpi da-kpi-slate">
                <div class="da-kpi-icon-wrap">
                    <i class="bi bi-journal-richtext"></i>
                </div>
                <div class="da-kpi-body">
                    <div class="stat-label">Lớp học</div>
                    <div class="stat-value">@Model.TotalClassRooms</div>
                    <div class="stat-meta">
                        <span><i class="bi bi-book-fill"></i> @Model.TotalCourses khóa học</span>
                        <span><i class="bi bi-diagram-3-fill"></i> @Model.TotalDepartments khoa/ngành</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">

        <div class="col-12 col-xl-4">
            <div class="da-card da-card-gradient da-card-gradient-ice h-100">
                <div class="da-card-header">
                    <i class="bi bi-person-badge-fill da-card-header-icon"></i>
                    <span>Thông tin Admin</span>
                </div>
                <div class="da-card-body">
                    <ul class="da-info-list">
                        <li class="da-info-item">
                            <span class="da-info-label"><i class="bi bi-person-fill"></i> Họ tên</span>
                            <span class="da-info-value">@Model.AdminFullName</span>
                        </li>
                        <li class="da-info-item">
                            <span class="da-info-label"><i class="bi bi-envelope-fill"></i> Email</span>
                            <span class="da-info-value">@Model.AdminEmail</span>
                        </li>
                        <li class="da-info-item">
                            <span class="da-info-label"><i class="bi bi-shield-fill"></i> Vai trò</span>
                            <span class="da-info-value">
                                <span class="da-badge da-badge-role">@Model.AdminRole</span>
                            </span>
                        </li>
                        <li class="da-info-item">
                            <span class="da-info-label"><i class="bi bi-globe2"></i> Website</span>
                            <span class="da-info-value">
                                @if (Model.IsWebsiteEnabled)
                                {
                                    <span class="da-badge da-badge-online">Đang hoạt động</span>
                                }
                                else
                                {
                                    <span class="da-badge da-badge-maintenance">Bảo trì</span>
                                }
                            </span>
                        </li>
                        <li class="da-info-item">
                            <span class="da-info-label"><i class="bi bi-send-fill"></i> Email hệ thống</span>
                            <span class="da-info-value">
                                @if (Model.EnableEmail)
                                {
                                    <span class="da-badge da-badge-online">Đã bật</span>
                                }
                                else
                                {
                                    <span class="da-badge da-badge-off">Đang tắt</span>
                                }
                            </span>
                        </li>
                        <li class="da-info-item">
                            <span class="da-info-label"><i class="bi bi-image-fill"></i> Banner</span>
                            <span class="da-info-value">@Model.ActiveBannerCount đang hiển thị</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-8">
            <div class="da-card da-card-gradient da-card-gradient-cyan h-100">
                <div class="da-card-header">
                    <i class="bi bi-lightning-charge-fill da-card-header-icon"></i>
                    <span>Tác vụ nhanh</span>
                </div>
                <div class="da-card-body">
                    <div class="da-actions-grid">

                        <a asp-area="Admin" asp-controller="UserManagement" asp-action="Index"
                               class="da-action-item">
                            <div class="da-action-icon-wrap" style="--ai-color:#1a56db">
                                <i class="bi bi-person-lines-fill"></i>
                            </div>
                            <div class="da-action-content">
                                <div class="da-action-title">Quản lý tài khoản</div>
                                <div class="da-action-desc">Tạo, sửa, khóa tài khoản nội bộ</div>
                            </div>
                            <i class="bi bi-chevron-right da-action-arrow"></i>
                        </a>

                        <a asp-area="Admin" asp-controller="SystemSettings" asp-action="Index"
                               class="da-action-item">
                            <div class="da-action-icon-wrap" style="--ai-color:#0891b2">
                                <i class="bi bi-gear-wide-connected"></i>
                            </div>
                            <div class="da-action-content">
                                <div class="da-action-title">Cấu hình hệ thống</div>
                                <div class="da-action-desc">Website, email, liên hệ, banner</div>
                            </div>
                            <i class="bi bi-chevron-right da-action-arrow"></i>
                        </a>

                        <a asp-area="Admin" asp-controller="BulkNotification" asp-action="Index"
                               class="da-action-item">
                            <div class="da-action-icon-wrap" style="--ai-color:#0369a1">
                                <i class="bi bi-megaphone-fill"></i>
                            </div>
                            <div class="da-action-content">
                                <div class="da-action-title">Gửi thông báo</div>
                                <div class="da-action-desc">Gửi email hàng loạt tới HV/GV</div>
                            </div>
                            <i class="bi bi-chevron-right da-action-arrow"></i>
                        </a>

                        <a asp-area="Admin" asp-controller="AdminAuditLog" asp-action="Index"
                               class="da-action-item">
                            <div class="da-action-icon-wrap" style="--ai-color:#1d4ed8">
                                <i class="bi bi-journal-text"></i>
                            </div>
                            <div class="da-action-content">
                                <div class="da-action-title">Nhật ký hoạt động</div>
                                <div class="da-action-desc">Theo dõi thao tác và truy cập</div>
                            </div>
                            <i class="bi bi-chevron-right da-action-arrow"></i>
                        </a>

                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="row g-3 mb-4">

        <div class="col-12 col-xl-7">
            <div class="da-card da-chart-card da-chart-card-overview h-100">
                <div class="da-chart-card-body">
                    <div class="da-chart-card-top">
                        <div>
                            <div class="da-chart-card-title">Tổng quan dữ liệu đào tạo</div>
                            <div class="da-chart-card-value">@overviewTotal.ToString("N0")</div>
                            <div class="da-chart-card-note">5 nhóm dữ liệu đang theo dõi</div>
                        </div>
                        <span class="da-chart-card-pill">Data live</span>
                    </div>
                    <div class="da-chart-stage">
                        <div class="da-chart-wrap">
                            <canvas id="overviewBarChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-5">
            <div class="da-card da-chart-card da-chart-card-status h-100">
                <div class="da-chart-card-body">
                    <div class="da-chart-card-top">
                        <div>
                            <div class="da-chart-card-title">Trạng thái tài khoản</div>
                            <div class="da-chart-card-value">@activeRate.ToString("0.#")%</div>
                            <div class="da-chart-card-note">@Model.ActiveUsers / @Model.TotalUsers tài khoản đang hoạt động</div>
                        </div>
                        <span class="da-chart-card-pill">Account</span>
                    </div>
                    <div class="da-chart-stage da-chart-stage-donut">
                        <div class="da-chart-wrap da-chart-donut">
                            <canvas id="userStatusChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="da-card da-chart-card da-chart-card-link">
                <div class="da-chart-card-body">
                    <div class="da-chart-card-top">
                        <div>
                            <div class="da-chart-card-title">Tình trạng liên kết tài khoản</div>
                            <div class="da-chart-card-value">@linkedRate.ToString("0.#")%</div>
                            <div class="da-chart-card-note">@totalLinkedAccounts / @totalLinkTargets tài khoản học viên và giáo viên đã liên kết</div>
                        </div>
                        <span class="da-chart-card-pill">Link sync</span>
                    </div>
                    <div class="da-chart-stage">
                        <div class="da-chart-wrap">
                            <canvas id="linkStatusChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="da-card da-card-gradient da-card-gradient-aurora">
        <div class="da-card-header da-card-header-between">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-clock-history da-card-header-icon"></i>
                <span>Hoạt động gần đây</span>
            </div>
            <a asp-area="Admin" asp-controller="AdminAuditLog" asp-action="Index"
                   class="da-view-all-btn">
                <i class="bi bi-arrow-up-right-square"></i> Xem tất cả
            </a>
        </div>
        <div class="da-card-body p-0">
            @if (Model.RecentActivities != null && Model.RecentActivities.Any())
            {
                <div class="table-responsive">
                    <table class="table da-table mb-0">
                        <thead>
                            <tr>
                                <th><i class="bi bi-clock me-1"></i>Thời gian</th>
                                <th><i class="bi bi-person me-1"></i>Người thao tác</th>
                                <th><i class="bi bi-cursor-fill me-1"></i>Hành động</th>
                                <th><i class="bi bi-tag me-1"></i>Đối tượng</th>
                                <th><i class="bi bi-info-circle me-1"></i>Thông tin</th>
                                <th><i class="bi bi-chat-left-text me-1"></i>Ghi chú</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.RecentActivities)
                            {
                                <tr>
                                    <td class="da-td-time">
                                        @item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")
                                        <span class="da-td-time-sub">@item.CreatedAt.ToLocalTime().ToString("HH:mm:ss")</span>
                                    </td>
                                    <td>@item.ActorEmail</td>
                                    <td><span class="da-action-badge">@item.ActionName</span></td>
                                    <td class="text-muted">@item.TargetType</td>
                                    <td>@item.TargetDisplay</td>
                                    <td class="text-muted small">@item.Note</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="da-empty">
                    <i class="bi bi-inbox da-empty-icon"></i>
                    <div>Chưa có dữ liệu hoạt động gần đây.</div>
                </div>
            }
        </div>
    </div>

</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/dashboardAdmin.css" asp-append-version="true" />
}

@section Scripts {
    <script>
        window.adminDashboardData = {
            TotalStudents:    @Model.TotalStudents,
            TotalTeachers:    @Model.TotalTeachers,
            TotalCourses:     @Model.TotalCourses,
            TotalClassRooms:  @Model.TotalClassRooms,
            TotalDepartments: @Model.TotalDepartments,
            ActiveUsers:      @Model.ActiveUsers,
            LockedUsers:      @Model.LockedUsers,
            LinkedStudents:   @Model.LinkedStudents,
            UnlinkedStudents: @Model.UnlinkedStudents,
            LinkedTeachers:   @Model.LinkedTeachers,
            UnlinkedTeachers: @Model.UnlinkedTeachers
        };
    </script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js" defer></script>
    <script src="~/js/dashboardAdmin.js" asp-append-version="true" defer></script>
}
