@model IEnumerable<QLKH.Web.Areas.Admin.Models.UserListItemViewModel>

@{
    ViewData["Title"] = "Quản lý tài khoản";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var currentTab = ViewBag.Tab as string ?? "";
}

<div class="admin-account-page">
    <div class="admin-page-header">
        <div>
            <h2 class="admin-page-title">QUẢN LÝ TÀI KHOẢN</h2>
            <p class="admin-page-subtitle">
                Quản lý tài khoản hệ thống quản lý khóa học...
            </p>
        </div>

        <a asp-area="Admin"
           asp-controller="UserManagement"
           asp-action="Create"
           class="btn btn-primary admin-btn-main">
            + Tạo tài khoản
        </a>
    </div>

    @if (!string.IsNullOrWhiteSpace(TempData["SuccessMessage"]?.ToString()))
    {
        <div class="alert alert-success admin-alert">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(TempData["ErrorMessage"]?.ToString()))
    {
        <div class="alert alert-danger admin-alert">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="admin-tabbar">
        <a class="admin-tab @(string.IsNullOrEmpty(currentTab) ? "active" : "")"
           asp-area="Admin"
           asp-controller="UserManagement"
           asp-action="Index"
           asp-route-keyword="@ViewBag.Keyword"
           asp-route-role="@ViewBag.Role"
           asp-route-linkStatus="@ViewBag.LinkStatus">
            Tất cả
        </a>

        <a class="admin-tab @(currentTab == "active" ? "active" : "")"
           asp-area="Admin"
           asp-controller="UserManagement"
           asp-action="Index"
           asp-route-tab="active"
           asp-route-keyword="@ViewBag.Keyword"
           asp-route-role="@ViewBag.Role"
           asp-route-linkStatus="@ViewBag.LinkStatus">
            Đang hoạt động
        </a>

        <a class="admin-tab @(currentTab == "locked" ? "active" : "")"
           asp-area="Admin"
           asp-controller="UserManagement"
           asp-action="Index"
           asp-route-tab="locked"
           asp-route-keyword="@ViewBag.Keyword"
           asp-route-role="@ViewBag.Role"
           asp-route-linkStatus="@ViewBag.LinkStatus">
            Đã khóa
        </a>
    </div>

    <div class="admin-filter-card">
        <form asp-area="Admin" asp-controller="UserManagement" asp-action="Index" method="get">
            <input type="hidden" name="tab" value="@ViewBag.Tab" />

            <div class="row g-3 align-items-end">
                <div class="col-12 col-lg-5">
                    <label class="form-label admin-label">Tìm kiếm</label>
                    <input type="text"
                           name="keyword"
                           value="@ViewBag.Keyword"
                           class="form-control admin-input"
                           placeholder="Nhập tên, username hoặc mã tài khoản..." />
                </div>

                <div class="col-12 col-md-6 col-lg-3">
                    <label class="form-label admin-label">Vai trò</label>
                    <select name="role" asp-items="ViewBag.RoleList" class="form-select admin-input"></select>
                </div>

                <div class="col-12 col-md-6 col-lg-2">
                    <label class="form-label admin-label">Liên kết</label>
                    <select name="linkStatus" class="form-select admin-input">
                        <option value="">-- Tất cả --</option>
                        <option value="linked" selected="@(ViewBag.LinkStatus == "linked")">Đã liên kết</option>
                        <option value="unlinked" selected="@(ViewBag.LinkStatus == "unlinked")">Chưa liên kết</option>
                    </select>
                </div>

                <div class="col-12 col-lg-2">
                    <div class="admin-filter-actions">
                        <button type="submit" class="btn btn-primary">
                            Lọc
                        </button>

                        <a asp-area="Admin"
                           asp-controller="UserManagement"
                           asp-action="Index"
                           class="btn btn-outline-secondary">
                            Bỏ lọc
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <div class="admin-table-card">
        <div class="admin-table-title">
            <span>Danh sách tài khoản</span>
        </div>

        <div class="table-responsive">
            <table class="table admin-table align-middle mb-0">
                <colgroup>
                    <col style="width: 8%;" />
                    <col style="width: 16%;" />
                    <col style="width: 23%;" />
                    <col style="width: 9%;" />
                    <col style="width: 12%;" />
                    <col style="width: 12%;" />
                    <col style="width: 20%;" />
                </colgroup>

                <thead>
                    <tr>
                        <th class="text-center">Mã TK</th>
                        <th class="text-center">Họ tên</th>
                        <th class="text-center">UserName</th>
                        <th class="text-center">Vai trò</th>
                        <th class="text-center">Liên kết</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var user in Model)
                        {
                            <tr>
                                <td class="text-center">
                                    <span class="admin-code">@user.UserCode</span>
                                </td>

                                <td>
                                    <div class="admin-name">@user.FullName</div>
                                </td>

                                <td>
                                    <div class="admin-username">@user.UserName</div>
                                </td>

                                <td class="text-center">
                                    <span class="admin-badge admin-badge-role">@user.Role</span>
                                </td>

                                <td class="text-center">
                                    @if (user.IsLinkedStudent)
                                    {
                                        <span class="admin-badge admin-badge-linked">@user.LinkedLabel</span>
                                    }
                                    else if (user.IsLinkedTeacher)
                                    {
                                        <span class="admin-badge admin-badge-linked">@user.LinkedLabel</span>
                                    }
                                    else
                                    {
                                        <span class="admin-badge admin-badge-muted">@user.LinkedLabel</span>
                                    }
                                </td>

                                <td class="text-center">
                                    @if (user.IsLocked)
                                    {
                                        <span class="admin-badge admin-badge-danger">Đã khóa</span>
                                    }
                                    else
                                    {
                                        <span class="admin-badge admin-badge-success">Đang hoạt động</span>
                                    }
                                </td>

                                <td class="text-center">
                                    <div class="admin-actions">
                                        <a asp-area="Admin"
                                           asp-controller="UserManagement"
                                           asp-action="Edit"
                                           asp-route-id="@user.Id"
                                           class="btn btn-outline-primary btn-sm">
                                            Sửa
                                        </a>

                                        <a asp-area="Admin"
                                           asp-controller="UserManagement"
                                           asp-action="Delete"
                                           asp-route-id="@user.Id"
                                           class="btn btn-outline-danger btn-sm">
                                            Xóa
                                        </a>

                                        @if (user.IsLocked)
                                        {
                                            <form asp-area="Admin"
                                                  asp-controller="UserManagement"
                                                  asp-action="UnlockUser"
                                                  method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@user.Id" />
                                                <button type="submit" class="btn btn-outline-success btn-sm">
                                                    Mở khóa
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-area="Admin"
                                                  asp-controller="UserManagement"
                                                  asp-action="LockUser"
                                                  method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@user.Id" />
                                                <button type="submit" class="btn btn-outline-secondary btn-sm">
                                                    Khóa
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                Không có tài khoản nào phù hợp.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .admin-account-page {
            color: #1f2937;
        }

        .admin-page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 18px;
            padding-bottom: 14px;
            border-bottom: 1px solid #e5e7eb;
        }

        .admin-page-title {
            margin: 0;
            color: #111827;
            font-size: 1.55rem;
            font-weight: 800;
            letter-spacing: -0.02em;
        }

        .admin-page-subtitle {
            margin: 6px 0 0;
            color: #6b7280;
            font-size: 0.94rem;
        }

        .admin-btn-main {
            border-radius: 8px;
            font-weight: 700;
            white-space: nowrap;
            padding: 9px 14px;
        }

        .admin-alert {
            border-radius: 8px;
            border: 0;
            margin-bottom: 14px;
        }

        .admin-tabbar {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
            margin-bottom: 14px;
            padding: 6px;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            background: #ffffff;
        }

        .admin-tab {
            padding: 8px 13px;
            border-radius: 8px;
            color: #4b5563;
            font-size: 0.92rem;
            font-weight: 700;
            text-decoration: none;
        }

            .admin-tab:hover {
                background: #f3f4f6;
                color: #111827;
            }

            .admin-tab.active {
                background: #111827;
                color: #ffffff;
            }

        .admin-filter-card,
        .admin-table-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            margin-bottom: 16px;
        }

        .admin-filter-card {
            padding: 16px;
        }

        .admin-label {
            color: #374151;
            font-weight: 700;
            font-size: 0.9rem;
            margin-bottom: 6px;
        }

        .admin-input {
            border-radius: 8px;
            border-color: #d1d5db;
            min-height: 40px;
            font-size: 0.94rem;
        }

            .admin-input:focus {
                border-color: #2563eb;
                box-shadow: 0 0 0 0.18rem rgba(37, 99, 235, 0.12);
            }

        .admin-filter-actions {
            display: flex;
            gap: 8px;
        }

            .admin-filter-actions .btn {
                flex: 1;
                border-radius: 8px;
                font-weight: 700;
                min-height: 40px;
            }

        .admin-table-title {
            padding: 13px 16px;
            border-bottom: 1px solid #e5e7eb;
            color: #111827;
            font-weight: 800;
            background: #f9fafb;
            border-radius: 10px 10px 0 0;
        }

        .admin-table {
            width: 100%;
            table-layout: fixed;
            margin-bottom: 0;
        }

            .admin-table thead th {
                background: #f9fafb;
                color: #374151;
                font-size: 0.78rem;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: 0.035em;
                border-bottom: 1px solid #e5e7eb;
                padding: 14px 12px;
                white-space: nowrap;
                vertical-align: middle;
            }

            .admin-table tbody td {
                padding: 14px 12px;
                border-bottom: 1px solid #edf0f3;
                vertical-align: middle;
                font-size: 0.92rem;
            }

            .admin-table tbody tr:hover {
                background: #f9fafb;
            }

            .admin-table tbody tr:last-child td {
                border-bottom: 0;
            }

            .admin-table th:nth-child(1),
            .admin-table td:nth-child(1),
            .admin-table th:nth-child(4),
            .admin-table td:nth-child(4),
            .admin-table th:nth-child(5),
            .admin-table td:nth-child(5),
            .admin-table th:nth-child(6),
            .admin-table td:nth-child(6),
            .admin-table th:nth-child(7),
            .admin-table td:nth-child(7) {
                text-align: center;
            }

        .admin-code {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 64px;
            padding: 6px 10px;
            border-radius: 999px;
            background: #f3f4f6;
            color: #111827;
            font-size: 0.82rem;
            font-weight: 800;
            white-space: nowrap;
        }

        .admin-name {
            color: #111827;
            font-weight: 700;
            line-height: 1.45;
            word-break: break-word;
        }

        .admin-username {
            color: #4b5563;
            line-height: 1.5;
            word-break: break-word;
            overflow-wrap: anywhere;
        }

        .admin-badge {
            display: inline-flex;
            justify-content: center;
            align-items: center;
            max-width: 100%;
            padding: 6px 10px;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 700;
            line-height: 1.25;
            white-space: normal;
            text-align: center;
        }

        .admin-badge-role {
            background: #eef2ff;
            color: #3730a3;
        }

        .admin-badge-linked {
            background: #ecfeff;
            color: #155e75;
        }

        .admin-badge-muted {
            background: #f3f4f6;
            color: #4b5563;
        }

        .admin-badge-success {
            background: #ecfdf5;
            color: #166534;
        }

        .admin-badge-danger {
            background: #fef2f2;
            color: #991b1b;
        }

        .admin-actions {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 8px;
        }

            .admin-actions form {
                margin: 0;
            }

            .admin-actions .btn {
                min-width: 76px;
                border-radius: 7px;
                font-size: 0.8rem;
                font-weight: 700;
                white-space: nowrap;
                padding: 6px 10px;
            }

        @@media (max-width: 1199.98px) {
            .admin-table {
                min-width: 1100px;
            }
        }

        @@media (max-width: 767.98px) {
            .admin-page-header {
                flex-direction: column;
            }

            .admin-btn-main {
                width: 100%;
            }

            .admin-filter-actions {
                flex-direction: column;
            }

            .admin-tabbar {
                flex-direction: column;
            }

            .admin-tab {
                width: 100%;
            }
        }
    </style>
}