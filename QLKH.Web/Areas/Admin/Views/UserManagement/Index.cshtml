@model IEnumerable<QLKH.Web.Areas.Admin.Models.UserListItemViewModel>

@{
    ViewData["Title"] = "Quản lý tài khoản nội bộ";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<h2 class="mb-4">Quản lý tài khoản nội bộ</h2>

<div class="mb-3">
    <a asp-area="Admin" asp-controller="UserManagement" asp-action="Create" class="btn btn-primary">
        + Tạo tài khoản
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Họ tên</th>
                    <th>Email</th>
                    <th>UserName</th>
                    <th>Vai trò</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.FullName</td>
                        <td>@user.Email</td>
                        <td>@user.UserName</td>
                        <td>@user.Role</td>
                        <td>
                            @if (user.IsLocked)
                            {
                                <span class="badge bg-danger">Đã khóa</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Đang hoạt động</span>
                            }
                        </td>
                        <td class="d-flex gap-2">
                            <a asp-area="Admin"
                               asp-controller="UserManagement"
                               asp-action="EditRole"
                               asp-route-id="@user.Id"
                               class="btn btn-warning btn-sm">
                                Sửa role
                            </a>

                            @if (user.IsLocked)
                            {
                                <form asp-area="Admin"
                                      asp-controller="UserManagement"
                                      asp-action="UnlockUser"
                                      method="post"
                                      style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="btn btn-success btn-sm">
                                        Mở khóa
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-area="Admin"
                                      asp-controller="UserManagement"
                                      asp-action="LockUser"
                                      method="post"
                                      style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        Khóa
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>