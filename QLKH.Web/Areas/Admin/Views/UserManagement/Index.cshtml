@model IEnumerable<QLKH.Web.Areas.Admin.Models.UserListItemViewModel>

@{
    ViewData["Title"] = "Quản lý tài khoản";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var currentTab = ViewBag.Tab as string ?? "";
}

<h2 class="mb-4">QUẢN LÝ TÀI KHOẢN</h2>

@if (!string.IsNullOrWhiteSpace(TempData["SuccessMessage"]?.ToString()))
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (!string.IsNullOrWhiteSpace(TempData["ErrorMessage"]?.ToString()))
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

<div class="mb-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <a asp-area="Admin"
       asp-controller="UserManagement"
       asp-action="Create"
       class="btn btn-primary">
        + Tạo tài khoản
    </a>
</div>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <a class="nav-link @(string.IsNullOrEmpty(currentTab) ? "active" : "")"
           asp-area="Admin"
           asp-controller="UserManagement"
           asp-action="Index"
           asp-route-keyword="@ViewBag.Keyword"
           asp-route-role="@ViewBag.Role"
           asp-route-linkStatus="@ViewBag.LinkStatus">
            Tất cả
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(currentTab == "active" ? "active" : "")"
           asp-area="Admin"
           asp-controller="UserManagement"
           asp-action="Index"
           asp-route-tab="active"
           asp-route-keyword="@ViewBag.Keyword"
           asp-route-role="@ViewBag.Role"
           asp-route-linkStatus="@ViewBag.LinkStatus">
            Đang hoạt động
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(currentTab == "locked" ? "active" : "")"
           asp-area="Admin"
           asp-controller="UserManagement"
           asp-action="Index"
           asp-route-tab="locked"
           asp-route-keyword="@ViewBag.Keyword"
           asp-route-role="@ViewBag.Role"
           asp-route-linkStatus="@ViewBag.LinkStatus">
            Đã khóa
        </a>
    </li>
</ul>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <form asp-area="Admin" asp-controller="UserManagement" asp-action="Index" method="get">
            <input type="hidden" name="tab" value="@ViewBag.Tab" />

            <div class="row g-3">
                <div class="col-md-5">
                    <label class="form-label">Tìm kiếm</label>
                    <input type="text"
                           name="keyword"
                           value="@ViewBag.Keyword"
                           class="form-control"/>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Vai trò</label>
                    <select name="role" asp-items="ViewBag.RoleList" class="form-select"></select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Liên kết</label>
                    <select name="linkStatus" class="form-select">
                        <option value="">-- Tất cả --</option>
                        <option value="linked" selected="@(ViewBag.LinkStatus == "linked")">Đã liên kết</option>
                        <option value="unlinked" selected="@(ViewBag.LinkStatus == "unlinked")">Chưa liên kết</option>
                    </select>
                </div>

                <div class="col-md-2 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-primary w-100">Lọc</button>
                    <a asp-area="Admin"
                       asp-controller="UserManagement"
                       asp-action="Index"
                       class="btn btn-secondary w-100">
                        Bỏ lọc
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-striped align-middle">
                <thead>
                    <tr>
                        <th class="text-center">Mã TK</th>
                        <th class="text-center">Họ tên</th>
                        <th class="text-center">UserName</th>
                        <th class="text-center">Vai trò</th>
                        <th class="text-center">Liên kết</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center" style="width: 190px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>@user.UserCode</td>
                                <td>@user.FullName</td>
                                <td>@user.UserName</td>
                                <td>@user.Role</td>
                                <td>
                                    @if (user.IsLinkedStudent)
                                    {
                                        <span class="badge bg-info text-dark">@user.LinkedLabel</span>
                                    }
                                    else if (user.IsLinkedTeacher)
                                    {
                                        <span class="badge bg-warning text-dark">@user.LinkedLabel</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@user.LinkedLabel</span>
                                    }
                                </td>
                                <td>
                                    @if (user.IsLocked)
                                    {
                                        <span class="badge bg-danger">Đã khóa</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Đang hoạt động</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-2 flex-wrap">
                                        <a asp-area="Admin"
                                           asp-controller="UserManagement"
                                           asp-action="Edit"
                                           asp-route-id="@user.Id"
                                           class="btn btn-primary btn-sm">
                                            Sửa
                                        </a>

                                        <a asp-area="Admin"
                                           asp-controller="UserManagement"
                                           asp-action="Delete"
                                           asp-route-id="@user.Id"
                                           class="btn btn-danger btn-sm">
                                            Xóa
                                        </a>

                                        @if (user.IsLocked)
                                        {
                                            <form asp-area="Admin"
                                                  asp-controller="UserManagement"
                                                  asp-action="UnlockUser"
                                                  method="post"
                                                  style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@user.Id" />
                                                <button type="submit" class="btn btn-success btn-sm">
                                                    Mở khóa
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-area="Admin"
                                                  asp-controller="UserManagement"
                                                  asp-action="LockUser"
                                                  method="post"
                                                  style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@user.Id" />
                                                <button type="submit" class="btn btn-danger btn-sm">
                                                    Khóa
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted">
                                Không có tài khoản nào phù hợp.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>