@model IEnumerable<QLKH.Web.Areas.Admin.Models.UserListItemViewModel>

@{
    ViewData["Title"] = "Quản lý tài khoản";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var currentTab = ViewBag.Tab as string ?? "";
}

<div class="admin-account-page">
    <div class="admin-page-header">
        <div>
            <h2 class="admin-page-title">QUẢN LÝ TÀI KHOẢN</h2>
            <p class="admin-page-subtitle">
                Quản lý tài khoản hệ thống quản lý khóa học...
            </p>
        </div>

        <a asp-area="Admin"
           asp-controller="UserManagement"
           asp-action="Create"
           class="btn btn-primary admin-btn-main">
            + Tạo tài khoản
        </a>
    </div>

    @if (!string.IsNullOrWhiteSpace(TempData["SuccessMessage"]?.ToString()))
    {
        <div class="alert alert-success admin-alert">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(TempData["ErrorMessage"]?.ToString()))
    {
        <div class="alert alert-danger admin-alert">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="admin-tabbar">
        <a class="admin-tab @(string.IsNullOrEmpty(currentTab) ? "active" : "")"
           asp-area="Admin"
           asp-controller="UserManagement"
           asp-action="Index"
           asp-route-keyword="@ViewBag.Keyword"
           asp-route-role="@ViewBag.Role"
           asp-route-linkStatus="@ViewBag.LinkStatus">
            Tất cả
        </a>

        <a class="admin-tab @(currentTab == "active" ? "active" : "")"
           asp-area="Admin"
           asp-controller="UserManagement"
           asp-action="Index"
           asp-route-tab="active"
           asp-route-keyword="@ViewBag.Keyword"
           asp-route-role="@ViewBag.Role"
           asp-route-linkStatus="@ViewBag.LinkStatus">
            Đang hoạt động
        </a>

        <a class="admin-tab @(currentTab == "locked" ? "active" : "")"
           asp-area="Admin"
           asp-controller="UserManagement"
           asp-action="Index"
           asp-route-tab="locked"
           asp-route-keyword="@ViewBag.Keyword"
           asp-route-role="@ViewBag.Role"
           asp-route-linkStatus="@ViewBag.LinkStatus">
            Đã khóa
        </a>
    </div>

    <div class="admin-filter-card">
        <form asp-area="Admin" asp-controller="UserManagement" asp-action="Index" method="get">
            <input type="hidden" name="tab" value="@ViewBag.Tab" />

            <div class="row g-3 align-items-end">
                <div class="col-12 col-lg-5">
                    <label class="form-label admin-label">Tìm kiếm</label>
                    <input type="text"
                           name="keyword"
                           value="@ViewBag.Keyword"
                           class="form-control admin-input"
                           placeholder="Nhập tên, username hoặc mã tài khoản..." />
                </div>

                <div class="col-12 col-md-6 col-lg-3">
                    <label class="form-label admin-label">Vai trò</label>
                    <select name="role" asp-items="ViewBag.RoleList" class="form-select admin-input"></select>
                </div>

                <div class="col-12 col-md-6 col-lg-2">
                    <label class="form-label admin-label">Liên kết</label>
                    <select name="linkStatus" class="form-select admin-input">
                        <option value="">-- Tất cả --</option>
                        <option value="linked" selected="@(ViewBag.LinkStatus == "linked")">Đã liên kết</option>
                        <option value="unlinked" selected="@(ViewBag.LinkStatus == "unlinked")">Chưa liên kết</option>
                    </select>
                </div>

                <div class="col-12 col-lg-2">
                    <div class="admin-filter-actions">
                        <button type="submit" class="btn btn-primary">
                            Lọc
                        </button>

                        <a asp-area="Admin"
                           asp-controller="UserManagement"
                           asp-action="Index"
                           class="btn btn-outline-secondary">
                            Bỏ lọc
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <div class="admin-table-card">
        <div class="admin-table-title">
            <span>Danh sách tài khoản</span>
        </div>

        <div class="table-responsive">
            <table class="table admin-table align-middle mb-0">
                <colgroup>
                    <col style="width: 8%;" />
                    <col style="width: 16%;" />
                    <col style="width: 23%;" />
                    <col style="width: 9%;" />
                    <col style="width: 12%;" />
                    <col style="width: 12%;" />
                    <col style="width: 20%;" />
                </colgroup>

                <thead>
                    <tr>
                        <th class="text-center">Mã TK</th>
                        <th class="text-center">Họ tên</th>
                        <th class="text-center">UserName</th>
                        <th class="text-center">Vai trò</th>
                        <th class="text-center">Liên kết</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var user in Model)
                        {
                            <tr>
                                <td class="text-center">
                                    <span class="admin-code">@user.UserCode</span>
                                </td>

                                <td>
                                    <div class="admin-name">@user.FullName</div>
                                </td>

                                <td>
                                    <div class="admin-username">@user.UserName</div>
                                </td>

                                <td class="text-center">
                                    <span class="admin-badge admin-badge-role">@user.Role</span>
                                </td>

                                <td class="text-center">
                                    @if (user.IsLinkedStudent)
                                    {
                                        <span class="admin-badge admin-badge-linked">@user.LinkedLabel</span>
                                    }
                                    else if (user.IsLinkedTeacher)
                                    {
                                        <span class="admin-badge admin-badge-linked">@user.LinkedLabel</span>
                                    }
                                    else
                                    {
                                        <span class="admin-badge admin-badge-muted">@user.LinkedLabel</span>
                                    }
                                </td>

                                <td class="text-center">
                                    @if (user.IsLocked)
                                    {
                                        <span class="admin-badge admin-badge-danger">Đã khóa</span>
                                    }
                                    else
                                    {
                                        <span class="admin-badge admin-badge-success">Đang hoạt động</span>
                                    }
                                </td>

                                <td class="text-center">
                                    <div class="admin-actions">
                                        <a asp-area="Admin"
                                           asp-controller="UserManagement"
                                           asp-action="Edit"
                                           asp-route-id="@user.Id"
                                           class="admin-icon-action admin-action-edit"
                                           data-label="Sửa"
                                           title="Sửa"
                                           aria-label="Sửa">
                                            <svg class="edit-svgIcon" viewBox="0 0 512 512" aria-hidden="true">
                                                <path d="M410.3 231l11.3-11.3-33.9-33.9-62.1-62.1L291.7 89.8l-11.3 11.3-22.6 22.6L58.6 322.9c-10.4 10.4-18 23.3-22.2 37.4L1 480.7c-2.5 8.4-.2 17.5 6.1 23.7s15.3 8.5 23.7 6.1l120.3-35.4c14.1-4.2 27-11.8 37.4-22.2L387.7 253.7 410.3 231zM160 399.4l-9.1 22.7c-4 3.1-8.5 5.4-13.3 6.9L59.4 452l23-78.1c1.4-4.9 3.8-9.4 6.9-13.3l22.7-9.1v32c0 8.8 7.2 16 16 16h32zM362.7 18.7L348.3 33.2 325.7 55.8 314.3 67.1l33.9 33.9 62.1 62.1 33.9 33.9 11.3-11.3 22.6-22.6 14.5-14.5c25-25 25-65.5 0-90.5L453.3 18.7c-25-25-65.5-25-90.5 0zm-47.4 168l-144 144c-6.2 6.2-16.4 6.2-22.6 0s-6.2-16.4 0-22.6l144-144c6.2-6.2 16.4-6.2 22.6 0s6.2 16.4 0 22.6z"></path>
                                            </svg>
                                        </a>

                                        <a asp-area="Admin"
                                           asp-controller="UserManagement"
                                           asp-action="Delete"
                                           asp-route-id="@user.Id"
                                           class="admin-icon-action admin-action-delete"
                                           data-label="Xóa"
                                           title="Xóa"
                                           aria-label="Xóa">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 39 7" class="bin-top" aria-hidden="true">
                                                <line stroke-width="4" stroke="white" y2="5" x2="39" y1="5"></line>
                                                <line stroke-width="3" stroke="white" y2="1.5" x2="26.0357" y1="1.5" x1="12"></line>
                                            </svg>
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 33 39" class="bin-bottom" aria-hidden="true">
                                                <mask fill="white" id="user-delete-mask-@user.Id">
                                                    <path d="M0 0H33V35C33 37.2091 31.2091 39 29 39H4C1.79086 39 0 37.2091 0 35V0Z"></path>
                                                </mask>
                                                <path mask="url(#user-delete-mask-@user.Id)" fill="white" d="M0 0H33H0ZM37 35C37 39.4183 33.4183 43 29 43H4C-0.418278 43 -4 39.4183 -4 35H4H29H37ZM4 43C-0.418278 43 -4 39.4183 -4 35V0H4V35V43ZM37 0V35C37 39.4183 33.4183 43 29 43V35V0H37Z"></path>
                                                <path stroke-width="4" stroke="white" d="M12 6L12 29"></path>
                                                <path stroke-width="4" stroke="white" d="M21 6V29"></path>
                                            </svg>
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 89 80" class="garbage" aria-hidden="true">
                                                <path fill="white" d="M20.5 10.5L37.5 15.5L42.5 11.5L51.5 12.5L68.75 0L72 11.5L79.5 12.5H88.5L87 22L68.75 31.5L75.5066 25L86 26L87 35.5L77.5 48L70.5 49.5L80 50L77.5 71.5L63.5 58.5L53.5 68.5L65.5 70.5L45.5 73L35.5 79.5L28 67L16 63L12 51.5L0 48L16 25L22.5 17L20.5 10.5Z"></path>
                                            </svg>
                                        </a>

                                        @if (user.IsLocked)
                                        {
                                            <form asp-area="Admin"
                                                  asp-controller="UserManagement"
                                                  asp-action="UnlockUser"
                                                  method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@user.Id" />
                                                <button type="submit"
                                                        class="admin-icon-action admin-action-unlock"
                                                        data-label="Mở khóa"
                                                        title="Mở khóa"
                                                        aria-label="Mở khóa">
                                                    <svg class="lock-action-svg" width="36" height="40" viewBox="0 0 36 40" aria-hidden="true">
                                                        <path class="lockb" d="M27 27C27 34.1797 21.1797 40 14 40C6.8203 40 1 34.1797 1 27C1 19.8203 6.8203 14 14 14C21.1797 14 27 19.8203 27 27ZM15.6298 26.5191C16.4544 25.9845 17 25.056 17 24C17 22.3431 15.6569 21 14 21C12.3431 21 11 22.3431 11 24C11 25.056 11.5456 25.9845 12.3702 26.5191L11 32H17L15.6298 26.5191Z"></path>
                                                        <path class="lock" d="M6 21V10C6 5.58172 9.58172 2 14 2C18.4183 2 22 5.58172 22 10V21"></path>
                                                        <path class="bling" d="M29 20L31 22"></path>
                                                        <path class="bling" d="M31.5 15H34.5"></path>
                                                        <path class="bling" d="M29 10L31 8"></path>
                                                    </svg>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-area="Admin"
                                                  asp-controller="UserManagement"
                                                  asp-action="LockUser"
                                                  method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@user.Id" />
                                                <button type="submit"
                                                        class="admin-icon-action admin-action-lock"
                                                        data-label="Khóa"
                                                        title="Khóa"
                                                        aria-label="Khóa">
                                                    <svg class="lock-action-svg" width="36" height="40" viewBox="0 0 36 40" aria-hidden="true">
                                                        <path class="lockb" d="M27 27C27 34.1797 21.1797 40 14 40C6.8203 40 1 34.1797 1 27C1 19.8203 6.8203 14 14 14C21.1797 14 27 19.8203 27 27ZM15.6298 26.5191C16.4544 25.9845 17 25.056 17 24C17 22.3431 15.6569 21 14 21C12.3431 21 11 22.3431 11 24C11 25.056 11.5456 25.9845 12.3702 26.5191L11 32H17L15.6298 26.5191Z"></path>
                                                        <path class="lock" d="M6 21V10C6 5.58172 9.58172 2 14 2C18.4183 2 22 5.58172 22 10V21"></path>
                                                        <path class="bling" d="M29 20L31 22"></path>
                                                        <path class="bling" d="M31.5 15H34.5"></path>
                                                        <path class="bling" d="M29 10L31 8"></path>
                                                    </svg>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                Không có tài khoản nào phù hợp.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

