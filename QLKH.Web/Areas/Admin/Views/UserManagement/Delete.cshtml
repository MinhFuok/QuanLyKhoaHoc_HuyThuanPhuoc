@model QLKH.Web.Areas.Admin.Models.DeleteUserViewModel

@{
    ViewData["Title"] = "Xóa tài khoản";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<h2 class="mb-4">XÓA TÀI KHOẢN</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="alert alert-warning">
            <strong>Cảnh báo:</strong> Bạn có chắc chắn muốn xóa tài khoản này không?
            Nếu tài khoản đang liên kết với hồ sơ học viên hoặc giáo viên thì hệ thống sẽ không cho xóa.
        </div>

        <dl class="row mb-4">
            <dt class="col-sm-3">Họ tên</dt>
            <dd class="col-sm-9">@Model.FullName</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Vai trò</dt>
            <dd class="col-sm-9">
                <span class="badge bg-primary">@Model.Role</span>
            </dd>

            <dt class="col-sm-3">Liên kết học viên</dt>
            <dd class="col-sm-9">
                @if (Model.IsLinkedStudent)
                {
                    <span class="badge bg-danger">
                        Có - @Model.LinkedStudentCode
                    </span>
                }
                else
                {
                    <span class="badge bg-success">
                        Không
                    </span>
                }
            </dd>

            <dt class="col-sm-3">Liên kết giáo viên</dt>
            <dd class="col-sm-9">
                @if (Model.IsLinkedTeacher)
                {
                    <span class="badge bg-danger">
                        Có - @Model.LinkedTeacherCode
                    </span>
                }
                else
                {
                    <span class="badge bg-success">
                        Không
                    </span>
                }
            </dd>
        </dl>

        @if (!Model.CanDelete)
        {
            <div class="alert alert-danger">
                Không thể xóa tài khoản này vì tài khoản đang liên kết với hồ sơ nghiệp vụ.
                Vui lòng kiểm tra lại hồ sơ học viên hoặc giáo viên trước khi xóa.
            </div>
        }

        <form asp-area="Admin" asp-controller="UserManagement" asp-action="Delete" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" name="id" value="@Model.Id" />

            <div class="d-flex gap-2">
                @if (Model.CanDelete)
                {
                    <button type="submit"
                            class="btn btn-danger"
                            onclick="return confirm('Bạn có chắc chắn muốn xóa tài khoản này không?');">
                        Xác nhận xóa
                    </button>
                }

                <a asp-area="Admin"
                   asp-controller="UserManagement"
                   asp-action="Index"
                   class="btn btn-secondary">
                    Hủy
                </a>
            </div>
        </form>
    </div>
</div>