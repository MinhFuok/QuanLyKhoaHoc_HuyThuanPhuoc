@model QLKH.Web.Areas.Admin.Models.DeleteUserViewModel

@{
    ViewData["Title"] = "Xóa tài khoản";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="admin-account-page">
    <div class="admin-page-header admin-page-header--danger">
        <div>
            <h2 class="admin-page-title">XÓA TÀI KHOẢN</h2>
        </div>

        <a asp-area="Admin"
           asp-controller="UserManagement"
           asp-action="Index"
           class="btn btn-outline-secondary admin-btn-main">
            Quay lại
        </a>
    </div>

    <div class="admin-delete-card">
        <div class="admin-delete-title">
            <span>Thông tin tài khoản</span>
        </div>

        <div class="admin-delete-body">
            <div class="admin-warning-box">
                <strong>Cảnh báo:</strong>
                Bạn có chắc chắn muốn xóa tài khoản này không?
                Nếu tài khoản đang liên kết với hồ sơ học viên hoặc giáo viên thì hệ thống sẽ không cho xóa.
            </div>

            <div class="admin-detail-list">
                <div class="admin-detail-row">
                    <div class="admin-detail-label">Họ tên</div>
                    <div class="admin-detail-value">@Model.FullName</div>
                </div>

                <div class="admin-detail-row">
                    <div class="admin-detail-label">Email</div>
                    <div class="admin-detail-value">@Model.Email</div>
                </div>

                <div class="admin-detail-row">
                    <div class="admin-detail-label">Vai trò</div>
                    <div class="admin-detail-value">
                        <span class="admin-badge admin-badge-role">@Model.Role</span>
                    </div>
                </div>

                <div class="admin-detail-row">
                    <div class="admin-detail-label">Liên kết học viên</div>
                    <div class="admin-detail-value">
                        @if (Model.IsLinkedStudent)
                        {
                            <span class="admin-badge admin-badge-danger">Có - @Model.LinkedStudentCode</span>
                        }
                        else
                        {
                            <span class="admin-badge admin-badge-success">Không</span>
                        }
                    </div>
                </div>

                <div class="admin-detail-row">
                    <div class="admin-detail-label">Liên kết giáo viên</div>
                    <div class="admin-detail-value">
                        @if (Model.IsLinkedTeacher)
                        {
                            <span class="admin-badge admin-badge-danger">Có - @Model.LinkedTeacherCode</span>
                        }
                        else
                        {
                            <span class="admin-badge admin-badge-success">Không</span>
                        }
                    </div>
                </div>
            </div>

            @if (!Model.CanDelete)
            {
                <div class="admin-danger-box">
                    Không thể xóa tài khoản này vì tài khoản đang liên kết với hồ sơ nghiệp vụ.
                    Vui lòng kiểm tra lại hồ sơ học viên hoặc giáo viên trước khi xóa.
                </div>
            }

            <form asp-area="Admin" asp-controller="UserManagement" asp-action="Delete" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" name="id" value="@Model.Id" />

                <div class="admin-form-actions">
                    @if (Model.CanDelete)
                    {
                        <button type="submit"
                                class="btn btn-danger"
                                onclick="return confirm('Bạn có chắc chắn muốn xóa tài khoản này không?');">
                            Xác nhận xóa
                        </button>
                    }

                    <a asp-area="Admin"
                       asp-controller="UserManagement"
                       asp-action="Index"
                       class="btn btn-outline-secondary">
                        Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

