@model QLKH.Web.Areas.Admin.Models.DeleteUserViewModel

@{
    ViewData["Title"] = "Xóa tài khoản";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="admin-account-page">
    <div class="admin-page-header">
        <div>
            <h2 class="admin-page-title">XÓA TÀI KHOẢN</h2>
        </div>

        <a asp-area="Admin"
           asp-controller="UserManagement"
           asp-action="Index"
           class="btn btn-outline-secondary admin-btn-main">
            Quay lại
        </a>
    </div>

    <div class="admin-delete-card">
        <div class="admin-delete-title">
            <span>Thông tin tài khoản</span>
        </div>

        <div class="admin-delete-body">
            <div class="admin-warning-box">
                <strong>Cảnh báo:</strong>
                Bạn có chắc chắn muốn xóa tài khoản này không?
                Nếu tài khoản đang liên kết với hồ sơ học viên hoặc giáo viên thì hệ thống sẽ không cho xóa.
            </div>

            <div class="admin-detail-list">
                <div class="admin-detail-row">
                    <div class="admin-detail-label">Họ tên</div>
                    <div class="admin-detail-value">@Model.FullName</div>
                </div>

                <div class="admin-detail-row">
                    <div class="admin-detail-label">Email</div>
                    <div class="admin-detail-value">@Model.Email</div>
                </div>

                <div class="admin-detail-row">
                    <div class="admin-detail-label">Vai trò</div>
                    <div class="admin-detail-value">
                        <span class="admin-badge admin-badge-role">@Model.Role</span>
                    </div>
                </div>

                <div class="admin-detail-row">
                    <div class="admin-detail-label">Liên kết học viên</div>
                    <div class="admin-detail-value">
                        @if (Model.IsLinkedStudent)
                        {
                            <span class="admin-badge admin-badge-danger">Có - @Model.LinkedStudentCode</span>
                        }
                        else
                        {
                            <span class="admin-badge admin-badge-success">Không</span>
                        }
                    </div>
                </div>

                <div class="admin-detail-row">
                    <div class="admin-detail-label">Liên kết giáo viên</div>
                    <div class="admin-detail-value">
                        @if (Model.IsLinkedTeacher)
                        {
                            <span class="admin-badge admin-badge-danger">Có - @Model.LinkedTeacherCode</span>
                        }
                        else
                        {
                            <span class="admin-badge admin-badge-success">Không</span>
                        }
                    </div>
                </div>
            </div>

            @if (!Model.CanDelete)
            {
                <div class="admin-danger-box">
                    Không thể xóa tài khoản này vì tài khoản đang liên kết với hồ sơ nghiệp vụ.
                    Vui lòng kiểm tra lại hồ sơ học viên hoặc giáo viên trước khi xóa.
                </div>
            }

            <form asp-area="Admin" asp-controller="UserManagement" asp-action="Delete" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" name="id" value="@Model.Id" />

                <div class="admin-form-actions">
                    @if (Model.CanDelete)
                    {
                        <button type="submit"
                                class="btn btn-danger"
                                onclick="return confirm('Bạn có chắc chắn muốn xóa tài khoản này không?');">
                            Xác nhận xóa
                        </button>
                    }

                    <a asp-area="Admin"
                       asp-controller="UserManagement"
                       asp-action="Index"
                       class="btn btn-outline-secondary">
                        Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .admin-account-page {
            color: #1f2937;
        }

        .admin-page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 18px;
            padding-bottom: 14px;
            border-bottom: 1px solid #e5e7eb;
        }

        .admin-page-title {
            margin: 0;
            color: #111827;
            font-size: 1.55rem;
            font-weight: 800;
            letter-spacing: -0.02em;
        }

        .admin-page-subtitle {
            margin: 6px 0 0;
            color: #6b7280;
            font-size: 0.94rem;
        }

        .admin-btn-main {
            border-radius: 8px;
            font-weight: 700;
            white-space: nowrap;
            padding: 9px 14px;
        }

        .admin-delete-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            overflow: hidden;
        }

        .admin-delete-title {
            padding: 13px 16px;
            border-bottom: 1px solid #e5e7eb;
            color: #111827;
            font-weight: 800;
            background: #f9fafb;
        }

        .admin-delete-body {
            padding: 16px;
        }

        .admin-warning-box {
            padding: 12px 14px;
            margin-bottom: 16px;
            border-radius: 8px;
            border: 1px solid #fde68a;
            background: #fffbeb;
            color: #92400e;
            font-size: 0.92rem;
        }

        .admin-danger-box {
            padding: 12px 14px;
            margin-top: 16px;
            border-radius: 8px;
            border: 1px solid #fecaca;
            background: #fef2f2;
            color: #991b1b;
            font-size: 0.92rem;
            font-weight: 600;
        }

        .admin-detail-list {
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            overflow: hidden;
        }

        .admin-detail-row {
            display: grid;
            grid-template-columns: 220px minmax(0, 1fr);
            border-bottom: 1px solid #e5e7eb;
        }

            .admin-detail-row:last-child {
                border-bottom: 0;
            }

        .admin-detail-label {
            padding: 12px 14px;
            background: #f9fafb;
            color: #374151;
            font-weight: 800;
            font-size: 0.9rem;
        }

        .admin-detail-value {
            padding: 12px 14px;
            color: #111827;
            font-weight: 600;
            word-break: break-word;
        }

        .admin-badge {
            display: inline-flex;
            justify-content: center;
            align-items: center;
            max-width: 100%;
            padding: 6px 10px;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 700;
            line-height: 1.25;
            white-space: normal;
            text-align: center;
        }

        .admin-badge-role {
            background: #eef2ff;
            color: #3730a3;
        }

        .admin-badge-success {
            background: #ecfdf5;
            color: #166534;
        }

        .admin-badge-danger {
            background: #fef2f2;
            color: #991b1b;
        }

        .admin-form-actions {
            display: flex;
            gap: 8px;
            justify-content: flex-end;
            margin-top: 18px;
            padding-top: 16px;
            border-top: 1px solid #e5e7eb;
        }

            .admin-form-actions .btn {
                border-radius: 8px;
                font-weight: 700;
                min-width: 120px;
            }

        @@media (max-width: 767.98px) {
            .admin-page-header {
                flex-direction: column;
            }

            .admin-btn-main,
            .admin-form-actions .btn {
                width: 100%;
            }

            .admin-form-actions {
                flex-direction: column;
            }

            .admin-detail-row {
                grid-template-columns: 1fr;
            }

            .admin-detail-label {
                border-bottom: 1px solid #e5e7eb;
            }
        }
    </style>
}