@model QLKH.Web.Areas.Admin.Models.CreateUserViewModel

@{
    ViewData["Title"] = "Tạo tài khoản";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="admin-account-page">
    <div class="admin-page-header">
        <div>
            <h2 class="admin-page-title">TẠO TÀI KHOẢN</h2>
            <p class="admin-page-subtitle">
                Tạo tài khoản đăng nhập mới và phân quyền....
            </p>
        </div>

        <a asp-area="Admin"
           asp-controller="UserManagement"
           asp-action="Index"
           class="btn btn-outline-secondary admin-btn-main">
            Quay lại
        </a>
    </div>

    <div class="admin-form-card">
        <div class="admin-form-title">
            <span>Thông tin tài khoản</span>
        </div>

        <form asp-area="Admin" asp-controller="UserManagement" asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="text-danger admin-validation"></div>

            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label asp-for="UserCode" class="form-label admin-label"></label>
                    <input asp-for="UserCode" class="form-control admin-input" readonly />
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="Role" class="form-label admin-label"></label>
                    <select asp-for="Role" asp-items="ViewBag.RoleList" class="form-select admin-input">
                        <option value="">-- Chọn vai trò --</option>
                    </select>
                    <span asp-validation-for="Role" class="text-danger admin-field-error"></span>
                </div>

                <div class="col-12">
                    <label asp-for="FullName" class="form-label admin-label"></label>
                    <input asp-for="FullName" class="form-control admin-input" />
                    <span asp-validation-for="FullName" class="text-danger admin-field-error"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Email" class="form-label admin-label"></label>
                    <input asp-for="Email" class="form-control admin-input" />
                    <span asp-validation-for="Email" class="text-danger admin-field-error"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="Password" class="form-label admin-label"></label>
                    <input asp-for="Password" class="form-control admin-input" />
                    <span asp-validation-for="Password" class="text-danger admin-field-error"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="ConfirmPassword" class="form-label admin-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control admin-input" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger admin-field-error"></span>
                </div>
            </div>

            <div class="admin-form-actions">
                <button type="submit" class="btn btn-primary">
                    Xác nhận
                </button>

                <a asp-area="Admin"
                   asp-controller="UserManagement"
                   asp-action="Index"
                   class="btn btn-outline-secondary">
                    Hủy
                </a>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
