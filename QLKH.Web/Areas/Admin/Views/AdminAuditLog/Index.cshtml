@model IEnumerable<QLKH.Domain.Entities.AdminAuditLog>
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Lịch sử hoạt động";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="admin-account-page admin-audit-page">
    <div class="admin-page-header">
        <div>
            <h2 class="admin-page-title">LỊCH SỬ HOẠT ĐỘNG</h2>
            <p class="admin-page-subtitle">
                Theo dõi các thao tác quản trị, thời gian thực hiện và thông tin liên quan trong hệ thống...
            </p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(TempData["SuccessMessage"]?.ToString()))
    {
        <div class="alert alert-success admin-alert">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(TempData["ErrorMessage"]?.ToString()))
    {
        <div class="alert alert-danger admin-alert">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="admin-filter-card">
        <form asp-area="Admin" asp-controller="AdminAuditLog" asp-action="Index" method="get">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-6 col-xl-3">
                    <label class="form-label admin-label">Admin</label>
                    <select name="adminEmail" class="form-select admin-input">
                        <option value="">-- Tất cả admin --</option>
                        @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.AdminEmailList)
                        {
                            <option value="@item.Value" selected="@(ViewBag.AdminEmail == item.Value)">
                                @item.Text
                            </option>
                        }
                    </select>
                </div>

                <div class="col-12 col-md-6 col-xl-2">
                    <label class="form-label admin-label">Hành động</label>
                    <select name="actionName" class="form-select admin-input">
                        <option value="">-- Tất cả --</option>
                        @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.ActionList)
                        {
                            <option value="@item.Value" selected="@(ViewBag.ActionName == item.Value)">
                                @item.Text
                            </option>
                        }
                    </select>
                </div>

                <div class="col-12 col-md-6 col-xl-2">
                    <label class="form-label admin-label">Từ ngày</label>
                    <input type="date"
                           name="fromDate"
                           value="@ViewBag.FromDate"
                           class="form-control admin-input" />
                </div>

                <div class="col-12 col-md-6 col-xl-2">
                    <label class="form-label admin-label">Đến ngày</label>
                    <input type="date"
                           name="toDate"
                           value="@ViewBag.ToDate"
                           class="form-control admin-input" />
                </div>

                <div class="col-12 col-xl-3">
                    <label class="form-label admin-label">Từ khóa</label>
                    <input type="text"
                           name="keyword"
                           value="@ViewBag.Keyword"
                           class="form-control admin-input"
                           placeholder="Thông tin ..." />
                </div>

                <div class="col-12">
                    <div class="admin-filter-actions">
                        <button type="submit" class="btn btn-primary">
                            Lọc
                        </button>

                        <a asp-area="Admin"
                           asp-controller="AdminAuditLog"
                           asp-action="Index"
                           class="btn btn-outline-secondary">
                            Bỏ lọc
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <div class="admin-table-card">
        <div class="admin-table-title">
            <span>Nhật ký thao tác</span>
        </div>

        <div class="table-responsive">
            <table class="table admin-table admin-audit-table align-middle mb-0">
                <colgroup>
                    <col style="width: 15%;" />
                    <col style="width: 19%;" />
                    <col style="width: 13%;" />
                    <col style="width: 12%;" />
                    <col style="width: 24%;" />
                    <col style="width: 17%;" />
                </colgroup>

                <thead>
                    <tr>
                        <th class="text-center">Thời gian</th>
                        <th class="text-center">Tài khoản</th>
                        <th class="text-center">Hành động</th>
                        <th class="text-center">Đối tượng</th>
                        <th class="text-center">Thông tin</th>
                        <th class="text-center">Ghi chú</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var log in Model)
                        {
                            <tr>
                                <td>
                                    <span class="admin-time">
                                        @log.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")
                                    </span>
                                </td>

                                <td>
                                    <div class="admin-email">
                                        @log.ActorEmail
                                    </div>
                                </td>

                                <td>
                                    <span class="admin-badge admin-badge-role">
                                        @log.ActionName
                                    </span>
                                </td>

                                <td>
                                    <div class="admin-text-limit">
                                        @log.TargetType
                                    </div>
                                </td>

                                <td>
                                    <div class="admin-text-limit">
                                        @log.TargetDisplay
                                    </div>
                                </td>

                                <td>
                                    <div class="admin-text-limit">
                                        @log.Note
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                Không có nhật ký thao tác nào phù hợp.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="admin-table-note">
            Nhật ký sẽ tự động xóa sau 30 ngày.
        </div>
    </div>
</div>

@section Styles {
    <style>
        .admin-account-page {
            color: #1f2937;
        }

        .admin-page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 18px;
            padding-bottom: 14px;
            border-bottom: 1px solid #e5e7eb;
        }

        .admin-page-title {
            margin: 0;
            color: #111827;
            font-size: 1.55rem;
            font-weight: 800;
            letter-spacing: -0.02em;
        }

        .admin-page-subtitle {
            margin: 6px 0 0;
            color: #6b7280;
            font-size: 0.94rem;
        }

        .admin-alert {
            border-radius: 8px;
            border: 0;
            margin-bottom: 14px;
        }

        .admin-filter-card,
        .admin-table-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            margin-bottom: 16px;
        }

        .admin-filter-card {
            padding: 16px;
        }

        .admin-label {
            color: #374151;
            font-weight: 700;
            font-size: 0.9rem;
            margin-bottom: 6px;
        }

        .admin-input {
            border-radius: 8px;
            border-color: #d1d5db;
            min-height: 40px;
            font-size: 0.94rem;
        }

            .admin-input:focus {
                border-color: #2563eb;
                box-shadow: 0 0 0 0.18rem rgba(37, 99, 235, 0.12);
            }

        .admin-filter-actions {
            display: flex;
            gap: 8px;
            justify-content: flex-end;
        }

            .admin-filter-actions .btn {
                border-radius: 8px;
                font-weight: 700;
                min-width: 110px;
                min-height: 40px;
            }

        .admin-table-title {
            padding: 13px 16px;
            border-bottom: 1px solid #e5e7eb;
            color: #111827;
            font-weight: 800;
            background: #f9fafb;
            border-radius: 10px 10px 0 0;
        }

        .admin-table {
            width: 100%;
            table-layout: fixed;
            margin-bottom: 0;
        }

            .admin-table thead th {
                background: #f9fafb;
                color: #374151;
                font-size: 0.78rem;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: 0.035em;
                border-bottom: 1px solid #e5e7eb;
                padding: 14px 12px;
                white-space: nowrap;
                vertical-align: middle;
            }

            .admin-table tbody td {
                padding: 14px 12px;
                border-bottom: 1px solid #edf0f3;
                vertical-align: middle;
                font-size: 0.92rem;
            }

            .admin-table tbody tr:hover {
                background: #f9fafb;
            }

            .admin-table tbody tr:last-child td {
                border-bottom: 0;
            }

        .admin-time {
            color: #374151;
            font-weight: 700;
            font-size: 0.86rem;
            line-height: 1.45;
        }

        .admin-email {
            color: #111827;
            font-weight: 650;
            word-break: break-word;
            overflow-wrap: anywhere;
        }

        .admin-text-limit {
            color: #4b5563;
            line-height: 1.45;
            word-break: break-word;
            overflow-wrap: anywhere;
        }

        .admin-badge {
            display: inline-flex;
            justify-content: center;
            align-items: center;
            max-width: 100%;
            padding: 6px 10px;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 700;
            line-height: 1.25;
            white-space: normal;
            text-align: center;
        }

        .admin-badge-role {
            background: #eef2ff;
            color: #3730a3;
        }

        .admin-table-note {
            padding: 12px 16px;
            border-top: 1px solid #e5e7eb;
            color: #6b7280;
            font-size: 0.86rem;
            text-align: center;
            background: #f9fafb;
        }

        @@media (max-width: 1199.98px) {
            .admin-audit-table {
                min-width: 1050px;
            }
        }

        @@media (max-width: 767.98px) {
            .admin-page-header {
                flex-direction: column;
            }

            .admin-filter-actions {
                flex-direction: column;
            }

                .admin-filter-actions .btn {
                    width: 100%;
                }
        }
    </style>
}