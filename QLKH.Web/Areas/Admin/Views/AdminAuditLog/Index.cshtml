@model IEnumerable<QLKH.Domain.Entities.AdminAuditLog>
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Lịch sử hoạt động";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="admin-account-page admin-audit-page">
    <div class="admin-page-header">
        <div>
            <h2 class="admin-page-title">LỊCH SỬ HOẠT ĐỘNG</h2>
            <p class="admin-page-subtitle">
                Theo dõi các thao tác quản trị, thời gian thực hiện và thông tin liên quan trong hệ thống...
            </p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(TempData["SuccessMessage"]?.ToString()))
    {
        <div class="alert alert-success admin-alert">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(TempData["ErrorMessage"]?.ToString()))
    {
        <div class="alert alert-danger admin-alert">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="admin-filter-card">
        <form asp-area="Admin" asp-controller="AdminAuditLog" asp-action="Index" method="get">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-6 col-xl-3">
                    <label class="form-label admin-label">Admin</label>
                    <select name="adminEmail" class="form-select admin-input">
                        <option value="">-- Tất cả account --</option>
                        @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.AdminEmailList)
                        {
                            <option value="@item.Value" selected="@(ViewBag.AdminEmail == item.Value)">
                                @item.Text
                            </option>
                        }
                    </select>
                </div>

                <div class="col-12 col-md-6 col-xl-2">
                    <label class="form-label admin-label">Hành động</label>
                    <select name="actionName" class="form-select admin-input">
                        <option value="">-- Tất cả --</option>
                        @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.ActionList)
                        {
                            <option value="@item.Value" selected="@(ViewBag.ActionName == item.Value)">
                                @item.Text
                            </option>
                        }
                    </select>
                </div>

                <div class="col-12 col-md-6 col-xl-2">
                    <label class="form-label admin-label">Từ ngày</label>
                    <input type="date"
                           name="fromDate"
                           value="@ViewBag.FromDate"
                           class="form-control admin-input" />
                </div>

                <div class="col-12 col-md-6 col-xl-2">
                    <label class="form-label admin-label">Đến ngày</label>
                    <input type="date"
                           name="toDate"
                           value="@ViewBag.ToDate"
                           class="form-control admin-input" />
                </div>

                <div class="col-12 col-xl-3">
                    <label class="form-label admin-label">Từ khóa</label>
                    <input type="text"
                           name="keyword"
                           value="@ViewBag.Keyword"
                           class="form-control admin-input"
                           placeholder="Thông tin ..." />
                </div>

                <div class="col-12">
                    <div class="admin-filter-actions">
                        <button type="submit" class="btn btn-primary">
                            Lọc
                        </button>

                        <a asp-area="Admin"
                           asp-controller="AdminAuditLog"
                           asp-action="Index"
                           class="btn btn-outline-secondary">
                            Bỏ lọc
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <div class="admin-table-card">
        <div class="admin-table-title">
            <span>Nhật ký thao tác</span>
        </div>

        <div class="table-responsive">
            <table class="table admin-table admin-audit-table align-middle mb-0">
                <colgroup>
                    <col style="width: 10%;" />
                    <col style="width: 24%;" />
                    <col style="width: 13%;" />
                    <col style="width: 12%;" />
                    <col style="width: 24%;" />
                    <col style="width: 17%;" />
                </colgroup>

                <thead>
                    <tr>
                        <th class="text-center">Thời gian</th>
                        <th class="text-center">Tài khoản</th>
                        <th class="text-center">Hành động</th>
                        <th class="text-center">Đối tượng</th>
                        <th class="text-center">Thông tin</th>
                        <th class="text-center">Ghi chú</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var log in Model)
                        {
                            <tr>
                                <td>
                                    <span class="admin-time">
                                        @log.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")
                                    </span>
                                </td>

                                <td>
                                    <div class="admin-email">
                                        @log.ActorEmail
                                    </div>
                                </td>

                                <td>
                                    <span class="admin-badge admin-badge-role">
                                        @log.ActionName
                                    </span>
                                </td>

                                <td>
                                    <div class="admin-text-limit">
                                        @log.TargetType
                                    </div>
                                </td>

                                <td>
                                    <div class="admin-text-limit">
                                        @log.TargetDisplay
                                    </div>
                                </td>

                                <td>
                                    <div class="admin-text-limit">
                                        @log.Note
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                Không có nhật ký thao tác nào phù hợp.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="admin-table-note">
            Nhật ký sẽ tự động xóa sau 30 ngày.
        </div>
    </div>
</div>
@section Styles {
    <style>
        .admin-audit-page {
            padding-bottom: 40px;
        }

            .admin-audit-page .admin-filter-card {
                margin-bottom: 24px;
            }

            .admin-audit-page .admin-table-card {
                display: block !important;
                visibility: visible !important;
                opacity: 1 !important;
                position: relative !important;
                z-index: 2 !important;
                margin-top: 24px !important;
                padding: 24px !important;
                background: #ffffff !important;
                border: 1px solid #dbeafe !important;
                border-radius: 24px !important;
                box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08) !important;
                overflow: hidden !important;
            }

            .admin-audit-page .admin-table-title {
                display: flex !important;
                align-items: center;
                justify-content: space-between;
                margin-bottom: 16px;
                padding-bottom: 16px;
                color: #0f172a;
                font-size: 18px;
                font-weight: 800;
                border-bottom: 1px solid #e2e8f0;
            }

            .admin-audit-page .table-responsive {
                width: 100%;
                overflow-x: auto;
            }

            .admin-audit-page .admin-table {
                width: 100%;
                min-width: 1120px;
                table-layout: fixed;
                border-collapse: separate;
                border-spacing: 0;
                color: #0f172a;
            }

                .admin-audit-page .admin-table thead th {
                    padding: 16px 16px;
                    background: #f8fafc;
                    color: #64748b;
                    font-size: 13px;
                    font-weight: 900;
                    letter-spacing: 0.06em;
                    text-transform: uppercase;
                    border-bottom: 1px solid #94a3b8;
                    white-space: nowrap;
                    vertical-align: middle;
                }

                .admin-audit-page .admin-table tbody td {
                    padding: 18px 16px;
                    border-bottom: 1px solid #eef2f7;
                    vertical-align: middle;
                    color: #64748b;
                    font-size: 15px;
                    line-height: 1.45;
                }

                .admin-audit-page .admin-table tbody tr:hover td {
                    background: #f8fbff;
                }

                .admin-audit-page .admin-table tbody tr:last-child td {
                    border-bottom: none;
                }

                .admin-audit-page .admin-table td:nth-child(1) {
                    white-space: normal;
                }

                .admin-audit-page .admin-table td:nth-child(3),
                .admin-audit-page .admin-table td:nth-child(4) {
                    text-align: center;
                    white-space: nowrap;
                }

            .admin-audit-page .admin-time {
                display: block;
                max-width: 100%;
                color: #64748b;
                font-size: 14px;
                font-weight: 800;
                line-height: 1.45;
                white-space: normal;
                word-break: normal;
            }

            .admin-audit-page .admin-email {
                display: block;
                max-width: 100%;
                color: #64748b;
                font-weight: 800;
                line-height: 1.45;
                overflow-wrap: anywhere;
                word-break: break-word;
            }

            .admin-audit-page .admin-text-limit {
                display: block;
                max-width: 100%;
                color: #64748b;
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            .admin-audit-page td:nth-child(5) .admin-text-limit,
            .admin-audit-page td:nth-child(6) .admin-text-limit {
                white-space: normal;
                overflow-wrap: anywhere;
                word-break: break-word;
                line-height: 1.55;
            }

            .admin-audit-page .admin-badge {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                min-height: 34px;
                padding: 8px 14px;
                border-radius: 999px;
                font-size: 12px;
                font-weight: 900;
                line-height: 1;
                white-space: nowrap;
            }

            .admin-audit-page .admin-badge-role {
                color: #4c1d95;
                background: #ede9fe;
                border: 1px solid #ddd6fe;
            }

            .admin-audit-page .admin-table-note {
                margin-top: 14px;
                color: #64748b;
                font-size: 13px;
                font-weight: 600;
            }

        @@media (max-width: 768px) {
            .admin-audit-page .admin-table-card {
                padding: 16px !important;
                border-radius: 18px !important;
            }

            .admin-audit-page .admin-table {
                min-width: 1050px;
            }
        }
    </style>
}
