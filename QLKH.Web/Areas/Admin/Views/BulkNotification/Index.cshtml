@model QLKH.Web.Areas.Admin.Models.BulkNotificationViewModel

@{
    ViewData["Title"] = "Gửi thông báo";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="admin-account-page admin-notification-page">
    <div class="admin-page-header">
        <div>
            <h2 class="admin-page-title">GỬI THÔNG BÁO</h2>
            <p class="admin-page-subtitle">
                Gửi thông báo hệ thống cho người dùng...
            </p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(TempData["SuccessMessage"]?.ToString()))
    {
        <div class="alert alert-success admin-alert">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(TempData["ErrorMessage"]?.ToString()))
    {
        <div class="alert alert-danger admin-alert">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="admin-form-card">
        <div class="admin-form-title">
            <span>Nội dung thông báo</span>
        </div>

        <form asp-area="Admin"
              asp-controller="BulkNotification"
              asp-action="Index"
              method="post"
              enctype="multipart/form-data">

            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
            {
                <div asp-validation-summary="All" class="text-danger admin-validation"></div>
            }

            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Subject" class="form-label admin-label"></label>
                    <input asp-for="Subject"
                           class="form-control admin-input"/>
                    <span asp-validation-for="Subject" class="text-danger admin-field-error"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Message" class="form-label admin-label"></label>
                    <textarea asp-for="Message"
                              class="form-control admin-input admin-textarea"
                              rows="8"></textarea>
                    <span asp-validation-for="Message" class="text-danger admin-field-error"></span>
                </div>

                <div class="col-12">
                    <div class="admin-section-box">
                        <div class="admin-section-label">Đối tượng nhận</div>

                        <div class="admin-check-list">
                            <label class="admin-check-row">
                                <input asp-for="SendToStudents" class="form-check-input admin-check-input" />
                                <span>Học viên</span>
                            </label>

                            <label class="admin-check-row">
                                <input asp-for="SendToTeachers" class="form-check-input admin-check-input" />
                                <span>Giáo viên</span>
                            </label>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <label asp-for="AttachmentFile" class="form-label admin-label"></label>
                    <input asp-for="AttachmentFile"
                           type="file"
                           class="form-control admin-input" />
                    <span asp-validation-for="AttachmentFile" class="text-danger admin-field-error"></span>
                    <div class="admin-help-text">
                        Cho phép đính kèm 1 file, tối đa 10MB.
                    </div>
                </div>
            </div>

            <div class="admin-form-actions">
                <button type="submit" class="btn btn-primary">
                    Xác nhận gửi thông báo
                </button>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
