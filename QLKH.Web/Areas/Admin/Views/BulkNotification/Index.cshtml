@model QLKH.Web.Areas.Admin.Models.BulkNotificationViewModel

@{
    ViewData["Title"] = "Gửi thông báo";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="admin-account-page admin-notification-page">
    <div class="admin-page-header">
        <div>
            <h2 class="admin-page-title">GỬI THÔNG BÁO</h2>
            <p class="admin-page-subtitle">
                Gửi thông báo hệ thống cho người dùng...
            </p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(TempData["SuccessMessage"]?.ToString()))
    {
        <div class="alert alert-success admin-alert">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(TempData["ErrorMessage"]?.ToString()))
    {
        <div class="alert alert-danger admin-alert">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="admin-form-card">
        <div class="admin-form-title">
            <span>Nội dung thông báo</span>
        </div>

        <form asp-area="Admin"
              asp-controller="BulkNotification"
              asp-action="Index"
              method="post"
              enctype="multipart/form-data">

            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
            {
                <div asp-validation-summary="All" class="text-danger admin-validation"></div>
            }

            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Subject" class="form-label admin-label"></label>
                    <input asp-for="Subject"
                           class="form-control admin-input"/>
                    <span asp-validation-for="Subject" class="text-danger admin-field-error"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Message" class="form-label admin-label"></label>
                    <textarea asp-for="Message"
                              class="form-control admin-input admin-textarea"
                              rows="8"></textarea>
                    <span asp-validation-for="Message" class="text-danger admin-field-error"></span>
                </div>

                <div class="col-12">
                    <div class="admin-section-box">
                        <div class="admin-section-label">Đối tượng nhận</div>

                        <div class="admin-check-list">
                            <label class="admin-check-row">
                                <input asp-for="SendToStudents" class="form-check-input admin-check-input" />
                                <span>Học viên</span>
                            </label>

                            <label class="admin-check-row">
                                <input asp-for="SendToTeachers" class="form-check-input admin-check-input" />
                                <span>Giáo viên</span>
                            </label>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <label asp-for="AttachmentFile" class="form-label admin-label"></label>
                    <input asp-for="AttachmentFile"
                           type="file"
                           class="form-control admin-input" />
                    <span asp-validation-for="AttachmentFile" class="text-danger admin-field-error"></span>
                    <div class="admin-help-text">
                        Cho phép đính kèm 1 file, tối đa 10MB.
                    </div>
                </div>
            </div>

            <div class="admin-form-actions">
                <button type="submit" class="btn btn-primary">
                    Xác nhận gửi thông báo
                </button>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <style>
        .admin-account-page {
            color: #1f2937;
        }

        .admin-page-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 18px;
            padding-bottom: 14px;
            border-bottom: 1px solid #e5e7eb;
        }

        .admin-page-title {
            margin: 0;
            color: #111827;
            font-size: 1.55rem;
            font-weight: 800;
            letter-spacing: -0.02em;
        }

        .admin-alert {
            border-radius: 8px;
            border: 0;
            margin-bottom: 14px;
        }

        .admin-form-card {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            overflow: hidden;
            margin-bottom: 16px;
        }

        .admin-form-title {
            padding: 13px 16px;
            border-bottom: 1px solid #e5e7eb;
            color: #111827;
            font-weight: 800;
            background: #f9fafb;
        }

        .admin-form-card form {
            padding: 16px;
        }

        .admin-label {
            color: #374151;
            font-weight: 700;
            font-size: 0.9rem;
            margin-bottom: 6px;
        }

        .admin-input {
            border-radius: 8px;
            border-color: #d1d5db;
            min-height: 40px;
            font-size: 0.94rem;
        }

            .admin-input:focus {
                border-color: #2563eb;
                box-shadow: 0 0 0 0.18rem rgba(37, 99, 235, 0.12);
            }

        .admin-textarea {
            resize: vertical;
            min-height: 170px;
        }

        .admin-validation {
            margin-bottom: 14px;
            font-size: 0.9rem;
        }

        .admin-field-error {
            font-size: 0.84rem;
            margin-top: 4px;
            display: block;
        }

        .admin-help-text {
            margin-top: 6px;
            color: #6b7280;
            font-size: 0.84rem;
        }

        .admin-section-box {
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            background: #f9fafb;
            padding: 14px;
        }

        .admin-section-label {
            color: #374151;
            font-weight: 800;
            font-size: 0.9rem;
            margin-bottom: 10px;
        }

        .admin-check-list {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .admin-check-row {
            display: inline-flex;
            align-items: center;
            gap: 9px;
            margin: 0;
            padding: 10px 12px;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            background: #ffffff;
            color: #374151;
            font-weight: 700;
            cursor: pointer;
        }

        .admin-check-input {
            margin: 0;
            width: 18px;
            height: 18px;
            cursor: pointer;
        }

        .admin-form-actions {
            display: flex;
            gap: 8px;
            justify-content: flex-end;
            margin-top: 18px;
            padding-top: 16px;
            border-top: 1px solid #e5e7eb;
        }

            .admin-form-actions .btn {
                border-radius: 8px;
                font-weight: 700;
                min-width: 180px;
            }

        @@media (max-width: 767.98px) {
            .admin-check-list {
                flex-direction: column;
            }

            .admin-form-actions {
                flex-direction: column;
            }

                .admin-form-actions .btn {
                    width: 100%;
                }
        }
    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}